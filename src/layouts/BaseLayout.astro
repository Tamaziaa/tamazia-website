---
import HeadAnalytics from '../components/analytics/HeadAnalytics.astro';
import Sentry from '../components/analytics/Sentry.astro';
import BodyAnalytics from '../components/analytics/BodyAnalytics.astro';

// Tamazia analytics tokens · replace empty strings with actual values when provider properties are created.
// Cloudflare Web Analytics token: replace '' with the token from CF dashboard.
// GA4 Measurement ID: replace '' with G-XXXXXXX from GA4 property.
// Bing site verification: replace '' with the verification value from Bing Webmaster.
const bingVerify = 'A6D1CFDEAC2B9278717C900496D50628';
const cfBeacon = 'f087d7b882c64c67b7ac67bf27de1c61';
const ga4Id = 'G-4P8F2BHLFZ';

import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /* Optional: per-route Service or Article schema to append to JSON-LD graph */
  extraSchema?: Record<string, any> | Record<string, any>[];
}

const {
  title = 'Tamazia · International SEO for regulated enterprises',
  description = 'Lawyer-led SEO and regulatory compliance firm. Every campaign passes through 200+ laws before anything goes live. Trusted by an NSE-listed hotel group, CG Oncology (Nasdaq: CGON), Meraas (Dubai Holding).',
  canonical = 'https://tamazia.co.uk/',
  ogImage = '/og-default.png',
  noindex = false,
  extraSchema = null,
} = Astro.props as any;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LegalService',
      '@id': 'https://tamazia.co.uk/#organization',
      name: 'Tamazia',
      alternateName: 'Tamazia · International SEO for regulated enterprises',
      url: 'https://tamazia.co.uk',
      logo: {
        '@type': 'ImageObject',
        url: 'https://tamazia.co.uk/og-default.png',
      },
      image: 'https://tamazia.co.uk/og-default.png',
      description: 'Lawyer-led SEO and regulatory compliance firm for regulated enterprises. Every campaign passes through 200+ frameworks before anything goes live.',
      slogan: 'Ranking is only valuable if it is legal.',
      areaServed: ['United Kingdom', 'European Union', 'United Arab Emirates', 'United States', 'France', 'Global'],
      knowsAbout: [
        'Search engine optimisation',
        'Regulatory compliance',
        'International arbitration',
        'Business law',
        'Healthcare advertising law',
        'Financial services regulation',
        'Real estate marketing compliance',
        'Hospitality marketing compliance',
      ],
      priceRange: '££',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '18:00',
      }],
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'GB',
      },
      sameAs: [
        'https://linkedin.com/company/tamazia',
        'https://instagram.com/tamazia',
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: 'founder@tamazia.co.uk',
        url: 'https://tamazia.co.uk/contact/',
        availableLanguage: ['English'],
      },
      founder: {
        '@type': 'Person',
        name: 'Aman Pareek',
        jobTitle: 'Founder',
        sameAs: [
          'https://linkedin.com/in/amanpareek',
        ],
        alumniOf: {
          '@type': 'EducationalOrganization',
          name: "King’s College London",
        },
      },
      memberOf: [
        { '@type': 'Organization', name: 'Chartered Institute of Arbitrators', url: 'https://www.ciarb.org' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://tamazia.co.uk/#website',
      url: 'https://tamazia.co.uk',
      name: 'Tamazia',
      publisher: { '@id': 'https://tamazia.co.uk/#organization' },
      inLanguage: 'en-GB',
    },
  ],
};

// K3 · BreadcrumbList auto-derived from canonical path on non-home routes
const _path = (canonical || 'https://tamazia.co.uk/').replace('https://tamazia.co.uk', '').replace(/\/$/, '');
const _segs = _path.split('/').filter(Boolean);
if (extraSchema) {
  const items = Array.isArray(extraSchema) ? extraSchema : [extraSchema];
  for (const item of items) {
    (jsonLd['@graph'] as any[]).push(item);
  }
}

if (_segs.length > 0) {
  (jsonLd['@graph'] as any[]).push({
    '@type': 'BreadcrumbList',
    '@id': canonical + '#breadcrumb',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Tamazia', item: 'https://tamazia.co.uk/' },
      ..._segs.map((seg, i) => ({
        '@type': 'ListItem',
        position: i + 2,
        name: seg.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
        item: 'https://tamazia.co.uk/' + _segs.slice(0, i + 1).join('/') + '/',
      })),
    ],
  });
}
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="preload" as="image" href="/tamazia-lockup-masthead-transparent.png" fetchpriority="high" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage.startsWith("http") ? ogImage : `https://tamazia.co.uk${ogImage}`} />
    <meta property="og:site_name" content="Tamazia" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@tamazia_co" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.startsWith("http") ? ogImage : `https://tamazia.co.uk${ogImage}`} />

    {/* Round-13 · fonts are now self-hosted from /public/fonts (latin + latin-ext WOFF2 subsets,
        loaded via @font-face declarations in src/styles/fonts.css). No cross-origin Google Fonts
        request → no SRI exception, no DNS roundtrip, no critical-path stylesheet fetch.
        Preloading the two LCP-critical faces. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400-normal-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/playfair-display-500-normal-latin.woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon set -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5A1A2B" />
    <meta name="theme-color" content="#5A1A2B" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#2A0C14" media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content="#5A1A2B" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Tamazia" />

    <!-- G.39 · hreflang · en-GB canonical + en + x-default -->
    <link rel="alternate" hreflang="en-GB" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://api.resend.com" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Named slot for page-level JSON-LD and additional head tags -->
    <slot name="head" />
  <HeadAnalytics bingVerify={bingVerify} />
  
<style is:global>
/* Phase 11 a11y · global media queries */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
@media (prefers-contrast: more) {
  :root {
    --ink: #000000;
    --ink-muted: #1a1a1a;
    --bg: #ffffff;
  }
  a, button { outline: 2px solid currentColor; outline-offset: 2px; }
}
@media (forced-colors: active) {
  /* Windows High Contrast Mode · let system colours through */
  button, .cookie-btn, .contact-form button { border: 2px solid ButtonText; }
}
:focus-visible {
  outline: 2px solid #C9A772;
  outline-offset: 3px;
  border-radius: 2px;
}
/* Skip-to-main link · WCAG 2.4.1 bypass blocks */
.skip-to-main {
  position: absolute;
  left: -9999px;
  top: 0;
  z-index: 9999;
  padding: 12px 20px;
  background: #2A0C14;
  color: #FAF7F2;
  text-decoration: none;
  font-family: 'Inter', system-ui, sans-serif;
  font-weight: 600;
  font-size: 14px;
}
.skip-to-main:focus {
  left: 12px;
  top: 12px;
}

      /* β-06 · Mobile sticky bottom CTA bar */
      .mobile-sticky-cta {
        display: none;
      }
      @media (max-width: 720px) {
        .mobile-sticky-cta {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          position: fixed;
          bottom: 0;
          left: 0;
          right: 0;
          z-index: 80;
          padding: 12px 16px env(safe-area-inset-bottom, 12px) 16px;
          background: var(--oxblood);
          border-top: 1px solid var(--gold-hairline);
          box-shadow: 0 -8px 24px -8px rgba(42, 12, 20, 0.45);
          transform: translateY(100%);
          transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
          font-family: var(--ff-body);
        }
        .mobile-sticky-cta:not([hidden]) { transform: translateY(0); }
        .msc-price {
          color: var(--pearl);
          font-size: 11px;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          line-height: 1.3;
          flex: 1 1 auto;
        }
        .msc-price strong { color: var(--gold); font-weight: 600; }
        .msc-cta {
          background: var(--gold);
          color: var(--oxblood-ink);
          padding: 10px 18px;
          font-size: 11px;
          letter-spacing: 0.16em;
          text-transform: uppercase;
          font-weight: 600;
          text-decoration: none;
          border-radius: 2px;
          white-space: nowrap;
          transition: background 240ms ease;
        }
        .msc-cta:hover { background: var(--gold-warm); }
        @media (prefers-reduced-motion: reduce) { .mobile-sticky-cta { transition: none; } }
      }
</style>
</head>
  <body>
<a href="#main" class="skip-to-main">Skip to main content</a>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />

    {/* Cookie consent strip — UK GDPR + EU PECR */}
    <div id="cookie-strip" class="cookie-strip" role="region" aria-label="Cookie consent" hidden>
      <p class="cookie-text">
        We use only essential cookies for site functionality. No third-party tracking. No marketing pixels.
        Read the <a href="/cookie-policy/" class="cookie-link">cookie policy</a> or the
        <a href="/privacy-notice/" class="cookie-link">privacy notice</a>.
      </p>
      <div class="cookie-actions">
        <button type="button" class="cookie-btn cookie-btn--reject" id="cookie-reject">Reject non-essential</button>
        <button type="button" class="cookie-btn cookie-btn--accept" id="cookie-accept">Accept all</button>
      </div>
    </div>

    <style>
      .cookie-strip {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        box-sizing: border-box;
        z-index: 9999;
        background: linear-gradient(180deg, #2A0C14 0%, #1F0810 100%);
        color: var(--pearl);
        padding: 10px 20px;
        display: flex;
        gap: 12px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        border-top: 1px solid #C9A772;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 12px;
        letter-spacing: 0.04em;
        animation: cookie-up 380ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      @keyframes cookie-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
      .cookie-text { margin: 0; max-width: 720px; line-height: 1.5; }
      .cookie-link {
        color: #C9A772;
        text-decoration: underline;
        margin-left: 6px;
        padding: 6px 4px;
        display: inline-block;
        line-height: 1.6;
      }
      .cookie-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
      }
      .cookie-btn {
        position: relative;
        z-index: 10000;
        border: 1px solid var(--gold);
        font-family: inherit;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        border-radius: 2px;
        cursor: pointer;
        transition: background 240ms ease, color 240ms ease, border-color 240ms ease;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        pointer-events: auto !important;
        user-select: none;
        -webkit-user-select: none;
        padding: 8px 16px;
        min-height: 36px;
      }
      .cookie-btn--accept {
        background: var(--gold);
        color: var(--oxblood-ink);
      }
      .cookie-btn--accept:hover { background: var(--gold-warm); }
      .cookie-btn--reject {
        background: transparent;
        color: var(--pearl);
      }
      .cookie-btn--reject:hover {
        background: rgba(232, 228, 220, 0.1);
        border-color: var(--gold-warm);
      }
      .cookie-btn:focus-visible { outline: 2px solid var(--gold-warm); outline-offset: 2px; }
      @media (max-width: 640px) {
        .cookie-strip {
          font-size: 11px; padding: 8px 14px; gap: 12px;
          flex-direction: column;
          z-index: 2000;
          bottom: 64px;
          border-bottom: 1px solid var(--gold-hairline);
        }
        .cookie-text { text-align: center; }
        .cookie-actions { width: 100%; justify-content: stretch; }
        .cookie-btn {
          flex: 1 1 auto; min-width: 0; padding: 10px 12px; min-height: 48px;
          border-radius: 999px;
          touch-action: manipulation;
          -webkit-tap-highlight-color: transparent;
          pointer-events: auto !important;
          font-size: 12px;
        }
      }
    </style>

    <script is:inline data-cfasync="false">
      (function() {
        var KEY = 'tamazia-cookie-consent';
        var TTMS = 13 * 30 * 86400000; // 13 months in ms

        // --- Check existing valid consent ---
        try {
          var raw = localStorage.getItem(KEY);
          if (raw) {
            // v2 JSON schema: { v:2, analytics:bool, ad:false, ts:unixMs }
            var c = null;
            try { c = JSON.parse(raw); } catch(_) {}
            if (c && c.v === 2 && typeof c.analytics === 'boolean' && (Date.now() - c.ts) < TTMS) {
              return; // valid — do not show banner
            }
            // Legacy string migration
            if (raw === 'granted' || raw === 'denied') {
              try { localStorage.setItem(KEY, JSON.stringify({ v: 2, analytics: raw === 'granted', ad: false, ts: Date.now() })); } catch(_) {}
              return;
            }
          }
        } catch(_) {}

        // --- QA override: ?force-reconsent=1 re-shows the banner ---
        try { if (location.search.indexOf('force-reconsent=1') !== -1) localStorage.removeItem(KEY); } catch(_) {}

        // --- Dismiss: save consent, update Google, hide banner ---
        function dismiss(analytics) {
          var strip = document.getElementById('cookie-strip');
          // Idempotency guard: if strip is already hidden, do nothing
          if (!strip || strip.hasAttribute('hidden')) return;
          // Hide first so rapid taps are safe
          strip.style.display = 'none';
          strip.setAttribute('hidden', '');
          strip.setAttribute('aria-hidden', 'true');
          // Persist consent record
          try { localStorage.setItem(KEY, JSON.stringify({ v: 2, analytics: analytics, ad: false, ts: Date.now() })); } catch(_) {}
          // Update Google Consent Mode v2 if gtag has loaded
          try {
            if (typeof window.gtag === 'function') {
              window.gtag('consent', 'update', {
                analytics_storage: analytics ? 'granted' : 'denied',
                ad_storage: 'denied',
                ad_user_data: 'denied',
                ad_personalization: 'denied'
              });
            }
          } catch(_) {}
          // Notify other listeners
          try { window.dispatchEvent(new CustomEvent('tamazia:consent', { detail: { analytics: analytics } })); } catch(_) {}
        }

        // --- Show banner ---
        function showStrip() {
          var strip = document.getElementById('cookie-strip');
          if (!strip) return;
          strip.removeAttribute('hidden');
          strip.removeAttribute('aria-hidden');
          strip.style.display = 'flex';
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', showStrip);
        } else {
          showStrip();
        }

        // --- Capture-phase click delegation ---
        // Fires before any child handler, immune to Rocket Loader timing.
        // Walks up DOM to handle any nested child elements inside the button.
        document.addEventListener('click', function(ev) {
          var t = ev.target;
          while (t && t !== document) {
            if (t.id === 'cookie-accept') { dismiss(true); return; }
            if (t.id === 'cookie-reject') { dismiss(false); return; }
            t = t.parentNode;
          }
        }, true);

      }());

      /* Safety net: reveal scroll-triggered elements 4s after load in case IntersectionObserver
         never fired (deep-link, JS race, unsupported browser) */
      window.addEventListener('load', function() {
        setTimeout(function() {
          var els = document.querySelectorAll(
            '.sector-card:not(.in-view), .case-panel:not(.in-view), .interstitial:not(.in-view), .stat-value:not(.counted)'
          );
          for (var i = 0; i < els.length; i++) {
            els[i].classList.add('in-view');
            els[i].classList.add('counted');
          }
        }, 4000);
      });
    </script>

  <BodyAnalytics cfBeacon={cfBeacon} ga4Id={ga4Id} />

    <!-- β-06 · Mobile sticky bottom CTA bar (appears after 30% scroll, hides on input focus) -->
    <script>
      /* β-06 · Mobile sticky CTA show/hide */
      const mscBar = document.getElementById('mobile-sticky-cta');
      if (mscBar) {
        let mscShown = false;
        const showBar = (show) => {
          if (mscShown === show) return;
          mscShown = show;
          if (show) { mscBar.removeAttribute('hidden'); mscBar.setAttribute('aria-hidden', 'false'); }
          else { mscBar.setAttribute('hidden', ''); mscBar.setAttribute('aria-hidden', 'true'); }
        };
        const onScroll = () => {
          const doc = document.documentElement;
          const scrolled = window.scrollY;
          const total = doc.scrollHeight - window.innerHeight;
          if (total <= 0) return;
          const pct = scrolled / total;
          // show between 25% and 92% scroll, hide near footer to avoid stacking
          showBar(pct > 0.25 && pct < 0.92);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
        // Hide on input focus (so the bar does not collide with mobile keyboard)
        document.addEventListener('focusin', (e) => {
          const t = e.target;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT')) {
            mscBar.setAttribute('hidden', '');
            mscBar.setAttribute('aria-hidden', 'true');
            mscShown = false;
          }
        });
        document.addEventListener('focusout', () => setTimeout(onScroll, 200));
      }
</script>
    <div id="mobile-sticky-cta" class="mobile-sticky-cta" hidden aria-hidden="true">
      <span class="msc-price">From <strong>£2,500</strong>/month · 90 day rolling</span>
      <a class="msc-cta" href="/book/">Book a strategy call</a>
    </div>

  </body>
</html>
