<script>
  
  // Currency tween · interpolate displayed price over 600ms easeOutQuart
  function countUpTween(el, fromN, toN, dur, formatter) {
    const start = performance.now();
    const tick = (now) => {
      const t = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - t, 4);
      const val = Math.round(fromN + (toN - fromN) * eased);
      el.textContent = formatter(val);
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
// Currency switcher (rates GBP 1 : USD 1.27 : AED 4.67) + pilot engagement toggle
  (function () {
    const RATES: Record<string, number> = { GBP: 1, USD: 1.27, EUR: 1.16, AED: 4.67 };
    const SYMBOLS: Record<string, string> = { GBP: '£', USD: '$', EUR: '€', AED: 'د.إ' };
    const LS_CURRENCY = 'tamazia_currency';
    const LS_PILOT = 'tamazia_pilot'; // 'on' | 'off' (default 'on')

    function rounded(gbp: number, currency: string): number {
      return Math.round(gbp * RATES[currency] / 100) * 100;
    }

    function formatPrice(gbp: number, currency: string): string {
      return `From ${SYMBOLS[currency]}${rounded(gbp, currency).toLocaleString()}`;
    }

    function formatPlain(gbp: number, currency: string): string {
      return `${SYMBOLS[currency]}${rounded(gbp, currency).toLocaleString()}`;
    }

    function activeAttr(pilotOn: boolean): string {
      return pilotOn ? 'data-gbp' : 'data-gbp-standard';
    }

    function applyAll(currency: string, pilotOn: boolean): void {
      document.querySelectorAll<HTMLElement>('[data-gbp]').forEach((priceEl) => {
        const card = priceEl.closest<HTMLElement>('.tier-card');
        const headlineGbp = parseInt(priceEl.getAttribute(activeAttr(pilotOn)) ?? '0', 10);
        const standardGbp = parseInt(priceEl.getAttribute('data-gbp-standard') ?? '0', 10);
        const savesGbp = parseInt(priceEl.getAttribute('data-saves-gbp') ?? '0', 10);

        // Headline price · tween between previous and new value over 600ms
        const display = priceEl.querySelector<HTMLElement>('.price-display');
        if (display) {
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduce) {
            display.textContent = formatPrice(headlineGbp, currency);
          } else {
            const fromN = parseInt((display.dataset.lastVal || '0'), 10);
            const toN = headlineGbp * (RATES[currency] || 1);
            const dur = 600;
            const start = performance.now();
            const tick = (now: number) => {
              const t = Math.min((now - start) / dur, 1);
              const eased = 1 - Math.pow(1 - t, 4);
              const v = Math.round(fromN + (toN - fromN) * eased);
              display.textContent = formatPrice(Math.round(v / (RATES[currency] || 1)), currency);
              if (t < 1) requestAnimationFrame(tick);
              else { display.textContent = formatPrice(headlineGbp, currency); display.dataset.lastVal = String(toN); }
            };
            requestAnimationFrame(tick);
          }
        }

        // Strike-through standard rate (only visible when pilot is on)
        const strike = priceEl.querySelector<HTMLElement>('.price-strike');
        if (strike) strike.textContent = formatPlain(standardGbp, currency);

        // Saves line (only visible when pilot is on)
        if (card) {
          const savesEl = card.querySelector<HTMLElement>('.saves-line');
          if (savesEl) {
            savesEl.textContent = `Saves ${formatPlain(savesGbp, currency)} over the first six months.`;
          }
          card.classList.toggle('show-strike', pilotOn);
          card.classList.toggle('show-saves', pilotOn);
          card.classList.toggle('show-microcopy', !pilotOn);
        }
      });
    }

    function activateCurrencyButton(currency: string): void {
      document.querySelectorAll<HTMLButtonElement>('.currency-btn').forEach((btn) => {
        const isActive = btn.dataset.currency === currency;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    function activatePilotButton(pilotOn: boolean): void {
      document.querySelectorAll<HTMLButtonElement>('.pilot-btn').forEach((btn) => {
        const isActive = (btn.dataset.pilot === 'on') === pilotOn;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    let currentCurrency = 'GBP';
    let currentPilot = true; // default ON

    function setCurrency(currency: string): void {
      currentCurrency = RATES[currency] ? currency : 'GBP';
      try { localStorage.setItem(LS_CURRENCY, currentCurrency); } catch (_) {}
      activateCurrencyButton(currentCurrency);
      applyAll(currentCurrency, currentPilot);
    }

    function setPilot(on: boolean): void {
      currentPilot = on;
      try { localStorage.setItem(LS_PILOT, on ? 'on' : 'off'); } catch (_) {}
      activatePilotButton(currentPilot);
      applyAll(currentCurrency, currentPilot);
    }

    // Init from localStorage with safe defaults
    try {
      const lsCurrency = localStorage.getItem(LS_CURRENCY);
      if (lsCurrency && RATES[lsCurrency]) currentCurrency = lsCurrency;
      const lsPilot = localStorage.getItem(LS_PILOT);
      if (lsPilot === 'off') currentPilot = false;
    } catch (_) {}

    document.querySelectorAll<HTMLButtonElement>('.currency-btn').forEach((btn) => {
      btn.addEventListener('click', () => setCurrency(btn.dataset.currency ?? 'GBP'));
    });
    document.querySelectorAll<HTMLButtonElement>('.pilot-btn').forEach((btn) => {
      btn.addEventListener('click', () => setPilot(btn.dataset.pilot === 'on'));
    });

    activateCurrencyButton(currentCurrency);
    activatePilotButton(currentPilot);
    applyAll(currentCurrency, currentPilot);
  })();

  /* Pricing inclusion accordion · works on desktop AND mobile.
     Default state: all <details> closed (no [open] attribute in markup).
     Behavior: opening one <details> inside a tier card closes any other open
     <details> in the same card. Also, the mobile per-feature expander uses a
     single-open-at-a-time policy per card. */
  (function () {
    function attachAccordion(scope) {
      const detailsList = Array.from(scope.querySelectorAll(':scope > .features-collapse, :scope > .additional-block'));
      detailsList.forEach((d) => {
        d.addEventListener('toggle', () => {
          if (d.open) {
            detailsList.forEach((other) => {
              if (other !== d && other.open) other.open = false;
            });
          }
        });
      });
    }
    document.querySelectorAll('.tier-card').forEach(attachAccordion);

    /* Mobile rich-feature inclusion tap-to-expand · single-open-at-a-time within each tier card */
    document.querySelectorAll('.tier-card').forEach((card) => {
      const features = Array.from(card.querySelectorAll('.rich-feature'));
      features.forEach((rf) => {
        const headline = rf.querySelector('.feature-headline');
        if (!headline) return;
        // a11y: role=button is not allowed on a heading element (axe aria-allowed-role);
        // keyboard/expand behaviour is conveyed by tabindex + aria-expanded instead.
        headline.setAttribute('tabindex', '0');
        headline.setAttribute('aria-expanded', 'false');
        const toggle = () => {
          const willOpen = !rf.classList.contains('expanded');
          if (willOpen) {
            features.forEach((other) => {
              if (other !== rf) {
                other.classList.remove('expanded');
                const oh = other.querySelector('.feature-headline');
                if (oh) oh.setAttribute('aria-expanded', 'false');
              }
            });
          }
          rf.classList.toggle('expanded', willOpen);
          headline.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        };
        headline.addEventListener('click', (e) => { e.preventDefault(); toggle(); });
        headline.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
        });
      });
    });
  })();
</script>
