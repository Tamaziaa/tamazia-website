---
import { heroContent } from '../../content/hero';
---
{/* B-02 fix · top credentials strip removed per Aman directive */}

<nav class="main-nav" aria-label="Primary">
  <a href="/" class="logo-lockup" aria-label="Tamazia home">
    <img src="/tamazia-mark-horse.png" alt="" class="logo-mark" width="56" height="56" />
    <span class="logo-text">TAMAZIA</span>
  </a>
  <ul class="nav-items">
    {heroContent.headerNav.map(item => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ul>
  <a class="nav-cta" href={heroContent.navCtaUrl}>{heroContent.navCta}</a>
  {/* Phase B · mobile burger */}
  <button class="burger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-drawer">
    <svg width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
      <rect y="0"  width="22" height="2" rx="1" fill="currentColor"/>
      <rect y="7"  width="22" height="2" rx="1" fill="currentColor"/>
      <rect y="14" width="22" height="2" rx="1" fill="currentColor"/>
    </svg>
  </button>
</nav>

{/* Phase B · mobile drawer */}
<nav class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation" hidden>
  <button class="drawer-close" aria-label="Close navigation menu">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <line x1="17" y1="1" x2="1"  y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <ul class="drawer-items">
    {heroContent.headerNav.map(item => (
      <li><a href={item.href} class="drawer-link">{item.label}</a></li>
    ))}
  </ul>
  <a class="drawer-cta" href={heroContent.navCtaUrl}>{heroContent.navCta}</a>
</nav>

<div class="progress-bar" id="progress"></div>

<style>
  .top-strip {
    height: 36px;
    background: var(--ivory);
    border-bottom: 1px solid var(--hairline);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    position: sticky;
    top: 0;
    z-index: 100;
    font-weight: 400;
    padding: 0 16px;
  }

  .top-strip .dot {
    color: var(--gold);
    margin: 0 10px;
    opacity: 0.85;
  }

  .main-nav {
    height: 76px;
    background: var(--ivory);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 72px;
    border-bottom: 1px solid var(--hairline);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* Brand lockup · horse mark + TAMAZIA wordmark, horizontal */
  .logo-lockup {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    text-decoration: none;
    transition: transform var(--duration-short) var(--ease-out);
    white-space: nowrap;
  }

  .logo-mark {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--oxblood);
    border: 1px solid var(--gold);
    box-shadow: 0 0 0 1px rgba(201, 167, 114, 0.1);
    object-fit: cover;
    display: block;
    transition: box-shadow var(--duration-short) var(--ease-out);
  }

  .logo-text {
    font-family: var(--ff-display);
    font-size: 19px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }

  .logo-lockup:hover .logo-mark {
    box-shadow: 0 0 0 4px rgba(201, 167, 114, 0.12);
  }
  .logo-lockup:hover .logo-text {
    color: var(--oxblood);
  }

  .nav-items {
    display: flex;
    list-style: none;
    gap: 22px;
    align-items: center;
    flex-wrap: nowrap;
  }
  .nav-items li { white-space: nowrap; }

  .nav-items li a {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    position: relative;
    padding: 6px 0;
    transition: color var(--duration-short) ease;
    font-weight: 400;
    text-decoration: none;
    display: inline-block;
  }

  .nav-items li a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 500ms var(--ease-out);
  }

  .nav-items li a:hover::after { width: 100%; }
  .nav-items li a:hover { color: var(--oxblood); }

  /* Round-12 fix · keyboard focus indicator */
  .nav-items li a:focus-visible,
  .nav-cta:focus-visible,
  .logo-lockup:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .nav-items li a:focus-visible::after { width: 100%; }

  .nav-cta {
    background: var(--oxblood);
    color: var(--ivory);
    border: 1px solid var(--gold);
    height: 46px;
    padding: 0 22px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    margin-left: 24px;
    transition: background var(--duration-short) ease, border-color var(--duration-short) ease, box-shadow var(--duration-short) ease;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .nav-cta:hover {
    background: var(--oxblood-warm);
    border-color: var(--gold-warm);
    box-shadow: 0 0 0 3px rgba(201, 167, 114, 0.12);
  }

  /* Phase B · burger button */
  .burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: var(--ink);
    cursor: pointer;
    margin-left: 12px;
    padding: 0;
    border-radius: 2px;
    transition: color var(--duration-short) ease;
  }
  .burger:hover { color: var(--oxblood); }
  .burger:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  /* Phase B · mobile drawer */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    background: var(--oxblood);
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 32px 28px 48px;
    transform: translateX(100%);
    transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-drawer:not([hidden]) {
    display: flex;
    transform: translateX(0);
  }
  .mobile-drawer[hidden] {
    display: flex;
    transform: translateX(100%);
    pointer-events: none;
  }

  .drawer-close {
    align-self: flex-end;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: var(--gold);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
    padding: 0;
    border-radius: 2px;
  }
  .drawer-close:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .drawer-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    margin: 0 0 32px;
    padding: 0;
  }

  .drawer-link {
    display: block;
    font-family: var(--ff-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--gold);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid rgba(201, 167, 114, 0.18);
    transition: color var(--duration-short) ease, padding-left var(--duration-short) ease;
  }
  .drawer-link:hover { color: var(--ivory); padding-left: 8px; }
  .drawer-link:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .drawer-cta {
    margin-top: auto;
    background: var(--gold);
    color: var(--oxblood);
    border: none;
    height: 52px;
    padding: 0 32px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    border-radius: 2px;
    transition: background var(--duration-short) ease;
  }
  .drawer-cta:hover { background: var(--gold-warm); }

  .progress-bar {
    position: fixed;
    top: 76px;
    left: 0;
    height: 1px;
    background: var(--oxblood);
    width: 0%;
    transition: width 120ms linear;
    z-index: 99;
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .main-nav { padding: 0 32px; }
    .nav-items { display: none; }
    .nav-cta { display: none; }
    .burger { display: flex; }
  }

  @media (max-width: 640px) {
    .top-strip { font-size: 8.5px; letter-spacing: 0.15em; }
    .main-nav { padding: 0 16px; height: 64px; }
    .logo-mark { width: 44px; height: 44px; }
    .logo-text { font-size: 17px; letter-spacing: 0.12em; }
    .logo-lockup { gap: 10px; }
    .progress-bar { top: 64px; }
  }
</style>

<script>
  // Progress bar follows scroll
  const bar = document.getElementById('progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const scrolled = window.scrollY;
      const progress = scrollable > 0 ? (scrolled / scrollable) * 100 : 0;
      bar.style.width = progress + '%';
    });
  }

  // Phase B · burger menu toggle
  const burger = document.querySelector('.burger') as HTMLButtonElement | null;
  const drawer = document.getElementById('mobile-drawer') as HTMLElement | null;
  const drawerClose = document.querySelector('.drawer-close') as HTMLButtonElement | null;
  const drawerLinks = document.querySelectorAll('.drawer-link, .drawer-cta');

  function openDrawer() {
    if (!drawer || !burger) return;
    drawer.hidden = false;
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    (drawerClose as HTMLButtonElement)?.focus();
  }

  function closeDrawer() {
    if (!drawer || !burger) return;
    drawer.hidden = true;
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    burger.focus();
  }

  burger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  drawerLinks.forEach(link => link.addEventListener('click', closeDrawer));

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.hidden) closeDrawer();
  });
</script>
