---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FinalHero from '../components/sections/FinalHero.astro';
import LawsStrip from '../components/sections/LawsStrip.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import Sectors from '../components/sections/Sectors.astro';
import Interstitial from '../components/sections/Interstitial.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import HowWeWork from '../components/sections/HowWeWork.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
import Contact from '../components/sections/Contact.astro';
import SextantInstrument from '../components/sections/SextantInstrument.astro';
import { faqContent } from '../content/faq';
import { pricingContent } from '../content/pricing';

// Remodel M2 · REAL-only structured data (no ratings markup — see _audit/trust-signals.md).
const faqSchema = {
  '@type': 'FAQPage',
  '@id': 'https://tamazia.co.uk/#faq-schema',
  mainEntity: (faqContent.questions as any[]).map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: (q.answerParagraphs || []).join(' '),
    },
  })),
};

const offerSchema = {
  '@type': 'OfferCatalog',
  '@id': 'https://tamazia.co.uk/#mandates',
  name: 'Tamazia mandates',
  itemListElement: (pricingContent.tiers as any[]).map((t) => ({
    '@type': 'Offer',
    name: `${t.name} mandate`,
    description: t.tagline,
    url: 'https://tamazia.co.uk/#pricing',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: t.priceGbp,
      priceCurrency: 'GBP',
      unitText: 'per month, from',
    },
    itemOffered: {
      '@type': 'Service',
      name: `${t.name}: compliance-led SEO mandate`,
      serviceType: 'Search engine optimisation with regulatory compliance review',
      provider: { '@id': 'https://tamazia.co.uk/#org' },
    },
  })),
};
---
<BaseLayout extraSchema={[faqSchema, offerSchema]}>
  <Header />
  <main id="main">
    <FinalHero />
    <LawsStrip />
    <WhyUs />
    <Sectors />
    <Interstitial numeral="III." label="Case Studies" />
    <CaseStudies />
    <Testimonials />
    <Interstitial numeral="IV." label="The Process" />
    <HowWeWork />
    <Interstitial numeral="V." label="Engagement" />
    <Pricing />
    <Interstitial numeral="VI." label="Questions & Findings" />
    <FAQ />
    <Contact />
    {/* Founder directive 2026-06-10: The Sextant closes the page, after the FAQ
        reach-out box and the Contact box. */}
    <SextantInstrument />
  </main>
  <Footer />
</BaseLayout>
