---
// G.2 · About page · /about/
// JSON-LD: ProfilePage + Person
// Pull quote: "Ranking is only valuable if it is legal."
// Credentials: LLM King's College London, CIArb, ABA, Supreme Court of India internship
// One-sentence LexQuity reference

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';

const canonicalUrl = 'https://tamazia.co.uk/about/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      '@id': `${canonicalUrl}#profilepage`,
      url: canonicalUrl,
      name: 'About Aman Pareek · Founder, Tamazia',
      description: 'Aman Pareek is the founder of Tamazia, a lawyer-led SEO firm for regulated enterprises. LLM King\'s College London, Member CIArb and ABA.',
      mainEntity: { '@id': `${canonicalUrl}#person` },
    },
    {
      '@type': 'Person',
      '@id': `${canonicalUrl}#person`,
      name: 'Aman Pareek',
      jobTitle: 'Founder',
      worksFor: {
        '@id': 'https://tamazia.co.uk/#organization',
      },
      alumniOf: [
        {
          '@type': 'EducationalOrganization',
          name: "King's College London",
          url: 'https://www.kcl.ac.uk',
        },
      ],
      memberOf: [
        {
          '@type': 'Organization',
          name: 'Chartered Institute of Arbitrators',
          url: 'https://www.ciarb.org',
        },
        {
          '@type': 'Organization',
          name: 'American Bar Association',
          url: 'https://www.americanbar.org',
        },
      ],
      knowsAbout: [
        'International arbitration',
        'Business law',
        'Search engine optimisation',
        'Regulatory compliance',
        'Financial services regulation',
        'Healthcare advertising law',
        'Real estate marketing compliance',
      ],
      url: canonicalUrl,
      sameAs: ['https://tamazia.co.uk'],
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tamazia.co.uk/' },
        { '@type': 'ListItem', position: 2, name: 'About', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="About · Aman Pareek · Founder, Tamazia"
  description="Aman Pareek is the founder of Tamazia. LLM in International Business Law, King's College London. Member, Chartered Institute of Arbitrators. Member, American Bar Association. Lawyer-led SEO for regulated enterprises."
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Header />

  <main id="main">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">About</li>
      </ol>
    </nav>

    {/* Hero */}
    <section class="about-hero" aria-labelledby="about-h1">
      <div class="about-hero-inner">
        <div class="about-hero-text">
          <p class="about-eyebrow">TAMAZIA · ABOUT</p>
          <h1 id="about-h1" class="about-h1">Aman Pareek</h1>
          <p class="about-title-line">Founder, Tamazia</p>
          <p class="about-credentials-line">
            LLM, International Business Law · King's College London<br />
            Member, Chartered Institute of Arbitrators<br />
            Member, American Bar Association
          </p>
        </div>
        <figure class="about-pull-quote" aria-label="Founder's guiding principle">
          <blockquote>
            <p class="pull-quote-text">Ranking is only valuable if it is <em>legal</em>.</p>
          </blockquote>
          <figcaption class="pull-quote-attr">Aman Pareek · Founder, Tamazia</figcaption>
        </figure>
      </div>
    </section>

    {/* Founder profile */}
    <section class="founder-profile" aria-labelledby="founder-profile-heading">
      <div class="profile-inner">
        <h2 id="founder-profile-heading" class="profile-section-label">The Foundation</h2>

        <div class="profile-body">
          <p>
            Tamazia was built on a specific observation: regulated enterprises face a compliance gap that generic SEO agencies cannot close. Every piece of content, every service page, every case study, every blog post, touches a regulatory framework. Most agencies treat compliance as a constraint. Tamazia treats it as the methodology.
          </p>
          <p>
            The firm is led by a founder with an LLM in International Business Law from King's College London, with a specialism in business law and international arbitration. Membership of the Chartered Institute of Arbitrators and the American Bar Association provides access to institutional frameworks and practitioner networks that inform how Tamazia approaches regulated content.
          </p>
          <p>
            Earlier exposure to the Supreme Court of India's constitutional chambers, and work across ICC and LCIA arbitration proceedings, established the discipline that underpins Tamazia's compliance review process: the same rigour applied to a legal argument applies to a published webpage. What is written in public becomes the record.
          </p>
          <p>
            Tamazia's clients include an NSE-listed hotel group, CG Oncology (Nasdaq: CGON), and Meraas, a Dubai Holding subsidiary. Those engagements were not won on the basis of technical SEO credentials alone. They were won on the basis that the firm could produce content that survives regulatory scrutiny in the jurisdictions where those clients operate: the United Kingdom, the United Arab Emirates, the United States, and the European Union simultaneously.
          </p>
        </div>
      </div>
    </section>

    {/* Credentials */}
    <section class="credentials-section" aria-labelledby="credentials-heading">
      <div class="credentials-inner">
        <h2 id="credentials-heading" class="profile-section-label">Credentials</h2>
        <ul class="credentials-list" role="list">
          <li class="credential-item">
            <span class="credential-label">Education</span>
            <span class="credential-value">LLM, International Business Law · King's College London</span>
          </li>
          <li class="credential-item">
            <span class="credential-label">Specialism</span>
            <span class="credential-value">Business law and international arbitration</span>
          </li>
          <li class="credential-item">
            <span class="credential-label">Memberships</span>
            <span class="credential-value">Chartered Institute of Arbitrators (CIArb) · American Bar Association (ABA)</span>
          </li>
          <li class="credential-item">
            <span class="credential-label">Institutional exposure</span>
            <span class="credential-value">ICC · LCIA · UNCITRAL · Supreme Court of India</span>
          </li>
          <li class="credential-item">
            <span class="credential-label">Jurisdictions</span>
            <span class="credential-value">United Kingdom · United Arab Emirates · United States · European Union</span>
          </li>
        </ul>
      </div>
    </section>

    {/* LexQuity reference */}
    <section class="lexquity-ref" aria-labelledby="lexquity-ref-heading">
      <div class="lexquity-ref-inner">
        <h2 id="lexquity-ref-heading" class="profile-section-label">Beyond Tamazia</h2>
        <p class="lexquity-ref-text">
          Aman Pareek is also the founder of LexQuity, a legal technology company building the first AI-native research and document infrastructure for the international arbitration market.
        </p>
      </div>
    </section>

    {/* CTA */}
    <section class="about-cta" aria-labelledby="about-cta-heading">
      <div class="about-cta-inner">
        <h2 id="about-cta-heading" class="about-cta-heading">Work with Tamazia</h2>
        <p class="about-cta-sub">
          Every engagement opens with a regulatory and SEO audit against the standards applicable to your sector. No commitment required to begin.
        </p>
        <a href="/#contact" class="about-cta-btn">Begin an audit enquiry →</a>
        <p class="about-cta-note">Responses within one business day. All communications confidential.</p>
      </div>
    </section>

  </main>

  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Tamazia home"><span class="t">T</span></a>
        <p class="footer-tagline">Lawyer-led SEO for regulated enterprises.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <ul>
          <li><a href="/services/">Services</a></li>
          <li><a href="/case-studies/">Case Studies</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/privacy-notice/">Privacy Notice</a></li>
          <li><a href="/cookie-policy/">Cookie Policy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </nav>
      <p class="footer-legal">
        &copy; {new Date().getFullYear()} Tamazia Ltd. Registered in England and Wales.
        All engagements invoiced in GBP. Content reviewed against applicable regulatory standards before publication.
      </p>
    </div>
  </footer>

</BaseLayout>

<style>
  .breadcrumb {
    background: var(--ivory); border-bottom: 1px solid var(--hairline); padding: 12px 72px;
  }

  .breadcrumb ol {
    display: flex; list-style: none; gap: 8px; margin: 0; padding: 0;
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink); opacity: 0.6; align-items: center;
  }

  .breadcrumb li + li::before { content: '/'; margin-right: 8px; opacity: 0.4; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: var(--oxblood); opacity: 1; }
  .breadcrumb li[aria-current="page"] { opacity: 1; color: var(--oxblood); }

  /* About hero */
  .about-hero {
    background: var(--oxblood);
    padding: 80px 72px 88px;
    position: relative;
    overflow: hidden;
  }

  .about-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(198,160,80,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .about-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .about-eyebrow {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin: 0 0 20px; opacity: 0.9;
  }

  .about-h1 {
    font-family: var(--font-serif); font-size: clamp(36px, 5vw, 60px);
    font-weight: 500; color: var(--ivory); margin: 0 0 8px; letter-spacing: -0.02em;
  }

  .about-title-line {
    font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); opacity: 0.8; margin: 0 0 28px; font-weight: 500;
  }

  .about-credentials-line {
    font-size: 14px; line-height: 1.8; color: var(--ivory); opacity: 0.65;
    margin: 0;
  }

  .about-pull-quote {
    margin: 0;
    padding: 40px;
    border-left: 3px solid var(--gold);
    background: rgba(198,160,80,0.06);
  }

  .pull-quote-text {
    font-family: var(--font-serif); font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400; color: var(--ivory); line-height: 1.35; margin: 0 0 20px;
    font-style: normal;
  }

  .pull-quote-text em {
    color: var(--gold); font-style: italic;
  }

  .pull-quote-attr {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ivory); opacity: 0.45;
  }

  /* Profile sections */
  .founder-profile {
    background: var(--ivory);
    padding: 80px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .profile-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .profile-section-label {
    font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--oxblood); font-weight: 600; margin: 0 0 32px; opacity: 0.8;
  }

  .profile-body p {
    font-size: 16px; line-height: 1.78; color: var(--ink); opacity: 0.85; margin: 0 0 22px;
  }

  .profile-body p:last-child { margin-bottom: 0; }

  /* Credentials */
  .credentials-section {
    background: var(--parchment, #F5F0E8);
    padding: 64px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .credentials-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .credentials-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .credential-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--hairline);
    align-items: baseline;
  }

  .credential-item:first-child { border-top: 1px solid var(--hairline); }

  .credential-label {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--oxblood); font-weight: 600; opacity: 0.7;
  }

  .credential-value {
    font-size: 15px; color: var(--ink); opacity: 0.85; line-height: 1.5;
  }

  /* LexQuity ref */
  .lexquity-ref {
    background: var(--ivory);
    padding: 64px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .lexquity-ref-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .lexquity-ref-text {
    font-size: 16px; line-height: 1.7; color: var(--ink); opacity: 0.75; margin: 0;
  }

  /* About CTA */
  .about-cta {
    background: var(--ivory);
    padding: 96px 0;
  }

  .about-cta-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 72px;
    text-align: center;
  }

  .about-cta-heading {
    font-family: var(--font-serif); font-size: clamp(24px, 3vw, 36px);
    font-weight: 500; color: var(--ink); margin: 0 0 20px; letter-spacing: -0.01em;
  }

  .about-cta-sub {
    font-size: 16px; line-height: 1.7; color: var(--ink); opacity: 0.75; margin: 0 0 36px;
  }

  .about-cta-btn {
    display: inline-block; padding: 15px 36px; background: var(--oxblood);
    color: var(--gold); font-size: 12px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 600; text-decoration: none;
    border: 1px solid var(--oxblood); transition: background var(--t-bg), color var(--t-color);
    margin-bottom: 16px;
  }

  .about-cta-btn:hover { background: transparent; color: var(--oxblood); }

  .about-cta-note {
    font-size: 12px; letter-spacing: 0.06em; color: var(--ink); opacity: 0.5; margin: 0;
  }

  /* Footer */
  .footer { background: linear-gradient(180deg, #2A0C14 0%, #1F0810 100%); padding: 64px 0 48px; border-top: 1px solid rgba(255,255,255,0.06); }
  .footer-inner { max-width: 1100px; margin: 0 auto; padding: 0 72px; display: grid; grid-template-columns: auto 1fr; gap: 32px 64px; align-items: start; }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; }
  .footer-logo { width: 40px; height: 40px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--oxblood); font-family: var(--font-serif); font-size: 20px; font-weight: 500; text-decoration: none; }
  .footer-tagline { font-size: 12px; color: var(--ivory); opacity: 0.5; margin: 0; letter-spacing: 0.04em; }
  .footer-nav ul { display: flex; flex-wrap: wrap; gap: 8px 24px; list-style: none; margin: 0; padding: 0; }
  .footer-nav a { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ivory); text-decoration: none; opacity: 0.55; transition: opacity var(--t-opacity); }
  .footer-nav a:hover { opacity: 1; }
  .footer-legal { grid-column: 1 / -1; font-size: 11px; color: var(--ivory); opacity: 0.35; margin: 0; line-height: 1.6; letter-spacing: 0.04em; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 24px; }

  /* Responsive */
  @media (max-width: 900px) {
    .breadcrumb, .about-hero, .profile-inner, .credentials-inner, .lexquity-ref-inner, .about-cta-inner, .footer-inner { padding-left: 24px; padding-right: 24px; }

    .about-hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .credential-item { grid-template-columns: 1fr; gap: 4px; }
    .footer-inner { grid-template-columns: 1fr; }
  }

  @media print {
    .about-cta, .footer { display: none !important; }
    .about-hero { background: #fff !important; }
    .about-eyebrow, .about-h1, .about-title-line, .about-credentials-line { color: #000 !important; }
    .about-pull-quote { border-left-color: #000; background: #f5f5f5; }
    .pull-quote-text, .pull-quote-attr { color: #000 !important; }
  }
</style>
