---
// /admin/audit · founder-only audit runner with custom URL input
// Auth: ADMIN_SECRET via login form (in-memory only · matches /admin/submissions).
// Calls /api/audit with the same payload as the public form, renders identical output,
// plus a shareable permalink. noindex via meta.
import BaseLayout from '../../layouts/BaseLayout.astro';
const lastUpdated = '29 May 2026';
---
<BaseLayout
  title="Audit Runner · Tamazia admin"
  description="Auth-gated audit runner · custom URL or keyword input"
  canonical="https://tamazia.co.uk/admin/audit/"
  noindex={true}
>
  <main id="main" class="admin-audit">
    <header class="admin-head">
      <h1>Audit Runner</h1>
      <p class="updated">Founder console. Last verified {lastUpdated}.</p>
      <form id="login-form" class="login" autocomplete="off">
        <label for="adminkey">Admin secret</label>
        <input id="adminkey" type="password" autocomplete="off" placeholder="ADMIN_SECRET" />
        <button type="submit">Authenticate</button>
      </form>
    </header>

    <section id="runner" class="runner" hidden>
      <form id="audit-form" class="audit-runner-form" autocomplete="off">
        <label class="field-label" for="audit-input">Domain or primary keyword</label>
        <div class="row">
          <input id="audit-input" type="text" placeholder="yourdomain.com  ·  or keyword" required />
          <label class="field-label sector-label" for="audit-sector">Sector</label>
          <select id="audit-sector">
            <option value="">auto-detect</option>
            <option value="law firm">Law firm</option>
            <option value="hotels and hospitality">Hotels and hospitality</option>
            <option value="real estate">Real estate</option>
            <option value="financial services">Financial services</option>
            <option value="restaurants and f&amp;b">Restaurants and F and B</option>
            <option value="healthcare">Healthcare</option>
            <option value="e-commerce">E-commerce</option>
            <option value="automotive">Automotive</option>
            <option value="wellness and fitness">Wellness and fitness</option>
            <option value="executive personal brand">Executive personal brand</option>
            <option value="other">Other</option>
          </select>
          <button type="submit" id="run-btn">Run audit</button>
        </div>
      </form>

      <div id="permalink-wrap" class="permalink-wrap" hidden>
        <span class="permalink-label">Shareable link</span>
        <input id="permalink" class="permalink-input" type="text" readonly />
        <button id="copy-link" type="button">Copy</button>
      </div>

      <div id="status-bar" class="status-bar"></div>

      <div id="report" class="report" hidden>
        <header class="report-header">
          <div class="report-title">Tamazia Instrument · <span id="report-input">·</span></div>
          <div class="report-badges">
            <span class="badge" id="report-sector">·</span>
            <span class="badge" id="report-regulator">·</span>
            <span class="badge" id="report-overall">·</span>
          </div>
        </header>

        <section class="report-gauges">
          <div class="gauge-row" id="report-gauges"></div>
        </section>

        <section class="report-observation">
          <blockquote id="report-observation">·</blockquote>
          <p class="report-citation"><span id="report-citation">·</span></p>
        </section>

        <section class="report-findings">
          <h3>Findings</h3>
          <ul id="report-findings"></ul>
        </section>

        <section class="report-compliance">
          <h3>Compliance positioning</h3>
          <p id="report-compliance">·</p>
        </section>

        <section class="report-upsell">
          <h3 id="upsell-headline">·</h3>
          <p id="upsell-body">·</p>
          <p id="upsell-microfooter">·</p>
        </section>

        <details class="report-raw">
          <summary>Raw JSON response (debug)</summary>
          <pre id="report-raw">·</pre>
        </details>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (function () {
    let adminSecret = null;

    const loginForm = document.getElementById('login-form');
    const runner = document.getElementById('runner');
    const auditForm = document.getElementById('audit-form');
    const runBtn = document.getElementById('run-btn');
    const statusBar = document.getElementById('status-bar');
    const report = document.getElementById('report');
    const permalinkWrap = document.getElementById('permalink-wrap');
    const permalinkInput = document.getElementById('permalink');
    const copyBtn = document.getElementById('copy-link');

    function setStatus(msg, kind) {
      statusBar.textContent = msg || '';
      statusBar.className = 'status-bar ' + (kind || '');
    }

    loginForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const key = document.getElementById('adminkey').value.trim();
      if (!key) return;
      adminSecret = key;
      loginForm.hidden = true;
      runner.hidden = false;
      setStatus('Ready · enter a URL or keyword above.', 'ok');

      // Pre-fill from query string ?u= or ?q=
      const qs = new URLSearchParams(location.search);
      const u = qs.get('u') || qs.get('q');
      const s = qs.get('s');
      if (u) {
        document.getElementById('audit-input').value = u;
        if (s) document.getElementById('audit-sector').value = s;
        auditForm.dispatchEvent(new Event('submit'));
      }
    });

    auditForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('audit-input').value.trim();
      const sector = document.getElementById('audit-sector').value;
      if (!input) return;

      runBtn.disabled = true;
      runBtn.textContent = 'Running…';
      report.hidden = true;
      setStatus('Calling /api/audit …');

      // Build permalink for sharing
      const params = new URLSearchParams({ u: input });
      if (sector) params.set('s', sector);
      const permaUrl = location.origin + '/admin/audit/?' + params.toString();
      permalinkInput.value = permaUrl;
      permalinkWrap.hidden = false;

      try {
        const fd = new FormData();
        fd.append('audit-input', input);
        if (sector) fd.append('sector', sector);
        fd.append('email', 'admin@tamazia.co.uk');
        fd.append('admin-source', '1');

        const res = await fetch('/api/audit', { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Audit failed (' + res.status + ')');

        renderReport(data, input, sector);
        setStatus('Audit complete · ' + (data.overall ? data.overall.grade : '·') + ' · ' + new Date().toLocaleString(), 'ok');
      } catch (err) {
        setStatus('Error: ' + (err.message || 'unknown'), 'error');
        document.getElementById('report-raw').textContent = String(err);
      } finally {
        runBtn.disabled = false;
        runBtn.textContent = 'Run audit';
      }
    });

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(permalinkInput.value);
        copyBtn.textContent = 'Copied';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1400);
      } catch (e) {
        permalinkInput.select();
      }
    });

    function renderReport(data, input, sector) {
      document.getElementById('report-input').textContent = input;
      document.getElementById('report-sector').textContent = (data.sector || sector || 'auto').toString().toUpperCase();
      document.getElementById('report-regulator').textContent = (data.regulator || '·').toString();
      document.getElementById('report-overall').textContent = data.overall ? ('SCORE ' + (data.overall.score || '·') + ' · ' + (data.overall.grade || '·')) : '·';

      const g = document.getElementById('report-gauges');
      g.innerHTML = '';
      const gauges = data.gauges || data.metrics || [];
      gauges.forEach((m) => {
        const card = document.createElement('div');
        card.className = 'gauge-cell';
        card.innerHTML =
          '<div class="g-label">' + (m.label || '') + '</div>' +
          '<div class="g-score">' + (m.score != null ? m.score : '·') + '</div>' +
          '<div class="g-layman">' + (m.laymanLabel || '') + '</div>' +
          '<div class="g-status status-' + (m.status || '') + '">' + (m.status || '').toUpperCase() + '</div>' +
          (m.potential != null ? '<div class="g-pot">Potential: ' + m.potential + '</div>' : '');
        g.appendChild(card);
      });

      document.getElementById('report-observation').textContent = data.observation || '·';
      document.getElementById('report-citation').textContent = data.citation || '·';

      const findings = document.getElementById('report-findings');
      findings.innerHTML = '';
      (data.findings || data.errorsVsShouldBe || []).forEach((f) => {
        const li = document.createElement('li');
        li.className = 'finding finding-' + (f.severity || f.level || 'medium');
        li.innerHTML = '<strong>' + (f.label || f.title || '·') + '</strong>: ' + (f.body || f.detail || '');
        findings.appendChild(li);
      });

      document.getElementById('report-compliance').textContent = data.compliance || data.complianceShort || '·';

      const u = data.upsell || {};
      document.getElementById('upsell-headline').textContent = u.headline || '·';
      document.getElementById('upsell-body').textContent = u.body || '·';
      document.getElementById('upsell-microfooter').textContent = u.microFooter || u.microfooter || '·';

      document.getElementById('report-raw').textContent = JSON.stringify(data, null, 2);
      report.hidden = false;
    }
  })();
</script>

<style>
  .admin-audit { padding: 32px 24px 96px; max-width: 1100px; margin: 0 auto; font-family: 'Inter', system-ui, sans-serif; color: #2A0C14; }
  .admin-audit h1 { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-weight: 500; font-size: 36px; margin: 0; }
  .updated { font-size: 12px; color: #5C4047; margin: 4px 0 16px; }
  .login { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .login label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; }
  .login input, .audit-runner-form input, .audit-runner-form select, .login button, .audit-runner-form button, .permalink-input, .permalink-wrap button {
    font: inherit; padding: 9px 11px; border: 1px solid #C9A772; background: #FAF7F2;
  }
  .login input { min-width: 240px; }
  .login button, .audit-runner-form button, .permalink-wrap button { cursor: pointer; background: #2A0C14; color: #FAF7F2; border-color: #2A0C14; }
  .audit-runner-form .field-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: #5C4047; display: block; margin: 0 0 6px; }
  .audit-runner-form .row { display: grid; grid-template-columns: 2fr 100px 1fr auto; gap: 10px; align-items: end; }
  .audit-runner-form .sector-label { grid-column: 2; align-self: end; padding-bottom: 11px; }
  @media (max-width: 720px) {
    .audit-runner-form .row { grid-template-columns: 1fr; }
    .audit-runner-form .sector-label { grid-column: auto; padding-bottom: 0; }
  }
  .permalink-wrap { display: flex; gap: 10px; align-items: center; margin: 16px 0; padding: 12px 14px; background: rgba(74,144,226,0.06); border: 1px solid rgba(74,144,226,0.25); border-radius: 6px; }
  .permalink-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #335A9E; font-weight: 600; }
  .permalink-input { flex: 1; min-width: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; }
  .status-bar { font-size: 13px; color: #5C4047; margin: 12px 0 18px; min-height: 18px; }
  .status-bar.ok { color: #0A5C2F; }
  .status-bar.error { color: #8E1B2C; }
  .report { background: #FAF7F2; border: 1px solid #E5DDCB; border-radius: 6px; padding: 22px 24px; }
  .report-header { display: flex; flex-direction: column; gap: 8px; margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid #E5DDCB; }
  .report-title { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-size: 20px; }
  .report-badges { display: flex; gap: 8px; flex-wrap: wrap; }
  .badge { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; background: #2A0C14; color: #FAF7F2; padding: 4px 10px; border-radius: 2px; font-weight: 600; }
  .gauge-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; }
  .gauge-cell { background: #fff; border: 1px solid #E5DDCB; border-radius: 4px; padding: 14px 16px; }
  .g-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #5C4047; font-weight: 600; margin-bottom: 6px; }
  .g-score { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-size: 32px; line-height: 1; color: #2A0C14; }
  .g-layman { font-size: 12px; color: #5C4047; margin-top: 4px; font-style: italic; }
  .g-status { font-size: 10px; letter-spacing: 0.14em; font-weight: 600; margin-top: 8px; }
  .status-green { color: #0A5C2F; }
  .status-amber { color: #8A5A00; }
  .status-red { color: #8E1B2C; }
  .g-pot { font-size: 11px; color: #5C4047; margin-top: 4px; }
  .report-observation { margin: 22px 0; padding: 16px 18px; background: #F4F0E8; border-left: 3px solid #C9A772; }
  .report-observation blockquote { font-family: var(--ff-display, Georgia, serif); font-style: italic; font-size: 16px; margin: 0 0 6px; }
  .report-citation { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #5C4047; margin: 0; }
  .report-findings ul { list-style: none; padding: 0; margin: 0; }
  .finding { padding: 10px 14px; border-left: 3px solid #C9A772; background: #fff; margin-bottom: 8px; font-size: 13px; line-height: 1.5; border-radius: 0 4px 4px 0; }
  .finding-critical, .finding-high { border-left-color: #8E1B2C; }
  .finding-medium { border-left-color: #B89149; }
  .report-compliance p { font-size: 13px; line-height: 1.6; }
  .report-upsell { margin-top: 22px; padding: 16px 18px; background: rgba(201,167,114,0.10); border: 1px solid #C9A772; border-radius: 4px; }
  .report-upsell h3 { font-family: var(--ff-display, Georgia, serif); font-size: 16px; margin: 0 0 8px; color: #5A1A2B; }
  .report-raw summary { cursor: pointer; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #5C4047; margin-top: 18px; }
  .report-raw pre { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; background: #1B0A12; color: #E8D9C9; padding: 12px 14px; border-radius: 4px; max-height: 320px; overflow: auto; }
</style>
