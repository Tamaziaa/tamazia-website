---
import { sectorsContent } from '../../content/sectors';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, subline, sectors, closingLine } = sectorsContent;

// SVG icon map for each sector. Each icon contains an inner class that drives
// per-sector hover animations. Stroke 1.5 base, 1.6-2.4 for emphasis lines.
const iconPaths: Record<string, string> = {
  // Legal · refined gavel with sound block + impact lines on strike
  gavel: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <g class="gavel-body">
      <ellipse cx="62" cy="30" rx="14" ry="6.5" transform="rotate(-30 62 30)" stroke-width="1.6"/>
      <line x1="50" y1="40" x2="76" y2="20" stroke-width="2.4"/>
      <line x1="48" y1="42" x2="22" y2="68" stroke-width="2.4"/>
      <circle cx="22" cy="68" r="2.5" fill="currentColor"/>
    </g>
    <rect x="30" y="78" width="40" height="6" rx="1.5"/>
    <ellipse cx="50" cy="86" rx="26" ry="3.5"/>
    <g class="impact-lines" opacity="0">
      <line x1="50" y1="74" x2="50" y2="68"/>
      <line x1="58" y1="75" x2="62" y2="70"/>
      <line x1="42" y1="75" x2="38" y2="70"/>
      <line x1="64" y1="78" x2="69" y2="76"/>
      <line x1="36" y1="78" x2="31" y2="76"/>
    </g>
  </g>`,
  // Healthcare · DNA double helix · rotateY for 3D-illusion spin
  caduceus: `<g class="dna-helix" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 30 15 Q 70 27, 30 39 Q 70 51, 30 63 Q 70 75, 30 87"/>
    <path d="M 70 15 Q 30 27, 70 39 Q 30 51, 70 63 Q 30 75, 70 87"/>
    <line x1="38" y1="20" x2="62" y2="20" stroke-width="1"/>
    <line x1="38" y1="33" x2="62" y2="33" stroke-width="1"/>
    <line x1="38" y1="46" x2="62" y2="46" stroke-width="1"/>
    <line x1="38" y1="58" x2="62" y2="58" stroke-width="1"/>
    <line x1="38" y1="69" x2="62" y2="69" stroke-width="1"/>
    <line x1="38" y1="82" x2="62" y2="82" stroke-width="1"/>
  </g>`,
  // Hospitality · concierge key in keyhole · 90° turn animation
  bell: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="50" r="38" stroke-width="1" stroke-dasharray="2,4" opacity="0.5"/>
    <g class="key-body">
      <circle cx="50" cy="25" r="10"/>
      <circle cx="50" cy="25" r="5"/>
      <line x1="50" y1="35" x2="50" y2="74" stroke-width="2.4"/>
      <line x1="50" y1="56" x2="58" y2="56" stroke-width="1.8"/>
      <line x1="50" y1="62" x2="56" y2="62" stroke-width="1.8"/>
      <line x1="50" y1="68" x2="60" y2="68" stroke-width="1.8"/>
    </g>
  </g>`,
  // Real estate / IPO · brass bell with three orbital rings
  'opening-bell': `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <ellipse class="ring-outer"  cx="50" cy="50" rx="46" ry="14" stroke-width="0.8" opacity="0.4"/>
    <ellipse class="ring-middle" cx="50" cy="50" rx="42" ry="11" stroke-width="0.8" opacity="0.5"  transform="rotate(60 50 50)"/>
    <ellipse class="ring-inner"  cx="50" cy="50" rx="38" ry="8"  stroke-width="0.8" opacity="0.6"  transform="rotate(-60 50 50)"/>
    <g class="bell-body">
      <line x1="50" y1="18" x2="50" y2="26" stroke-width="1.8"/>
      <circle cx="50" cy="16" r="3" fill="currentColor"/>
      <path d="M 32 56 Q 32 30, 50 26 Q 68 30, 68 56 L 72 66 L 28 66 Z" stroke-width="1.8"/>
      <line x1="26" y1="66" x2="74" y2="66" stroke-width="1.8"/>
      <circle cx="50" cy="58" r="2.5" fill="currentColor"/>
    </g>
  </g>`,
  // F&B · decanter with continuous swirl arc
  cloche: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="50" cy="20" rx="11" ry="3"/>
    <line x1="42" y1="22" x2="42" y2="36"/>
    <line x1="58" y1="22" x2="58" y2="36"/>
    <path d="M 42 36 Q 26 44, 24 62 Q 24 84, 50 86 Q 76 84, 76 62 Q 74 44, 58 36"/>
    <g class="swirl">
      <path d="M 32 65 A 18 18 0 1 1 67 65" stroke-width="1.4"/>
      <circle cx="32" cy="65" r="1.6" fill="currentColor"/>
    </g>
  </g>`,
  // Every sector · compass · kept from prior build
  compass: `<g class="compass-body" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="50" r="32"/>
    <circle cx="50" cy="50" r="26"/>
    <path d="M 50 20 L 54 50 L 50 80 L 46 50 Z" fill="currentColor"/>
    <path d="M 20 50 L 50 46 L 80 50 L 50 54 Z"/>
    <circle cx="50" cy="50" r="2" fill="currentColor"/>
    <line x1="50" y1="14" x2="50" y2="20"/>
    <line x1="50" y1="80" x2="50" y2="86"/>
    <line x1="14" y1="50" x2="20" y2="50"/>
    <line x1="80" y1="50" x2="86" y2="50"/>
  </g>`,
};
---
<section class="sectors" id="sectors" aria-labelledby="sectors-heading">
  <!-- Monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="sectors-heading" class="section-h2" set:html={parseEmph(h2)} />
      <p class="subline">{subline}</p>
    </div>

    {/* Round-12 fix · drop role="list"/"listitem" pair on bento-grid + sector article.
        axe-allowed-role disallows role="listitem" on <article>. Sector cards are
        standalone content blocks (article landmarks); they don't need list semantics. */}
    <div class="bento-grid">
      {sectors.map((sector) => (
        <article
          class={`sector-card sector-${sector.size}`}
          data-sector={sector.id}
        >
          <div class="card-inner">
            <span class="card-numeral">{sector.numeral}</span>

            <div class="card-3d" aria-hidden="true">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <Fragment set:html={iconPaths[sector.icon]} />
              </svg>
            </div>

            <div class="card-eyebrow">SECTOR {sector.index} / VI</div>
            <h3 class="card-headline">{sector.headline}</h3>
            <div class="card-shorthand">{sector.regulatoryShorthand}</div>
            <p class="card-body">{sector.body}</p>
            {sector.pullQuote && <blockquote class="card-pullquote">{sector.pullQuote}</blockquote>}
            <a href="#contact" class="card-cta">{sector.cta}</a>

            <!-- Tooltip regulation detail (appears on hover) -->
            <div class="card-tooltip" aria-hidden="true">
              <div class="tooltip-header">Specific frameworks applied</div>
              <ul>
                {sector.tooltip.map((t) => <li>{t}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="closing-line-wrap">
      <div class="closing-hairline" aria-hidden="true"></div>
      <p class="closing-line">{closingLine}</p>
    </div>
  </div>
</section>

<style>
  .sectors {
    position: relative;
    background: var(--obsidian);
    padding-block: var(--section-padding-block);
    overflow: hidden;
    color: var(--ivory);
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: clamp(280px, 45vw, 680px);
    color: var(--gold);
    line-height: 1;
    opacity: 0.025;
    letter-spacing: -0.04em;
    animation: monogram-breath 8s ease-in-out infinite;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    position: relative;
    z-index: 2;
  }

  .header-block {
    max-width: 720px;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--eyebrow-light, #6B5058);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--gold);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: var(--ls-h2);
    color: var(--ivory);
    margin-bottom: 24px;
  }

  .section-h2 :global(.emph) {
    color: var(--gold);
    font-style: italic;
    font-weight: 500;
  }

  .subline {
    font-family: var(--ff-display);
    font-size: 17px;
    font-style: italic;
    color: var(--pearl);
    opacity: 0.75;
    line-height: 1.5;
    max-width: 520px;
  }

  /* Bento grid: 12-column equal layout (B-03 fix) */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: auto;
    gap: 24px;
    align-items: stretch;
  }

  .sector-card {
    container-type: inline-size;
    position: relative;
    background: var(--obsidian-deep);
    border: 1px solid rgba(201, 167, 114, 0.3);
    border-radius: 16px;
    padding: 32px 32px 36px;
    overflow: visible; /* B-03: allow content to flow naturally */
    min-width: 0;
    height: 100%;
    transition: transform 400ms var(--ease-out),
                border-color 400ms var(--ease-out),
                box-shadow 400ms var(--ease-out);
    opacity: 0;
    transform: translateY(20px);
  }

  .sector-card.in-view {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 700ms var(--ease-out), transform 700ms var(--ease-out),
                border-color 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }

  /* All sectors equal weight (Aman directive: no dominant card) */
  .sector-large    { grid-column: span 4; grid-row: span 1; }
  .sector-standard { grid-column: span 4; grid-row: span 1; }
  .sector-medium   { grid-column: span 4; grid-row: span 1; }

  /* Per-card pull quote (6th unique element per sector card) */
  .card-pullquote {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--gold);
    border-left: 2px solid var(--gold);
    padding-left: 14px;
    margin: 16px 0;
  }

  .sector-card:hover {
    transform: translateY(-8px);
    border-color: var(--gold);
    box-shadow: 0 30px 60px -30px rgba(201, 167, 114, 0.3);
  }

  .card-inner {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow: visible;
  }
  .card-cta {
    margin-top: auto;
    padding-top: 16px;
  }

  .card-numeral {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
    opacity: 0.9;
    letter-spacing: 0.02em;
  }

  .card-3d {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 120px;
    height: 120px;
    color: var(--gold);
    opacity: 0.85;
    transition: transform 600ms var(--ease-out), opacity 600ms var(--ease-out);
  }

  .card-3d svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sector-card:hover .card-3d {
    opacity: 1;
  }

  /* Per-sector hover animations · drives inner SVG class targets */

  /* Legal · gavel strike with impact-line flash */
  .sector-card[data-sector="legal"] .card-3d svg .gavel-body { transform-origin: 22px 68px; }
  .sector-card[data-sector="legal"]:hover .card-3d svg .gavel-body {
    animation: gavel-strike 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .sector-card[data-sector="legal"]:hover .card-3d svg .impact-lines {
    animation: impact-flash 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  @keyframes gavel-strike {
    0%, 100% { transform: rotate(-26deg); }
    30%      { transform: rotate(2deg); }
    40%      { transform: rotate(-4deg); }
    60%      { transform: rotate(-12deg); }
    80%      { transform: rotate(-26deg); }
  }
  @keyframes impact-flash {
    0%, 28% { opacity: 0; }
    32%     { opacity: 1; }
    50%     { opacity: 0; }
    100%    { opacity: 0; }
  }

  /* Healthcare · DNA double-helix rotateY spin */
  .sector-card[data-sector="healthcare"] .card-3d svg .dna-helix { transform-origin: 50px 50px; transform-style: preserve-3d; }
  .sector-card[data-sector="healthcare"]:hover .card-3d svg .dna-helix {
    animation: dna-spin 2.4s linear infinite;
  }
  @keyframes dna-spin {
    0%   { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
  }

  /* Hospitality · concierge key 90° turn */
  .sector-card[data-sector="hospitality"] .card-3d svg .key-body { transform-origin: 50px 50px; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .key-body {
    animation: key-turn 1.8s ease-in-out infinite;
  }
  @keyframes key-turn {
    0%, 100% { transform: rotate(0deg); }
    40%      { transform: rotate(90deg); }
    60%      { transform: rotate(90deg); }
  }

  /* Real estate · orbital rings + bell pulse */
  .sector-card[data-sector="real-estate"] .card-3d svg .ring-outer,
  .sector-card[data-sector="real-estate"] .card-3d svg .ring-middle,
  .sector-card[data-sector="real-estate"] .card-3d svg .ring-inner,
  .sector-card[data-sector="real-estate"] .card-3d svg .bell-body { transform-origin: 50px 50px; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .ring-outer  { animation: ring-spin-cw  4s linear infinite; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .ring-middle { animation: ring-spin-ccw 3s linear infinite; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .ring-inner  { animation: ring-spin-cw  2s linear infinite; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .bell-body   { animation: bell-pulse    2s ease-in-out infinite; }
  @keyframes ring-spin-cw  { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes ring-spin-ccw { from { transform: rotate(0deg); } to { transform: rotate(-360deg); } }
  @keyframes bell-pulse    { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); } }

  /* F&B · decanter swirl */
  .sector-card[data-sector="fb"] .card-3d svg .swirl { transform-origin: 50px 65px; }
  .sector-card[data-sector="fb"]:hover .card-3d svg .swirl {
    animation: decanter-swirl 2.2s linear infinite;
  }
  @keyframes decanter-swirl {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Every sector · compass full rotation */
  .sector-card[data-sector="every-sector"] .card-3d svg .compass-body { transform-origin: 50px 50px; }
  .sector-card[data-sector="every-sector"]:hover .card-3d svg .compass-body {
    animation: compass-rotate 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  @keyframes compass-rotate {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Reduced motion: halt every per-sector animation */
  @media (prefers-reduced-motion: reduce) {
    .sector-card .card-3d svg * { animation: none !important; }
  }

  .card-eyebrow {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-top: 48px;
    margin-bottom: 16px;
    max-width: 60%;
  }

  .card-headline {
    font-family: var(--ff-display);
    font-weight: 500;
    color: var(--ivory);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    max-width: 85%;
  }

  .sector-large .card-headline { font-size: 32px; }
  .sector-standard .card-headline { font-size: 24px; }
  .sector-medium .card-headline { font-size: 22px; }

  .card-shorthand {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .card-body {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--pearl);
    opacity: 0.92;
    margin-bottom: 20px;
    flex: 1;
    /* B-01 fix · removed line-clamp so full body text shows */
    font-weight: 300;
  }

  .card-cta {
    /* B-06 fix · orange CTA per Aman directive · Round-7 contrast fix · ivory on accent-orange was 3.45:1, on accent-orange-deep is 4.81:1 (passes 4.5:1) */
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ivory);
    background: var(--accent-orange-deep);
    text-decoration: none;
    padding: 12px 16px;
    /* Round-8 fix · 44px min touch target on mobile */
    min-height: 44px;
    border-radius: 4px;
    border: 1px solid var(--accent-orange-deep);
    align-self: flex-start;
    transition: background 240ms ease, transform 240ms ease, box-shadow 240ms ease;
    margin-top: auto;
  }

  .card-cta:hover {
    /* Round-7 fix · use even deeper orange on hover for clear state change */
    background: #7A3E18;
    transform: translateX(2px);
    box-shadow: 0 0 18px rgba(168, 88, 32, 0.4);
  }

  /* Tooltip */
  .card-tooltip {
    position: absolute;
    bottom: 100%;
    right: 0;
    /* Round-13 fix · grow with content at 200% text zoom (was fixed width 280px which clipped) */
    min-width: 280px;
    max-width: min(380px, 90vw);
    width: max-content;
    overflow: visible;
    background: var(--ivory);
    color: var(--ink);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--gold);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 300ms ease, transform 300ms ease;
    z-index: 10;
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.3);
    /* Round-8 fix · also reveal on focus-within for keyboard users */
    visibility: hidden;
  }

  .sector-card:hover .card-tooltip,
  .sector-card:focus-within .card-tooltip {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  /* Round-8 fix · tooltip is hover-only and unreachable on touch devices · hide entirely on mobile */
  @media (max-width: 768px), (hover: none) {
    .card-tooltip { display: none; }
  }

  .tooltip-header {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--gold-hairline);
  }

  .card-tooltip ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card-tooltip li {
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--ink-muted);
    padding: 2px 0;
    letter-spacing: 0.02em;
  }

  .card-tooltip li::before {
    content: '·';
    color: var(--gold);
    margin-right: 6px;
  }

  /* Closing line */
  .closing-line-wrap {
    text-align: center;
    margin-top: clamp(64px, 8vw, 96px);
  }

  .closing-hairline {
    height: 1px;
    background: var(--gold);
    width: 40%;
    max-width: 400px;
    margin: 0 auto 32px;
    opacity: 0.5;
  }

  .closing-line {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--pearl);
    opacity: 0.7;
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .sector-large { grid-column: span 6; grid-row: span 2; }
    .sector-standard { grid-column: span 6; grid-row: span 1; }
    .sector-medium { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .sector-large, .sector-standard, .sector-medium {
      grid-column: span 1;
      grid-row: auto;
    }
    .card-3d {
      width: 80px;
      height: 80px;
    }
    .card-eyebrow { margin-top: 24px; max-width: 100%; }
    .sector-large .card-headline { font-size: 24px; }
    .sector-standard .card-headline { font-size: 20px; }
    .sector-medium .card-headline { font-size: 20px; }
    /* B-25 fix · tap-to-toggle tooltip on mobile */
    .card-tooltip {
      display: block;
      position: static;
      width: 100%;
      margin-top: 12px;
      max-height: 0;
      padding-block: 0;
      opacity: 0;
      transform: none;
      overflow: hidden;
      transition: max-height 280ms ease, opacity 280ms ease, padding-block 280ms ease;
    }
    .sector-card.tooltip-open .card-tooltip {
      max-height: 600px;
      opacity: 1;
      padding-block: 16px;
    }
  }
</style>

<script>
  // Sequential fade-in reveal on scroll-into-view
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      document.querySelectorAll('.sector-card').forEach((c) => c.classList.add('in-view'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, idx) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        setTimeout(() => el.classList.add('in-view'), idx * 100);
        observer.unobserve(el);
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.sector-card').forEach((c, i) => {
      (c as HTMLElement).style.transitionDelay = `${i * 80}ms`;
      observer.observe(c);
    });

    /* Round-10 safety fallback · if observer hasn't fired within 3s (e.g. user lands deep-linked
       below the section), reveal all cards anyway so content never stays invisible to a real visitor */
    setTimeout(() => {
      document.querySelectorAll('.sector-card:not(.in-view)').forEach(c => c.classList.add('in-view'));
    }, 3000);

    /* B-25 · sector card tap-to-toggle tooltip on touch devices */
    const isTouch = window.matchMedia('(hover: none)').matches || ('ontouchstart' in window);
    if (isTouch) {
      document.querySelectorAll('.sector-card').forEach((card) => {
        card.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a,button')) return;
          card.classList.toggle('tooltip-open');
        });
      });
    }
  });
</script>
