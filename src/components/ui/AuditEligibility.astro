---
// AuditEligibility · Founder r4: a VERY small box shown wherever the £1,500 audit
// is mentioned. Collapsed by default to a single line ("100 free audits a month —
// check eligibility"); clicking reveals a compact domain + email capture that
// routes to the same lead pipeline as the audit request (/api/audit-request → KV
// + Neon + Slack + Telegram) and shows a submitted state.
---
<details class="ae" data-ae>
  <summary class="ae-sum"><span class="ae-num">100</span> free audits a month. Check your eligibility.</summary>
  <form class="ae-form" novalidate>
    <input type="text" name="bot-field" tabindex="-1" autocomplete="off" class="tamz-hp" aria-hidden="true" />
    <input type="hidden" name="ts_form_open" value="" data-ae-ts />
    <input type="hidden" name="source" value="100-free-audits" />
    <div class="ae-row">
      <input class="ae-in" type="text" name="audit-input" inputmode="url" autocomplete="url" placeholder="yourfirm.com" aria-label="Your domain" required />
      <input class="ae-in" type="email" name="email" autocomplete="email" placeholder="you@firm.com" aria-label="Work email" required />
      <button class="ae-btn" type="submit">Check</button>
    </div>
    <p class="ae-err" data-ae-err hidden></p>
  </form>
  <p class="ae-done" data-ae-done hidden><span class="ae-tick" aria-hidden="true">✓</span> Submitted. If a slot is free this month we will email your audit shortly.</p>
</details>

<script is:inline>
  (function () {
    document.querySelectorAll('[data-ae]').forEach(function (box) {
      if (box.dataset.aeWired) return; box.dataset.aeWired = '1';
      var form = box.querySelector('form'); if (!form) return;
      var ts = box.querySelector('[data-ae-ts]'); if (ts) ts.value = String(Date.now());
      var err = box.querySelector('[data-ae-err]');
      var done = box.querySelector('[data-ae-done]');
      var btn = form.querySelector('.ae-btn');
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (err) err.hidden = true;
        var data = {}; new FormData(form).forEach(function (v, k) { data[k] = v; });
        if (!data['audit-input'] || !data.email) { if (err) { err.textContent = 'Add your domain and email.'; err.hidden = false; } return; }
        btn.disabled = true; btn.textContent = '…';
        try {
          var res = await fetch('/api/audit-request', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          var j = {}; try { j = await res.json(); } catch (e2) {}
          if (res.ok && j && j.ok) { form.hidden = true; if (done) done.hidden = false; }
          else { if (err) { err.textContent = (j && j.error && /email/i.test(j.error)) ? 'That email did not look deliverable.' : 'Please try again, or email founder@tamazia.co.uk.'; err.hidden = false; } btn.disabled = false; btn.textContent = 'Check'; }
        } catch (e3) { if (err) { err.textContent = 'Network hiccup. Please try again.'; err.hidden = false; } btn.disabled = false; btn.textContent = 'Check'; }
      });
    });
  })();
</script>

<style>
  .ae {
    border: 1px solid var(--gold-hairline, rgba(201,167,114,0.4));
    border-radius: 8px;
    background: rgba(201,167,114,0.05);
    max-width: 440px;
    margin: 10px auto 0;
    overflow: hidden;
  }
  .ae-sum {
    list-style: none; cursor: pointer;
    font-family: var(--ff-body, Inter, sans-serif);
    font-size: 11px; line-height: 1.3; color: var(--ink-muted, #5C3F40);
    letter-spacing: 0.01em; padding: 8px 12px;
    display: flex; align-items: center; gap: 6px;
    transition: color 200ms ease;
  }
  .ae-sum::-webkit-details-marker { display: none; }
  .ae-sum::after { content: '+'; margin-left: auto; color: var(--gold-text, #8A6520); font-size: 14px; transition: transform 240ms ease; }
  .ae[open] .ae-sum::after { transform: rotate(45deg); }
  .ae-sum:hover { color: var(--ink, #2A0C14); }
  .ae-num { font-family: var(--ff-display, Georgia, serif); font-style: italic; font-weight: 600; color: var(--gold-text, #8A6520); font-size: 13px; }
  .ae-form { padding: 0 12px 11px; }
  .ae-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .ae-in {
    flex: 1 1 130px; min-width: 0; box-sizing: border-box;
    min-height: 34px; padding: 6px 9px;
    border: 1px solid var(--gold-hairline, rgba(201,167,114,0.45)); border-radius: 6px;
    background: var(--ivory, #FAF7F2); color: var(--ink, #2A0C14);
    font-family: var(--ff-body, Inter, sans-serif); font-size: 12.5px;
  }
  .ae-in:focus { outline: none; border-color: var(--gold, #C9A772); box-shadow: 0 0 0 2px rgba(201,167,114,0.2); }
  .ae-btn {
    flex: 0 0 auto; min-height: 34px; padding: 6px 14px; cursor: pointer;
    border: 1px solid var(--gold, #C9A772); border-radius: 6px;
    background: var(--ink, #2A0C14); color: var(--ivory, #FAF7F2);
    font-family: var(--ff-body, Inter, sans-serif); font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    transition: background 200ms ease, color 200ms ease;
  }
  .ae-btn:hover:not(:disabled) { background: var(--gold, #C9A772); color: var(--ink, #2A0C14); }
  .ae-btn:disabled { opacity: 0.6; cursor: default; }
  .ae-err { font-family: var(--ff-body, Inter, sans-serif); font-size: 10.5px; color: #9c3a3a; margin: 6px 0 0; }
  .ae-done {
    font-family: var(--ff-body, Inter, sans-serif); font-size: 11.5px; line-height: 1.45;
    color: var(--ink, #2A0C14); display: flex; gap: 7px; align-items: flex-start; padding: 0 12px 11px; margin: 0;
  }
  .ae-tick {
    flex: 0 0 auto; width: 17px; height: 17px; border-radius: 50%;
    background: rgba(201,167,114,0.18); color: var(--gold-text, #8A6520);
    display: inline-flex; align-items: center; justify-content: center; font-size: 11px; margin-top: 1px;
  }
  @media (max-width: 480px) {
    .ae-row { flex-direction: column; }
    .ae-in, .ae-btn { width: 100%; }
  }
</style>
