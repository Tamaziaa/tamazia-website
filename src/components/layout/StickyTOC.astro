---
// S48 (Impl Doc v1.0) · Sticky table-of-contents anchor menu
// Slim bar at top of viewport, visible from scroll 240px onwards, desktop only.
// Anchors: Why Us | Sectors | Cases | Pricing | FAQ | Book a Call
// Mobile uses the existing hamburger nav (no overlap; this is display:none below 1024px).
const items = [
  { label: 'Why Us',     href: '#why-us'   },
  { label: 'Sectors',    href: '#sectors'  },
  { label: 'Cases',      href: '#cases'    },
  { label: 'Pricing',    href: '#pricing'  },
  { label: 'FAQ',        href: '#faq'      },
  { label: 'Book a Call', href: '#contact' },
];
---
<nav class="sticky-toc" id="sticky-toc" aria-label="Section anchor navigation" data-visible="false">
  <ul class="sticky-toc-items">
    {items.map((it) => (
      <li>
        <a href={it.href} data-target={it.href.replace('#', '')}>{it.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* Sticky TOC — fixed below the main header (76px), full-width slim bar */
  .sticky-toc {
    position: fixed;
    top: 76px;
    left: 0;
    right: 0;
    z-index: 90;
    background: rgba(250, 247, 242, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(201, 167, 114, 0.32);
    box-shadow: 0 2px 12px rgba(26, 12, 16, 0.06);
    /* Hidden by default; the script toggles data-visible="true" past 240px */
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 280ms cubic-bezier(.2,.7,.2,1), opacity 200ms ease;
    pointer-events: none;
  }
  .sticky-toc[data-visible="true"] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .sticky-toc-items {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 32px;
    margin: 0;
    padding: 10px 24px;
    max-width: var(--container-max, 1280px);
    margin-inline: auto;
  }

  .sticky-toc-items a {
    font-family: var(--ff-body, 'Inter', system-ui, sans-serif);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #5C4047;
    text-decoration: none;
    padding: 6px 0;
    position: relative;
    transition: color 200ms ease;
  }
  .sticky-toc-items a:hover { color: #5A1A2B; }
  .sticky-toc-items a::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 2px;
    background: #5A1A2B;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms cubic-bezier(.2,.7,.2,1);
  }
  .sticky-toc-items a[aria-current="true"] {
    color: #5A1A2B;
  }
  .sticky-toc-items a[aria-current="true"]::after {
    transform: scaleX(1);
  }

  .sticky-toc-items a:focus-visible {
    outline: 2px solid #C9A772;
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* Desktop only — mobile uses the existing hamburger */
  @media (max-width: 1024px) {
    .sticky-toc { display: none !important; }
  }

  /* Reduced motion — no slide, fade only */
  @media (prefers-reduced-motion: reduce) {
    .sticky-toc { transition: opacity 200ms ease; transform: none; }
  }
</style>

<script>
  // Show after 240px scroll; active-section tracking via IntersectionObserver
  (() => {
    const bar = document.getElementById('sticky-toc') as HTMLElement | null;
    if (!bar) return;

    let visible = false;
    const onScroll = () => {
      const next = window.scrollY > 240;
      if (next !== visible) {
        visible = next;
        bar.setAttribute('data-visible', next ? 'true' : 'false');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Active section tracking — highlight the anchor whose target section is in view
    const links = Array.from(bar.querySelectorAll<HTMLAnchorElement>('a[data-target]'));
    const targets = links
      .map((a) => ({ id: a.dataset.target!, el: document.getElementById(a.dataset.target!), a }))
      .filter((t) => t.el);

    if ('IntersectionObserver' in window && targets.length) {
      const setActive = (id: string) => {
        for (const { a, id: tid } of targets as any) {
          if (tid === id) a.setAttribute('aria-current', 'true');
          else a.removeAttribute('aria-current');
        }
      };
      const io = new IntersectionObserver(
        (entries) => {
          // Pick the entry currently intersecting with the largest ratio
          const visibleEntries = entries.filter((e) => e.isIntersecting);
          if (visibleEntries.length === 0) return;
          visibleEntries.sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          setActive(visibleEntries[0].target.id);
        },
        { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] }
      );
      for (const t of targets) if (t.el) io.observe(t.el);
    }
  })();
</script>
