---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import { insightSectors, insightPosts } from '../../../content/insights';

export function getStaticPaths() {
  return insightSectors.map((s) => ({ params: { sector: s.slug } }));
}

const { sector } = Astro.params;
const sectorMeta = insightSectors.find((s) => s.slug === sector)!;
const posts = insightPosts.filter((p) => p.sectorSlug === sector);
const published = posts.filter((p) => p.status === 'published');
const inPrep = posts.filter((p) => p.status === 'in-preparation');
---
<BaseLayout title={`${sectorMeta.title} Insights · Tamazia`} description={sectorMeta.hero}>
  <Header />
  <main id="main">
    <section class="sector-hero">
      <div class="container">
        <a class="back-link" href="/insights/">← All sectors</a>
        <div class="eyebrow">TAMAZIA · INSIGHTS · {sectorMeta.title.toUpperCase()}</div>
        <h1>{sectorMeta.title}</h1>
        <p class="subline">{sectorMeta.hero}</p>
        <div class="regulator-strip">{sectorMeta.regulator}</div>
      </div>
    </section>

    {published.length > 0 && (
      <section class="published-block">
        <div class="container">
          <h2 class="section-h2">Published</h2>
          <div class="posts-grid">
            {published.map((p) => (
              <a class="post-card published" href={`/insights/${p.sectorSlug}/${p.slug}/`}>
                <div class="post-meta">{p.regulator}</div>
                <h3 class="post-title">{p.title}</h3>
                <p class="post-excerpt">{p.excerpt}</p>
                <div class="post-footer">
                  <span class="reading-time">{p.readingTime}</span>
                  <span class="read-link">Read →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {inPrep.length > 0 && (
      <section class="prep-block">
        <div class="container">
          <h2 class="section-h2">In preparation</h2>
          <p class="prep-note">These slots are reserved with working titles. Each will be researched, drafted, and published over the coming weeks.</p>
          <div class="prep-list">
            {inPrep.map((p) => (
              <article class="prep-card">
                <div class="prep-meta">
                  <span class="status-chip">In preparation</span>
                  <span class="regulator">{p.regulator}</span>
                </div>
                <h3 class="prep-title">{p.title}</h3>
                <p class="prep-excerpt">{p.excerpt}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }
  .sector-hero {
    background: var(--grad-hero);
    padding-block: clamp(64px, 8vw, 112px);
  }
  .back-link {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 600;
    text-decoration: none;
    /* Round-13 fix · ≥44×44 touch target (was 19px tall) */
    padding: 12px 6px;
    margin: -12px -6px 16px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
  }
  .back-link:hover { color: var(--gold); background: rgba(201, 167, 114, 0.08); }
  .back-link:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .eyebrow {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 18px;
  }
  .sector-hero h1 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(36px, 5vw + 0.5rem, 64px);
    color: var(--oxblood-ink);
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .subline {
    font-family: var(--ff-body);
    font-size: clamp(15px, 0.6vw + 0.7rem, 17px);
    color: var(--ink-muted);
    line-height: 1.55;
    max-width: 720px;
    margin-bottom: 18px;
  }
  .regulator-strip {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
  }
  .published-block, .prep-block {
    background: var(--grad-whyus);
    padding-block: clamp(48px, 6vw, 96px);
  }
  .prep-block { background: var(--grad-contact); }
  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(28px, 2.5vw + 0.5rem, 40px);
    color: var(--oxblood-ink);
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .prep-note {
    font-family: var(--ff-body);
    font-size: 14px;
    color: var(--ink-muted);
    margin-bottom: 32px;
    max-width: 640px;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    background: var(--ivory);
    border: 1px solid var(--gold-hairline);
    border-radius: 4px;
    text-decoration: none;
    transition: transform 280ms var(--ease-out), border-color 280ms var(--ease-out);
  }
  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--gold);
  }
  .post-meta {
    font-family: var(--ff-body);
    /* Round-12 fix · 11px + bronze token clears axe AA threshold */
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-text-strong);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .post-title {
    font-family: var(--ff-display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--oxblood-ink);
    margin-bottom: 14px;
  }
  .post-excerpt {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-muted);
    flex: 1;
    margin-bottom: 18px;
  }
  .post-footer {
    display: flex;
    justify-content: space-between;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .reading-time { color: var(--ink-muted); }
  /* Round-12 fix · bronze token replaces decorative gold for accessible contrast */
  .read-link { color: var(--gold-text-strong); }
  .prep-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }
  .prep-card {
    padding: 24px;
    background: rgba(250, 247, 242, 0.6);
    border: 1px dashed var(--gold-hairline);
    border-radius: 4px;
  }
  .prep-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
  }
  .status-chip {
    font-family: var(--ff-body);
    /* Round-12 fix · 11px (was 9px); --oxblood-ink on --gold = ~7.85:1 */
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxblood-ink);
    background: var(--gold);
    padding: 4px 10px;
    border-radius: 2px;
    font-weight: 700;
  }
  .prep-meta .regulator {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .prep-title {
    font-family: var(--ff-display);
    font-size: 17px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--oxblood-ink);
    margin-bottom: 10px;
  }
  .prep-excerpt {
    font-family: var(--ff-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-muted);
  }
</style>
