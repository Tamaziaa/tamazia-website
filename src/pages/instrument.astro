---
// /instrument/ — the Tamazia Instrument page. Reached from the homepage "Run my free
// audit" button. Founder directive 2026-06-11: this page carries the FULL audit
// narrative — the £1,500 price lives here and only here, the request widget works,
// and the finished Monzo audit is showcased as the open specimen.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import QuickAudit from '../components/sections/QuickAudit.astro';
import InstrumentShowcase from '../components/sections/InstrumentShowcase.astro';

const canonical = 'https://tamazia.co.uk/instrument/';

// M2 · Service schema for the audit product (real terms only).
const auditSchema = {
  '@type': 'Service',
  '@id': 'https://tamazia.co.uk/instrument/#audit',
  name: 'Tamazia SEO, compliance and AI-visibility audit',
  serviceType: 'Website compliance and search audit',
  description:
    'A fixed-fee audit covering technical SEO, regulatory compliance of published content, competitive keyword gaps, and AI-search visibility. Findings are delivered before any commercial conversation and the fee is credited in full to the first month of an engagement.',
  provider: { '@id': 'https://tamazia.co.uk/#org' },
  areaServed: ['United Kingdom', 'European Union', 'United Arab Emirates', 'United States'],
  offers: {
    '@type': 'Offer',
    price: 1500,
    priceCurrency: 'GBP',
    url: canonical,
  },
};
---

<BaseLayout
  title="The Tamazia Instrument · The £1,500 audit"
  description="The full Tamazia audit: technical SEO, regulatory compliance, competitive gaps and AI-search visibility in one scored document. Read the finished Monzo audit, then request yours. £1,500, credited in full to your first month."
  canonical={canonical}
  extraSchema={auditSchema}
>
  <Header />
  <main id="main">
    <QuickAudit />
    <InstrumentShowcase />
  </main>
  <Footer />
</BaseLayout>
