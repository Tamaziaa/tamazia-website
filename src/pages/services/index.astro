---
// G.1 · Services hub page · /services/
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import { sectorPages } from '../../data/sectorContent';

const canonicalUrl = 'https://tamazia.co.uk/services/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tamazia.co.uk/' },
        { '@type': 'ListItem', position: 2, name: 'Services', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="Services · Regulated-Sector SEO by Specialism · Tamazia"
  description="Tamazia builds search visibility for law firms, healthcare providers, hospitality groups, financial services firms, and real estate developers. Every sector reviewed against its applicable regulatory standards before any content goes live."
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Header />

  <main id="main">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Services</li>
      </ol>
    </nav>

    <section class="hub-hero" aria-labelledby="hub-h1">
      <p class="hub-eyebrow">TAMAZIA · SERVICES</p>
      <h1 id="hub-h1" class="hub-h1">SEO engineered for regulated sectors.</h1>
      <p class="hub-sub">
        Every regulated industry has a different regulator, a different set of obligations, and a different enforcement posture. We build search visibility that satisfies both the algorithm and the applicable standards simultaneously.
      </p>
    </section>

    <section class="sector-cards-section" aria-labelledby="sectors-heading">
      <div class="sector-cards-inner">
        <h2 id="sectors-heading" class="sr-only">Our service sectors</h2>
        <ul class="sector-cards" role="list">
          {sectorPages.map((sector) => (
            <li class="sector-card">
              <a href={`/services/${sector.slug}/`} class="sector-card-link" aria-label={`${sector.name} SEO services`}>
                <div class="sector-card-top">
                  <p class="sector-card-eyebrow">{sector.eyebrow}</p>
                  <h3 class="sector-card-name">{sector.name}</h3>
                </div>
                <p class="sector-card-stat">
                  <span class="sector-stat-value" data-stat>{sector.proofStat}</span>
                  <span class="sector-stat-label">{sector.proofCaption.split('·')[0].trim()}</span>
                </p>
                <p class="sector-card-cta">
                  {sector.mandateCta}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="hub-mandate" aria-labelledby="hub-mandate-heading">
      <div class="hub-mandate-inner">
        <h2 id="hub-mandate-heading" class="hub-mandate-heading">Every engagement starts with a compliance audit.</h2>
        <p class="hub-mandate-sub">
          Before any content goes live, we audit your existing digital presence against the standards applicable to your sector and jurisdiction. The audit identifies every gap between where you are and what your regulator expects to see.
        </p>
        <a href="/#contact" class="hub-mandate-cta">Begin an audit enquiry →</a>
        <p class="hub-mandate-note">Responses within one business day. All communications confidential.</p>
      </div>
    </section>

  </main>

  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Tamazia home">
          <span class="t">T</span>
        </a>
        <p class="footer-tagline">Lawyer-led SEO for regulated enterprises.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <ul>
          <li><a href="/services/">Services</a></li>
          <li><a href="/case-studies/">Case Studies</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/privacy-notice/">Privacy Notice</a></li>
          <li><a href="/cookie-policy/">Cookie Policy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </nav>
      <p class="footer-legal">
        &copy; {new Date().getFullYear()} Tamazia Ltd. Registered in England and Wales.
        All engagements invoiced in GBP. Content reviewed against applicable regulatory standards before publication.
      </p>
    </div>
  </footer>

</BaseLayout>

<style>
  .breadcrumb {
    background: var(--ivory);
    border-bottom: 1px solid var(--hairline);
    padding: 12px 72px;
  }

  .breadcrumb ol {
    display: flex; list-style: none; gap: 8px; margin: 0; padding: 0;
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink); opacity: 0.6; align-items: center;
  }

  .breadcrumb li + li::before { content: '/'; margin-right: 8px; opacity: 0.4; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: var(--oxblood); opacity: 1; }
  .breadcrumb li[aria-current="page"] { opacity: 1; color: var(--oxblood); }

  /* Hub hero */
  .hub-hero {
    background: var(--oxblood);
    padding: 80px 72px 88px;
    position: relative;
    overflow: hidden;
  }

  .hub-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(198,160,80,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .hub-eyebrow {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin: 0 0 24px; opacity: 0.9;
  }

  .hub-h1 {
    font-family: var(--font-serif); font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 500; color: var(--ivory); line-height: 1.15;
    max-width: 700px; margin: 0 0 24px; letter-spacing: -0.01em;
  }

  .hub-sub {
    font-size: 17px; line-height: 1.7; color: var(--ivory); opacity: 0.75;
    max-width: 620px; margin: 0;
  }

  /* Sector cards */
  .sector-cards-section {
    background: var(--ivory);
    padding: 80px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .sector-cards-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .sector-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sector-card {
    border: 1px solid var(--hairline);
  }

  .sector-card-link {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 36px 32px;
    text-decoration: none;
    background: var(--ivory);
    height: 100%;
    transition: background var(--t-bg), border-color var(--t-border);
  }

  .sector-card-link:hover {
    background: rgba(90,26,43,0.03);
  }

  .sector-card:has(.sector-card-link:hover) {
    border-color: var(--oxblood);
  }

  .sector-card-eyebrow {
    font-size: 9px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--oxblood); font-weight: 600; margin: 0 0 12px; opacity: 0.7;
  }

  .sector-card-name {
    font-family: var(--font-serif); font-size: 24px; font-weight: 500;
    color: var(--ink); margin: 0 0 28px; letter-spacing: -0.01em;
  }

  .sector-card-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0 0 auto;
    padding: 20px 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }

  .sector-stat-value {
    font-family: var(--font-serif); font-size: 40px; font-weight: 500;
    color: var(--oxblood); line-height: 1; font-variant-numeric: tabular-nums;
  }

  .sector-stat-label {
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink); opacity: 0.5; line-height: 1.4;
  }

  .sector-card-cta {
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--oxblood); font-weight: 600; margin: 20px 0 0;
  }

  /* Hub mandate */
  .hub-mandate {
    background: var(--parchment, #F5F0E8);
    padding: 96px 0;
  }

  .hub-mandate-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 72px;
    text-align: center;
  }

  .hub-mandate-heading {
    font-family: var(--font-serif); font-size: clamp(24px, 3vw, 36px);
    font-weight: 500; color: var(--ink); margin: 0 0 20px; letter-spacing: -0.01em;
  }

  .hub-mandate-sub {
    font-size: 16px; line-height: 1.7; color: var(--ink); opacity: 0.75; margin: 0 0 36px;
  }

  .hub-mandate-cta {
    display: inline-block; padding: 15px 36px; background: var(--oxblood);
    color: var(--gold); font-size: 12px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 600; text-decoration: none;
    border: 1px solid var(--oxblood); transition: background var(--t-bg), color var(--t-color);
    margin-bottom: 16px;
  }

  .hub-mandate-cta:hover { background: transparent; color: var(--oxblood); }

  .hub-mandate-note {
    font-size: 12px; letter-spacing: 0.06em; color: var(--ink); opacity: 0.5;
    margin: 0; text-align: center;
  }

  /* Footer */
  .footer {
    background: linear-gradient(180deg, #2A0C14 0%, #1F0810 100%);
    padding: 64px 0 48px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 72px;
    display: grid; grid-template-columns: auto 1fr;
    gap: 32px 64px; align-items: start;
  }

  .footer-brand { display: flex; flex-direction: column; gap: 12px; }

  .footer-logo {
    width: 40px; height: 40px; background: var(--gold); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--oxblood); font-family: var(--font-serif); font-size: 20px;
    font-weight: 500; text-decoration: none;
  }

  .footer-tagline { font-size: 12px; color: var(--ivory); opacity: 0.5; margin: 0; letter-spacing: 0.04em; }

  .footer-nav ul { display: flex; flex-wrap: wrap; gap: 8px 24px; list-style: none; margin: 0; padding: 0; }

  .footer-nav a {
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ivory); text-decoration: none; opacity: 0.55;
    transition: opacity var(--t-opacity);
  }

  .footer-nav a:hover { opacity: 1; }

  .footer-legal {
    grid-column: 1 / -1; font-size: 11px; color: var(--ivory); opacity: 0.35;
    margin: 0; line-height: 1.6; letter-spacing: 0.04em;
    border-top: 1px solid rgba(255,255,255,0.08); padding-top: 24px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .breadcrumb, .hub-hero, .sector-cards-inner, .hub-mandate-inner, .footer-inner { padding-left: 24px; padding-right: 24px; }
    .footer-inner { grid-template-columns: 1fr; }
    .sector-cards { grid-template-columns: 1fr; }
  }

  @media print {
    .hub-mandate, .footer { display: none !important; }
    .hub-hero { background: #fff !important; }
    .hub-eyebrow, .hub-h1, .hub-sub { color: #000 !important; }
  }
</style>

