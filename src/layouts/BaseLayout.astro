---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Tamazia · International SEO for regulated enterprises',
  description = 'Lawyer-led SEO and regulatory compliance firm. Every campaign passes through 200+ laws before anything goes live. Trusted by Kamat Hotels (NSE), CG Oncology (NYSE: CGON), Meraas (Dubai Holding).',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': 'https://tamazia.in/#organization',
      name: 'Tamazia',
      url: 'https://tamazia.in',
      description: 'Lawyer-led SEO and regulatory compliance firm for regulated enterprises.',
      areaServed: ['United Kingdom', 'United Arab Emirates', 'United States', 'France', 'Global'],
      founder: {
        '@type': 'Person',
        name: 'Aman Pareek',
        jobTitle: 'Founder',
        alumniOf: {
          '@type': 'EducationalOrganization',
          name: "King's College London",
        },
      },
      memberOf: [
        { '@type': 'Organization', name: 'Chartered Institute of Arbitrators' },
        { '@type': 'Organization', name: 'American Bar Association' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://tamazia.in/#website',
      url: 'https://tamazia.in',
      name: 'Tamazia',
      publisher: { '@id': 'https://tamazia.in/#organization' },
      inLanguage: 'en-GB',
    },
  ],
};
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.url).href} />
    <meta property="og:site_name" content="Tamazia" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700&family=Great+Vibes&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />
    <script>
      // Placeholder for GSAP ScrollTrigger initialisation.
      // We'll wire this up in Phase 2 when we have more scroll-driven content.
      if (typeof window !== 'undefined' && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // GSAP runs per-section via their own <script> blocks to keep layout lean.
      }
    </script>
  </body>
</html>
