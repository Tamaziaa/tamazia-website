---
import { heroContent } from '../../content/hero';
---
{/* α-04 · semantic <header class="site-header"> wraps the nav (WCAG 1.3.1) */}
<header class="site-header">
<nav class="main-nav" aria-label="Primary">
  <a href="/" class="logo-lockup" aria-label="Tamazia home">
    <img src="/tamazia-lockup-masthead-transparent.png" alt="" class="logo-img" width="343" height="64" loading="eager" decoding="async" fetchpriority="high" />
  </a>
  <ul class="nav-items">
    {heroContent.headerNav.map(item => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ul>
  <a class="nav-cta" href={heroContent.navCtaUrl}>{heroContent.navCta}</a>
  {/* A-06 · burger with morph-to-X via .open class on click */}
  <button class="burger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-drawer">
    <span class="burger-icon" aria-hidden="true">
      <span class="burger-line burger-line-1"></span>
      <span class="burger-line burger-line-2"></span>
      <span class="burger-line burger-line-3"></span>
    </span>
  </button>
</nav>

{/* A-10b · backdrop overlay; click closes drawer */}
<div class="drawer-backdrop" id="drawer-backdrop" hidden aria-hidden="true"></div>

{/* Phase B · mobile drawer */}
<nav class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation" hidden>
  <button class="drawer-close" aria-label="Close navigation menu">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <line x1="17" y1="1" x2="1"  y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <ul class="drawer-items">
    {heroContent.headerNav.map((item, i) => (
      <li><a href={item.href} class="drawer-link">{item.label}</a></li>
    ))}
  </ul>
  <a class="drawer-cta" href={heroContent.navCtaUrl}>{heroContent.navCta}</a>
</nav>

<div class="progress-bar" id="progress"></div>
</header>

<style>
  /* Hardening · ensure outer <header> landmark is always visible above any sticky/floating element */
  .site-header {
    /* Use display:contents so the outer <header> is a landmark only;
       sticky positioning lives on inner .main-nav and sticks to viewport. */
    display: contents;
  }
  .site-header[hidden] { display: none; }


  .main-nav {
    height: 76px;
    background: var(--oxblood);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 56px;
    border-bottom: 1px solid rgba(201, 167, 114, 0.25);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* Brand lockup · oxblood masthead, horse + TAMAZIA wordmark as one image */
  .logo-lockup {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity var(--duration-short) var(--ease-out);
  }
  .logo-img {
    height: 50px;
    width: auto;
    display: block;
    /* α-G06 · prefer crisp rendering on retina until SVG ships */
    image-rendering: -webkit-optimize-contrast;
  }
  .logo-lockup:hover { opacity: 0.88; }
  .logo-lockup:focus-visible { outline: 2px solid var(--gold); outline-offset: 4px; border-radius: 2px; }

  .nav-items {
    display: flex;
    list-style: none;
    gap: 22px;
    align-items: center;
    flex-wrap: nowrap;
  }
  .nav-items li { white-space: nowrap; }

  .nav-items li a {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    position: relative;
    padding: 6px 0;
    transition: color var(--duration-short) ease;
    font-weight: 400;
    text-decoration: none;
    display: inline-block;
    opacity: 0.92;
  }

  .nav-items li a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 500ms var(--ease-out);
  }

  .nav-items li a:hover::after { width: 100%; }
  .nav-items li a:hover { color: var(--ivory); opacity: 1; }

  /* Round-12 fix · keyboard focus indicator */
  .nav-items li a:focus-visible,
  .nav-cta:focus-visible,
  .logo-lockup:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .nav-items li a:focus-visible::after { width: 100%; }

  .nav-cta {
    background: var(--gold);
    color: var(--oxblood);
    border: 1px solid var(--gold);
    height: 44px;
    padding: 0 clamp(14px, 1.4vw, 22px);
    font-family: var(--ff-body);
    font-size: clamp(10px, 0.78vw, 11px);
    font-weight: 600;
    letter-spacing: clamp(0.08em, 0.18vw, 0.14em);
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    margin-left: clamp(12px, 1.6vw, 22px);
    transition: background var(--duration-short) ease, border-color var(--duration-short) ease, box-shadow var(--duration-short) ease;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    border-radius: 999px;
  }

  .nav-cta:hover {
    background: var(--gold-warm);
    border-color: var(--gold-warm);
    box-shadow: 0 0 0 3px rgba(201, 167, 114, 0.18);
  }

  /* A-06 · Burger with morph-to-X animation */
  .burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: var(--gold);
    cursor: pointer;
    margin-left: 12px;
    padding: 0;
    border-radius: 2px;
    transition: color var(--duration-short) ease;
  }
  .burger:hover { color: var(--ivory); }
  .burger:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .burger-icon {
    position: relative;
    width: 22px;
    height: 16px;
    display: block;
  }
  .burger-line {
    position: absolute;
    left: 0;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1), opacity 200ms ease;
    transform-origin: center;
  }
  .burger-line-1 { top: 0; }
  .burger-line-2 { top: 7px; }
  .burger-line-3 { top: 14px; }

  /* When drawer is open, morph 3 lines to X */
  .burger[aria-expanded="true"] .burger-line-1 { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded="true"] .burger-line-2 { opacity: 0; transform: scaleX(0); }
  .burger[aria-expanded="true"] .burger-line-3 { transform: translateY(-7px) rotate(-45deg); }

  /* A-10b · Backdrop click-to-close behind drawer */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(42, 12, 20, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 190;
    opacity: 0;
    transition: opacity 280ms ease;
    pointer-events: none;
  }
  .drawer-backdrop:not([hidden]) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Phase B · mobile drawer */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    background: var(--oxblood);
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 32px 28px 48px;
    transform: translateX(100%);
    transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
    /* Hard-clip so the off-screen drawer cannot widen the document on any browser. */
    contain: layout paint;
    will-change: transform;
  }
  .mobile-drawer:not([hidden]) {
    display: flex;
    transform: translateX(0);
  }
  .mobile-drawer[hidden] {
    display: flex;
    transform: translateX(100%);
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-drawer:not([hidden]) { visibility: visible; }
  /* On desktop the drawer is functionally unused — remove from layout entirely. */
  @media (min-width: 901px) {
    .mobile-drawer,
    .drawer-backdrop {
      display: none !important;
    }
  }

  .drawer-close {
    align-self: flex-end;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: var(--gold);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
    padding: 0;
    border-radius: 2px;
  }
  .drawer-close:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .drawer-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    margin: 0 0 32px;
    padding: 0;
  }

  /* A-09 · stagger fade-in entrance for drawer items */
  .drawer-items li {
    opacity: 0;
    transform: translateX(16px);
  }
  .mobile-drawer:not([hidden]) .drawer-items li {
    animation: drawer-item-in 380ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: 180ms;
  }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(2) { animation-delay: 215ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(3) { animation-delay: 250ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(4) { animation-delay: 285ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(5) { animation-delay: 320ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(6) { animation-delay: 355ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(7) { animation-delay: 390ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(8) { animation-delay: 425ms; }
  .mobile-drawer:not([hidden]) .drawer-items li:nth-child(9) { animation-delay: 460ms; }
  @keyframes drawer-item-in {
    to { opacity: 1; transform: translateX(0); }
  }

  .drawer-link {
    display: block;
    font-family: var(--ff-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--gold);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid rgba(201, 167, 114, 0.18);
    transition: color var(--duration-short) ease, transform var(--duration-short) ease;
  }
  .drawer-link:hover { color: var(--ivory); transform: translateX(8px); }
  .drawer-link:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .drawer-cta {
    margin-top: auto;
    background: var(--gold);
    color: var(--oxblood);
    border: none;
    height: 52px;
    padding: 0 32px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    border-radius: 2px;
    transition: background var(--duration-short) ease;
    opacity: 0;
    transform: translateY(12px);
  }
  .mobile-drawer:not([hidden]) .drawer-cta {
    animation: drawer-cta-in 420ms cubic-bezier(0.2, 0.8, 0.2, 1) 520ms forwards;
  }
  @keyframes drawer-cta-in {
    to { opacity: 1; transform: translateY(0); }
  }
  .drawer-cta:hover { background: var(--gold-warm); }

  .progress-bar {
    position: fixed;
    top: 76px;
    left: 0;
    height: 2px;
    background: var(--gold);
    width: 0%;
    transition: width 120ms linear;
    z-index: 99;
    opacity: 0.85;
  }

  /* Reduced motion · halt drawer slide + stagger */
  @media (prefers-reduced-motion: reduce) {
    .mobile-drawer { transition: none !important; }
    .drawer-items li,
    .drawer-cta {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .burger-line { transition: none !important; }
    .drawer-backdrop { transition: none !important; }
  }

  @media (max-width: 1024px) {
    .main-nav { padding: 0 32px; }
    .nav-items { display: none; }
    .nav-cta { display: none; }
    .burger { display: flex; }
  }

  @media (max-width: 640px) {
    .top-strip { font-size: 8.5px; letter-spacing: 0.15em; }
    .main-nav { padding: 0 16px; height: 64px; }
    .logo-img { height: 40px; }
    .progress-bar { top: 64px; }
  }
</style>

<script>
  // Progress bar follows scroll
  const bar = document.getElementById('progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const scrolled = window.scrollY;
      const progress = scrollable > 0 ? (scrolled / scrollable) * 100 : 0;
      bar.style.width = progress + '%';
    });
  }

  // Phase B · burger menu toggle + A-09/A-10/A-10b/A-11 drawer behaviour
  const burger = document.querySelector('.burger') as HTMLButtonElement | null;
  const drawer = document.getElementById('mobile-drawer') as HTMLElement | null;
  const backdrop = document.getElementById('drawer-backdrop') as HTMLElement | null;
  const drawerClose = document.querySelector('.drawer-close') as HTMLButtonElement | null;
  const drawerLinks = document.querySelectorAll('.drawer-link, .drawer-cta');

  // Focus-trap helpers
  let lastFocused: HTMLElement | null = null;
  function getFocusable(root: HTMLElement): HTMLElement[] {
    return Array.from(root.querySelectorAll<HTMLElement>(
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
    ));
  }

  function openDrawer() {
    if (!drawer || !burger) return;
    lastFocused = document.activeElement as HTMLElement;
    drawer.hidden = false;
    if (backdrop) backdrop.hidden = false;
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    // Defer focus until paint (drawer entrance animation begins)
    requestAnimationFrame(() => (drawerClose as HTMLButtonElement)?.focus());
  }

  function closeDrawer() {
    if (!drawer || !burger) return;
    drawer.hidden = true;
    if (backdrop) backdrop.hidden = true;
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    (lastFocused || burger).focus();
  }

  burger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  drawerLinks.forEach(link => link.addEventListener('click', closeDrawer));

  // Close on Escape + focus trap (Tab and Shift+Tab cycle within drawer)
  document.addEventListener('keydown', (e) => {
    if (!drawer || drawer.hidden) return;
    if (e.key === 'Escape') { e.preventDefault(); closeDrawer(); return; }
    if (e.key !== 'Tab') return;
    const focusable = getFocusable(drawer);
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });

  // A-10c · swipe-right to close drawer (touch devices)
  let touchStartX = 0;
  drawer?.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  drawer?.addEventListener('touchend', (e: TouchEvent) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (dx > 64) closeDrawer();
  }, { passive: true });
</script>
