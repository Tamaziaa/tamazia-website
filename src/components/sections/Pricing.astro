---
import Motif from '../ui/Motif.astro';
import FounderLink from '../atoms/FounderLink.astro';
import FleuronDivider from '../atoms/FleuronDivider.astro';
import {
  pricingContent,
  entryAuditGbp,
  independentSolutionsGbp,
} from '../../content/pricing';

const { eyebrow, h2, intro, tiers, mandateCallout, mandateCta, mandateSignature, microNote } = pricingContent;

// D1/D3 · everything below renders FROM the single pricing config constant
// (src/content/pricing.ts). No price is hardcoded here.
const gbp = (n: number) => '£' + n.toLocaleString('en-GB');

// D1 · Independent Solutions · struck-then-offer where an anchor exists, results-led.
// Display names + outcome lines map 1:1 to the independentSolutionsGbp keys.
// S10 · `href` deep-links a solution to its own standalone page when one exists
// (currently only Website Remodelling). Others stay on the #contact enquiry CTA.
const independentSolutionsMeta: Record<string, { name: string; outcome: string; href?: string }> = {
  websiteRemodelling: { name: 'Website Remodelling', outcome: 'A site that converts the traffic it earns, rebuilt to brief.', href: '/services/website-remodelling/' },
  aiAuthority: { name: 'AI Authority', outcome: 'Cited inside ChatGPT, Claude, Perplexity, Gemini, and Google AI Overviews.' },
  icpOutreach: { name: 'ICP Outreach', outcome: 'Compliant outbound to the decision-makers who match your client profile.' },
  onlinePersonalBranding: { name: 'Online Personal Branding', outcome: 'The named-expert authority buyers check before they instruct.' },
  instagramPresence: { name: 'Instagram Presence', outcome: 'Audience growth that builds the social proof enterprise buyers expect.' },
  ymylContent: { name: 'YMYL Content', outcome: 'Health and legal grade content, reviewed before it publishes.' },
  reputationCrisis: { name: 'Reputation and Crisis', outcome: 'Monitoring, suppression, and a response architecture ready before it is needed.' },
  gbpDomination: { name: 'Google Business Profile Domination', outcome: 'Local map dominance, every listing reviewed against sector ad rules.' },
};
// Preserve the config key order.
const independentSolutions = Object.keys(independentSolutionsGbp).map((key) => {
  const cfg: any = (independentSolutionsGbp as any)[key];
  const meta = independentSolutionsMeta[key] || { name: key, outcome: '' };
  return {
    key,
    name: meta.name,
    outcome: meta.outcome,
    href: meta.href || '#contact',
    anchor: typeof cfg.anchor === 'number' ? cfg.anchor : null,
    offer: typeof cfg.offer === 'number' ? cfg.offer : null,
    price: typeof cfg.price === 'number' ? cfg.price : null,
  };
});

const featureIcons: Record<string, string> = {
  Audit: `<circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.2"/><line x1="18" y1="18" x2="22" y2="22" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>`,
  Team: `<circle cx="9" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="16" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M 4 20 Q 4 15, 9 15 Q 14 15, 14 20" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M 11 20 Q 11 15, 16 15 Q 21 15, 21 20" fill="none" stroke="currentColor" stroke-width="1.2"/>`,
  Deliverables: `<rect x="5" y="6" width="14" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.2"/><line x1="8" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>`,
  Review: `<path d="M 4 12 L 9 17 L 20 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---
<section class="pricing" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <div class="motif-row" style="display:flex;justify-content:center;margin-bottom:10px"><Motif name="column" size={42} /></div>
      <h2 id="pricing-heading" class="section-h2">{h2}</h2>
      <p class="intro">{intro}</p>
    </div>

    {/* G.6 · Currency switcher · GBP:1 USD:1.27 AED:4.67 */}
    <div class="currency-switcher" role="group" aria-label="Display currency">
      <button class="currency-btn active" data-currency="GBP" aria-pressed="true">GBP £</button>
      <button class="currency-btn" data-currency="USD" aria-pressed="false">USD $</button>
      <button class="currency-btn" data-currency="EUR" aria-pressed="false">EUR €</button>
      <button class="currency-btn" data-currency="AED" aria-pressed="false">AED د.إ</button>
      <span class="currency-note">All engagements are invoiced in GBP</span>
    </div>

    {/* Pilot engagement toggle · first six-month engagement at preferential rate */}
    <div class="pilot-toggle" role="group" aria-label="Engagement rate">
      <button class="pilot-btn active" data-pilot="on" aria-pressed="true">Pilot engagement <span class="pilot-btn-sub">first six months</span></button>
      <button class="pilot-btn" data-pilot="off" aria-pressed="false">Standard rate</button>
    </div>

    <div class="tiers-grid">
      {tiers.map((t: any) => (
        <div class={`tier-card tier-${t.tier} ${t.mostPopular ? 'tier-most-popular' : ''}`} data-tier={t.name}>
          {t.mostPopular && <span class="most-popular-ribbon" aria-label="Most popular tier">Most popular</span>}

          <div class="tier-head">
            <span class="tier-numeral">{t.numeral}</span>
            <h3 class="tier-name">{t.name}</h3>
            <div class="tier-price"
              data-gbp={t.priceGbp}
              data-gbp-standard={t.priceGbpStandard}
              data-saves-gbp={t.savesGbp6}>
              <span class="price-strike" aria-hidden="true"></span>
              <span class="price-display">{t.price}</span>
              {t.priceUnit && <span class="price-unit">{t.priceUnit}</span>}
            </div>
            <p class="saves-line" aria-live="polite"></p>
            <p class="tier-tagline">{t.tagline}</p>
            <p class="tier-ideal-clients">{t.idealClients || t.description}</p>
          </div>

          {t.includesAllOfPrior && (
            <div class="tier-includes-prior">{t.includesAllOfPrior}</div>
          )}

          <div class="features-heading">{t.featuresHeading || 'WHAT IS INCLUDED'}</div>

          {(() => {
            const allFeats = t.featuresDetailed || [];
            const topFeats = allFeats.slice(0, 3);
            const restFeats = allFeats.slice(3);
            return (
              <>
                <ul class="rich-features">
                  {topFeats.map((feat: any) => (
                    <li class="rich-feature">
                      <span class="feature-bullet" aria-hidden="true"><svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M3 2 L7 5 L3 8 Z"/></svg></span>
                      <div>
                        <h4 class="feature-headline">{feat.headline}</h4>
                        <p class="feature-body">{feat.body}</p>
                      </div>
                    </li>
                  ))}
                </ul>
                {restFeats.length > 0 && (
                  <details class="features-collapse">
                    <summary class="features-collapse-summary">
                      <span>See all {allFeats.length} inclusions</span>
                      <span class="chevron" aria-hidden="true">+</span>
                    </summary>
                    <ul class="rich-features">
                      {restFeats.map((feat: any) => (
                        <li class="rich-feature">
                          <span class="feature-bullet" aria-hidden="true"><svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M3 2 L7 5 L3 8 Z"/></svg></span>
                          <div>
                            <h4 class="feature-headline">{feat.headline}</h4>
                            <p class="feature-body">{feat.body}</p>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </>
            );
          })()}

          {Array.isArray(t.additionalCapabilities) && t.additionalCapabilities.length > 0 && (
            <details class="additional-block">
              <summary class="additional-summary">
                <span>{t.additionalCapabilitiesHeading || 'Additional capabilities'}</span>
                <span class="chevron" aria-hidden="true">+</span>
              </summary>
              <ul class="additional-list">
                {t.additionalCapabilities.map((cap: string) => (
                  <li class="additional-item">+ {cap}</li>
                ))}
              </ul>
            </details>
          )}

          <a href="#contact" class={`tier-cta ${t.tier === 'enterprise' ? 'tier-cta-filled' : 'tier-cta-ghost'}`}>{t.cta} <span class="cta-arrow" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 10 L10 4 M5 4 H10 V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>

          <p class="pilot-microcopy"><em>Six-month commitment unlocks the pilot rate.</em></p>

          {Array.isArray(t.microFooter) && t.microFooter.length > 0 && (
            <div class="tier-micro-footer">
              {t.microFooter.map((line: string) => <p>{line}</p>)}
            </div>
          )}
        </div>
      ))}
    </div>

    {/* D3 · Audit hook · figure sourced from entryAuditGbp (pricing.ts) */}
    <p class="audit-reference-line">
      Every engagement opens with a full audit. <strong>{gbp(entryAuditGbp)}</strong> to unlock, first month free, then included in your retainer. Compliance, search, and AI visibility assessed against the frameworks that govern you, before any scope is agreed.
    </p>

    {/* D1 · Independent Solutions · struck-then-offer · prices from independentSolutionsGbp (pricing.ts) */}
    <div class="independent-block" aria-labelledby="independent-heading">
      <div class="ib-head">
        <h3 id="independent-heading" class="ib-h3">Independent Solutions</h3>
        <p class="ib-sub">Single outcomes, bought on their own. No retainer required.</p>
      </div>
      <div class="independent-grid">
        {independentSolutions.map((s) => (
          <div class="independent-card" data-solution={s.key}>
            <div class="is-name">{s.name}</div>
            <p class="is-outcome">{s.outcome}</p>
            <div class="is-price-row">
              {s.anchor !== null && s.offer !== null ? (
                <>
                  <span class="is-anchor" aria-label={`Was ${gbp(s.anchor)}`}>{gbp(s.anchor)}</span>
                  <span class="is-offer" data-gbp={s.offer}>{gbp(s.offer)}</span>
                </>
              ) : (
                <span class="is-offer" data-gbp={s.price ?? 0}>{gbp(s.price ?? 0)}</span>
              )}
            </div>
            <a href={s.href} class="is-cta">{s.href === '#contact' ? 'Add this' : 'See the engagement'} <span class="cta-arrow" aria-hidden="true">→</span></a>
          </div>
        ))}
      </div>
      <p class="ib-foot"><em>Indicative pricing. Every solution is scoped to your footprint and jurisdictions before anything is signed.</em></p>
    </div>

    {/* P4-1 · OS-V4 C4 disclosure. Mirrors the audit so the site and the audit never
        diverge on the claims standard. S7[D44/D46] · the "Full terms" reference now points
        to the canonical, indexable /terms/ page instead of the noindex DRAFT
        /legal/service-terms/ (which still carries [TODO] founder-identity placeholders and
        must not be linked from production copy until the founder supplies that identity). */}
    <p class="results-disclosure">
      Figures shown for client engagements are drawn from verified analytics and are identified as such. Any figure labelled illustrative is a worked example, not a client result. Each solution commits to defined deliverables and to reach; commercial outcomes depend on factors outside any agency's control and are not guaranteed. Full terms: <a href="/terms/">/terms</a>.
    </p>

    <FleuronDivider width={220} ariaLabel="Section divider" />

    <div class="mandate-block">
      <div class="mandate-rule" aria-hidden="true"></div>
      <p class="mandate-text">{mandateCallout}</p>
      <div class="mandate-actions">
        <a href="#contact" class="mandate-cta">{mandateCta}</a>
        <a href="/book/" class="mandate-calendar" aria-label="Open the calendar">Open the calendar <span class="calendar-arrow" aria-hidden="true">↗</span></a>
      </div>
      {/* S6[D15] · render mandateSignature from config (was destructured + styled but never
          output, so the .mandate-signature CSS was dead). Decorative signature of the founder. */}
      {mandateSignature && <p class="mandate-signature" aria-hidden="true">{mandateSignature}</p>}
      <div class="mandate-rule" aria-hidden="true"></div>
    </div>

    <p class="micro-note">{microNote}</p>
  </div>
</section>

<style>
  .pricing {
    background: var(--ivory);
    padding-block: clamp(40px, 5vw, 64px);
    position: relative;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .header-block {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 20px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    color: var(--ink);
    margin-bottom: 16px;
    letter-spacing: var(--ls-h2);
  }

  .intro {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-muted);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Tier head + ideal clients */
  .tier-head { margin-bottom: 22px; }
  .tier-ideal-clients {
    font-family: var(--ff-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-muted);
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
  }

  /* Rich feature list (Round-1 fix B-01/B-16) */
  .features-heading {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* Round-7 fix · 10px gold = 1.79:1; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 600;
    margin: 18px 0 14px;
  }
  .rich-features {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
  }
  .rich-feature {
    display: flex;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .rich-feature:last-child { border-bottom: 0; }
  .feature-bullet {
    /* Round-7 fix · gold on pearl/bisque was 1.79:1; deeper bronze passes 4.5:1 on every light bg in the journey */
    color: var(--gold-text);
    font-size: 14px;
    line-height: 1.4;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .feature-headline {
    font-family: var(--ff-display);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--oxblood-ink);
    margin-bottom: 6px;
  }
  .feature-body {
    font-family: var(--ff-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 0;
  }

  /* B1-B4 fix · Enterprise dark tier · light text */
  .tier-card.tier-enterprise {
    background: var(--obsidian-deep, var(--oxblood-ink));
    color: var(--ivory);
    border: 1px solid var(--gold);
    }
  /* Enterprise dark-bg child colour overrides (P0 — restored after BATCH C regression) */
  .tier-card.tier-enterprise .tier-numeral { color: var(--gold); }
  .tier-card.tier-enterprise .tier-name { color: var(--ivory); }
  .tier-card.tier-enterprise .tier-price { color: var(--gold); }
  .tier-card.tier-enterprise .price-unit { color: var(--pearl); }
  .tier-card.tier-enterprise .price-display { color: var(--gold); }
  .tier-card.tier-enterprise .price-strike { color: var(--pearl); opacity: 0.55; }
  .tier-card.tier-enterprise .tier-tagline { color: var(--pearl); }
  .tier-card.tier-enterprise .tier-saves { color: var(--gold); }
  .tier-card.tier-enterprise .tier-ideal { color: var(--pearl); opacity: 0.92; }
  .tier-card.tier-enterprise .tier-ideal-clients { color: var(--pearl); border-top-color: rgba(201,167,114,0.35); }
  .tier-card.tier-enterprise .tier-includes-prior { color: var(--gold); border-top-color: rgba(201,167,114,0.35); }
  .tier-card.tier-enterprise .features-heading { color: var(--gold); }
  .tier-card.tier-enterprise .feature-headline { color: var(--ivory); }
  .tier-card.tier-enterprise .feature-body { color: rgba(232,228,220,0.92); line-height: 1.55; }
  .tier-card.tier-enterprise .rich-feature { border-bottom-color: rgba(201,167,114,0.25); }
  .tier-card.tier-enterprise .feature-bullet { color: var(--gold); }
  .tier-card.tier-enterprise .additional-block { border-top-color: rgba(201,167,114,0.5); }
  .tier-card.tier-enterprise .additional-summary { color: var(--gold); }
  .tier-card.tier-enterprise .additional-item { color: rgba(232,228,220,0.85); }
  .tier-card.tier-enterprise .features-collapse-summary { background: rgba(42,12,20,0.6); color: var(--gold); border-color: rgba(201,167,114,0.35); }
  .tier-card.tier-enterprise .features-collapse-summary .chevron { color: var(--gold-warm, #D4B787); }
  .tier-card.tier-enterprise .tier-cta-ghost { color: var(--gold); border-color: var(--gold); }
  .tier-card.tier-enterprise .tier-cta-ghost:hover { background: var(--gold); color: var(--oxblood-ink); }

  /* Bug-fix B-03 · main features collapsible (top 3 visible, rest collapsed) */
  .features-collapse {
    margin-bottom: 16px;
  }
  .features-collapse-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    margin: 12px 0;
    background: rgba(201, 167, 114, 0.06);
    border: 1px solid var(--gold-hairline);
    border-radius: 4px;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oxblood);
    transition: background 240ms ease, border-color 240ms ease;
  }
  .features-collapse-summary:hover {
    background: rgba(201, 167, 114, 0.12);
    border-color: var(--gold);
  }
  .features-collapse-summary::-webkit-details-marker { display: none; }
  .features-collapse-summary .chevron {
    /* Round-7 fix · 18px gold on gold-tint = 1.00:1; deeper bronze passes */
    color: var(--gold-text-strong);
    font-size: 18px;
    font-weight: 700;
    transition: transform 240ms var(--ease-out);
  }
  .features-collapse[open] .features-collapse-summary .chevron { transform: rotate(45deg); }

  /* Additional capabilities collapsible (Round-1 fix B-28) */
  .additional-block {
    margin-bottom: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--gold-hairline);
  }
  .additional-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oxblood);
  }
  .additional-summary::-webkit-details-marker { display: none; }
  .additional-summary .chevron {
    /* Round-7 fix · 16px gold on bisque = 1.79:1; deeper bronze passes */
    color: var(--gold-text);
    font-size: 16px;
    font-weight: 700;
    transition: transform 240ms var(--ease-out);
  }
  .additional-block[open] .chevron { transform: rotate(45deg); }
  .additional-list {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
  }
  .additional-item {
    font-family: var(--ff-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--ink-muted);
    padding: 6px 0;
    border-bottom: 1px dashed var(--hairline);
  }
  .additional-item:last-child { border-bottom: 0; }

  /* Most-popular ribbon (Authority) */
  .tier-most-popular {
    position: relative;
    border-color: var(--gold) !important;
    box-shadow: 0 8px 28px rgba(90, 26, 43, 0.18);
    /* Same size as Foundation and Enterprise · ribbon is the only differentiator */
  }
  .most-popular-ribbon {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--grad-gold-shimmer);
    color: var(--oxblood-ink);
    font-family: var(--ff-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 2px;
    z-index: 5;
  }
  .tier-includes-prior {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    color: var(--oxblood);
    border-top: 1px solid var(--gold-hairline);
    padding-top: 14px;
    margin: 14px 0 18px;
  }
  .price-unit {
    font-size: 0.42em;
    color: var(--ink-muted);
    font-style: italic;
    margin-left: 4px;
    letter-spacing: 0;
  }
  .tier-micro-footer {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
  }
  .tier-micro-footer p {
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--ink-muted);
    font-style: italic;
    font-weight: 300;
    line-height: 1.55;
    letter-spacing: 0.02em;
    margin: 4px 0;
  }
  .tier-card.tier-enterprise .tier-micro-footer p { color: rgba(232, 228, 220, 0.65); }

  /* Tier grid */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    align-items: stretch;
    gap: 32px;
    margin-bottom: clamp(32px, 5vw, 48px); /* R10 · was 64-96 */
  }
  .tier-card { height: 100%; display: flex; flex-direction: column; }
  /* M-punch 11: CTAs sit parallel across all three tiers */
  .tier-card .tier-cta { margin-top: auto; }

  .tier-card {
    container-type: inline-size;
    position: relative;
    padding: 40px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: min-content;
    transition: transform 400ms var(--ease-out), box-shadow 400ms var(--ease-out),
                border-color 400ms var(--ease-out);
  }
  .tier-card.tier-foundation { background: linear-gradient(180deg, var(--ivory) 0%, var(--ivory-warm) 100%); }

  .tier-standard {
    background: var(--pearl);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.5);
  }

  .tier-elevated {
    background: var(--pearl);
    border: 1px solid var(--gold);
    box-shadow: 0 20px 40px -20px rgba(201, 167, 114, 0.3);
  }

  .tier-enterprise {
