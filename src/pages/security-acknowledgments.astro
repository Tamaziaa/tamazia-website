---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
const lastUpdated = '4 May 2026';
---
<BaseLayout
  title="Security Acknowledgements · Tamazia"
  description="Researchers who reported vulnerabilities to Tamazia under coordinated disclosure."
  canonical="https://tamazia.co.uk/security-acknowledgments/"
>
  <Header />
  <main id="main" class="legal">
    <article class="legal-inner">
      <p class="eyebrow">SECURITY · ACKNOWLEDGEMENTS</p>
      <p class="entity-disclosure"><em>Operated by Tamazia Ltd, a private limited company registered in England and Wales. Data Controller contact: dpo@tamazia.co.uk.</em></p>
      <h1>Researchers we thank</h1>
      <p class="updated">Last updated {lastUpdated}.</p>

      <p>This page lists researchers who have reported confirmed vulnerabilities to Tamazia under our <a href="/security-policy/">coordinated disclosure policy</a>, with their consent. We are grateful for the work that strengthens our handling of regulated client data.</p>

      <h2>2026</h2>
      <p>None reported yet.</p>

      <h2>Becoming listed</h2>
      <p>If you reported an issue and would like to be added, reply to the acknowledgement email with the name or handle you would like shown. We do not list researchers by default.</p>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal { background: var(--ivory); color: var(--oxblood-ink); padding: 88px 24px 120px; }
  .legal-inner { max-width: 760px; margin: 0 auto; }
  .eyebrow { font-family: var(--ff-sans); font-size: 11px; letter-spacing: 0.16em; color: var(--oxblood); margin-bottom: 14px; }
  .legal h1 { font-family: var(--ff-display); font-weight: 500; font-size: clamp(34px, 5vw, 52px); margin: 0 0 8px; }
  .updated { font-family: var(--ff-sans); font-size: 13px; color: var(--ink-muted); margin-bottom: 32px; }
  .legal h2 { font-family: var(--ff-display); font-weight: 500; font-size: 24px; margin: 36px 0 12px; }
  .legal p { font-family: Georgia, serif; font-size: 17px; line-height: 1.6; margin: 0 0 18px; }
  .legal a { color: var(--oxblood); border-bottom: 1px solid var(--gold-soft); }
</style>
