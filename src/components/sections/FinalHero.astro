---
// FinalHero.astro — Sextant sector compass hero
// Inserted in index.astro: after <Header />, before <LawsStrip />
// Founder portrait: /public/aman-portrait.webp (already in repo)
// No external font imports — site uses self-hosted WOFF2
import { heroContent } from '../../content/hero';
const frameworks = (heroContent as any).regulationFrameworks || [];
const goldFrameworks: string[] = (heroContent as any).goldHighlightedFrameworks || [];
const ribbonDouble = [...frameworks, ...frameworks];
---

<div class="tz-hero-wrap">
<aside class="tz-laws-ribbon" aria-hidden="true">
  <div class="tz-laws-ribbon-track">
    {ribbonDouble.map((reg: string) => (
      <span class={goldFrameworks.includes(reg) ? 'gold' : ''}>{reg}</span>
    ))}
  </div>
</aside>
<section class="tz-mhero" aria-label="Tamazia sector compass hero">

  <div class="tz-rail" data-reveal="fade">
    <span>§ I</span>
    <span class="tz-rail-title"><em>The Sextant</em></span>
    <span class="tz-rail-year">MMXVIII</span>
  </div>
  {/* S3 (Impl Doc v1.0) · Sextant micro-copy */}
  <p class="tz-rail-microcopy" data-reveal="fade" style="--rd:80ms"><em>Tamazia's regulatory orientation system. We read the rulebook before plotting your course.</em></p>

  <div class="tz-panel" data-reveal="slide" style="--rd:60ms">
    <div class="tz-panel-head">
      <span>I · SECTOR</span>
      <span class="tz-panel-mid"><em>matched · live</em></span>
      <span>§ <strong id="tz-idx">02</strong> / 07</span>
    </div>
    <div class="tz-cp">
      <svg viewBox="0 0 300 130" aria-hidden="true">
        <path class="tz-cp-arc" d="M 30 130 A 120 120 0 0 1 270 130"/>
        <path class="tz-cp-arc-inner" d="M 60 130 A 90 90 0 0 1 240 130"/>
        <line x1="0" y1="130" x2="300" y2="130" stroke="#1A1A1D" stroke-width="0.3" opacity="0.4"/>
        <text x="30" y="144" class="tz-cp-deg" text-anchor="middle">0°</text>
        <text x="150" y="6" class="tz-cp-deg" text-anchor="middle">45°</text>
        <text x="270" y="144" class="tz-cp-deg" text-anchor="middle">90°</text>
        <g id="tz-secs"></g>
        <g class="tz-cp-needle-g">
          <line class="tz-cp-needle" x1="150" y1="130" x2="150" y2="20"/>
          <circle class="tz-cp-needle-tip" cx="150" cy="20" r="3"/>
          <circle class="tz-cp-needle-halo" cx="150" cy="20" r="6.5"/>
        </g>
        <circle cx="150" cy="130" r="3.4" fill="#1A1A1D"/>
        <circle cx="150" cy="130" r="1.4" fill="#C9A772"/>
        <text x="150" y="122" class="tz-cp-sx-label" text-anchor="middle">sextant · TMZ</text>
      </svg>
    </div>
    <div class="tz-band">
      <div class="tz-band-l">
        <div class="tz-band-l-kicker">NOW</div>
        <div class="tz-band-l-name" id="tz-name">Healthcare</div>
        <div class="tz-band-l-idx">§ <span id="tz-idx-inline">02</span> / 07</div>
      </div>
      <div class="tz-band-laws" id="tz-laws"></div>
    </div>
    <div class="tz-fine">
      <span class="tz-fine-rule"></span>
      <span class="tz-fine-pill">
        <span class="tz-fine-dot"></span>
        <span class="tz-fine-lab">Fined .</span>
        <span id="tz-fine">MHRA · POM weight-loss enforcement · <em>2025</em></span>
      </span>
      <span class="tz-fine-rule"></span>
    </div>
    <div class="tz-panel-foot">
      <span class="tz-foot-kicker">Trusted by</span>
      <span class="tz-foot-clients">KAMAT HOTELS (NSE) &middot; CG ONCOLOGY (NASDAQ: CGON) &middot; MERAAS (DUBAI HOLDING)</span>
      <span class="tz-foot-tail">Engagements delivered across UK, UAE, USA, and EU.</span>
    </div>
  </div>

  <h2 class="tz-headline">
    <span class="tz-line tz-tw-line" data-text="Outrank {{competitors.}}"></span>
    <span class="tz-line tz-tw-line" data-text="Master {{regulators.}}"></span>
    <span class="tz-line tz-line-em tz-tw-line" data-text="One agency."></span>
  </h2>

  <div class="tz-subs">
    <div class="tz-sub" data-reveal="slide" style="--rd:480ms"><span class="tz-sub-rule"></span><em>Search dominance, every market.</em></div>
    <div class="tz-sub" data-reveal="slide" style="--rd:580ms"><span class="tz-sub-rule"></span><em>200+ frameworks reviewed, every word.</em></div>
    <div class="tz-sub" data-reveal="slide" style="--rd:680ms"><span class="tz-sub-rule"></span><em>Counsel-led, every campaign.</em></div>
  </div>

  <div class="tz-body" data-reveal="slide">
    {/* S8 (Impl Doc v1.0) · founder credential — names Aman Pareek explicitly */}
    <p><span class="tz-dropcap">F</span>ounded by <em>Aman Pareek</em>, LLM in International Business Law, King's College London. Compliance reviewed before publication, every engagement.</p>
  </div>

  <div class="tz-pull-left" data-reveal="lift">
    <p>Your SEO agency doesn't have a <em>lawyer.</em> <em>Ours is run by one.</em></p>
  </div>

  <div class="tz-pull-centre" data-reveal="lift">
    <span class="tz-corner tz-corner-tl"></span><span class="tz-corner tz-corner-tr"></span>
    <span class="tz-corner tz-corner-bl"></span><span class="tz-corner tz-corner-br"></span>
    <p>Ranking is only valuable if it is <em>legal.</em></p>
    <div class="tz-pull-cite">&mdash; THE FIRST PRINCIPLE &mdash;</div>
  </div>

  <div class="tz-body tz-body-tight" data-reveal="slide">
    <p>Every campaign executed through us passes through <strong>200+ laws</strong> before anything goes live:</p>
  </div>
  <div class="tz-chips" data-reveal="fade" style="--rd:80ms">
    <span>GDPR</span><span>FCA</span><span>SRA</span><span>MHRA</span><span>ASA</span><span>HIPAA</span><span>EU AI ACT</span>
  </div>
  <p class="tz-chips-suffix" data-reveal="fade" style="--rd:160ms"><em>and international advertising laws.</em></p>

  <div class="tz-founder-cta-row">
  <aside class="tz-founder" data-reveal="lift">
    <div class="tz-founder-rule"><span></span><em>Founder</em><span></span></div>
    <div class="tz-founder-pill">
      <div class="tz-founder-photo">
        <img
          class="tz-founder-photo-img"
          src="/aman-portrait.webp"
          alt="Aman Pareek, founder of Tamazia"
          width="52"
          height="52"
          loading="lazy"
        />
        <span class="tz-founder-photo-mark" aria-hidden="true">AP</span>
      </div>
      <div class="tz-founder-body">
        <div class="tz-founder-name">Aman Pareek</div>
        <div class="tz-founder-creds">FOUNDER · LLM, KING'S COLLEGE LONDON</div>
      </div>
      <div class="tz-founder-socials">
        <a
          class="tz-founder-li"
          href="https://www.linkedin.com/in/amanpareektamazia/"
          aria-label="Aman Pareek on LinkedIn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" width="15" height="15" fill="currentColor">
            <path d="M19 0H5a5 5 0 0 0-5 5v14a5 5 0 0 0 5 5h14a5 5 0 0 0 5-5V5a5 5 0 0 0-5-5zM8 19H5V8h3v11zM6.5 6.7c-1 0-1.7-.8-1.7-1.7s.7-1.7 1.7-1.7 1.7.8 1.7 1.7-.7 1.7-1.7 1.7zM20 19h-3v-5.6c0-3.4-4-3.1-4 0V19h-3V8h3v1.8c1.4-2.6 7-2.8 7 2.5V19z"/>
          </svg>
        </a>
        <a
          class="tz-founder-ig"
          href="https://www.instagram.com/tamaziauk/"
          aria-label="Tamazia on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" width="15" height="15" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>
  </aside>
  <div class="tz-ribbon-caption" aria-hidden="true"><span>200+ Frameworks reviewed every campaign</span></div>



  <div class="tz-cta-wrap" data-reveal="lift">
    <a href="#contact" class="tz-cta">
      <span>Request your compliance &amp; SEO audit</span>
      <span class="tz-cta-arr" aria-hidden="true">→</span>
    </a>
  </div>
  </div><!-- /.tz-founder-cta-row -->

  <div class="tz-colophon">
    <span>LONDON</span><span class="tz-dot">·</span>
    <span class="tz-colophon-prose">Engagements delivered in UK, UAE, USA, EU</span>
  </div>

</section>
</div><!-- /.tz-hero-wrap -->

<style is:global>
  /* ===== FinalHero - Sextant component ===== */
  /* All selectors under .tz-mhero - no bleed into other sections */

  .tz-mhero {
    --tz-ivory:   #FAF7F2;
    --tz-obsidian:#1A1A1D;
    --tz-oxblood: #5A1A2B;
    --tz-gold:    #C9A772;
    --tz-gold-light:#E8CF9C;
    --tz-pearl:   #E8E4DC;
    --tz-muted:   #6B6B6F;
    --tz-display: "Playfair Display", Georgia, serif;
    --tz-body:    "Inter", system-ui, sans-serif;
    --tz-mono:    "JetBrains Mono", ui-monospace, monospace;

    background: var(--tz-ivory);
    color: var(--tz-obsidian);
    font-family: var(--tz-body);
    -webkit-font-smoothing: antialiased;
    position: relative;
    overflow: hidden;

    /* Responsive centering */
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    border-left: 1px solid rgba(201,167,114,0.12);
    border-right: 1px solid rgba(201,167,114,0.12);
  }

  /* ===== Scroll-reveal system ===== */
  .tz-mhero [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 720ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms),
      transform 720ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms),
      filter 720ms ease var(--rd, 0ms);
    will-change: opacity, transform;
  }
  .tz-mhero [data-reveal="fade"]  { transform: none; filter: blur(2px); }
  .tz-mhero [data-reveal="slide"] { transform: translateY(20px); }
  .tz-mhero [data-reveal="lift"]  { transform: translateY(8px) scale(.985); }
  .tz-mhero [data-reveal="rule"]  { transform: scaleX(0); transform-origin: left; opacity: 1; transition: transform 700ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms); }
  .tz-mhero .is-revealed[data-reveal]        { opacity: 1; transform: none; filter: none; }
  .tz-mhero .is-revealed[data-reveal="rule"] { transform: scaleX(1); }
  @media (prefers-reduced-motion: reduce) {
    .tz-mhero [data-reveal] { opacity: 1 !important; transform: none !important; filter: none !important; transition: none !important; }
  }

  /* ===== Rail ===== */
  .tz-rail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 22px;
    border-bottom: 1px solid rgba(26,26,29,0.08);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.32em;
    color: var(--tz-muted);
    text-transform: uppercase;
  }
  .tz-rail-title {
    font-family: var(--tz-display);
    font-style: italic;
    letter-spacing: 0.06em;
    font-size: 12px;
    color: var(--tz-oxblood);
    text-transform: none;
  }
  .tz-rail-year { color: var(--tz-gold); }

  /* S3 · Sextant micro-copy line */
  .tz-rail-microcopy {
    margin: 0;
    padding: 8px 22px 4px;
    font-family: var(--tz-display);
    font-style: italic;
    font-size: 12px;
    color: var(--tz-muted);
    line-height: 1.45;
    letter-spacing: 0.01em;
    text-align: center;
    border-bottom: 1px solid rgba(26,26,29,0.06);
  }
  .tz-rail-microcopy em { font-style: italic; color: var(--tz-oxblood); }
  @media (min-width: 1024px) {
    .tz-rail-microcopy { padding: 10px 28px 6px; font-size: 13px; }
  }

  /* ===== Sector panel ===== */
  .tz-panel {
    padding: 14px 14px 12px;
    position: relative;
  }
  .tz-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(0deg, transparent 0 31px, rgba(201,167,114,0.16) 31px 32px, transparent 32px 64px);
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
  }
  .tz-panel > * { position: relative; z-index: 1; }
  .tz-panel-head {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--tz-muted);
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .tz-panel-head > :first-child,
  .tz-panel-head > :last-child { color: var(--tz-oxblood); }
  .tz-panel-mid {
    font-family: var(--tz-display);
    font-style: italic;
    letter-spacing: 0.04em;
    font-size: 10px;
    color: var(--tz-gold);
    text-transform: none;
  }

  /* ===== Dual-band compass ===== */
  .tz-cp {
    width: 100%;
    aspect-ratio: 2.4 / 1;
    max-height: 150px;
    margin: 0 auto;
    position: relative;
  }
  .tz-cp svg { width: 100%; height: 100%; overflow: visible; display: block; }
  .tz-cp-arc      { fill: none; stroke: var(--tz-gold); stroke-width: 0.8; }
  .tz-cp-arc-inner{ stroke: rgba(26,26,29,0.16); stroke-dasharray: 1 3; stroke-width: 0.6; fill: none; }
  .tz-cp-deg      { font: 500 6.5px var(--tz-body); fill: var(--tz-muted); letter-spacing: 0.18em; }
  .tz-cp-sx-label { font: italic 8px var(--tz-display); fill: var(--tz-gold); letter-spacing: 0.04em; }
  .tz-cp-tick     { stroke: rgba(26,26,29,0.45); stroke-width: 0.7; transition: stroke 250ms ease, stroke-width 250ms ease; }
  .tz-cp-tick.is-active { stroke: var(--tz-oxblood); stroke-width: 1.6; }
  .tz-cp-abbr     { font: 600 6.5px var(--tz-body); fill: rgba(26,26,29,0.4); letter-spacing: 0.2em; transition: fill 250ms ease, font-size 250ms ease; }
  .tz-cp-abbr.is-active { fill: var(--tz-oxblood); font-size: 8px; font-weight: 700; }
  .tz-cp-needle-g { transform-origin: 150px 130px; transform: rotate(-60deg); transition: transform 1100ms cubic-bezier(.5,.05,.2,1); }
  .tz-cp-needle   { stroke: var(--tz-oxblood); stroke-width: 1.4; stroke-linecap: round; }
  .tz-cp-needle-tip  { fill: var(--tz-oxblood); }
  .tz-cp-needle-halo { fill: none; stroke: var(--tz-oxblood); stroke-width: 0.5; opacity: 0.4; }

  /* ===== Sector band ===== */
  .tz-band {
    margin-top: 8px;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid rgba(201,167,114,0.55);
    border-radius: 3px;
    background: linear-gradient(180deg, rgba(201,167,114,0.06), transparent 80%);
    align-items: center;
  }
  .tz-band-l        { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .tz-band-l-kicker { font: 600 7px var(--tz-body); letter-spacing: 0.3em; color: var(--tz-muted); text-transform: uppercase; }
  .tz-band-l-name   { font-family: var(--tz-display); font-style: italic; font-size: 18px; color: var(--tz-oxblood); line-height: 1; font-weight: 500; }
  .tz-band-l-idx    { font: 600 7px var(--tz-body); letter-spacing: 0.3em; color: var(--tz-gold); margin-top: 2px; }
  .tz-band-laws     { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 8px; }
  .tz-band-laws span {
    font: 500 9px var(--tz-mono);
    color: var(--tz-obsidian);
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .tz-band-laws span::before { content: ""; width: 3px; height: 3px; background: var(--tz-gold); border-radius: 50%; flex-shrink: 0; }

  /* ===== Fine enforcement pill ===== */
  .tz-fine {
    margin-top: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--tz-mono);
    font-size: 9px;
    color: var(--tz-muted);
    letter-spacing: 0.04em;
  }
  .tz-fine-rule { flex: 1 1 0; min-width: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(90,26,43,0.5), transparent); }
  .tz-fine-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(90,26,43,0.06);
    border: 1px solid rgba(90,26,43,0.25);
    border-radius: 999px;
    color: var(--tz-oxblood);
    max-width: 100%;
    min-width: 0;
    flex-shrink: 0;
    white-space: nowrap;
    transition: opacity 240ms ease, transform 240ms ease;
  }
  .tz-fine-pill .tz-fine-dot { width: 5px; height: 5px; background: var(--tz-oxblood); border-radius: 50%; flex-shrink: 0; }
  .tz-fine-pill .tz-fine-lab { font-family: var(--tz-display); font-style: italic; color: var(--tz-oxblood); font-weight: 500; font-size: 11px; letter-spacing: 0.01em; padding-right: 2px; white-space: nowrap; }
  .tz-fine-pill #tz-fine     { white-space: nowrap; font-size: 8.5px; letter-spacing: 0.02em; }
  .tz-fine-pill em           { font-family: var(--tz-display); font-style: italic; font-size: 10.5px; color: var(--tz-oxblood); white-space: nowrap; }
  .tz-fine.is-swapping .tz-fine-pill { opacity: 0; transform: translateY(3px); }
  .tz-band-l-name, #tz-laws  { transition: opacity 240ms ease, transform 240ms ease; }
  .tz-band.is-swapping .tz-band-l-name,
  .tz-band.is-swapping #tz-laws { opacity: 0; transform: translateY(3px); }

  /* ===== Panel foot ===== */
  .tz-panel-foot {
    margin-top: 10px;
    padding: 8px 0 0;
    border-top: 1px dashed rgba(26,26,29,0.18);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .tz-foot-kicker {
    font-family: var(--tz-body);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tz-muted);
  }
  .tz-foot-clients {
    font-family: var(--tz-display);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--tz-oxblood);
    line-height: 1.5;
  }
  .tz-foot-tail {
    font-family: var(--tz-body);
    font-size: 9px;
    font-style: italic;
    color: var(--tz-muted);
    letter-spacing: 0.02em;
  }
  .tz-panel-foot strong { font-weight: 500; }

  /* ===== Coordinates ===== */
  .tz-coord {
    display: flex;
    justify-content: center;
    gap: 14px;
    padding: 18px 22px 6px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.32em;
    color: var(--tz-gold);
  }
  .tz-coord-dot { opacity: 0.7; }

  /* ===== Headline ===== */
  .tz-headline {
    padding: 4px 22px 0;
    font-family: var(--tz-display);
    font-size: 42px;
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--tz-obsidian);
  }
  .tz-headline .tz-line    { display: block; }
  .tz-headline em.tz-word  { font-style: italic; color: var(--tz-oxblood); font-weight: 400; }
  .tz-line-em              { color: var(--tz-oxblood); }
  .tz-headline .tz-word    { display: inline-block; }
  .tz-headline .tz-word + .tz-word { margin-left: 0.22em; }

  /* ===== Sub-bullets ===== */
  .tz-subs { padding: 14px 22px 0; display: flex; flex-direction: column; gap: 6px; }
  .tz-sub  { display: flex; align-items: center; gap: 8px; font-family: var(--tz-display); font-style: italic; font-size: 13px; color: var(--tz-gold); }
  .tz-sub-rule { width: 14px; height: 1px; background: var(--tz-gold); }

  /* ===== Body text ===== */
  .tz-body       { padding: 18px 22px; }
  .tz-body-tight { padding: 10px 22px 12px; }
  .tz-body p     { font-family: var(--tz-display); font-size: 14px; line-height: 1.6; margin: 0; }
  .tz-body em    { color: var(--tz-oxblood); font-style: italic; }
  .tz-body strong{ color: var(--tz-oxblood); }
  .tz-dropcap    { font-family: var(--tz-display); font-size: 50px; line-height: 0.8; float: left; padding: 4px 8px 0 0; color: var(--tz-oxblood); font-weight: 500; }

