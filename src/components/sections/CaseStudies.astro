---
// Case Studies · Founder r4: adopt the attached layout — each case is a left story
// (eyebrow, name, sector, body, italic quote, verified shield) beside a right
// metric stack whose cards lift on hover and whose numbers count up on scroll-in.
// Richer copy from the brief. Kept in the site's light/ivory theme. The 96% metric
// preserves the founder's CG Oncology IPO link.
import { parseEmph } from '../../content/hero';

type Metric = { n?: number; suffix?: string; word?: string; label: string; sub: string };
type Case = { rn: string; name: string; tag: string; body: string; quote: string; verified: string; metrics: Metric[] };

const CASES: Case[] = [
  {
    rn: 'Case I.',
    name: 'Orchid Hotels',
    tag: 'HOSPITALITY · HOTEL GROUP · ASIA PACIFIC',
    body: "A nationally recognised hotel group was paying Booking.com and Expedia 15 to 25% of every reservation. The guests were theirs. The revenue was not. We built direct search visibility across every property simultaneously. Organic search became the primary booking channel within a single six-month campaign.",
    quote: "If you are paying OTA commission, you are funding your competitor's marketing.",
    verified: 'GA4 VERIFIED · INTERNAL BOOKING SYSTEM CROSS-REFERENCED',
    metrics: [
      { n: 840, suffix: '%', label: 'Organic user growth', sub: 'Six-month campaign. GA4 verified.' },
      { n: 113, suffix: '%', label: 'Revenue growth, year on year', sub: 'GA4 verified.' },
      { n: 83, suffix: '%', label: 'More direct bookings', sub: 'OTA dependency reduced.' },
    ],
  },
  {
    rn: 'Case II.',
    name: 'Meraas',
    tag: 'REAL ESTATE AND LIFESTYLE · DUBAI HOLDING SUBSIDIARY · UAE',
    body: "Meraas is a subsidiary of Dubai Holding, operating under a strategic directive from His Highness Sheikh Mohammed bin Rashid Al Maktoum, Ruler of Dubai. Every piece of content represents a brand answerable to the principal of the emirate. We built the digital presence and content architecture for Meraas properties. Every word written to Dubai Holding standard. Every piece published without incident.",
    quote: 'If this standard was adequate here, it is adequate for your brand.',
    verified: 'DUBAI HOLDING STANDARD · RERA · TRAKHEESI VERIFIED',
    metrics: [
      { word: 'Dubai Holding', label: 'Group standard', sub: 'Sheikh Mohammed directive' },
      { word: 'Zero', label: 'Compliance incidents', sub: 'RERA · Trakheesi' },
      { word: 'UAE', label: 'Verified regulatory standard', sub: 'Real estate compliance.' },
    ],
  },
  {
    rn: 'Case III.',
    name: 'CG Oncology',
    tag: 'HEALTHCARE · NASDAQ IPO · USA · CGON',
    body: "CG Oncology was preparing for its Nasdaq listing under ticker CGON. Every piece of digital content had to be accurate on the science, correct on the financials, and clean under SEC Regulation FD simultaneously. Tamazia produced and reviewed every IPO-window digital asset against SEC Reg FD before publication. Zero violations across the IPO window. Shares closed 96% above the offer price at listing.",
    quote: 'Your digital agency is either a compliance asset or a compliance risk. There is no middle position.',
    verified: 'VERIFIED PER SEC FILINGS · PUBLIC RECORD',
    metrics: [
      { n: 96, suffix: '%', label: 'Share price increase at IPO', sub: 'Tamazia\'s <a href="https://synthetic.com/cg-oncology-enters-bladder-cancer-therapy-space-with-ipo/" target="_blank" rel="noopener noreferrer">digital content</a> and strategy was one factor in that outcome.' },
      { word: 'Nasdaq', label: 'Listed: CGON', sub: 'Public market debut.' },
      { word: 'Zero', label: 'Compliance incidents', sub: 'Across the IPO window.' },
    ],
  },
];

const shield = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3zM9 12l2 2 4-4"/></svg>';
---
<section class="cs2" id="cases" aria-labelledby="cases-heading">
  <div class="cs2-wrap">
    <div class="cs2-head" data-reveal>
      <p class="cs2-eyebrow">Case Studies</p>
      <h2 id="cases-heading" class="cs2-h2">Three clients. Three regulators.<br />Every number below is verified.</h2>
      <p class="cs2-sub">No projections. GA4, SEC filings and internal booking systems cross-referenced.
        <span class="cs2-hint"><span class="cs2-hint-ic" aria-hidden="true">&rsaquo;</span> Hover the metrics to lift them</span>
      </p>
    </div>

    {CASES.map((c) => (
      <div class="cs2-case">
        <div class="cs2-left" data-reveal>
          <div class="cs2-rn">{c.rn}</div>
          <h3 class="cs2-name">{c.name}</h3>
          <div class="cs2-tag">{c.tag}</div>
          <p class="cs2-body">{c.body}</p>
          <p class="cs2-quote">&ldquo;{c.quote}&rdquo;</p>
          <div class="cs2-verified"><span class="cs2-shield" set:html={shield} />{c.verified}</div>
        </div>
        <div class="cs2-metrics" data-reveal style="--d:120ms">
          {c.metrics.map((m) => (
            <div class="cs2-metric">
              {m.word
                ? <div class="cs2-mn cs2-word">{m.word}</div>
                : <div class="cs2-mn"><span class="cs2-count" data-count={m.n} data-suffix={m.suffix || ''}>0</span></div>}
              <div class="cs2-ml">{m.label}<span set:html={m.sub} /></div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  (function () {
    var rm = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // reveal
    var ro = new IntersectionObserver(function (es) {
      es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); ro.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.cs2 [data-reveal]').forEach(function (el) { ro.observe(el); });
    // count-up
    var co = new IntersectionObserver(function (es) {
      es.forEach(function (e) {
        if (!e.isIntersecting) return;
        var el = e.target, target = parseFloat(el.dataset.count), suffix = el.dataset.suffix || '';
        if (rm) { el.textContent = target + suffix; co.unobserve(el); return; }
        var dur = 1400, start = null;
        function tick(now) {
          if (start === null) start = now;
          var p = Math.min((now - start) / dur, 1), ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * ease) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        co.unobserve(el);
      });
    }, { threshold: 0.6 });
    document.querySelectorAll('.cs2 [data-count]').forEach(function (el) { co.observe(el); });
  })();
</script>

<style>
  .cs2 { background: var(--ivory, #FAF7F2); padding-block: clamp(56px, 8vh, 112px); }
  .cs2-wrap { max-width: var(--container-max, 1280px); margin-inline: auto; padding-inline: var(--container-padding, clamp(20px,4vw,48px)); }

  .cs2-head { max-width: 820px; margin-bottom: clamp(28px, 4vh, 48px); }
  .cs2-eyebrow {
    font-family: var(--ff-body, Inter, sans-serif);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold-text, #8A6520); font-weight: 600; margin: 0 0 12px;
    display: flex; align-items: center; gap: 12px;
  }
  .cs2-eyebrow::before { content: ''; width: 34px; height: 1px; background: var(--gold, #C9A772); opacity: 0.6; }
  .cs2-h2 { font-family: var(--ff-display, Georgia, serif); font-weight: 500; font-size: clamp(28px, 4vw, 52px); line-height: 1.05; letter-spacing: -0.01em; color: var(--ink, #2A0C14); margin: 0; }
  .cs2-sub { font-family: var(--ff-body, Inter, sans-serif); font-size: clamp(14px, 1.4vw, 16px); color: var(--ink-muted, #5C3F40); margin: 14px 0 0; line-height: 1.55; }
  .cs2-hint { display: inline-flex; align-items: center; gap: 7px; font-size: 12px; color: var(--gold-text, #8A6520); margin-left: 8px; }
  .cs2-hint-ic { color: var(--gold, #C9A772); animation: cs2Nudge 1.8s ease-in-out infinite; }
  @keyframes cs2Nudge { 0%,100%{transform:translateX(0)} 50%{transform:translateX(3px)} }

  .cs2-case {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(20px, 3vw, 52px);
    align-items: start; padding-block: clamp(26px, 4vh, 42px);
    border-top: 1px solid var(--gold-hairline, rgba(201,167,114,0.3));
  }
  .cs2-case:last-child { border-bottom: 1px solid var(--gold-hairline, rgba(201,167,114,0.3)); }

  .cs2-left { display: flex; flex-direction: column; align-items: flex-start; }
  .cs2-rn { font-family: var(--ff-display, Georgia, serif); font-style: italic; font-size: 15px; color: var(--gold-text, #8A6520); }
  .cs2-name { font-family: var(--ff-display, Georgia, serif); font-weight: 500; font-size: clamp(26px, 3.4vw, 44px); line-height: 1.02; color: var(--ink, #2A0C14); margin: 8px 0 0; }
  .cs2-tag { font-family: var(--ff-body, Inter, sans-serif); font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted, #5C3F40); margin-top: 10px; }
  .cs2-body { font-family: var(--ff-body, Inter, sans-serif); font-size: 14px; color: var(--ink-muted, #5C3F40); line-height: 1.6; margin: 18px 0 0; max-width: 48ch; }
  .cs2-quote { font-family: var(--ff-display, Georgia, serif); font-style: italic; font-size: clamp(16px, 1.8vw, 20px); color: var(--oxblood, #5A1A2B); margin: 18px 0 0; line-height: 1.35; }
  .cs2-verified { display: inline-flex; align-items: center; gap: 8px; margin-top: 20px; font-family: var(--ff-body, Inter, sans-serif); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted, #5C3F40); }
  .cs2-shield { display: inline-flex; }
  .cs2-shield svg { width: 14px; height: 14px; color: var(--gold-text, #8A6520); flex-shrink: 0; }

  .cs2-metrics { display: flex; flex-direction: column; gap: 8px; padding-top: 4px; }
  .cs2-metric {
    border: 1px solid var(--gold-hairline, rgba(201,167,114,0.32)); border-radius: 9px;
    padding: 13px 18px; background: var(--pearl, #F4F0E8);
    display: flex; align-items: center; gap: 16px; cursor: default;
    transition: transform 0.4s var(--ease-out, cubic-bezier(.22,1,.36,1)), border-color 0.35s, box-shadow 0.4s, background 0.35s;
  }
  .cs2-metric:hover {
    border-color: var(--gold, #C9A772);
    background: linear-gradient(150deg, rgba(201,167,114,0.12), rgba(90,26,43,0.06));
    box-shadow: 0 12px 34px -16px rgba(90,26,43,0.34);
    transform: translateX(7px);
  }
  .cs2-mn { font-family: var(--ff-display, Georgia, serif); font-size: clamp(28px, 3.2vw, 40px); line-height: 0.9; color: var(--gold-text, #8A6520); flex: 0 0 auto; min-width: 2.2ch; font-feature-settings: 'lnum','tnum'; }
  .cs2-mn.cs2-word { font-size: clamp(18px, 1.9vw, 24px); min-width: 0; letter-spacing: -0.01em; }
  .cs2-ml { font-family: var(--ff-body, Inter, sans-serif); font-size: 13px; color: var(--ink, #2A0C14); flex: 1; line-height: 1.3; }
  .cs2-ml span { display: block; font-size: 10px; letter-spacing: 0.04em; color: var(--ink-muted, #5C3F40); margin-top: 4px; text-transform: none; }
  .cs2-ml span a { color: var(--oxblood, #5A1A2B); text-decoration: underline; text-decoration-color: var(--gold, #C9A772); }

  [data-reveal] { opacity: 0; transform: translateY(24px); transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1); transition-delay: var(--d, 0ms); }
  [data-reveal].in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; } }

  @media (max-width: 760px) {
    .cs2-case { grid-template-columns: 1fr; gap: 18px; }
    .cs2-metrics { padding-top: 0; }
  }
</style>
