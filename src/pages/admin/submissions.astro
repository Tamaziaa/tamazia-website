---
// /admin/submissions · Phase 3 perfection · KV-backed dashboard
// Auth: ADMIN_SECRET via query string (?key=) or X-Admin-Secret header.
// Reads /api/admin-submissions then renders.
import BaseLayout from '../../layouts/BaseLayout.astro';
const lastUpdated = '5 May 2026';
---
<BaseLayout
  title="Submissions · Tamazia admin"
  description="Auth-gated form submissions dashboard"
  canonical="https://tamazia.co.uk/admin/submissions/"
  noindex={true}
>
  <main id="main" class="admin">
    <header class="admin-head">
      <h1>Form Submissions</h1>
      <p class="updated">Last verified {lastUpdated}.</p>
      <div class="filters">
        <label>Tab <select id="tab"><option value="">all</option><option>contact</option><option>briefings</option><option>audit</option><option>bookings</option><option>errors</option></select></label>
        <input id="search" placeholder="Search email or company" />
        <button id="reload">Reload</button>
        <button id="export">Export CSV</button>
      </div>
    </header>

    <section id="status" class="status">Loading…</section>
    <table id="grid">
      <thead><tr><th>Submitted</th><th>Tab</th><th>Name</th><th>Email</th><th>Company</th><th>Intent</th><th>UTM</th><th>Country</th></tr></thead>
      <tbody></tbody>
    </table>
  </main>
</BaseLayout>

<style>
  .admin { padding: 32px 24px 96px; max-width: 1280px; margin: 0 auto; font-family: 'Inter', system-ui, sans-serif; color: #2A0C14; }
  .admin h1 { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-weight: 500; font-size: 36px; margin: 0; }
  .updated { font-size: 12px; color: #5C4047; margin: 4px 0 16px; }
  .filters { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .filters input, .filters select, .filters button { font: inherit; padding: 6px 10px; border: 1px solid #C9A772; background: #FAF7F2; }
  .filters button { cursor: pointer; }
  .status { font-size: 13px; color: #5C4047; margin-bottom: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { padding: 8px 10px; border-bottom: 1px solid #E5DDCB; vertical-align: top; text-align: left; }
  th { background: #F4F0E8; font-weight: 600; position: sticky; top: 0; }
  tr:hover td { background: #FAF7F2; }
</style>

<script is:inline>
  (function () {
    const params = new URLSearchParams(location.search);
    const KEY = params.get('key') || sessionStorage.getItem('tamazia-admin-key') || prompt('Admin secret');
    if (KEY) sessionStorage.setItem('tamazia-admin-key', KEY);
    let cache = [];

    async function load() {
      const tab = document.getElementById('tab').value;
      const url = '/api/admin-submissions?key=' + encodeURIComponent(KEY) + (tab ? '&tab=' + tab : '');
      document.getElementById('status').textContent = 'Loading…';
      try {
        const r = await fetch(url);
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();
        cache = data.submissions || [];
        render();
      } catch (e) {
        document.getElementById('status').textContent = 'Error: ' + e.message;
      }
    }

    function render() {
      const q = document.getElementById('search').value.trim().toLowerCase();
      const rows = cache.filter(s => !q || (s.email||'').toLowerCase().includes(q) || (s.company||'').toLowerCase().includes(q));
      document.getElementById('status').textContent = rows.length + ' rows';
      const tbody = document.querySelector('#grid tbody');
      tbody.innerHTML = '';
      for (const s of rows) {
        const tr = document.createElement('tr');
        tr.innerHTML = ['submitted_at','tab_source','name','email','company','intent_text','utm_source','ip_country']
          .map(k => '<td>' + esc(s[k] || '') + '</td>').join('');
        tbody.appendChild(tr);
      }
    }

    function esc(s) { return String(s).replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c])); }

    function exportCsv() {
      const headers = ['submitted_at','tab_source','request_id','name','email','company','intent_text','utm_source','utm_medium','ip_country'];
      const rows = [headers.join(',')];
      for (const s of cache) rows.push(headers.map(h => JSON.stringify(s[h] || '')).join(','));
      const blob = new Blob([rows.join('\n')], { type: 'text/csv' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'tamazia-submissions-' + new Date().toISOString().slice(0,10) + '.csv';
      a.click();
    }

    document.getElementById('tab').addEventListener('change', load);
    document.getElementById('search').addEventListener('input', render);
    document.getElementById('reload').addEventListener('click', load);
    document.getElementById('export').addEventListener('click', exportCsv);
    load();
  })();
</script>
