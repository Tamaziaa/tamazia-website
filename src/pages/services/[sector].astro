---
// G.1 · Five sector landing pages · dynamic route
// Generates: /services/law-firm/ /services/healthcare/ /services/hospitality/
//            /services/financial-services/ /services/real-estate/

import BaseLayout from '../../layouts/BaseLayout.astro';
import { sectorPages, getSectorBySlug } from '../../data/sectorContent';
import type { SectorPage } from '../../data/sectorContent';

export async function getStaticPaths() {
  return sectorPages.map((sector) => ({
    params: { sector: sector.slug },
    props: { sector },
  }));
}

interface Props {
  sector: SectorPage;
}

const { sector } = Astro.props;

const canonicalUrl = `https://tamazia.co.uk/services/${sector.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: `${sector.name} SEO, Tamazia`,
      description: sector.metaDescription,
      provider: {
        '@id': 'https://tamazia.co.uk/#organization',
      },
      url: canonicalUrl,
      areaServed: ['United Kingdom', 'United Arab Emirates', 'United States', 'Global'],
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://tamazia.co.uk/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Services',
          item: 'https://tamazia.co.uk/services/',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: sector.name,
          item: canonicalUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={sector.metaTitle}
  description={sector.metaDescription}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  {/* Header */}
  <header class="site-header" role="banner">
    <nav class="main-nav" aria-label="Primary">
      <div class="logo-group">
        <a href="/" class="logo-crest" aria-label="Tamazia home"><span class="t">T</span></a>
        <a href="/" class="logo-wordmark">Tamazia</a>
      </div>
      <ul class="nav-items">
        <li><a href="/#why-us">Why Us</a></li>
        <li><a href="/services/" aria-current="true">Services</a></li>
        <li><a href="/case-studies/">Cases</a></li>
        <li><a href="/#process">Process</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <a class="nav-cta" href="/#contact">Request a Briefing</a>
      <button class="burger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-drawer">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
          <rect y="0"  width="22" height="2" rx="1" fill="currentColor"/>
          <rect y="7"  width="22" height="2" rx="1" fill="currentColor"/>
          <rect y="14" width="22" height="2" rx="1" fill="currentColor"/>
        </svg>
      </button>
    </nav>
    <nav class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation" hidden>
      <button class="drawer-close" aria-label="Close navigation menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="17" y1="1" x2="1"  y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <ul class="drawer-items">
        <li><a href="/#why-us" class="drawer-link">Why Us</a></li>
        <li><a href="/services/" class="drawer-link">Services</a></li>
        <li><a href="/case-studies/" class="drawer-link">Cases</a></li>
        <li><a href="/#process" class="drawer-link">Process</a></li>
        <li><a href="/#pricing" class="drawer-link">Pricing</a></li>
        <li><a href="/#faq" class="drawer-link">FAQ</a></li>
        <li><a href="/#contact" class="drawer-link">Contact</a></li>
      </ul>
      <a class="drawer-cta" href="/#contact">Request a Briefing</a>
    </nav>
  </header>

  <main id="main">

    {/* Breadcrumb */}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services/">Services</a></li>
        <li aria-current="page">{sector.name}</li>
      </ol>
    </nav>

    {/* Hero block */}
    <section class="sector-hero" aria-labelledby="sector-h1">
      <p class="sector-eyebrow">{sector.eyebrow}</p>
      <h1 id="sector-h1" class="sector-h1">{sector.h1}</h1>
    </section>

    {/* Regulatory context */}
    <section class="regulatory-context" aria-labelledby="reg-context-heading">
      <div class="reg-context-inner">
        <h2 id="reg-context-heading" class="reg-context-heading">The Regulatory Landscape</h2>
        <div class="reg-context-body">
          {sector.regulatoryContext.split('\n\n').map((para) => (
            <p>{para}</p>
          ))}
        </div>
      </div>
    </section>

    {/* Regulator grid */}
    <section class="regulator-grid-section" aria-labelledby="regulators-heading">
      <div class="regulator-grid-inner">
        <h2 id="regulators-heading" class="regulators-heading">Standards We Review Against</h2>
        <ul class="regulator-grid" role="list">
          {sector.regulators.map((reg) => (
            <li class="regulator-chip">{reg}</li>
          ))}
        </ul>
      </div>
    </section>

    {/* Proof point */}
    <section class="proof-section" aria-labelledby="proof-heading">
      <div class="proof-inner">
        <h2 id="proof-heading" class="sr-only">Client proof point</h2>
        <div class="proof-stat-block">
          <span class="proof-stat" data-stat>{sector.proofStat}</span>
          <span class="proof-caption">{sector.proofCaption}</span>
        </div>
        <p class="proof-text">{sector.proofPoint}</p>
      </div>
    </section>

    {/* Mandate CTA */}
    <section class="sector-mandate" aria-labelledby="mandate-heading">
      <div class="mandate-inner">
        <h2 id="mandate-heading" class="mandate-heading">Start with a compliance audit</h2>
        <p class="mandate-sub">
          Every {sector.name.toLowerCase()} engagement opens with a regulatory and SEO audit. We identify the gap between your current digital presence and what your regulator expects to see. No commitment required.
        </p>
        <a href="/#contact" class="mandate-cta">{sector.mandateCta}</a>
        <p class="mandate-note">Responses within one business day. All communications confidential.</p>
      </div>
    </section>

    {/* Services cross-link */}
    <section class="other-sectors" aria-labelledby="other-sectors-heading">
      <div class="other-sectors-inner">
        <h2 id="other-sectors-heading" class="other-sectors-heading">Other regulated sectors</h2>
        <ul class="other-sectors-list" role="list">
          {sectorPages
            .filter((s) => s.slug !== sector.slug)
            .map((s) => (
              <li>
                <a href={`/services/${s.slug}/`} class="other-sector-link">
                  <span class="other-sector-name">{s.name}</span>
                  <span class="other-sector-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
        </ul>
      </div>
    </section>

  </main>

  {/* Footer */}
  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Tamazia home">
          <span class="t">T</span>
        </a>
        <p class="footer-tagline">Lawyer-led SEO for regulated enterprises.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <ul>
          <li><a href="/services/">Services</a></li>
          <li><a href="/case-studies/">Case Studies</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/privacy-notice/">Privacy Notice</a></li>
          <li><a href="/cookie-policy/">Cookie Policy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </nav>
      <p class="footer-legal">
        &copy; {new Date().getFullYear()} Tamazia Ltd. Registered in England and Wales.
        All engagements invoiced in GBP. Content reviewed against applicable regulatory standards before publication.
      </p>
    </div>
  </footer>

</BaseLayout>

<style>
  /* =============================================
     SECTOR PAGE · SCOPED STYLES · G.1
     ============================================= */

  /* Nav (repeated from Header.astro, scoped to this page) */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--ivory);
    border-bottom: 1px solid var(--hairline);
  }

  .main-nav {
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 72px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .logo-group {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-crest {
    width: 36px;
    height: 36px;
    background: var(--oxblood);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-wordmark {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .nav-items {
    display: flex;
    list-style: none;
    gap: 28px;
    margin: 0;
    padding: 0;
  }

  .nav-items a {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity var(--t-opacity);
    font-weight: 400;
  }

  .nav-items a:hover,
  .nav-items a[aria-current="true"] {
    opacity: 1;
    color: var(--oxblood);
  }

  .nav-cta {
    display: inline-block;
    padding: 9px 20px;
    background: var(--oxblood);
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--oxblood);
    transition: background var(--t-bg), color var(--t-color);
  }

  .nav-cta:hover {
    background: transparent;
    color: var(--oxblood);
  }

  .burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink);
    padding: 6px;
  }

  .mobile-drawer {
    display: none;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--ivory);
    border-bottom: 1px solid var(--hairline);
    padding: 12px 72px;
  }

  .breadcrumb ol {
    display: flex;
    list-style: none;
    gap: 8px;
    margin: 0;
    padding: 0;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.6;
    align-items: center;
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: 8px;
    opacity: 0.4;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--oxblood);
    opacity: 1;
  }

  .breadcrumb li[aria-current="page"] {
    opacity: 1;
    color: var(--oxblood);
  }

  /* Sector hero */
  .sector-hero {
    background: var(--oxblood);
    padding: 80px 72px 88px;
    position: relative;
    overflow: hidden;
  }

  .sector-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(198,160,80,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .sector-eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 24px;
    opacity: 0.9;
  }

  .sector-h1 {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 500;
    color: var(--ivory);
    line-height: 1.2;
    max-width: 820px;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* Regulatory context */
  .regulatory-context {
    background: var(--ivory);
    padding: 80px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .reg-context-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .reg-context-heading {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 32px;
    letter-spacing: -0.01em;
  }

  .reg-context-body p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink);
    margin: 0 0 20px;
    opacity: 0.85;
  }

  .reg-context-body p:last-child {
    margin-bottom: 0;
  }

  /* Regulator grid */
  .regulator-grid-section {
    background: var(--parchment, #F5F0E8);
    padding: 64px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .regulator-grid-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .regulators-heading {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 600;
    margin: 0 0 28px;
  }

  .regulator-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .regulator-chip {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid var(--oxblood);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    background: transparent;
    white-space: nowrap;
  }

  /* Proof section */
  .proof-section {
    background: var(--oxblood);
    padding: 80px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .proof-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 72px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 64px;
    align-items: center;
  }

  .proof-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    min-width: 200px;
  }

  .proof-stat {
    font-family: var(--font-serif);
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .proof-caption {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ivory);
    opacity: 0.6;
    text-align: center;
    max-width: 200px;
    line-height: 1.5;
  }

  .proof-text {
    font-family: var(--font-serif);
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 400;
    color: var(--ivory);
    line-height: 1.5;
    margin: 0;
    opacity: 0.92;
  }

  /* Mandate CTA */
  .sector-mandate {
    background: var(--ivory);
    padding: 96px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .mandate-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 72px;
    text-align: center;
  }

  .mandate-heading {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 20px;
    letter-spacing: -0.01em;
  }

  .mandate-sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    opacity: 0.75;
    margin: 0 0 36px;
  }

  .mandate-cta {
    display: inline-block;
    padding: 15px 36px;
    background: var(--oxblood);
    color: var(--gold);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--oxblood);
    transition: background var(--t-bg), color var(--t-color);
    margin-bottom: 16px;
  }

  .mandate-cta:hover {
    background: transparent;
    color: var(--oxblood);
  }

  .mandate-note {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink);
    opacity: 0.5;
    margin: 0;
    text-align: center;
  }

  /* Other sectors */
  .other-sectors {
    background: var(--ivory);
    padding: 64px 0;
    border-top: 1px solid var(--hairline);
  }

  .other-sectors-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 72px;
  }

  .other-sectors-heading {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 600;
    margin: 0 0 28px;
  }

  .other-sectors-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .other-sector-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border: 1px solid var(--hairline);
    text-decoration: none;
    transition: border-color var(--t-border), background var(--t-bg);
    background: var(--ivory);
  }

  .other-sector-link:hover {
    border-color: var(--oxblood);
    background: rgba(90,26,43,0.03);
  }

  .other-sector-name {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
  }

  .other-sector-arrow {
    color: var(--oxblood);
    font-size: 14px;
    opacity: 0.6;
    transition: opacity var(--t-opacity);
  }

  .other-sector-link:hover .other-sector-arrow {
    opacity: 1;
  }

  /* Footer */
  .footer {
    background: linear-gradient(180deg, #2A0C14 0%, #1F0810 100%);
    padding: 64px 0 48px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 72px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 32px 64px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-logo {
    width: 40px;
    height: 40px;
    background: var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--oxblood);
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 12px;
    color: var(--ivory);
    opacity: 0.5;
    margin: 0;
    letter-spacing: 0.04em;
  }

  .footer-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-nav a {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ivory);
    text-decoration: none;
    opacity: 0.55;
    transition: opacity var(--t-opacity);
  }

  .footer-nav a:hover {
    opacity: 1;
  }

  .footer-legal {
    grid-column: 1 / -1;
    font-size: 11px;
    color: var(--ivory);
    opacity: 0.35;
    margin: 0;
    line-height: 1.6;
    letter-spacing: 0.04em;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 24px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .main-nav {
      padding: 0 24px;
    }
    .nav-items,
    .nav-cta {
      display: none;
    }
    .burger {
      display: flex;
    }
    .mobile-drawer {
      display: flex;
      flex-direction: column;
      position: fixed;
      inset: 0;
      background: var(--oxblood);
      z-index: 200;
      padding: 32px 24px;
      gap: 24px;
    }
    .drawer-close {
      align-self: flex-end;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--ivory);
      padding: 8px;
    }
    .drawer-items {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .drawer-link {
      font-size: 20px;
      color: var(--ivory);
      text-decoration: none;
      font-family: var(--font-serif);
    }
    .drawer-cta {
      display: inline-block;
      padding: 14px 28px;
      background: var(--gold);
      color: var(--oxblood);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
      text-decoration: none;
      align-self: flex-start;
    }

    .breadcrumb,
    .reg-context-inner,
    .regulator-grid-inner,
    .proof-inner,
    .mandate-inner,
    .other-sectors-inner,
    .footer-inner,
    .sector-hero {
      padding-left: 24px;
      padding-right: 24px;
    }

    .proof-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: center;
    }

    .proof-stat-block {
      min-width: auto;
    }

    .footer-inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .sector-hero {
      padding-top: 56px;
      padding-bottom: 64px;
    }
    .other-sectors-list {
      grid-template-columns: 1fr;
    }
  }

  /* Print */
  @media print {
    .site-header,
    .burger,
    .mobile-drawer,
    .mandate-cta,
    .other-sectors,
    .footer { display: none !important; }
    .sector-hero { background: #fff !important; color: #000 !important; }
    .sector-eyebrow,
    .sector-h1 { color: #000 !important; }
    .proof-section { background: #fff !important; }
    .proof-stat,
    .proof-text { color: #000 !important; }
  }
</style>

<script>
  // Mobile drawer toggle
  const burger = document.querySelector('.burger');
  const drawer = document.querySelector('.mobile-drawer');
  const drawerClose = document.querySelector('.drawer-close');

  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const isOpen = drawer.hasAttribute('hidden');
      if (isOpen) {
        drawer.removeAttribute('hidden');
        burger.setAttribute('aria-expanded', 'true');
      } else {
        drawer.setAttribute('hidden', '');
        burger.setAttribute('aria-expanded', 'false');
      }
    });
  }

  if (drawerClose && drawer && burger) {
    drawerClose.addEventListener('click', () => {
      drawer.setAttribute('hidden', '');
      burger.setAttribute('aria-expanded', 'false');
    });
  }

  // Close drawer on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.hasAttribute('hidden')) {
      drawer.setAttribute('hidden', '');
      burger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
