---
import { sectorsContent } from '../../content/sectors';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, subline, sectors, closingLine } = sectorsContent;

// SVG icon map for each sector (gold-line sculptural placeholders until 3D renders are ready)
const iconPaths: Record<string, string> = {
  gavel: `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="40" y="20" width="28" height="16" rx="2" transform="rotate(-30 54 28)"/>
    <line x1="30" y1="52" x2="78" y2="14"/>
    <rect x="10" y="70" width="80" height="6" rx="1"/>
    <line x1="20" y1="70" x2="20" y2="76"/>
    <line x1="80" y1="70" x2="80" y2="76"/>
  </g>`,
  caduceus: `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="50" y1="15" x2="50" y2="85"/>
    <path d="M 50 25 Q 35 35, 50 45 Q 65 55, 50 65 Q 35 75, 50 85"/>
    <circle cx="40" cy="25" r="4"/>
    <path d="M 36 25 Q 30 15, 44 15 Q 40 20, 36 25"/>
    <path d="M 44 25 Q 50 15, 56 25"/>
  </g>`,
  bell: `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 30 60 Q 30 30, 50 25 Q 70 30, 70 60 Z"/>
    <circle cx="50" cy="22" r="3"/>
    <line x1="30" y1="60" x2="70" y2="60"/>
    <rect x="25" y="65" width="50" height="4" rx="1"/>
    <circle cx="50" cy="48" r="2"/>
  </g>`,
  'opening-bell': `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 20 30 Q 50 10, 80 30" />
    <line x1="50" y1="22" x2="50" y2="40"/>
    <path d="M 35 45 Q 35 65, 50 70 Q 65 65, 65 45 Z"/>
    <line x1="35" y1="45" x2="65" y2="45"/>
    <circle cx="50" cy="58" r="2"/>
    <line x1="20" y1="75" x2="80" y2="75"/>
    <text x="50" y="82" text-anchor="middle" font-size="6" font-family="Playfair Display" fill="currentColor" stroke="none" font-style="italic">NYSE</text>
  </g>`,
  cloche: `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 20 55 Q 20 25, 50 25 Q 80 25, 80 55"/>
    <circle cx="50" cy="20" r="3"/>
    <line x1="18" y1="60" x2="82" y2="60"/>
    <path d="M 46 70 Q 50 62, 54 70 L 54 80 L 46 80 Z"/>
    <circle cx="50" cy="66" r="1.5" fill="currentColor"/>
  </g>`,
  compass: `<g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="50" r="32"/>
    <circle cx="50" cy="50" r="26"/>
    <path d="M 50 20 L 54 50 L 50 80 L 46 50 Z" fill="currentColor"/>
    <path d="M 20 50 L 50 46 L 80 50 L 50 54 Z"/>
    <circle cx="50" cy="50" r="2" fill="currentColor"/>
    <line x1="50" y1="14" x2="50" y2="20"/>
    <line x1="50" y1="80" x2="50" y2="86"/>
    <line x1="14" y1="50" x2="20" y2="50"/>
    <line x1="80" y1="50" x2="86" y2="50"/>
  </g>`,
};
---
<section class="sectors" id="sectors" aria-labelledby="sectors-heading">
  <!-- Monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="sectors-heading" class="section-h2" set:html={parseEmph(h2)} />
      <p class="subline">{subline}</p>
    </div>

    {/* Round-12 fix · drop role="list"/"listitem" pair on bento-grid + sector article.
        axe-allowed-role disallows role="listitem" on <article>. Sector cards are
        standalone content blocks (article landmarks); they don't need list semantics. */}
    <div class="bento-grid">
      {sectors.map((sector) => (
        <article
          class={`sector-card sector-${sector.size}`}
          data-sector={sector.id}
        >
          <div class="card-inner">
            <span class="card-numeral">{sector.numeral}</span>

            <div class="card-3d" aria-hidden="true">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <Fragment set:html={iconPaths[sector.icon]} />
              </svg>
            </div>

            <div class="card-eyebrow">SECTOR {sector.index} / VI</div>
            <h3 class="card-headline">{sector.headline}</h3>
            <div class="card-shorthand">{sector.regulatoryShorthand}</div>
            <p class="card-body">{sector.body}</p>
            {sector.pullQuote && <blockquote class="card-pullquote">{sector.pullQuote}</blockquote>}
            <a href="#contact" class="card-cta">{sector.cta}</a>

            <!-- Tooltip regulation detail (appears on hover) -->
            <div class="card-tooltip" aria-hidden="true">
              <div class="tooltip-header">Specific frameworks applied</div>
              <ul>
                {sector.tooltip.map((t) => <li>{t}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="closing-line-wrap">
      <div class="closing-hairline" aria-hidden="true"></div>
      <p class="closing-line">{closingLine}</p>
    </div>
  </div>
</section>

<style>
  .sectors {
    position: relative;
    background: var(--obsidian);
    padding-block: var(--section-padding-block);
    overflow: hidden;
    color: var(--ivory);
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: clamp(280px, 45vw, 680px);
    color: var(--gold);
    line-height: 1;
    opacity: 0.025;
    letter-spacing: -0.04em;
    animation: monogram-breath 8s ease-in-out infinite;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    position: relative;
    z-index: 2;
  }

  .header-block {
    max-width: 720px;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--eyebrow-light, #6B5058);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--gold);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: var(--ls-h2);
    color: var(--ivory);
    margin-bottom: 24px;
  }

  .section-h2 :global(.emph) {
    color: var(--gold);
    font-style: italic;
    font-weight: 500;
  }

  .subline {
    font-family: var(--ff-display);
    font-size: 17px;
    font-style: italic;
    color: var(--pearl);
    opacity: 0.75;
    line-height: 1.5;
    max-width: 520px;
  }

  /* Bento grid: 12-column equal layout (B-03 fix) */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: auto;
    gap: 24px;
    align-items: stretch;
  }

  .sector-card {
    container-type: inline-size;
    position: relative;
    background: var(--obsidian-deep);
    border: 1px solid rgba(201, 167, 114, 0.3);
    border-radius: 16px;
    padding: 32px 32px 36px;
    overflow: visible; /* B-03: allow content to flow naturally */
    min-width: 0;
    height: 100%;
    transition: transform 400ms var(--ease-out),
                border-color 400ms var(--ease-out),
                box-shadow 400ms var(--ease-out);
    opacity: 0;
    transform: translateY(20px);
  }

  .sector-card.in-view {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 700ms var(--ease-out), transform 700ms var(--ease-out),
                border-color 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }

  /* All sectors equal weight (Aman directive: no dominant card) */
  .sector-large    { grid-column: span 4; grid-row: span 1; }
  .sector-standard { grid-column: span 4; grid-row: span 1; }
  .sector-medium   { grid-column: span 4; grid-row: span 1; }

  /* Per-card pull quote (6th unique element per sector card) */
  .card-pullquote {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--gold);
    border-left: 2px solid var(--gold);
    padding-left: 14px;
    margin: 16px 0;
  }

  .sector-card:hover {
    transform: translateY(-8px);
    border-color: var(--gold);
    box-shadow: 0 30px 60px -30px rgba(201, 167, 114, 0.3);
  }

  .card-inner {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow: visible;
  }
  .card-cta {
    margin-top: auto;
    padding-top: 16px;
  }

  .card-numeral {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
    opacity: 0.9;
    letter-spacing: 0.02em;
  }

  .card-3d {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 120px;
    height: 120px;
    color: var(--gold);
    opacity: 0.85;
    transition: transform 600ms var(--ease-out), opacity 600ms var(--ease-out);
  }

  .card-3d svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sector-card:hover .card-3d {
    opacity: 1;
  }

  /* B-14 fix · per-sector unique icon micro-animation on hover */
  .sector-card[data-sector="legal"]:hover .card-3d svg {
    animation: gavel-strike 800ms ease-in-out;
  }
  @keyframes gavel-strike {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-18deg) translate(-3px, -3px); }
    55% { transform: rotate(8deg) translate(2px, 1px); }
    75% { transform: rotate(-3deg); }
  }

  .sector-card[data-sector="healthcare"]:hover .card-3d svg {
    animation: caduceus-pulse 1500ms ease-in-out infinite;
  }
  @keyframes caduceus-pulse {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 0 transparent); }
    50% { transform: scale(1.06); filter: drop-shadow(0 0 8px rgba(201,167,114,0.6)); }
  }

  .sector-card[data-sector="hospitality"]:hover .card-3d svg {
    animation: bell-ring 600ms ease-in-out 2;
  }
  @keyframes bell-ring {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-12deg); }
    75% { transform: rotate(12deg); }
  }

  .sector-card[data-sector="real-estate"]:hover .card-3d svg {
    animation: bell-ticker 1200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes bell-ticker {
    0% { transform: scale(1) translateY(0); }
    30% { transform: scale(1.1) translateY(-3px); }
    60% { transform: scale(0.97) translateY(2px); }
    100% { transform: scale(1) translateY(0); }
  }

  .sector-card[data-sector="fb"]:hover .card-3d svg {
    animation: cloche-lift 1000ms ease-in-out;
    transform-origin: center bottom;
  }
  @keyframes cloche-lift {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-8px); }
    70% { transform: translateY(-2px); }
  }

  .sector-card[data-sector="every-sector"]:hover .card-3d svg {
    animation: compass-rotate 2000ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes compass-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .card-eyebrow {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-top: 48px;
    margin-bottom: 16px;
    max-width: 60%;
  }

  .card-headline {
    font-family: var(--ff-display);
    font-weight: 500;
    color: var(--ivory);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    max-width: 85%;
  }

  .sector-large .card-headline { font-size: 32px; }
  .sector-standard .card-headline { font-size: 24px; }
  .sector-medium .card-headline { font-size: 22px; }

  .card-shorthand {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .card-body {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--pearl);
    opacity: 0.92;
    margin-bottom: 20px;
    flex: 1;
    /* B-01 fix · removed line-clamp so full body text shows */
    font-weight: 300;
  }

  .card-cta {
    /* B-06 fix · orange CTA per Aman directive · Round-7 contrast fix · ivory on accent-orange was 3.45:1, on accent-orange-deep is 4.81:1 (passes 4.5:1) */
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ivory);
    background: var(--accent-orange-deep);
    text-decoration: none;
    padding: 12px 16px;
    /* Round-8 fix · 44px min touch target on mobile */
    min-height: 44px;
    border-radius: 4px;
    border: 1px solid var(--accent-orange-deep);
    align-self: flex-start;
    transition: background 240ms ease, transform 240ms ease, box-shadow 240ms ease;
    margin-top: auto;
  }

  .card-cta:hover {
    /* Round-7 fix · use even deeper orange on hover for clear state change */
    background: #7A3E18;
    transform: translateX(2px);
    box-shadow: 0 0 18px rgba(168, 88, 32, 0.4);
  }

  /* Tooltip */
  .card-tooltip {
    position: absolute;
    bottom: 100%;
    right: 0;
    /* Round-13 fix · grow with content at 200% text zoom (was fixed width 280px which clipped) */
    min-width: 280px;
    max-width: min(380px, 90vw);
    width: max-content;
    overflow: visible;
    background: var(--ivory);
    color: var(--ink);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--gold);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 300ms ease, transform 300ms ease;
    z-index: 10;
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.3);
    /* Round-8 fix · also reveal on focus-within for keyboard users */
    visibility: hidden;
  }

  .sector-card:hover .card-tooltip,
  .sector-card:focus-within .card-tooltip {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  /* Round-8 fix · tooltip is hover-only and unreachable on touch devices · hide entirely on mobile */
  @media (max-width: 768px), (hover: none) {
    .card-tooltip { display: none; }
  }

  .tooltip-header {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--gold-hairline);
  }

  .card-tooltip ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card-tooltip li {
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--ink-muted);
    padding: 2px 0;
    letter-spacing: 0.02em;
  }

  .card-tooltip li::before {
    content: '·';
    color: var(--gold);
    margin-right: 6px;
  }

  /* Closing line */
  .closing-line-wrap {
    text-align: center;
    margin-top: clamp(64px, 8vw, 96px);
  }

  .closing-hairline {
    height: 1px;
    background: var(--gold);
    width: 40%;
    max-width: 400px;
    margin: 0 auto 32px;
    opacity: 0.5;
  }

  .closing-line {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--pearl);
    opacity: 0.7;
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .sector-large { grid-column: span 6; grid-row: span 2; }
    .sector-standard { grid-column: span 6; grid-row: span 1; }
    .sector-medium { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .sector-large, .sector-standard, .sector-medium {
      grid-column: span 1;
      grid-row: auto;
    }
    .card-3d {
      width: 80px;
      height: 80px;
    }
    .card-eyebrow { margin-top: 24px; max-width: 100%; }
    .sector-large .card-headline { font-size: 24px; }
    .sector-standard .card-headline { font-size: 20px; }
    .sector-medium .card-headline { font-size: 20px; }
    /* B-25 fix · tap-to-toggle tooltip on mobile */
    .card-tooltip {
      display: block;
      position: static;
      width: 100%;
      margin-top: 12px;
      max-height: 0;
      padding-block: 0;
      opacity: 0;
      transform: none;
      overflow: hidden;
      transition: max-height 280ms ease, opacity 280ms ease, padding-block 280ms ease;
    }
    .sector-card.tooltip-open .card-tooltip {
      max-height: 600px;
      opacity: 1;
      padding-block: 16px;
    }
  }
</style>

<script>
  // Sequential fade-in reveal on scroll-into-view
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      document.querySelectorAll('.sector-card').forEach((c) => c.classList.add('in-view'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, idx) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        setTimeout(() => el.classList.add('in-view'), idx * 100);
        observer.unobserve(el);
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.sector-card').forEach((c, i) => {
      (c as HTMLElement).style.transitionDelay = `${i * 80}ms`;
      observer.observe(c);
    });

    /* Round-10 safety fallback · if observer hasn't fired within 3s (e.g. user lands deep-linked
       below the section), reveal all cards anyway so content never stays invisible to a real visitor */
    setTimeout(() => {
      document.querySelectorAll('.sector-card:not(.in-view)').forEach(c => c.classList.add('in-view'));
    }, 3000);

    /* B-25 · sector card tap-to-toggle tooltip on touch devices */
    const isTouch = window.matchMedia('(hover: none)').matches || ('ontouchstart' in window);
    if (isTouch) {
      document.querySelectorAll('.sector-card').forEach((card) => {
        card.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a,button')) return;
          card.classList.toggle('tooltip-open');
        });
      });
    }
  });
</script>
