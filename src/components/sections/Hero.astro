---
import { heroContent, parseEmph } from '../../content/hero';

const {
  eyebrow,
  subHeadline,
  pullQuote,
  h1,
  authorFrame,
  cta,
  regulationFrameworks,
  goldHighlightedFrameworks,
  ribbonLabel,
  tickerItems,
  signature,
} = heroContent;

// Duplicate ribbon entries for seamless loop
const ribbonDouble = [...regulationFrameworks, ...regulationFrameworks];
// Duplicate ticker for seamless loop
const tickerDouble = [...tickerItems, ...tickerItems];
---
<section class="hero" id="main" aria-labelledby="hero-h1">
  <!-- Monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <!-- Ribbon label (rotated) -->
  <div class="ribbon-label" aria-hidden="true">{ribbonLabel}</div>

  <!-- Regulation ribbon -->
  <div class="regulation-ribbon" aria-hidden="true">
    <div class="ribbon-column">
      {ribbonDouble.map(reg => (
        <span class={goldHighlightedFrameworks.includes(reg) ? 'gold' : ''}>{reg}</span>
      ))}
    </div>
  </div>

  <!-- Right margin hairline -->
  <div class="margin-rule" aria-hidden="true"></div>

  <!-- Main content -->
  <div class="hero-content">
    <div class="eyebrow">{eyebrow}</div>

    <p class="sub-headline" set:html={parseEmph(subHeadline)} />

    <div class="fleuron" aria-hidden="true">
      <div class="fleuron-rule"></div>
      <span class="fleuron-mark">&#10086;</span>
      <div class="fleuron-rule"></div>
    </div>

    <blockquote class="pull-quote" set:html={parseEmph(pullQuote)} />

    <div class="h1-divider" aria-hidden="true"></div>

    <h1 class="hero-h1" id="hero-h1">
      {h1.map((row) => (
        <div class="h1-row">
          <span class="numeral">{row.numeral}</span>
          <div class="line-wrap">
            <span class="line" data-text={row.text}></span>
            <span class="margin-note">{row.marginNote}</span>
          </div>
        </div>
      ))}
    </h1>

    <!-- Framed author card (pre-headline moved here) -->
    <div class="author-frame">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>

      <div class="author-eyebrow">
        <span class="roman">{authorFrame.numeral}</span>
        <span>{authorFrame.label}</span>
        <span class="rule"></span>
      </div>

      <div class="author-title">{authorFrame.title}</div>

      <p class="author-text" set:html={parseEmph(authorFrame.body)} />

      <div class="author-credentials">
        {authorFrame.credentials.map((c, i) => (
          <>
            {i > 0 && <span class="sep">·</span>}
            {c}
          </>
        ))}
      </div>
    </div>

    <a class="primary-cta" href={cta.href}>
      <span>{cta.label}</span>
      <span class="cta-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>

  <!-- Signature -->
  <div class="signature-wrap" aria-label="Founder's signature">
    <div class="vetted-by">{signature.vettedBy}</div>
    <div class="signature">{signature.name}</div>
    <div class="signature-flourish" aria-hidden="true">
      <svg width="180" height="22" viewBox="0 0 180 22">
        <path
          d="M 2 10 C 20 4, 40 18, 60 12 C 80 6, 100 16, 130 10 C 150 6, 165 14, 178 10"
          stroke="#C9A772"
          stroke-width="1"
          fill="none"
          stroke-linecap="round"
          style="stroke-dasharray: 220; stroke-dashoffset: 220; animation: flourish-draw 1400ms cubic-bezier(0.2, 0.8, 0.2, 1) 7900ms forwards;"
        />
      </svg>
    </div>
    <div class="signature-caption">
      {signature.caption.map((c, i) => (
        <>
          {i > 0 && <span class="sep">·</span>}
          {c}
        </>
      ))}
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <div class="scroll-track">
      <div class="scroll-diamond"></div>
    </div>
    <span>Continue</span>
  </div>

  <!-- Verified ticker -->
  <div class="verified-ticker" aria-label="Verified client case data">
    <div class="ticker-inner">
      {tickerDouble.map((item, i) => (
        <>
          <span>{item}</span>
          <span class="ornament">&#10030;</span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 112px);
    background: var(--ivory);
    overflow: hidden;
    padding: 56px 80px 120px;
    display: flex;
    align-items: flex-start;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 40% at 50% 0%, rgba(201, 167, 114, 0.1) 0%, transparent 65%),
      radial-gradient(ellipse 60% 30% at 50% 100%, rgba(90, 26, 43, 0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    animation: vignette-in 2500ms var(--ease-out) forwards;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.035;
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 2;
  }

  .margin-rule {
    position: absolute;
    right: 56px;
    top: 80px;
    bottom: 80px;
    width: 1px;
    background: var(--oxblood-hairline);
    z-index: 3;
    pointer-events: none;
  }

  .regulation-ribbon {
    position: absolute;
    right: 4%;
    top: 0;
    bottom: 0;
    width: 280px;
    overflow: hidden;
    pointer-events: none;
    z-index: 3;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 88%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 88%, transparent 100%);
  }

  .ribbon-label {
    position: absolute;
    top: 100px;
    right: 4px;
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--oxblood);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    opacity: 0;
    animation: fade-in-up 800ms ease 1000ms forwards;
    font-weight: 500;
    z-index: 4;
  }

  .ribbon-column {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 18px;
    animation: ribbon-vertical 110s linear infinite;
    font-family: var(--ff-display);
    font-size: 15px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--oxblood);
    opacity: 0.5;
    text-align: right;
    font-weight: 500;
    padding-right: 16px;
  }

  .ribbon-column span { white-space: nowrap; display: block; }
  .ribbon-column span.gold {
    color: var(--gold);
    font-style: italic;
    font-weight: 400;
    opacity: 0.75;
    font-size: 13px;
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: 680px;
    font-weight: 400;
    color: var(--oxblood);
    line-height: 1;
    opacity: 0.025;
    animation: monogram-breath 8s ease-in-out infinite;
    letter-spacing: -0.04em;
  }

  .hero-content {
    position: relative;
    z-index: 4;
    max-width: 900px;
    width: 62%;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    opacity: 0;
    animation: fade-in-up 800ms var(--ease-out) 400ms forwards;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .sub-headline {
    margin-top: 18px;
    font-family: var(--ff-display);
    font-size: clamp(22px, 1.8vw + 0.5rem, 28px);
    line-height: 1.3;
    color: var(--ink);
    font-weight: 400;
    max-width: 720px;
    letter-spacing: -0.005em;
    font-feature-settings: "kern", "liga", "dlig";
    opacity: 0;
    animation: fade-in-up 1000ms var(--ease-out) 600ms forwards;
  }

  .sub-headline :global(.emph),
  .pull-quote :global(.emph) {
    color: var(--oxblood);
    font-weight: 500;
    font-style: italic;
  }

  .fleuron {
    margin: 20px 0;
    display: flex;
    align-items: center;
    gap: 16px;
    opacity: 0;
    animation: fade-in-up 800ms var(--ease-out) 1000ms forwards;
  }

  .fleuron-rule {
    height: 1px;
    background: var(--gold);
    opacity: 0.45;
    flex: 0 0 80px;
  }

  .fleuron-mark {
    font-size: 16px;
    color: var(--gold);
    line-height: 1;
    font-family: var(--ff-display);
    animation: fleuron-rotate 14s linear infinite;
    display: inline-block;
  }

  .pull-quote {
    position: relative;
    padding: 4px 44px;
    max-width: 720px;
    font-family: var(--ff-display);
    font-size: clamp(18px, 1.4vw + 0.3rem, 21px);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.35;
    letter-spacing: 0.003em;
    opacity: 0;
    animation: fade-in-up 1000ms var(--ease-out) 1300ms forwards;
  }

  .pull-quote::before {
    content: '\201C';
    position: absolute;
    top: -22px;
    left: -2px;
    font-family: var(--ff-display);
    font-size: 72px;
    font-style: normal;
    color: var(--gold);
    line-height: 1;
    opacity: 0.7;
  }

  .pull-quote::after {
    content: '\201D';
    position: absolute;
    bottom: -52px;
    right: 20px;
    font-family: var(--ff-display);
    font-size: 72px;
    font-style: normal;
    color: var(--gold);
    line-height: 1;
    opacity: 0.7;
  }

  .h1-divider {
    margin: 28px 0 20px;
    height: 1px;
    background: linear-gradient(to right, transparent 0%, var(--gold) 20%, var(--gold) 80%, transparent 100%);
    opacity: 0;
    max-width: 520px;
    animation: hairline-draw 900ms var(--ease-out) 1800ms forwards;
    transform-origin: left center;
    transform: scaleX(0);
  }

  .hero-h1 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(48px, 5.2vw + 0.5rem, 90px);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--ink);
    font-feature-settings: "kern", "liga", "dlig", "lnum", "swsh";
  }

  .h1-row {
    display: flex;
    align-items: baseline;
    gap: 32px;
    position: relative;
    padding-bottom: 8px;
    margin-bottom: 0;
  }

  .numeral {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 18px;
    font-weight: 400;
    color: var(--oxblood);
    flex-shrink: 0;
    width: 36px;
    text-align: right;
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 600ms var(--ease-out), transform 600ms var(--ease-out);
    line-height: 1;
    align-self: flex-end;
    padding-bottom: 22px;
    letter-spacing: 0.02em;
  }

  .numeral.visible {
    opacity: 0.9;
    transform: translateX(0);
  }

  .line-wrap {
    flex: 1;
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 40px;
    flex-wrap: wrap;
  }

  .line {
    display: inline-block;
    position: relative;
    white-space: nowrap;
  }

  .line :global(.emph) {
    color: var(--oxblood);
    font-style: italic;
    font-weight: 500;
  }

  .line.typing::after {
    content: '';
    display: inline-block;
    width: 2px;
    height: 0.9em;
    background: var(--oxblood);
    margin-left: 4px;
    vertical-align: -0.1em;
    animation: blink 0.6s infinite;
  }

  .h1-row::after {
    content: '';
    position: absolute;
    left: 68px;
    right: 0;
    bottom: 0;
    height: 1px;
    background: var(--oxblood);
    opacity: 0.18;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 900ms var(--ease-out);
  }

  .h1-row.complete::after { transform: scaleX(1); }

  .margin-note {
    font-family: var(--ff-body);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--oxblood);
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 700ms var(--ease-out), transform 700ms var(--ease-out);
    white-space: nowrap;
    flex-shrink: 0;
    align-self: flex-end;
    padding-bottom: 24px;
    position: relative;
    padding-left: 20px;
  }

  .margin-note::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 12px;
    height: 1px;
    background: var(--oxblood);
    opacity: 0.6;
  }

  .margin-note.visible {
    opacity: 0.85;
    transform: translateX(0);
  }

  /* Author frame */
  .author-frame {
    position: relative;
    margin-top: 40px;
    max-width: 680px;
    padding: 32px 40px;
    border: 1px solid var(--gold);
    background: rgba(201, 167, 114, 0.04);
    opacity: 0;
    animation: fade-in-up 1200ms var(--ease-out) 4600ms forwards;
  }

  .author-frame::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(201, 167, 114, 0.35);
    pointer-events: none;
  }

  .corner {
    position: absolute;
    width: 10px;
    height: 10px;
    transform: rotate(45deg);
    background: var(--ivory);
    border: 1px solid var(--gold);
  }
  .corner.tl { top: -6px; left: -6px; }
  .corner.tr { top: -6px; right: -6px; }
  .corner.bl { bottom: -6px; left: -6px; }
  .corner.br { bottom: -6px; right: -6px; }

  .author-eyebrow {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .author-eyebrow .roman {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--oxblood);
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .author-eyebrow .rule {
    flex: 1;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
    max-width: 80px;
  }

  .author-title {
    font-family: var(--ff-display);
    font-size: 26px;
    font-style: italic;
    font-weight: 500;
    color: var(--oxblood);
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.005em;
  }

  .author-text {
    font-family: var(--ff-display);
    font-size: 17px;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.65;
    max-width: 580px;
    letter-spacing: 0.002em;
  }

  .author-text :global(.emph) {
    color: var(--oxblood);
    font-weight: 500;
    font-style: italic;
  }

  .author-credentials {
    margin-top: 20px;
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .author-credentials .sep { margin: 0 8px; opacity: 0.6; }

  /* Primary CTA */
  .primary-cta {
    margin-top: 36px;
    background: var(--oxblood);
    color: var(--ivory);
    border: 1px solid var(--gold);
    height: 66px;
    padding: 0 40px;
    min-width: 360px;
    font-family: var(--ff-display);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.06em;
    cursor: pointer;
    opacity: 0;
    animation: fade-in-up 900ms var(--ease-out) 5500ms forwards;
    transition: transform var(--duration-short) var(--ease-out), background var(--duration-short) ease, border-color var(--duration-short) ease, box-shadow var(--duration-short) ease, letter-spacing var(--duration-short) ease;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
  }

  .primary-cta .cta-arrow {
    display: inline-block;
    transition: transform var(--duration-short) var(--ease-out);
    color: var(--gold);
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: 20px;
  }

  .primary-cta:hover {
    background: var(--oxblood-warm);
    border-color: var(--gold-warm);
    box-shadow: 0 0 32px rgba(201, 167, 114, 0.25);
    letter-spacing: 0.08em;
  }

  .primary-cta:hover .cta-arrow {
    transform: translateX(6px);
    color: var(--gold-warm);
  }

  /* Ticker */
  .verified-ticker {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 52px;
    background: var(--obsidian);
    border-top: 1px solid var(--gold);
    overflow: hidden;
    display: flex;
    align-items: center;
    z-index: 6;
  }

  .ticker-inner {
    display: flex;
    gap: 56px;
    white-space: nowrap;
    animation: marquee-horizontal 70s linear infinite;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    padding-left: 80px;
    font-weight: 500;
  }

  .ticker-inner span { flex-shrink: 0; }
  .ticker-inner .ornament { color: var(--gold); opacity: 0.5; font-size: 10px; font-family: var(--ff-display); }

  /* Signature */
  .signature-wrap {
    position: absolute;
    right: 80px;
    bottom: 96px;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  .signature-wrap::before {
    content: '';
    display: block;
    width: 64px;
    height: 1px;
    background: var(--gold);
    opacity: 0;
    margin-bottom: 12px;
    align-self: flex-end;
    animation: line-draw 700ms var(--ease-out) 5800ms forwards;
  }

  .vetted-by {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--oxblood);
    margin-bottom: 8px;
    opacity: 0;
    animation: fade-in-up 600ms var(--ease-out) 6000ms forwards;
    font-weight: 400;
  }

  .signature {
    font-family: var(--ff-signature);
    font-size: 72px;
    color: var(--oxblood);
    line-height: 0.9;
    clip-path: inset(0 100% 0 0);
    animation: signature-draw 1800ms cubic-bezier(0.3, 0.7, 0.3, 1) 6200ms forwards;
    letter-spacing: 0.01em;
    padding-right: 8px;
    padding-bottom: 4px;
  }

  .signature-flourish {
    margin-top: -4px;
    margin-right: 20px;
    align-self: flex-end;
  }

  .signature-flourish svg { display: block; overflow: visible; }

  .signature-caption {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--oxblood);
    opacity: 0;
    margin-top: 10px;
    animation: fade-in-up 600ms var(--ease-out) 8200ms forwards;
    font-weight: 500;
  }

  .signature-caption .sep { margin: 0 6px; opacity: 0.5; color: var(--gold); }

  /* Scroll cue */
  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 100px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    z-index: 5;
    opacity: 0;
    animation: fade-in-up 1000ms var(--ease-out) 6500ms forwards;
  }

  .scroll-track {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent 0%, var(--oxblood) 30%, var(--oxblood) 70%, transparent 100%);
    opacity: 0.45;
    position: relative;
    overflow: hidden;
  }

  .scroll-diamond {
    position: absolute;
    left: 50%;
    top: 0;
    width: 5px;
    height: 5px;
    background: var(--oxblood);
    transform: translateX(-50%) rotate(45deg);
    animation: diamond-travel 3s ease-in-out infinite;
  }

  .scroll-cue span {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--oxblood);
    opacity: 0.7;
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 1280px) {
    .hero { padding: 48px 48px 120px; }
    .regulation-ribbon { right: 2%; width: 220px; }
    .signature-wrap { right: 48px; }
    .margin-rule { right: 28px; }
  }

  @media (max-width: 1024px) {
    .hero { padding: 40px 32px 140px; flex-direction: column; }
    .hero-content { width: 100%; }
    .h1-row { flex-direction: column; gap: 8px; align-items: flex-start; }
    .h1-row::after { display: none; }
    .line-wrap { flex-direction: column; gap: 8px; align-items: flex-start; }
    .margin-note { padding-bottom: 0; margin-bottom: 8px; align-self: flex-start; }
    .numeral { padding-bottom: 0; align-self: flex-start; width: auto; text-align: left; }
    .regulation-ribbon { right: 0; width: 160px; opacity: 0.6; }
    .signature-wrap { right: 32px; bottom: 96px; }
    .scroll-cue { display: none; }
    .margin-rule { display: none; }
    .primary-cta { min-width: 0; width: 100%; max-width: 420px; }
    .ribbon-label { display: none; }
  }

  @media (max-width: 640px) {
    .hero { padding: 32px 24px 120px; }
    .sub-headline { font-size: 19px; }
    .hero-h1 { font-size: 38px; }
    .pull-quote { font-size: 17px; padding: 12px 30px; }
    .pull-quote::before { font-size: 54px; top: -12px; }
    .pull-quote::after { font-size: 54px; bottom: -40px; }
    .primary-cta { font-size: 14px; height: 58px; padding: 0 24px; }
    .signature { font-size: 54px; }
    .signature-wrap { bottom: 84px; right: 24px; }
    .regulation-ribbon { display: none; }
    .monogram-t { font-size: 380px; }
    .eyebrow { font-size: 10px; padding-left: 32px; }
    .fleuron-rule { flex: 0 0 40px; }
    .author-frame { padding: 24px 20px; }
    .author-title { font-size: 20px; }
    .author-text { font-size: 15px; }
  }
</style>

<script>
  // Typewriter for H1 lines
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      document.querySelectorAll<HTMLElement>('.line').forEach(line => {
        line.innerHTML = parseEmph(line.dataset.text || '');
      });
      document.querySelectorAll('.margin-note, .numeral').forEach(el => el.classList.add('visible'));
      document.querySelectorAll('.h1-row').forEach(row => row.classList.add('complete'));
      return;
    }

    const rows = document.querySelectorAll<HTMLElement>('.h1-row');
    let cumulativeDelay = 2100;

    rows.forEach(row => {
      const numeral = row.querySelector('.numeral');
      const line = row.querySelector<HTMLElement>('.line');
      if (!line || !numeral) return;
      const text = line.dataset.text || '';
      const plainLength = text.replace(/\{\{|\}\}/g, '').length;
      const speed = 42;

      setTimeout(() => numeral.classList.add('visible'), cumulativeDelay - 200);
      setTimeout(() => typeText(line, text, speed), cumulativeDelay);

      const completeTime = cumulativeDelay + plainLength * speed + 100;
      setTimeout(() => row.classList.add('complete'), completeTime);

      cumulativeDelay += plainLength * speed + 300;
    });

    // Margin note staggered reveal
    const noteDelays = [3400, 4000, 4500];
    document.querySelectorAll<HTMLElement>('.margin-note').forEach((note, i) => {
      setTimeout(() => note.classList.add('visible'), noteDelays[i] || 3500);
    });
  });

  function parseEmph(text: string): string {
    return text.replace(/\{\{([^}]+)\}\}/g, '<span class="emph">$1</span>');
  }

  function typeText(el: HTMLElement, text: string, speed: number) {
    el.classList.add('typing');
    const segments: { text: string; emph: boolean }[] = [];
    let remaining = text;
    while (remaining.length > 0) {
      const start = remaining.indexOf('{{');
      if (start === -1) {
        segments.push({ text: remaining, emph: false });
        break;
      }
      if (start > 0) segments.push({ text: remaining.substring(0, start), emph: false });
      const end = remaining.indexOf('}}', start);
      segments.push({ text: remaining.substring(start + 2, end), emph: true });
      remaining = remaining.substring(end + 2);
    }

    let segIdx = 0;
    let charIdx = 0;
    const interval = setInterval(() => {
      if (segIdx >= segments.length) {
        clearInterval(interval);
        el.classList.remove('typing');
        return;
      }
      const seg = segments[segIdx];
      charIdx++;
      let html = '';
      for (let j = 0; j < segIdx; j++) {
        const s = segments[j];
        html += s.emph ? `<span class="emph">${s.text}</span>` : s.text;
      }
      const partial = seg.text.substring(0, charIdx);
      html += seg.emph ? `<span class="emph">${partial}</span>` : partial;
      el.innerHTML = html;
      if (charIdx >= seg.text.length) {
        segIdx++;
        charIdx = 0;
      }
    }, speed);
  }
</script>
