---
import { sectorsContent } from '../../content/sectors';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, subline, sectors, closingLine } = sectorsContent;

// SVG icon map for each sector. Inner classes drive per-sector hover animations.
const iconPaths: Record<string, string> = {
  // Legal · Scales of Justice with balance-teeter
  gavel: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="13" r="2" fill="currentColor"/>
    <line x1="50" y1="15" x2="50" y2="78" stroke-width="2"/>
    <g class="scales-beam">
      <line x1="20" y1="30" x2="80" y2="30" stroke-width="1.8"/>
      <line x1="22" y1="30" x2="22" y2="48"/>
      <line x1="78" y1="30" x2="78" y2="48"/>
      <ellipse cx="22" cy="50" rx="10" ry="2.4" fill="rgba(0,0,0,0)"/>
      <path d="M 12 50 Q 22 58 32 50"/>
      <ellipse cx="78" cy="50" rx="10" ry="2.4" fill="rgba(0,0,0,0)"/>
      <path d="M 68 50 Q 78 58 88 50"/>
    </g>
    <path d="M 38 78 L 50 68 L 62 78 Z"/>
    <line x1="32" y1="82" x2="68" y2="82" stroke-width="1.8"/>
  </g>`,
  // Healthcare · Stethoscope with ECG pulse trace
  caduceus: `<g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="26" cy="14" r="2.5" fill="currentColor"/>
    <circle cx="74" cy="14" r="2.5" fill="currentColor"/>
    <path d="M 26 16 Q 26 38 38 50 Q 48 60 50 65"/>
    <path d="M 74 16 Q 74 38 62 50 Q 52 60 50 65"/>
    <circle cx="50" cy="78" r="13" stroke-width="1.6"/>
    <circle cx="50" cy="78" r="9" stroke-width="0.9" opacity="0.6"/>
    <g class="ecg-line">
      <path d="M 39 78 L 44 78 L 46 72 L 48 84 L 50 70 L 52 84 L 54 78 L 61 78" stroke-width="1.4"/>
    </g>
  </g>`,
  // Hospitality · Champagne flute with rising bubbles (luxury)
  bell: `<g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 39 14 L 39 24 Q 39 50 50 56 Q 61 50 61 24 L 61 14 Z"/>
    <ellipse cx="50" cy="14" rx="11" ry="1.8" stroke-width="1.2"/>
    <line x1="41" y1="38" x2="59" y2="38" stroke-width="0.8" opacity="0.55"/>
    <line x1="50" y1="56" x2="50" y2="82" stroke-width="1.5"/>
    <ellipse cx="50" cy="84" rx="13" ry="2.4" stroke-width="1.4"/>
    <g class="bubbles">
      <circle class="bubble b1" cx="46" cy="50" r="1.2" fill="currentColor"/>
      <circle class="bubble b2" cx="50" cy="48" r="1.4" fill="currentColor"/>
      <circle class="bubble b3" cx="54" cy="52" r="1.0" fill="currentColor"/>
      <circle class="bubble b4" cx="48" cy="54" r="1.3" fill="currentColor"/>
      <circle class="bubble b5" cx="52" cy="46" r="0.9" fill="currentColor"/>
    </g>
  </g>`,
  // Real Estate / IPO · Skyline with sequential window-light animation
  'opening-bell': `<g fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <line x1="10" y1="86" x2="90" y2="86" stroke-width="1.2"/>
    <rect x="12" y="50" width="14" height="36" stroke-width="1.4"/>
    <rect x="28" y="38" width="14" height="48" stroke-width="1.4"/>
    <rect x="44" y="26" width="14" height="60" stroke-width="1.5"/>
    <line x1="51" y1="26" x2="51" y2="17" stroke-width="0.9"/>
    <circle cx="51" cy="15" r="1.4" fill="currentColor"/>
    <rect x="60" y="44" width="14" height="42" stroke-width="1.4"/>
    <rect x="76" y="56" width="12" height="30" stroke-width="1.4"/>
    <g class="windows">
      <rect class="window w1" x="15.5" y="55" width="3" height="3"/>
      <rect class="window w2" x="20" y="63" width="3" height="3"/>
      <rect class="window w3" x="31" y="44" width="3" height="3"/>
      <rect class="window w4" x="36" y="54" width="3" height="3"/>
      <rect class="window w5" x="47" y="34" width="3" height="3"/>
      <rect class="window w6" x="52" y="44" width="3" height="3"/>
      <rect class="window w7" x="47" y="56" width="3" height="3"/>
      <rect class="window w8" x="63" y="50" width="3" height="3"/>
      <rect class="window w9" x="68" y="62" width="3" height="3"/>
      <rect class="window w10" x="79" y="62" width="3" height="3"/>
    </g>
  </g>`,
  // F&B · Cocktail glass with olive-on-toothpick swirl
  cloche: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="50" cy="22" rx="22" ry="3" stroke-width="1.4"/>
    <path d="M 28 22 L 50 56 L 72 22"/>
    <line x1="36" y1="32" x2="64" y2="32" stroke-width="0.8" opacity="0.55"/>
    <line x1="50" y1="56" x2="50" y2="82" stroke-width="1.5"/>
    <ellipse cx="50" cy="84" rx="12" ry="2.4" stroke-width="1.4"/>
    <g class="olive-stir">
      <line x1="48" y1="20" x2="56" y2="38" stroke-width="0.9"/>
      <circle cx="56" cy="40" r="3" fill="currentColor"/>
    </g>
  </g>`,
  // Every Sector · compass with full-rotation animation
  compass: `<g class="compass-body" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="50" r="32"/>
    <circle cx="50" cy="50" r="26"/>
    <path d="M 50 20 L 54 50 L 50 80 L 46 50 Z" fill="currentColor"/>
    <path d="M 20 50 L 50 46 L 80 50 L 50 54 Z"/>
    <circle cx="50" cy="50" r="2" fill="currentColor"/>
    <line x1="50" y1="14" x2="50" y2="20"/>
    <line x1="50" y1="80" x2="50" y2="86"/>
    <line x1="14" y1="50" x2="20" y2="50"/>
    <line x1="80" y1="50" x2="86" y2="50"/>
  </g>`,
};
---
<section class="sectors" id="sectors" aria-labelledby="sectors-heading">
  <!-- Monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="sectors-heading" class="section-h2" set:html={parseEmph(h2)} />
      <p class="subline">{subline}</p>
    </div>

    {/* Round-12 fix · drop role="list"/"listitem" pair on bento-grid + sector article.
        axe-allowed-role disallows role="listitem" on <article>. Sector cards are
        standalone content blocks (article landmarks); they don't need list semantics. */}
    <div class="bento-grid">
      {sectors.map((sector) => (
        <article
          class={`sector-card sector-${sector.size}`}
          data-sector={sector.id}
        >
          <div class="card-inner">
            <span class="card-numeral">{sector.numeral}</span>

            <div class="card-3d" aria-hidden="true">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <Fragment set:html={iconPaths[sector.icon]} />
              </svg>
            </div>

            <div class="card-eyebrow">SECTOR {sector.index} / VI</div>
            <h3 class="card-headline">{sector.headline}</h3>
            <div class="card-shorthand">{sector.regulatoryShorthand}</div>
            <p class="card-body">{sector.body}</p>
            {sector.pullQuote && <blockquote class="card-pullquote">{sector.pullQuote}</blockquote>}
            <a href="#contact" class="card-cta">{sector.cta} <span class="cta-arrow">↗</span></a>

            <!-- Tooltip regulation detail (appears on hover) -->
            <div class="card-tooltip" aria-hidden="true">
              <div class="tooltip-header">Specific frameworks applied</div>
              <ul>
                {sector.tooltip.map((t) => <li>{t}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="closing-line-wrap">
      <div class="closing-hairline" aria-hidden="true"></div>
      <p class="closing-line">{closingLine}</p>
    </div>
  </div>
</section>

<style>
  .sectors {
    position: relative;
    background: var(--obsidian);
    padding-block: var(--section-padding-block);
    overflow: hidden;
    color: var(--ivory);
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: clamp(280px, 45vw, 680px);
    color: var(--gold);
    line-height: 1;
    opacity: 0.025;
    letter-spacing: -0.04em;
    animation: monogram-breath 8s ease-in-out infinite;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    position: relative;
    z-index: 2;
  }

  .header-block {
    max-width: 720px;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--eyebrow-light, #6B5058);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--gold);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: var(--ls-h2);
    color: var(--ivory);
    margin-bottom: 24px;
  }

  .section-h2 :global(.emph) {
    color: var(--gold);
    font-style: italic;
    font-weight: 500;
  }

  .subline {
    font-family: var(--ff-display);
    font-size: 17px;
    font-style: italic;
    color: var(--pearl);
    opacity: 0.75;
    line-height: 1.5;
    max-width: 520px;
  }

  /* Bento grid: 12-column equal layout (B-03 fix) */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: auto;
    gap: 24px;
    align-items: stretch;
  }

  .sector-card {
    container-type: inline-size;
    position: relative;
    background: var(--obsidian-deep);
    border: 1px solid rgba(201, 167, 114, 0.3);
    border-radius: 16px;
    padding: 32px 32px 36px;
    overflow: visible; /* B-03: allow content to flow naturally */
    min-width: 0;
    height: 100%;
    transition: transform 400ms var(--ease-out),
                border-color 400ms var(--ease-out),
                box-shadow 400ms var(--ease-out);
    opacity: 0;
    transform: translateY(20px);
  }

  .sector-card.in-view {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 700ms var(--ease-out), transform 700ms var(--ease-out),
                border-color 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }

  /* All sectors equal weight (Aman directive: no dominant card) */
  .sector-large    { grid-column: span 4; grid-row: span 1; }
  .sector-standard { grid-column: span 4; grid-row: span 1; }
  .sector-medium   { grid-column: span 4; grid-row: span 1; }

  /* Per-card pull quote (6th unique element per sector card) */
  .card-pullquote {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--gold);
    border-left: 2px solid var(--gold);
    padding-left: 14px;
    margin: 16px 0;
  }

  .sector-card:hover {
    transform: translateY(-8px);
    border-color: var(--gold);
    box-shadow: 0 30px 60px -30px rgba(201, 167, 114, 0.3);
  }

  .card-inner {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow: visible;
  }
  .card-cta {
    margin-top: auto;
    padding-top: 16px;
  }

  .card-numeral {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
    opacity: 0.9;
    letter-spacing: 0.02em;
  }

  .card-3d {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 88px;
    height: 88px;
    color: var(--gold);
    opacity: 0.92;
    transition: transform 600ms var(--ease-out), opacity 600ms var(--ease-out);
    pointer-events: none;
  }

  .card-3d svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sector-card:hover .card-3d {
    opacity: 1;
  }

  

  .card-eyebrow {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-top: 32px;
    margin-bottom: 16px;
    padding-right: 96px;
  }

  .card-headline {
    font-family: var(--ff-display);
    font-weight: 500;
    color: var(--ivory);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    padding-right: 96px;
  }

  .sector-large .card-headline { font-size: 32px; }
  .sector-standard .card-headline { font-size: 24px; }
  .sector-medium .card-headline { font-size: 22px; }

  .card-shorthand {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .card-body {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--pearl);
    opacity: 0.92;
    margin-bottom: 20px;
    flex: 1;
    /* B-01 fix · removed line-clamp so full body text shows */
    font-weight: 300;
  }

  .card-cta {
    /* B-06 fix · orange CTA per Aman directive · Round-7 contrast fix · ivory on accent-orange was 3.45:1, on accent-orange-deep is 4.81:1 (passes 4.5:1) */
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ivory);
    background: var(--accent-orange-deep);
    text-decoration: none;
    padding: 12px 16px;
    /* Round-8 fix · 44px min touch target on mobile */
    min-height: 44px;
    border-radius: 4px;
    border: 1px solid var(--accent-orange-deep);
    align-self: flex-start;
    transition: background 240ms ease, transform 240ms ease, box-shadow 240ms ease;
    margin-top: auto;
  }

  .card-cta:hover {
    /* Round-7 fix · use even deeper orange on hover for clear state change */
    background: #7A3E18;
    transform: translateX(2px);
    box-shadow: 0 0 18px rgba(168, 88, 32, 0.4);
  }

  /* Tooltip */
  .card-tooltip {
    position: absolute;
    bottom: 100%;
    right: 0;
    /* Round-13 fix · grow with content at 200% text zoom (was fixed width 280px which clipped) */
    min-width: 280px;
    max-width: min(380px, 90vw);
    width: max-content;
    overflow: visible;
    background: var(--ivory);
    color: var(--ink);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--gold);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 300ms ease, transform 300ms ease;
    z-index: 10;
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.3);
    /* Round-8 fix · also reveal on focus-within for keyboard users */
    visibility: hidden;
  }

  .sector-card:hover .card-tooltip,
  .sector-card:focus-within .card-tooltip {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  /* Round-8 fix · tooltip is hover-only and unreachable on touch devices · hide entirely on mobile */
  @media (max-width: 768px), (hover: none) {
    .card-tooltip { display: none; }
  }

  .tooltip-header {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--gold-hairline);
  }

  .card-tooltip ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card-tooltip li {
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--ink-muted);
    padding: 2px 0;
    letter-spacing: 0.02em;
  }

  .card-tooltip li::before {
    content: '·';
    color: var(--gold);
    margin-right: 6px;
  }

  /* Closing line */
  .closing-line-wrap {
    text-align: center;
    margin-top: clamp(64px, 8vw, 96px);
  }

  .closing-hairline {
    height: 1px;
    background: var(--gold);
    width: 40%;
    max-width: 400px;
    margin: 0 auto 32px;
    opacity: 0.5;
  }

  .closing-line {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--pearl);
    opacity: 0.7;
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .sector-large { grid-column: span 6; grid-row: span 2; }
    .sector-standard { grid-column: span 6; grid-row: span 1; }
    .sector-medium { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .sector-large, .sector-standard, .sector-medium {
      grid-column: span 1;
      grid-row: auto;
    }
    .card-3d {
      width: 80px;
      height: 80px;
    }
    .card-eyebrow { margin-top: 24px; max-width: 100%; }
    .sector-large .card-headline { font-size: 24px; }
    .sector-standard .card-headline { font-size: 20px; }
    .sector-medium .card-headline { font-size: 20px; }
    /* B-25 fix · tap-to-toggle tooltip on mobile */
    .card-tooltip {
      display: block;
      position: static;
      width: 100%;
      margin-top: 12px;
      max-height: 0;
      padding-block: 0;
      opacity: 0;
      transform: none;
      overflow: hidden;
      transition: max-height 280ms ease, opacity 280ms ease, padding-block 280ms ease;
    }
    .sector-card.tooltip-open .card-tooltip {
      max-height: 600px;
      opacity: 1;
      padding-block: 16px;
    }
  }

  @media (max-width: 768px) {
    .card-3d { width: 64px; height: 64px; top: 12px; right: 12px; }
    .card-eyebrow { padding-right: 72px; margin-top: 24px; }
    .card-headline { padding-right: 72px; }
  }

  </style>
<style is:global>
  /* Per-sector hover animations · drives inner SVG class targets */

  /* LEGAL · scales of justice teeter */
  .sector-card[data-sector="legal"] .card-3d svg .scales-beam { transform-origin: 50px 30px; transform-box: fill-box; }
  .sector-card[data-sector="legal"]:hover .card-3d svg .scales-beam {
    animation: scales-teeter 3.4s ease-in-out infinite;
  }
  @keyframes scales-teeter {
    0%, 100% { transform: rotate(0deg); }
    25%      { transform: rotate(-8deg); }
    75%      { transform: rotate(8deg); }
  }

  /* HEALTHCARE · stethoscope ECG pulse trace */
  .sector-card[data-sector="healthcare"] .card-3d svg .ecg-line path {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
  }
  .sector-card[data-sector="healthcare"]:hover .card-3d svg .ecg-line path {
    animation: ecg-trace 1.8s ease-in-out infinite;
  }
  @keyframes ecg-trace {
    0%   { stroke-dashoffset: 60; }
    55%  { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -60; }
  }

  /* HOSPITALITY · champagne bubbles rising */
  .sector-card[data-sector="hospitality"] .card-3d svg .bubble { opacity: 0; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .bubble {
    animation: bubble-rise 2.6s ease-out infinite;
  }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .b1 { animation-delay: 0s; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .b2 { animation-delay: 0.5s; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .b3 { animation-delay: 1.0s; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .b4 { animation-delay: 1.5s; }
  .sector-card[data-sector="hospitality"]:hover .card-3d svg .b5 { animation-delay: 2.0s; }
  @keyframes bubble-rise {
    0%   { opacity: 0; transform: translateY(0); }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { opacity: 0; transform: translateY(-22px); }
  }

  /* REAL ESTATE / IPO · skyline windows lighting up sequentially */
  .sector-card[data-sector="real-estate"] .card-3d svg .window {
    fill: transparent;
    opacity: 0.45;
    transition: fill 200ms ease, opacity 200ms ease;
  }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .window {
    animation: window-light 4.5s ease-in-out infinite;
  }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w1  { animation-delay: 0s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w2  { animation-delay: 0.3s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w3  { animation-delay: 0.6s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w4  { animation-delay: 0.9s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w5  { animation-delay: 1.2s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w6  { animation-delay: 1.5s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w7  { animation-delay: 1.8s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w8  { animation-delay: 2.1s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w9  { animation-delay: 2.4s; }
  .sector-card[data-sector="real-estate"]:hover .card-3d svg .w10 { animation-delay: 2.7s; }
  @keyframes window-light {
    0%, 70%, 100% { fill: transparent; opacity: 0.45; }
    15%, 55%      { fill: currentColor; opacity: 1; }
  }

  /* F&B · cocktail olive swirling around glass */
  .sector-card[data-sector="fb"] .card-3d svg .olive-stir { transform-origin: 50px 26px; transform-box: fill-box; }
  .sector-card[data-sector="fb"]:hover .card-3d svg .olive-stir {
    animation: olive-swirl 3.4s linear infinite;
  }
  @keyframes olive-swirl {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* EVERY SECTOR · compass full rotation */
  .sector-card[data-sector="every-sector"] .card-3d svg .compass-body { transform-origin: 50px 50px; transform-box: fill-box; }
  .sector-card[data-sector="every-sector"]:hover .card-3d svg .compass-body {
    animation: compass-rotate 2.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  @keyframes compass-rotate {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Reduced motion · halt animations only at the OS-level preference */
  @media (prefers-reduced-motion: reduce) {
    .sector-card .card-3d svg * { animation: none !important; }
  }

  .cta-arrow {
    display: inline-block;
    margin-left: 6px;
    font-size: 1.1em;
    line-height: 1;
    transition: transform 240ms ease;
    font-weight: normal;
  }
  .tier-cta:hover .cta-arrow {
    transform: translate(2px, -2px);
  }
</style>


<script>
  // Sequential fade-in reveal on scroll-into-view
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      document.querySelectorAll('.sector-card').forEach((c) => c.classList.add('in-view'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, idx) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        setTimeout(() => el.classList.add('in-view'), idx * 100);
        observer.unobserve(el);
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.sector-card').forEach((c, i) => {
      (c as HTMLElement).style.transitionDelay = `${i * 80}ms`;
      observer.observe(c);
    });

    /* Round-10 safety fallback · if observer hasn't fired within 3s (e.g. user lands deep-linked
       below the section), reveal all cards anyway so content never stays invisible to a real visitor */
    setTimeout(() => {
      document.querySelectorAll('.sector-card:not(.in-view)').forEach(c => c.classList.add('in-view'));
    }, 3000);

    /* B-25 · sector card tap-to-toggle tooltip on touch devices */
    const isTouch = window.matchMedia('(hover: none)').matches || ('ontouchstart' in window);
    if (isTouch) {
      document.querySelectorAll('.sector-card').forEach((card) => {
        card.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a,button')) return;
          card.classList.toggle('tooltip-open');
        });
      });
    }
  });
</script>
