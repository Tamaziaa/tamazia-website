---
import { howWeWorkContent } from '../../content/howWeWork';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, paragraph, pullQuote, roles } = howWeWorkContent;

const roleIcons: Record<string, string> = {
  book: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <rect x="10" y="10" width="28" height="28" rx="2"/>
    <line x1="10" y1="16" x2="38" y2="16"/>
    <line x1="16" y1="22" x2="32" y2="22"/>
    <line x1="16" y1="27" x2="32" y2="27"/>
    <line x1="16" y1="32" x2="28" y2="32"/>
  </g>`,
  signal: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="24" cy="24" r="4" fill="currentColor"/>
    <path d="M 14 14 Q 24 10, 34 14"/>
    <path d="M 10 10 Q 24 4, 38 10"/>
    <path d="M 14 34 Q 24 38, 34 34"/>
    <path d="M 10 38 Q 24 44, 38 38"/>
  </g>`,
  quill: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 12 36 L 32 16 Q 36 12, 38 14 L 34 18"/>
    <path d="M 30 18 L 12 36"/>
    <line x1="10" y1="38" x2="16" y2="32"/>
    <circle cx="36" cy="16" r="1.5" fill="currentColor"/>
  </g>`,
  wrench: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M 30 12 L 36 18 L 32 22 L 26 16 Q 22 18, 22 24 L 12 34 Q 10 36, 12 38 Q 14 40, 16 38 L 26 28 Q 32 28, 34 24 L 30 20 L 34 16 Z"/>
  </g>`,
  chart: `<g fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <line x1="10" y1="38" x2="38" y2="38"/>
    <line x1="10" y1="38" x2="10" y2="10"/>
    <path d="M 12 32 L 18 26 L 24 28 L 30 20 L 36 14"/>
    <circle cx="18" cy="26" r="1.5" fill="currentColor"/>
    <circle cx="24" cy="28" r="1.5" fill="currentColor"/>
    <circle cx="30" cy="20" r="1.5" fill="currentColor"/>
    <circle cx="36" cy="14" r="1.5" fill="currentColor"/>
  </g>`,
};
---
<section class="how-we-work" id="process" aria-labelledby="howwework-heading">
  <div class="container">
    <div class="grid">
      <div class="left-col">
        <div class="eyebrow">{eyebrow}</div>
        <h2 id="howwework-heading" class="section-h2">{h2}</h2>
        <p class="body">{paragraph}</p>
        <blockquote class="pull-quote" set:html={parseEmph(pullQuote)} />
      </div>

      <div class="right-col">
        {roles.map((role) => (
          <div class="role-card" data-role={role.id}>
            <div class="role-icon">
              <svg viewBox="0 0 48 48">
                <Fragment set:html={roleIcons[role.icon]} />
              </svg>
            </div>
            <div class="role-content">
              <h3 class="role-title">{role.title}</h3>
              <p class="role-description">{role.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .how-we-work {
    background: var(--ivory);
    padding-block: var(--section-padding-block);
    position: relative;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .grid {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: clamp(48px, 6vw, 96px);
    align-items: start;
  }

  /* Left column */
  .left-col { position: relative; }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: var(--ls-h2);
    margin-bottom: 48px;
  }

  .body {
    font-family: var(--ff-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-muted);
    margin-bottom: 32px;
    font-weight: 300;
  }

  .pull-quote {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: clamp(22px, 2vw + 0.5rem, 28px);
    line-height: 1.3;
    color: var(--oxblood);
    position: relative;
    padding: 24px 32px;
  }

  .pull-quote :global(.emph) {
    color: var(--oxblood);
    font-weight: 600;
    font-style: italic;
  }

  .pull-quote::before,
  .pull-quote::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--gold);
    border-style: solid;
    border-width: 0;
  }

  .pull-quote::before {
    top: 0;
    left: 0;
    border-top-width: 1.5px;
    border-left-width: 1.5px;
  }

  .pull-quote::after {
    bottom: 0;
    right: 0;
    border-bottom-width: 1.5px;
    border-right-width: 1.5px;
  }

  /* Role cards */
  .right-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .role-card {
    display: flex;
    gap: 20px;
    align-items: center;
    background: var(--ivory-warm);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 20px 24px;
    transition: border-color 400ms var(--ease-out),
                transform 400ms var(--ease-out),
                box-shadow 400ms var(--ease-out);
    opacity: 0;
    transform: translateX(20px);
  }

  .role-card.in-view {
    opacity: 1;
    transform: translateX(0);
    transition: opacity 700ms var(--ease-out), transform 700ms var(--ease-out),
                border-color 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }

  .role-card:hover {
    border-color: var(--gold);
    transform: translateX(0) translateY(-2px);
    box-shadow: 0 10px 30px -10px rgba(201, 167, 114, 0.2);
  }

  .role-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    color: var(--gold);
  }

  .role-icon svg { width: 100%; height: 100%; display: block; }

  .role-content { flex: 1; min-width: 0; }

  .role-title {
    font-family: var(--ff-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.005em;
    margin-bottom: 4px;
  }

  .role-description {
    font-family: var(--ff-body);
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.5;
    font-weight: 300;
  }

  /* Founder block */
  .founder-block {
    margin-top: clamp(64px, 8vw, 96px);
    padding-top: 48px;
    border-top: 1px solid var(--gold);
    border-top-color: rgba(201, 167, 114, 0.4);
    max-width: 720px;
  }

  .founder-hairline {
    display: none; /* using border-top on block */
  }

  .founder-line {
    font-family: var(--ff-display);
    font-size: 20px;
    font-style: italic;
    color: var(--oxblood);
    margin-bottom: 12px;
    font-weight: 500;
    line-height: 1.4;
  }

  .founder-line :global(.emph) {
    color: var(--oxblood);
    font-style: italic;
    font-weight: 500;
  }

  .founder-credentials {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* Round-7 fix · 11px gold = 2.12:1 on ivory; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 500;
    margin-bottom: 24px;
  }

  .founder-credentials .sep {
    margin: 0 8px;
    opacity: 0.5;
  }

  .founder-signature {
    font-family: var(--ff-signature);
    font-size: 56px;
    color: var(--oxblood);
    line-height: 0.9;
    margin-bottom: 24px;
    letter-spacing: 0.01em;
  }

  .founder-cta {
    display: inline-block;
    font-family: var(--ff-body);
    font-size: 14px;
    color: var(--oxblood);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    /* Round-8 fix · 44px min tap target on mobile (was 25px) */
    padding: 11px 4px;
    min-height: 44px;
    line-height: 1.5;
    transition: color 300ms ease, border-color 300ms ease;
  }

  .founder-cta:hover {
    color: var(--oxblood-warm);
    border-color: var(--gold-warm);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 640px) {
    .role-card { padding: 16px 18px; gap: 14px; }
    .role-icon { width: 36px; height: 36px; }
    .role-title { font-size: 16px; }
    .role-description { font-size: 13px; }
    .founder-signature { font-size: 42px; }
    .pull-quote { font-size: 20px; padding: 16px 24px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      document.querySelectorAll('.role-card').forEach(c => c.classList.add('in-view'));
      return;
    }
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const i = parseInt(el.dataset.i || '0', 10);
          setTimeout(() => el.classList.add('in-view'), i * 120);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.2 });
    document.querySelectorAll<HTMLElement>('.role-card').forEach((c, i) => {
      c.dataset.i = String(i);
      observer.observe(c);
    });
  });
</script>
