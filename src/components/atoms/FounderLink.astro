---
/**
 * FounderLink · canonical Aman Pareek treatment.
 * Renders a LinkedIn-linked card with either a portrait image (when public/aman-portrait.jpg
 * is present) or the "AP" monogram fallback. One consistent treatment everywhere.
 *
 * Props:
 *   variant: 'light' (default) | 'dark'
 *   compact: boolean (hides the title line)
 */
interface Props {
  variant?: 'light' | 'dark';
  compact?: boolean;
  className?: string;
}
const { variant = 'light', compact = false, className = '' } = Astro.props;
const cls = `founder-link${variant === 'dark' ? ' on-dark' : ''}${className ? ' ' + className : ''}`;
// Portrait file: drop a 200x200+ image at /public/aman-portrait.jpg to swap the AP monogram for a real photo.
const portraitSrc = '/aman-portrait.webp';
---
<a
  href="https://www.linkedin.com/in/amanpareekk/"
  target="_blank"
  rel="noopener noreferrer"
  class={cls}
  aria-label="Aman Pareek, Founder of Tamazia, on LinkedIn (opens in new tab)"
>
  <span class="founder-avatar" aria-hidden="true">
    <img
      class="founder-portrait"
      src={portraitSrc}
      alt=""
      width="56"
      height="56"
      loading="eager" fetchpriority="high"
      decoding="async"
      data-portrait-img
    />
    <span class="founder-initials">AP</span>
  </span>
  <span class="founder-text">
    <strong class="founder-name">Aman Pareek</strong>
    {!compact && <span class="founder-title">Founder · LLM, King’s College London</span>}
  </span>
  <svg
    class="founder-linkedin"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.34V9.97H5.67v8.37h2.67zM7 8.77a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zM18.34 18.34V13.7c0-2.48-1.32-3.63-3.09-3.63-1.43 0-2.07.79-2.43 1.34V9.97h-2.67v8.37h2.67v-4.55c0-.27.02-.55.1-.74.22-.55.72-1.11 1.55-1.11 1.1 0 1.54.83 1.54 2.05v4.35h2.33z"/>
  </svg>
</a>

<style>
  .founder-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--oxblood);
    color: var(--gold);
    font-family: var(--ff-display);
    font-size: 16px;
    font-weight: 500;
    overflow: hidden;
    border: 1px solid var(--gold-hairline);
  }
  .founder-portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    display: block;
  }
  .founder-initials {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    letter-spacing: -0.02em;
  }
  /* When portrait fails, JS adds .portrait-failed class to .founder-avatar */
  .founder-avatar.portrait-failed .founder-portrait { display: none; }
  .founder-avatar.portrait-failed .founder-initials { display: flex; }
</style>

<script>
  // CSP-safe portrait fallback — replaces banned onerror="this.style..." attribute
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('img[data-portrait-img]').forEach(img => {
      img.addEventListener('error', () => {
        img.closest('.founder-avatar')?.classList.add('portrait-failed');
      });
      // If already broken (cached 404 state)
      if (!img.complete || img.naturalWidth === 0) {
        img.closest('.founder-avatar')?.classList.add('portrait-failed');
      }
    });
  });
</script>
