---
// /instrument/ — the Tamazia Instrument page. Reached from the homepage "Run my
// audit" button. Founder directive r2 (2026-06-11): a compact two-half page — the
// ten strongest things the audit delivers (figures drawn from live reports),
// then a lean capture form that emails the report and routes the lead to Neon +
// Slack + Telegram. The live scoring widget and £1,500 sales framing were retired
// from this page in favour of an instant request-by-email lead capture.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import InstrumentAudit from '../components/sections/InstrumentAudit.astro';

const canonical = 'https://tamazia.co.uk/instrument/';

// Service schema — describes the audit honestly without a hard price (the page
// requests it by email; pricing is discussed in an engagement, not advertised here).
const auditSchema = {
  '@type': 'Service',
  '@id': 'https://tamazia.co.uk/instrument/#audit',
  name: 'Tamazia SEO, compliance and AI-visibility audit',
  serviceType: 'Website compliance and search audit',
  description:
    'A scored audit covering technical SEO, regulatory compliance of published content, competitive keyword gaps, Core Web Vitals and AI-search visibility, delivered as one prioritised document.',
  provider: { '@id': 'https://tamazia.co.uk/#organization' },
  areaServed: ['United Kingdom', 'European Union', 'United Arab Emirates', 'United States'],
};
---

<BaseLayout
  title="The Tamazia Instrument · Request your audit"
  description="See your site the way a regulator and an AI engine do: technical SEO, regulatory compliance, competitive gaps and AI-search visibility in one scored document. Request yours by email."
  canonical={canonical}
  extraSchema={auditSchema}
>
  <Header />
  <main id="main">
    <InstrumentAudit />
  </main>
  <Footer />
</BaseLayout>
