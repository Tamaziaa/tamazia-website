---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Tamazia · International SEO for regulated enterprises',
  description = 'Lawyer-led SEO and regulatory compliance firm. Every campaign passes through 200+ laws before anything goes live. Trusted by an NSE-listed hotel group, CG Oncology (Nasdaq: CGON), Meraas (Dubai Holding).',
  canonical = 'https://tamazia.co.uk/',
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': 'https://tamazia.co.uk/#organization',
      name: 'Tamazia',
      url: 'https://tamazia.co.uk',
      logo: {
        '@type': 'ImageObject',
        url: 'https://tamazia.co.uk/og-default.png',
      },
      description: 'Lawyer-led SEO and regulatory compliance firm for regulated enterprises.',
      areaServed: ['United Kingdom', 'United Arab Emirates', 'United States', 'France', 'Global'],
      founder: {
        '@type': 'Person',
        name: 'Aman Pareek',
        jobTitle: 'Founder',
        alumniOf: {
          '@type': 'EducationalOrganization',
          name: "King's College London",
        },
      },
      memberOf: [
        { '@type': 'Organization', name: 'Chartered Institute of Arbitrators' },
        { '@type': 'Organization', name: 'American Bar Association' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://tamazia.co.uk/#website',
      url: 'https://tamazia.co.uk',
      name: 'Tamazia',
      publisher: { '@id': 'https://tamazia.co.uk/#organization' },
      inLanguage: 'en-GB',
    },
  ],
};
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage.startsWith("http") ? ogImage : `https://tamazia.co.uk${ogImage}`} />
    <meta property="og:site_name" content="Tamazia" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@tamazia_co" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.startsWith("http") ? ogImage : `https://tamazia.co.uk${ogImage}`} />

    {/* Round-13 · fonts are now self-hosted from /public/fonts (latin + latin-ext WOFF2 subsets,
        loaded via @font-face declarations in src/styles/fonts.css). No cross-origin Google Fonts
        request → no SRI exception, no DNS roundtrip, no critical-path stylesheet fetch.
        Preloading the two LCP-critical faces. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400-normal-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/playfair-display-500-normal-latin.woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon set -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5A1A2B" />
    <meta name="theme-color" content="#5A1A2B" />

    <!-- G.39 · hreflang · en-GB canonical + en + x-default -->
    <link rel="alternate" hreflang="en-GB" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://api.resend.com" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Named slot for page-level JSON-LD and additional head tags -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />

    {/* Round-12 fix · UK GDPR + EU PECR cookie consent strip with equal Accept/Reject parity */}
    <div id="cookie-strip" class="cookie-strip" role="region" aria-label="Cookie consent" hidden>
      <p class="cookie-text">
        We use only essential cookies for site functionality. No third-party tracking. No marketing pixels.
        Read the <a href="/cookie-policy/" class="cookie-link">cookie policy</a> or the
        <a href="/privacy-notice/" class="cookie-link">privacy notice</a>.
      </p>
      <div class="cookie-actions">
        <button type="button" class="cookie-btn cookie-btn--reject" id="cookie-reject" onclick="window.__tamaziaCookieDismiss && window.__tamaziaCookieDismiss('denied', event)">Reject non-essential</button>
        <button type="button" class="cookie-btn cookie-btn--accept" id="cookie-accept" onclick="window.__tamaziaCookieDismiss && window.__tamaziaCookieDismiss('granted', event)">Accept all</button>
      </div>
    </div>

    <style>
      .cookie-strip {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: linear-gradient(180deg, #2A0C14 0%, #1F0810 100%);
        color: #E8E4DC;
        padding: 14px 24px;
        display: flex;
        gap: 18px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        border-top: 1px solid #C9A772;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 12px;
        letter-spacing: 0.04em;
        animation: cookie-up 380ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      @keyframes cookie-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
      .cookie-text { margin: 0; max-width: 720px; line-height: 1.5; }
      .cookie-link {
        color: #C9A772;
        text-decoration: underline;
        margin-left: 6px;
        /* Round-12 fix · ensure ≥24×24 touch target (was 19px tall) */
        padding: 6px 4px;
        display: inline-block;
        line-height: 1.6;
      }
      .cookie-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
      }
      .cookie-btn {
        border: 1px solid #C9A772;
        font-family: inherit;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        border-radius: 2px;
        cursor: pointer;
        transition: background 240ms ease, color 240ms ease, border-color 240ms ease;
        /* Round-12 · equal visual weight for Accept and Reject; both ≥44px tap target */
        padding: 14px 20px;
        min-height: 44px;
        min-width: 168px;
      }
      .cookie-btn--accept {
        background: #C9A772;
        color: #2A0C14;
      }
      .cookie-btn--accept:hover { background: #D4B787; }
      .cookie-btn--reject {
        background: transparent;
        color: #E8E4DC;
      }
      .cookie-btn--reject:hover {
        background: rgba(232, 228, 220, 0.1);
        border-color: #D4B787;
      }
      .cookie-btn:focus-visible { outline: 2px solid #D4B787; outline-offset: 2px; }
      @media (max-width: 640px) {
        .cookie-strip { font-size: 11px; padding: 12px 16px; gap: 12px; flex-direction: column; }
        .cookie-text { text-align: center; }
        .cookie-actions { width: 100%; justify-content: stretch; }
        .cookie-btn { flex: 1 1 auto; min-width: 0; padding: 12px 14px; }
      }
    </style>

    <script is:inline>
      // Round-12 · cookie strip with explicit Accept / Reject (UK GDPR + EU PECR equal-prominence)
      (() => {
        const KEY = 'tamazia-cookie-consent';

        // Expose dismiss globally so inline onclick attributes always work,
        // regardless of when this IIFE runs or whether listeners attached.
        window.__tamaziaCookieDismiss = function(decision, ev) {
          if (ev) { try { ev.preventDefault(); ev.stopPropagation(); } catch(_){} }
          try { localStorage.setItem(KEY, decision); } catch(_){}
          const strip = document.getElementById('cookie-strip');
          if (strip) {
            strip.style.display = 'none';
            strip.setAttribute('hidden', '');
            strip.setAttribute('aria-hidden', 'true');
          }
          try { window.dispatchEvent(new CustomEvent('tamazia:consent', { detail: { decision } })); } catch(_){}
        };

        try {
          let current = null;
          try { current = localStorage.getItem(KEY); } catch (_) {}
          if (current === 'granted' || current === 'denied') return;

          const strip = document.getElementById('cookie-strip');
          if (!strip) return;
          strip.hidden = false;
          strip.removeAttribute('hidden');
          strip.style.display = 'flex';
        } catch (e) { /* swallow */ }
      })();

      /* Round-10 global safety net · reveal every scroll-triggered element after 4s
         even if its IntersectionObserver never fired (deep-link, JS race, observer-not-supported, etc.) */
      window.addEventListener('load', () => {
        setTimeout(() => {
          document.querySelectorAll(
            '.sector-card:not(.in-view), .case-panel:not(.in-view), .interstitial:not(.in-view), .stat-value:not(.counted)'
          ).forEach(el => {
            el.classList.add('in-view');
            el.classList.add('counted');
          });
        }, 4000);
      });
    </script>
  </body>
</html>
