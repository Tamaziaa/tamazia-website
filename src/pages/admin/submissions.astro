---
// /admin/submissions · Phase 8 hardened · KV-backed dashboard
// Auth: ADMIN_SECRET via login form (in-memory only, never sessionStorage).
// Reads /api/admin-submissions then renders.
// noindex via _headers + meta robots.
import BaseLayout from '../../layouts/BaseLayout.astro';
const lastUpdated = '5 May 2026';
---
<BaseLayout
  title="Submissions · Tamazia admin"
  description="Auth-gated form submissions dashboard"
  canonical="https://tamazia.co.uk/admin/submissions/"
  noindex={true}
>
  <main id="main" class="admin">
    <header class="admin-head">
      <h1>Form Submissions</h1>
      <p class="updated">Last verified {lastUpdated}.</p>
      <form id="login-form" class="login" autocomplete="off">
        <label for="adminkey">Admin secret</label>
        <input id="adminkey" type="password" autocomplete="off" placeholder="ADMIN_SECRET" />
        <button type="submit">Authenticate</button>
      </form>
      <div id="dashboard" hidden>
        <div class="filters">
          <label>Tab
            <select id="tab"><option value="">all</option><option>contact</option><option>briefings</option><option>audit</option><option>bookings</option><option>nel</option></select>
          </label>
          <input id="search" placeholder="Search email, company, or request_id" />
          <input id="from" type="date" aria-label="From date" />
          <input id="to" type="date" aria-label="To date" />
          <button id="reload" type="button">Reload</button>
          <button id="export" type="button">Export CSV</button>
          <button id="signout" type="button">Sign out</button>
        </div>
      </div>
    </header>

    <section id="status" class="status"></section>
    <table id="grid" role="grid" aria-label="Form submissions" hidden>
      <thead role="rowgroup">
        <tr>
          <th class="sortable" data-sort="submitted_at" aria-sort="descending" tabindex="0" role="columnheader">Submitted ▾</th>
          <th class="sortable" data-sort="tab_source" tabindex="0" role="columnheader">Tab</th>
          <th class="sortable" data-sort="name" tabindex="0" role="columnheader">Name</th>
          <th class="sortable" data-sort="email" tabindex="0" role="columnheader">Email</th>
          <th class="sortable" data-sort="email_validation" tabindex="0" role="columnheader">Email check</th>
          <th class="sortable" data-sort="company" tabindex="0" role="columnheader">Company</th>
          <th>Intent</th>
          <th>UTM</th>
          <th class="sortable" data-sort="ip_country" tabindex="0" role="columnheader">Country</th>
          <th>Request ID</th>
        </tr>
      </thead>
      <tbody role="rowgroup"></tbody>
    </table>
  </main>
</BaseLayout>

<style>
  .admin { padding: 32px 24px 96px; max-width: 1320px; margin: 0 auto; font-family: 'Inter', system-ui, sans-serif; color: #2A0C14; }
  .admin h1 { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-weight: 500; font-size: 36px; margin: 0; }
  .updated { font-size: 12px; color: #5C4047; margin: 4px 0 16px; }
  .login { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .login label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; }
  .login input, .filters input, .filters select, .login button, .filters button {
    font: inherit; padding: 8px 10px; border: 1px solid #C9A772; background: #FAF7F2;
  }
  .login input { min-width: 240px; }
  .login button, .filters button { cursor: pointer; background: #2A0C14; color: #FAF7F2; border-color: #2A0C14; }
  .filters { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .status { font-size: 13px; color: #5C4047; margin-bottom: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { padding: 8px 10px; border-bottom: 1px solid #E5DDCB; vertical-align: top; text-align: left; }
  th { background: #F4F0E8; font-weight: 600; position: sticky; top: 0; }
  tr:hover td { background: #FAF7F2; }
  th.sortable { cursor: pointer; user-select: none; }
  th.sortable:hover { background: #EAE3D2; }
  th.sortable[aria-sort="ascending"]::after { content: ' ▴'; }
  th.sortable[aria-sort="descending"]::after { content: ' ▾'; }
  th.sortable:focus-visible { outline: 2px solid #C9A772; outline-offset: 2px; }
  /* Phase 12 · mobile card layout below 768px */
  @media (max-width: 768px) {
    table { display: block; }
    thead { display: none; }
    tbody { display: block; }
    tr { display: block; padding: 16px; border: 1px solid #E5DDCB; margin-bottom: 12px; background: #FAF7F2; }
    td { display: block; padding: 4px 0; border: none; }
    td::before { content: attr(data-label); font-weight: 600; display: block; font-size: 11px; color: #5C4047; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 6px; }
  }
  .tag-valid { color: #1F6B3A; font-weight: 600; }
  .tag-invalid { color: #B30A0A; font-weight: 600; }
  .tag-disposable { color: #B30A0A; font-weight: 600; }
  .tag-skipped { color: #5C4047; }
  .tag-risky, .tag-accept_all, .tag-unknown { color: #C9A772; font-weight: 600; }
</style>

<script is:inline>
  (function () {
    let KEY = ''; // In-memory only, never persisted.
    let cache = [];

    function csvEscape(value) {
      if (value === null || value === undefined) return '';
      let s = String(value);
      // Phase 12 · Excel formula injection guard · prepend ' to neutralise =, +, -, @, \t, \r
      if (/^[=+\-@\t\r]/.test(s)) s = "'" + s;
      if (/["\r\n,]/.test(s)) s = '"' + s.replace(/"/g, '""') + '"';
      return s;
    }

    let sortKey = 'submitted_at';
    let sortDir = 'desc';

    function debounce(fn, ms) {
      let t = null;
      return function () {
        const args = arguments;
        clearTimeout(t);
        t = setTimeout(() => fn.apply(null, args), ms);
      };
    }



    const $ = (id) => document.getElementById(id);

    function safeText(s) {
      // Set as textContent later, never innerHTML; this returns the safe escaped string for fallback.
      return String(s == null ? '' : s);
    }


    function sortCache() {
      cache.sort((a, b) => {
        let av = '', bv = '';
        if (sortKey === 'email_validation') {
          av = (a.email_validation && a.email_validation.status) || (a.email_validation && a.email_validation.skipped ? 'skipped' : '');
          bv = (b.email_validation && b.email_validation.status) || (b.email_validation && b.email_validation.skipped ? 'skipped' : '');
        } else {
          av = String(a[sortKey] || '');
          bv = String(b[sortKey] || '');
        }
        const cmp = av.localeCompare(bv);
        return sortDir === 'asc' ? cmp : -cmp;
      });
    }

    document.querySelectorAll('th.sortable').forEach(th => {
      const handler = () => {
        const k = th.getAttribute('data-sort');
        if (sortKey === k) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        else { sortKey = k; sortDir = 'desc'; }
        document.querySelectorAll('th.sortable').forEach(x => x.setAttribute('aria-sort', 'none'));
        th.setAttribute('aria-sort', sortDir === 'asc' ? 'ascending' : 'descending');
        sortCache();
        render();
      };
      th.addEventListener('click', handler);
      th.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); } });
    });

    async function load() {
      const tab = $('tab').value;
      const url = '/api/admin-submissions' + (tab ? '?tab=' + tab : '');
      $('status').textContent = 'Loading...';
      $('reload').setAttribute('aria-busy', 'true');
      try {
        const r = await fetch(url, { credentials: 'omit', headers: { 'X-Admin-Secret': KEY } });
        if (r.status === 401) {
          $('status').textContent = 'Authentication failed.';
          $('login-form').hidden = false;
          $('dashboard').hidden = true;
          $('grid').hidden = true;
          return;
        }
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();
        cache = data.submissions || [];
        sortCache();
        $('grid').hidden = false;
        render();
      } catch (e) {
        $('status').textContent = 'Error: ' + e.message;
      } finally {
        $('reload').removeAttribute('aria-busy');
      }
    }

    function render() {
      const q = $('search').value.trim().toLowerCase();
      const from = $('from').value;
      const to = $('to').value;
      let rows = cache;
      if (q) {
        rows = rows.filter(s =>
          (s.email||'').toLowerCase().includes(q) ||
          (s.company||'').toLowerCase().includes(q) ||
          (s.request_id||'').toLowerCase().includes(q)
        );
      }
      if (from) {
        rows = rows.filter(s => (s.submitted_at||'').slice(0,10) >= from);
      }
      if (to) {
        rows = rows.filter(s => (s.submitted_at||'').slice(0,10) <= to);
      }
      $('status').textContent = rows.length + ' rows · ' + cache.length + ' total in cache';
      const tbody = $('grid').querySelector('tbody');
      tbody.innerHTML = '';
      const fields = ['submitted_at','tab_source','name','email','email_validation','company','intent_text','utm_source','ip_country','request_id'];
      const labels = { submitted_at:'Submitted', tab_source:'Tab', name:'Name', email:'Email', email_validation:'Email check', company:'Company', intent_text:'Intent', utm_source:'UTM', ip_country:'Country', request_id:'Request ID' };
      for (const s of rows) {
        const tr = document.createElement('tr');
        for (const f of fields) {
          const td = document.createElement('td');
          td.setAttribute('data-label', labels[f] || f);
          if (f === 'email_validation') {
            const v = s.email_validation || {};
            const status = v.skipped ? 'skipped' : (v.status || 'unknown');
            td.className = 'tag-' + status;
            td.textContent = (v.provider || 'none') + ' · ' + status;
          } else if (f === 'request_id') {
            td.textContent = (s[f] || '').slice(0,8);
            td.title = s[f] || '';
          } else {
            td.textContent = safeText(s[f]);
          }
          tr.appendChild(td);
        }
        tbody.appendChild(tr);
      }
    }

    async function fetchAllPages() {
      const tab = $('tab').value;
      const all = [];
      let cursor = null;
      let safety = 0;
      do {
        const url = '/api/admin-submissions' + (tab ? '?tab=' + tab : '?') + (cursor ? '&cursor=' + encodeURIComponent(cursor) : '');
        const r = await fetch(url, { credentials: 'omit', headers: { 'X-Admin-Secret': KEY } });
        if (!r.ok) break;
        const data = await r.json();
        all.push(...(data.submissions || []));
        cursor = data.next_cursor || null;
        if (++safety > 50) break;
      } while (cursor);
      return all;
    }

    async function exportCsv() {
      $('export').setAttribute('aria-busy', 'true');
      try {
        const all = await fetchAllPages();
        cache = all;  // Phase 12 · refresh cache so visible rows match exported
      const headers = ['submitted_at','tab_source','request_id','name','email','email_validation_status','company','intent_text','utm_source','utm_medium','ip_country'];
      const csvRows = [headers.map(csvEscape).join(',')];
      for (const s of cache) {
        const row = headers.map(h => {
          if (h === 'email_validation_status') {
            const v = s.email_validation || {};
            return csvEscape(v.skipped ? 'skipped' : (v.status || 'unknown'));
          }
          return csvEscape(s[h]);
        });
        csvRows.push(row.join(','));
      }
      // RFC 4180 CRLF line ending + UTF-8 BOM for Excel
      const blob = new Blob(['\uFEFF' + csvRows.join('\r\n')], { type: 'text/csv;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'tamazia-submissions-' + new Date().toISOString().slice(0,10) + '.csv';
      a.click();
      } finally {
        $('export').removeAttribute('aria-busy');
      }
    }

    function signOut() {
      KEY = '';
      cache = [];
      $('login-form').hidden = false;
      $('dashboard').hidden = true;
      $('grid').hidden = true;
      $('status').textContent = 'Signed out. Memory cleared.';
      $('adminkey').value = '';
    }

    $('login-form').addEventListener('submit', function (e) {
      e.preventDefault();
      KEY = $('adminkey').value || '';
      if (!KEY) return;
      $('login-form').hidden = true;
      $('dashboard').hidden = false;
      $('adminkey').value = ''; // Don't leave in DOM.
      load();
    });

    $('tab').addEventListener('change', load);
    $('search').addEventListener('input', debounce(render, 200));
    $('from').addEventListener('change', render);
    $('to').addEventListener('change', render);
    $('reload').addEventListener('click', load);
    $('export').addEventListener('click', exportCsv);
    $('signout').addEventListener('click', signOut);

    // Drop key from memory if tab is hidden for >5 minutes (passive auto-signout).
    let hideStart = null;
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) hideStart = Date.now();
      else if (hideStart && (Date.now() - hideStart) > 5 * 60 * 1000) signOut();
    });
  })();
</script>
