---
/**
 * RatingStrip · greyscale/watermark 5-star marks for Trustpilot, Google and Clutch.
 * Founder directive 2026-06-11: stars + platform marks only, NO review counts,
 * UNLINKED. Single-ink watermark register so the strip reads editorial, not
 * e-commerce (benchmarks §3: monochrome ambient proof under the decision point).
 * Placements: hero CTA row · Testimonials header · /instrument/ request card.
 */
interface Props {
  tone?: 'light' | 'dark';
  align?: 'start' | 'center';
}
const { tone = 'light', align = 'center' } = Astro.props;
const stars = '★★★★★';
---
<div class={`rating-strip rating-strip--${tone} rating-strip--${align}`} role="img" aria-label="Rated five stars on Trustpilot, Google Reviews and Clutch">
  <span class="rs-item">
    <svg class="rs-mark" viewBox="0 0 24 24" aria-hidden="true" width="13" height="13"><path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.5 6.8L12 16.7 5.9 20.3l1.5-6.8L2.2 8.9l6.9-.6Z" fill="currentColor"/></svg>
    <span class="rs-name">Trustpilot</span>
    <span class="rs-stars" aria-hidden="true">{stars}</span>
  </span>
  <span class="rs-sep" aria-hidden="true">·</span>
  <span class="rs-item">
    <svg class="rs-mark" viewBox="0 0 24 24" aria-hidden="true" width="13" height="13"><path d="M12 2a10 10 0 1 0 10 10c0-.7-.07-1.36-.2-2H12v3.9h5.45A5.8 5.8 0 0 1 12 17.8a5.8 5.8 0 1 1 3.93-10.06l2.83-2.83A9.96 9.96 0 0 0 12 2Z" fill="currentColor"/></svg>
    <span class="rs-name">Google Reviews</span>
    <span class="rs-stars" aria-hidden="true">{stars}</span>
  </span>
  <span class="rs-sep" aria-hidden="true">·</span>
  <span class="rs-item">
    <svg class="rs-mark" viewBox="0 0 24 24" aria-hidden="true" width="13" height="13"><path d="M16.9 16.3a5 5 0 1 1 0-8.5l3-2.6A9 9 0 1 0 12 21a9 9 0 0 0 7.9-3.6l-3-2.6Z" fill="currentColor"/><circle cx="12" cy="12" r="2.6" fill="currentColor"/></svg>
    <span class="rs-name">Clutch</span>
    <span class="rs-stars" aria-hidden="true">{stars}</span>
  </span>
</div>

<style>
  .rating-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 14px;
    font-family: var(--ff-body, 'Inter', system-ui, sans-serif);
    user-select: none;
  }
  .rating-strip--center { justify-content: center; }
  .rating-strip--start { justify-content: flex-start; }

  .rs-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .rs-mark { display: inline-block; flex-shrink: 0; transform: translateY(1px); }
  .rs-name {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .rs-stars {
    font-size: 11px;
    letter-spacing: 0.08em;
    transform: translateY(-0.5px);
  }
  .rs-sep { opacity: 0.55; font-size: 11px; }

  /* Watermark registers · single ink, no platform colours */
  .rating-strip--light { color: var(--gold-text, #7B5520); opacity: 0.62; }
  .rating-strip--dark { color: var(--pearl, #E8E4DC); opacity: 0.5; }

  @media (max-width: 480px) {
    .rating-strip { gap: 4px 10px; }
    .rs-name { font-size: 9px; letter-spacing: 0.1em; }
    .rs-stars { font-size: 10px; }
  }
</style>
