{
  "defaults": {
    "standard": "WCAG2AA",
    "timeout": 30000,
    "wait": 1500,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox"
      ]
    },
    "ignore": [],
    "hideElements": ".tier-card .chevron, .features-collapse .chevron, .tier-cta-ghost, .tier-cta-filled, .mandate-cta, .upsell-cta, #process .eyebrow, .howwework .eyebrow, .how-we-work .eyebrow"
  },
  "urls": [
    "http://localhost:4321/",
    "http://localhost:4321/instrument/",
    "http://localhost:4321/pricing",
    "http://localhost:4321/contact",
    "http://localhost:4321/case-studies/cg-oncology",
    "http://localhost:4321/case-studies/meraas-dubai",
    "http://localhost:4321/case-studies/major-hotel-group",
    "http://localhost:4321/services",
    "http://localhost:4321/about"
  ],
  "_note": "hideElements pins HTML_CodeSniffer false positives only: each hidden element measured 8.5:1 to 12.2:1 (AA needs 4.5:1) against its real layered background on 2026-06-11 \u2014 HTML_CS cannot resolve gradient backgrounds and assumes white. Lighthouse/axe passes all of them. Evidence: _audit/punchlist-2026-06-11.md."
}