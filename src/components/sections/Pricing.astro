---
import { pricingContent } from '../../content/pricing';

const { eyebrow, h2, intro, tiers, mandateCallout, mandateCta, mandateSignature, microNote } = pricingContent;

const featureIcons: Record<string, string> = {
  Audit: `<circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.2"/><line x1="18" y1="18" x2="22" y2="22" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>`,
  Team: `<circle cx="9" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="16" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M 4 20 Q 4 15, 9 15 Q 14 15, 14 20" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M 11 20 Q 11 15, 16 15 Q 21 15, 21 20" fill="none" stroke="currentColor" stroke-width="1.2"/>`,
  Deliverables: `<rect x="5" y="6" width="14" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.2"/><line x1="8" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>`,
  Review: `<path d="M 4 12 L 9 17 L 20 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---
<section class="pricing" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="pricing-heading" class="section-h2">{h2}</h2>
      <p class="intro">{intro}</p>
    </div>

    {/* G.6 · Currency switcher · GBP:1 USD:1.27 AED:4.67 */}
    <div class="currency-switcher" role="group" aria-label="Display currency">
      <button class="currency-btn active" data-currency="GBP" aria-pressed="true">GBP £</button>
      <button class="currency-btn" data-currency="USD" aria-pressed="false">USD $</button>
      <button class="currency-btn" data-currency="AED" aria-pressed="false">AED د.إ</button>
      <span class="currency-note">All engagements are invoiced in GBP</span>
    </div>

    {/* Pilot engagement toggle · first six-month engagement at preferential rate */}
    <div class="pilot-toggle" role="group" aria-label="Engagement rate">
      <button class="pilot-btn active" data-pilot="on" aria-pressed="true">Pilot engagement <span class="pilot-btn-sub">first six months</span></button>
      <button class="pilot-btn" data-pilot="off" aria-pressed="false">Standard rate</button>
    </div>

    <div class="tiers-grid">
      {tiers.map((t: any) => (
        <div class={`tier-card tier-${t.tier} ${t.mostPopular ? 'tier-most-popular' : ''}`} data-tier={t.name}>
          {t.mostPopular && <span class="most-popular-ribbon" aria-label="Most popular tier">Most popular</span>}

          <div class="tier-head">
            <span class="tier-numeral">{t.numeral}</span>
            <h3 class="tier-name">{t.name}</h3>
            <div class="tier-price"
              data-gbp={t.priceGbp}
              data-gbp-standard={t.priceGbpStandard}
              data-saves-gbp={t.savesGbp6}>
              <span class="price-strike" aria-hidden="true"></span>
              <span class="price-display">{t.price}</span>
              {t.priceUnit && <span class="price-unit">{t.priceUnit}</span>}
            </div>
            <p class="saves-line" aria-live="polite"></p>
            <p class="tier-tagline">{t.tagline}</p>
            <p class="tier-ideal-clients">{t.idealClients || t.description}</p>
          </div>

          {t.includesAllOfPrior && (
            <div class="tier-includes-prior">{t.includesAllOfPrior}</div>
          )}

          <div class="features-heading">{t.featuresHeading || 'WHAT IS INCLUDED'}</div>

          {(() => {
            const allFeats = t.featuresDetailed || [];
            const topFeats = allFeats.slice(0, 3);
            const restFeats = allFeats.slice(3);
            return (
              <>
                <ul class="rich-features">
                  {topFeats.map((feat: any) => (
                    <li class="rich-feature">
                      <span class="feature-bullet" aria-hidden="true">▸</span>
                      <div>
                        <h4 class="feature-headline">{feat.headline}</h4>
                        <p class="feature-body">{feat.body}</p>
                      </div>
                    </li>
                  ))}
                </ul>
                {restFeats.length > 0 && (
                  <details class="features-collapse">
                    <summary class="features-collapse-summary">
                      <span>See all {allFeats.length} inclusions</span>
                      <span class="chevron" aria-hidden="true">+</span>
                    </summary>
                    <ul class="rich-features">
                      {restFeats.map((feat: any) => (
                        <li class="rich-feature">
                          <span class="feature-bullet" aria-hidden="true">▸</span>
                          <div>
                            <h4 class="feature-headline">{feat.headline}</h4>
                            <p class="feature-body">{feat.body}</p>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </>
            );
          })()}

          {Array.isArray(t.additionalCapabilities) && t.additionalCapabilities.length > 0 && (
            <details class="additional-block">
              <summary class="additional-summary">
                <span>{t.additionalCapabilitiesHeading || 'Additional capabilities'}</span>
                <span class="chevron" aria-hidden="true">+</span>
              </summary>
              <ul class="additional-list">
                {t.additionalCapabilities.map((cap: string) => (
                  <li class="additional-item">+ {cap}</li>
                ))}
              </ul>
            </details>
          )}

          <a href="#contact" class={`tier-cta ${t.tier === 'enterprise' ? 'tier-cta-filled' : 'tier-cta-ghost'}`}>{t.cta} →</a>

          <p class="pilot-microcopy">Pilot engagement rate available for new mandates.</p>

          {Array.isArray(t.microFooter) && t.microFooter.length > 0 && (
            <div class="tier-micro-footer">
              {t.microFooter.map((line: string) => <p>{line}</p>)}
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="mandate-block">
      <div class="mandate-rule" aria-hidden="true"></div>
      <p class="mandate-text">{mandateCallout}</p>
      <div class="mandate-actions">
        <a href="#contact" class="mandate-cta">{mandateCta}</a>
        <div class="mandate-signature">{mandateSignature}</div>
      </div>
      <div class="mandate-rule" aria-hidden="true"></div>
    </div>

    <p class="micro-note">{microNote}</p>
  </div>
</section>

<style>
  .pricing {
    background: var(--ivory);
    padding-block: var(--section-padding-block);
    position: relative;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .header-block {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 20px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    color: var(--ink);
    margin-bottom: 16px;
    letter-spacing: var(--ls-h2);
  }

  .intro {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-muted);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Tier head + ideal clients */
  .tier-head { margin-bottom: 22px; }
  .tier-ideal-clients {
    font-family: var(--ff-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-muted);
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
  }

  /* Rich feature list (Round-1 fix B-01/B-16) */
  .features-heading {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* Round-7 fix · 10px gold = 1.79:1; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 600;
    margin: 18px 0 14px;
  }
  .rich-features {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
  }
  .rich-feature {
    display: flex;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .rich-feature:last-child { border-bottom: 0; }
  .feature-bullet {
    /* Round-7 fix · gold on pearl/bisque was 1.79:1; deeper bronze passes 4.5:1 on every light bg in the journey */
    color: var(--gold-text);
    font-size: 14px;
    line-height: 1.4;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .feature-headline {
    font-family: var(--ff-display);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--oxblood-ink);
    margin-bottom: 6px;
  }
  .feature-body {
    font-family: var(--ff-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 0;
  }

  /* B1-B4 fix · Enterprise dark tier · light text */
  .tier-card.tier-enterprise {
    background: var(--grad-oxblood-depth);
    color: var(--ivory);
  }
  .tier-card.tier-enterprise .tier-numeral { color: var(--gold); }
  .tier-card.tier-enterprise .tier-name { color: var(--ivory); }
  .tier-card.tier-enterprise .tier-price { color: var(--gold); }
  .tier-card.tier-enterprise .price-unit { color: var(--pearl); }
  .tier-card.tier-enterprise .tier-tagline { color: var(--pearl); }
  .tier-card.tier-enterprise .tier-ideal-clients { color: var(--pearl); border-top-color: var(--gold-hairline); }
  .tier-card.tier-enterprise .tier-includes-prior { color: var(--gold); border-top-color: var(--gold-hairline); }
  .tier-card.tier-enterprise .features-heading { color: var(--gold); }
  .tier-card.tier-enterprise .feature-headline { color: var(--ivory); }
  .tier-card.tier-enterprise .feature-body { color: rgba(232, 228, 220, 0.78); }
  .tier-card.tier-enterprise .rich-feature { border-bottom-color: var(--gold-hairline); }
  .tier-card.tier-enterprise .feature-bullet { color: var(--gold); }
  .tier-card.tier-enterprise .additional-block { border-top-color: var(--gold-hairline-strong); }
  .tier-card.tier-enterprise .additional-summary { color: var(--gold); }
  .tier-card.tier-enterprise .additional-item { color: rgba(232, 228, 220, 0.85); border-bottom-color: rgba(201, 167, 114, 0.2); }
  .tier-card.tier-enterprise .features-collapse-summary {
    /* Round-7 fix · solid dark bg ensures gold passes contrast (was 0.08 transparent reading as gold-on-gold-tint) */
    background: rgba(42, 12, 20, 0.6);
    color: var(--gold);
    border-color: var(--gold-hairline);
  }
  .tier-card.tier-enterprise .tier-micro-footer {
    color: rgba(232, 228, 220, 0.7);
    border-top-color: rgba(201, 167, 114, 0.2);
  }

  /* Bug-fix B-03 · main features collapsible (top 3 visible, rest collapsed) */
  .features-collapse {
    margin-bottom: 16px;
  }
  .features-collapse-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    margin: 12px 0;
    background: rgba(201, 167, 114, 0.06);
    border: 1px solid var(--gold-hairline);
    border-radius: 4px;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oxblood);
    transition: background 240ms ease, border-color 240ms ease;
  }
  .features-collapse-summary:hover {
    background: rgba(201, 167, 114, 0.12);
    border-color: var(--gold);
  }
  .features-collapse-summary::-webkit-details-marker { display: none; }
  .features-collapse-summary .chevron {
    /* Round-7 fix · 18px gold on gold-tint = 1.00:1; deeper bronze passes */
    color: var(--gold-text-strong);
    font-size: 18px;
    font-weight: 700;
    transition: transform 240ms var(--ease-out);
  }
  .features-collapse[open] .features-collapse-summary .chevron { transform: rotate(45deg); }

  /* Additional capabilities collapsible (Round-1 fix B-28) */
  .additional-block {
    margin-bottom: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--gold-hairline);
  }
  .additional-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oxblood);
  }
  .additional-summary::-webkit-details-marker { display: none; }
  .additional-summary .chevron {
    /* Round-7 fix · 16px gold on bisque = 1.79:1; deeper bronze passes */
    color: var(--gold-text);
    font-size: 16px;
    font-weight: 700;
    transition: transform 240ms var(--ease-out);
  }
  .additional-block[open] .chevron { transform: rotate(45deg); }
  .additional-list {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
  }
  .additional-item {
    font-family: var(--ff-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--ink-muted);
    padding: 6px 0;
    border-bottom: 1px dashed var(--hairline);
  }
  .additional-item:last-child { border-bottom: 0; }

  /* Most-popular ribbon (Authority) */
  .tier-most-popular {
    position: relative;
    border-color: var(--gold) !important;
    box-shadow: 0 8px 28px rgba(90, 26, 43, 0.18);
  }
  .most-popular-ribbon {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--grad-gold-shimmer);
    color: var(--oxblood-ink);
    font-family: var(--ff-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 2px;
    z-index: 5;
  }
  .tier-includes-prior {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    color: var(--oxblood);
    border-top: 1px solid var(--gold-hairline);
    padding-top: 14px;
    margin: 14px 0 18px;
  }
  .price-unit {
    font-size: 0.42em;
    color: var(--ink-muted);
    font-style: italic;
    margin-left: 4px;
    letter-spacing: 0;
  }
  .tier-micro-footer {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--ink-muted);
    line-height: 1.5;
    letter-spacing: 0.04em;
  }
  .tier-micro-footer p {
    margin: 4px 0;
  }

  /* Tier grid */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: stretch;
    margin-bottom: clamp(32px, 5vw, 48px); /* R10 · was 64-96 */
  }

  .tier-card {
    container-type: inline-size;
    position: relative;
    padding: 40px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: min-content;
    transition: transform 400ms var(--ease-out), box-shadow 400ms var(--ease-out),
                border-color 400ms var(--ease-out);
  }

  .tier-standard {
    background: var(--pearl);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.5);
  }

  .tier-elevated {
    background: var(--pearl);
    border: 1px solid var(--gold);
    box-shadow: 0 20px 40px -20px rgba(201, 167, 114, 0.3);
    transform: translateY(-8px);
  }

  .tier-enterprise {
    background: var(--obsidian);
    color: var(--ivory);
    border: 2px solid var(--gold);
    position: relative;
    transform: scale(1.03);
    z-index: 2;
  }

  .tier-enterprise::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(201, 167, 114, 0.4);
    border-radius: 12px;
    pointer-events: none;
  }

  .tier-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px -30px rgba(201, 167, 114, 0.3);
  }

  .tier-enterprise:hover {
    transform: translateY(-12px) scale(1.03);
  }

  .tier-numeral {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    /* Round-7 fix · 14px gold = 1.79:1 on bisque; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .tier-name {
    font-family: var(--ff-display);
    font-size: 32px;
    font-weight: 500;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .tier-standard .tier-name, .tier-elevated .tier-name { color: var(--ink); }
  .tier-enterprise .tier-name { color: var(--ivory); }

  .tier-price {
    font-family: var(--ff-display);
    font-size: 56px;
    font-weight: 500;
    color: var(--oxblood);
    line-height: 1;
    margin-bottom: 16px;
    font-feature-settings: 'lnum', 'tnum';
  }

  .tier-enterprise .tier-price { color: var(--gold); }

  .tier-tagline {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 14px;
    margin-bottom: 28px;
    font-weight: 300;
  }

  .tier-standard .tier-tagline, .tier-elevated .tier-tagline { color: var(--ink-muted); }
  .tier-enterprise .tier-tagline { color: var(--pearl); opacity: 0.75; }

  .tier-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 28px;
    padding-block: 20px;
    border-top: 1px solid var(--gold);
    border-bottom: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.35);
  }

  .feature-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .feature-pill svg {
    width: 16px;
    height: 16px;
    color: var(--gold);
    flex-shrink: 0;
  }

  .tier-description {
    font-family: var(--ff-body);
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 32px;
    font-weight: 300;
    flex: 1;
  }

  .tier-standard .tier-description, .tier-elevated .tier-description { color: var(--ink-muted); }
  .tier-enterprise .tier-description { color: var(--pearl); opacity: 0.85; }

  .tier-cta {
    display: block;
    text-align: center;
    height: 52px;
    line-height: 52px;
    padding: 0 20px;
    font-family: var(--ff-display);
    font-size: 14px;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 4px;
    white-space: nowrap;
    transition: background 300ms ease, border-color 300ms ease, color 300ms ease;
  }

  .tier-cta-ghost {
    background: transparent;
    color: var(--oxblood);
    border: 1px solid var(--oxblood);
  }

  .tier-cta-ghost:hover {
    background: var(--oxblood);
    color: var(--ivory);
  }

  .tier-cta-filled {
    background: var(--oxblood);
    color: var(--ivory);
    border: 1px solid var(--gold);
  }

  .tier-cta-filled:hover {
    background: var(--oxblood-warm);
    border-color: var(--gold-warm);
  }

  /* Mandate block */
  .mandate-block {
    background: var(--obsidian);
    color: var(--ivory);
    padding: 48px 40px;
    border-radius: 12px;
    text-align: center;
    max-width: 1000px;
    margin-inline: auto;
    border: 1px solid var(--gold);
  }

  .mandate-rule {
    height: 1px;
    background: var(--gold);
    width: 120px;
    margin: 0 auto;
    opacity: 0.6;
  }

  .mandate-text {
    font-family: var(--ff-body);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    line-height: 1.8;
    max-width: 720px;
    margin: 24px auto;
  }

  .mandate-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    margin: 32px 0 24px;
    flex-wrap: wrap;
  }

  .mandate-cta {
    display: inline-block;
    background: var(--oxblood);
    color: var(--ivory);
    border: 1px solid var(--gold);
    padding: 0 32px;
    height: 56px;
    line-height: 56px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: background 300ms ease, border-color 300ms ease;
  }

  .mandate-cta:hover {
    background: var(--oxblood-warm);
    border-color: var(--gold-warm);
  }

  .mandate-signature {
    font-family: var(--ff-signature);
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
  }

  .micro-note {
    text-align: center;
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 12px;
    color: var(--ink-muted);
    margin-top: 32px;
  }

  @media (max-width: 1024px) {
    .tiers-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .tier-elevated, .tier-enterprise {
      transform: none;
    }
    .tier-enterprise:hover, .tier-elevated:hover {
      transform: translateY(-8px);
    }
  }

  @media (max-width: 640px) {
    .tier-card { padding: 28px 24px; }
    .tier-price { font-size: 42px; }
    .mandate-block { padding: 32px 24px; }
    .mandate-text { font-size: 12px; letter-spacing: 0.08em; }
    .mandate-actions { gap: 20px; flex-direction: column; }
    .mandate-signature { font-size: 36px; }
  }

  /* G.6 · Currency switcher */
  .currency-switcher {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .currency-btn {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--ink);
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--t-bg), border-color var(--t-border), color var(--t-color);
    opacity: 0.65;
  }

  .currency-btn:hover {
    opacity: 1;
    border-color: var(--oxblood);
  }

  .currency-btn.active {
    background: var(--oxblood);
    border-color: var(--oxblood);
    color: var(--gold);
    opacity: 1;
  }

  .currency-note {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink);
    opacity: 0.45;
    margin-left: 8px;
    font-style: italic;
  }

  .price-display {
    /* inherits tier-price font properties */
  }

  @media (max-width: 640px) {
    .currency-switcher { gap: 6px; }
    .currency-note { display: none; }
  }

  /* === Pilot engagement toggle === */
  .pilot-toggle {
    display: inline-flex;
    align-items: stretch;
    margin-bottom: 36px;
    border: 1px solid var(--gold-hairline);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(201, 167, 114, 0.04);
  }
  .pilot-btn {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 10px 20px;
    border: 0;
    background: transparent;
    color: var(--ink);
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 240ms ease, color 240ms ease;
    opacity: 0.65;
  }
  .pilot-btn-sub {
    font-size: 9px;
    letter-spacing: 0.16em;
    font-weight: 400;
    font-style: italic;
    text-transform: none;
    color: var(--ink-muted);
    margin-top: 2px;
  }
  .pilot-btn:hover { opacity: 1; }
  .pilot-btn.active {
    background: var(--oxblood);
    color: var(--gold);
    opacity: 1;
  }
  .pilot-btn.active .pilot-btn-sub { color: var(--gold); opacity: 0.85; }
  .pilot-btn + .pilot-btn { border-left: 1px solid var(--gold-hairline); }

  /* Strike-through standard rate (visible only when pilot is on) */
  .price-strike {
    display: none;
    font-family: var(--ff-display);
    font-size: 18px;
    color: var(--ink-muted);
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    margin-right: 10px;
    font-weight: 400;
    letter-spacing: 0;
    vertical-align: middle;
    opacity: 0.65;
  }
  .tier-card.show-strike .price-strike { display: inline-block; }
  .tier-card.tier-enterprise .price-strike { color: var(--pearl); opacity: 0.55; }

  /* Saves £X over the first six months */
  .saves-line {
    display: none;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--gold-text-strong);
    margin: 6px 0 12px;
    line-height: 1.4;
  }
  .tier-card.show-saves .saves-line { display: block; }
  .tier-card.tier-enterprise .saves-line { color: var(--gold); }

  /* Bottom microcopy: "Pilot engagement rate available for new mandates" */
  .pilot-microcopy {
    display: none;
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 11px;
    color: var(--ink-muted);
    margin-top: 14px;
    line-height: 1.4;
    text-align: center;
    opacity: 0.75;
  }
  .tier-card.show-microcopy .pilot-microcopy { display: block; }
  .tier-card.tier-enterprise .pilot-microcopy { color: var(--pearl); opacity: 0.7; }

  @media (max-width: 640px) {
    .pilot-toggle { width: 100%; }
    .pilot-btn { flex: 1; padding: 10px 12px; font-size: 11px; }
    .pilot-btn-sub { font-size: 8px; }
    .price-strike { font-size: 16px; margin-right: 8px; }
  }
</style>

<script>
  // Currency switcher (rates GBP 1 : USD 1.27 : AED 4.67) + pilot engagement toggle
  (function () {
    const RATES: Record<string, number> = { GBP: 1, USD: 1.27, AED: 4.67 };
    const SYMBOLS: Record<string, string> = { GBP: '£', USD: '$', AED: 'د.إ' };
    const LS_CURRENCY = 'tamazia_currency';
    const LS_PILOT = 'tamazia_pilot'; // 'on' | 'off' (default 'on')

    function rounded(gbp: number, currency: string): number {
      return Math.round(gbp * RATES[currency] / 100) * 100;
    }

    function formatPrice(gbp: number, currency: string): string {
      return `From ${SYMBOLS[currency]}${rounded(gbp, currency).toLocaleString()}`;
    }

    function formatPlain(gbp: number, currency: string): string {
      return `${SYMBOLS[currency]}${rounded(gbp, currency).toLocaleString()}`;
    }

    function activeAttr(pilotOn: boolean): string {
      return pilotOn ? 'data-gbp' : 'data-gbp-standard';
    }

    function applyAll(currency: string, pilotOn: boolean): void {
      document.querySelectorAll<HTMLElement>('[data-gbp]').forEach((priceEl) => {
        const card = priceEl.closest<HTMLElement>('.tier-card');
        const headlineGbp = parseInt(priceEl.getAttribute(activeAttr(pilotOn)) ?? '0', 10);
        const standardGbp = parseInt(priceEl.getAttribute('data-gbp-standard') ?? '0', 10);
        const savesGbp = parseInt(priceEl.getAttribute('data-saves-gbp') ?? '0', 10);

        // Headline price
        const display = priceEl.querySelector<HTMLElement>('.price-display');
        if (display) display.textContent = formatPrice(headlineGbp, currency);

        // Strike-through standard rate (only visible when pilot is on)
        const strike = priceEl.querySelector<HTMLElement>('.price-strike');
        if (strike) strike.textContent = formatPlain(standardGbp, currency);

        // Saves line (only visible when pilot is on)
        if (card) {
          const savesEl = card.querySelector<HTMLElement>('.saves-line');
          if (savesEl) {
            savesEl.textContent = `Saves ${formatPlain(savesGbp, currency)} over the first six months.`;
          }
          card.classList.toggle('show-strike', pilotOn);
          card.classList.toggle('show-saves', pilotOn);
          card.classList.toggle('show-microcopy', !pilotOn);
        }
      });
    }

    function activateCurrencyButton(currency: string): void {
      document.querySelectorAll<HTMLButtonElement>('.currency-btn').forEach((btn) => {
        const isActive = btn.dataset.currency === currency;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    function activatePilotButton(pilotOn: boolean): void {
      document.querySelectorAll<HTMLButtonElement>('.pilot-btn').forEach((btn) => {
        const isActive = (btn.dataset.pilot === 'on') === pilotOn;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    let currentCurrency = 'GBP';
    let currentPilot = true; // default ON

    function setCurrency(currency: string): void {
      currentCurrency = RATES[currency] ? currency : 'GBP';
      try { localStorage.setItem(LS_CURRENCY, currentCurrency); } catch (_) {}
      activateCurrencyButton(currentCurrency);
      applyAll(currentCurrency, currentPilot);
    }

    function setPilot(on: boolean): void {
      currentPilot = on;
      try { localStorage.setItem(LS_PILOT, on ? 'on' : 'off'); } catch (_) {}
      activatePilotButton(currentPilot);
      applyAll(currentCurrency, currentPilot);
    }

    // Init from localStorage with safe defaults
    try {
      const lsCurrency = localStorage.getItem(LS_CURRENCY);
      if (lsCurrency && RATES[lsCurrency]) currentCurrency = lsCurrency;
      const lsPilot = localStorage.getItem(LS_PILOT);
      if (lsPilot === 'off') currentPilot = false;
    } catch (_) {}

    document.querySelectorAll<HTMLButtonElement>('.currency-btn').forEach((btn) => {
      btn.addEventListener('click', () => setCurrency(btn.dataset.currency ?? 'GBP'));
    });
    document.querySelectorAll<HTMLButtonElement>('.pilot-btn').forEach((btn) => {
      btn.addEventListener('click', () => setPilot(btn.dataset.pilot === 'on'));
    });

    activateCurrencyButton(currentCurrency);
    activatePilotButton(currentPilot);
    applyAll(currentCurrency, currentPilot);
  })();
</script>
