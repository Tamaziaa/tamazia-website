---
import { caseStudiesContent } from '../../content/caseStudies';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, subline, cases, closingPullQuote } = caseStudiesContent;
---
<section class="case-studies" id="cases" aria-labelledby="cases-heading">
  <!-- Section header -->
  <div class="section-header">
    <div class="container">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="cases-heading" class="section-h2">{h2}</h2>
      <p class="subline">{subline}</p>
    </div>
  </div>

  <!-- Three alternating case panels -->
  {cases.map((c: any, i: number) => (
    <article
      class={`case-panel bg-${c.background}`}
      data-case={c.id}
      data-index={i}
      aria-label={`${c.numeral} ${c.client || c.meta}`}
    >
      <div class="parallax-bg" aria-hidden="true"></div>
      <div class="case-inner container">
        <div class="case-left">
          <div class="case-numeral">{c.numeral}</div>
          {c.client && <div class="case-client">{c.client}</div>}
          <div class="case-meta">{c.meta}</div>

          {Array.isArray(c.bodyParagraphs)
            ? c.bodyParagraphs.map((p: string) => <p class="case-body">{p}</p>)
            : <p class="case-body">{c.body}</p>
          }

          <blockquote class="case-verdict">{c.closingVerdict || c.pullQuote}</blockquote>

          <div class="case-verified">
            <span class="verified-seal">VERIFIED</span>
            <span class="verified-note">{c.verifiedNote}</span>
          </div>
        </div>
        <div class="case-right">
          {Array.isArray(c.metrics) ? (
            <div class="metrics-stack">
              {c.metrics.map((m: any) => (
                <div class="metric">
                  <div class="metric-value">{m.value}</div>
                  <div class="metric-label">{m.label}</div>
                  {m.note && <div class="metric-note">{m.note}</div>}
                </div>
              ))}
            </div>
          ) : (
            <>
              <div class="case-stat">{c.stat}</div>
              <div class="case-stat-caption">{c.statCaption}</div>
            </>
          )}
        </div>
      </div>
    </article>
  ))}

  <!-- Closing pull quote -->
  <div class="closing-block">
    <div class="container">
      <div class="closing-hairline" aria-hidden="true"></div>
      <blockquote class="closing-quote" set:html={parseEmph(closingPullQuote)} />
    </div>
  </div>
</section>

<style>
  .case-studies {
    position: relative;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  /* Section header · Round-10 · was 80-128 → 40-64 */
  .section-header {
    background: var(--ivory);
    padding-block: clamp(40px, 5vw, 64px);
    text-align: center;
  }

  .section-header .container { display: block; }

  .eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 20px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    color: var(--ink);
    margin-bottom: 16px;
    letter-spacing: var(--ls-h2);
  }

  .subline {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-muted);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Case panel · B-12 fix · reduced from 88vh to 70vh */
  .case-panel {
    position: relative;
    /* Round-10 · was min-height 70vh + padding 80-128 → 50vh + 40-64 */
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-block: clamp(40px, 5vw, 64px);
    overflow: hidden;
  }

  .bg-oxblood {
    background: var(--grad-oxblood-depth);
    color: var(--ivory);
  }

  /* Client name + new metrics stack */
  .case-client {
    font-family: var(--ff-display);
    font-size: clamp(28px, 2.5vw + 0.5rem, 38px);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  .bg-oxblood .case-client { color: var(--ivory); }
  .bg-ivory .case-client { color: var(--oxblood-ink); }

  .case-verdict {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: clamp(20px, 1.6vw + 0.4rem, 26px);
    line-height: 1.3;
    margin: 24px 0 32px;
    padding-left: 20px;
    border-left: 2px solid var(--gold);
    max-width: 600px;
  }
  .bg-oxblood .case-verdict { color: var(--gold-pale); }
  .bg-ivory .case-verdict { color: var(--oxblood); }

  .metrics-stack {
    display: grid;
    gap: 24px;
    align-items: start;
  }
  .metric {
    text-align: center;
    padding: 20px 16px;
    border: 1px solid var(--gold-hairline);
    border-radius: 2px;
  }
  .bg-oxblood .metric { border-color: var(--gold-hairline-strong); background: rgba(201, 167, 114, 0.04); }
  .bg-ivory .metric { background: rgba(255, 255, 255, 0.4); }

  .metric-value {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(36px, 4vw + 0.5rem, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .metric-label {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .bg-oxblood .metric-label { color: var(--pearl); }
  .bg-ivory .metric-label { color: var(--oxblood-ink); }

  .metric-note {
    font-family: var(--ff-body);
    font-size: 11px;
    line-height: 1.4;
    margin-top: 8px;
    font-style: italic;
  }
  .bg-oxblood .metric-note { color: rgba(232, 228, 220, 0.65); }
  .bg-ivory .metric-note { color: var(--ink-muted); }

  .bg-ivory {
    background: var(--ivory);
    color: var(--ink);
  }

  /* Parallax background layer */
  .parallax-bg {
    position: absolute;
    inset: -20% -10%;
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  /* B-27 fix · per-panel parallax accent palettes */
  /* Orchid (panel 1, ivory) · warm hospitality bronze */
  [data-case="orchid-hotels"] .parallax-bg {
    background:
      radial-gradient(ellipse 60% 40% at 15% 30%, rgba(178, 138, 86, 0.18) 0%, transparent 65%),
      radial-gradient(ellipse 70% 50% at 85% 75%, rgba(201, 167, 114, 0.14) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 100%, rgba(90, 26, 43, 0.05) 0%, transparent 60%);
  }

  /* Meraas (panel 2, oxblood) · oxblood depth + Dubai gold */
  [data-case="meraas"] .parallax-bg {
    background:
      radial-gradient(ellipse 70% 50% at 80% 20%, rgba(201, 167, 114, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 60% at 20% 80%, rgba(58, 15, 28, 0.7) 0%, transparent 70%),
      linear-gradient(135deg, rgba(58, 15, 28, 0.3) 0%, transparent 50%);
  }

  /* CGON (panel 3, ivory) · clinical pearl + NYSE oxblood accent */
  [data-case="cg-oncology"] .parallax-bg {
    background:
      radial-gradient(ellipse 60% 40% at 75% 25%, rgba(232, 228, 220, 0.7) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 25% 75%, rgba(90, 26, 43, 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 40% 25% at 50% 50%, rgba(201, 167, 114, 0.10) 0%, transparent 70%);
  }

  .case-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .case-numeral {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--gold);
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }

  .case-meta {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 32px;
  }

  .case-quote {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(28px, 3vw + 0.5rem, 48px);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin-bottom: 24px;
    position: relative;
    padding-left: 24px;
    border-left: 2px solid var(--gold);
  }

  .bg-oxblood .case-quote { color: var(--ivory); }
  .bg-ivory .case-quote { color: var(--ink); }

  .case-body {
    font-family: var(--ff-body);
    font-size: 16px;
    line-height: 1.65;
    max-width: 540px;
    margin-bottom: 32px;
    font-weight: 300;
  }

  .bg-oxblood .case-body { color: var(--pearl); opacity: 0.85; }
  .bg-ivory .case-body { color: var(--ink-muted); }

  .case-verified {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .verified-seal {
    font-family: var(--ff-body);
    /* Round-12 fix · 11px instead of 10px clears axe contrast threshold for small text;
       --oxblood-ink (#2A0C14) on --gold (#C9A772) gives ~7.85:1 vs prior --oxblood (~5.65:1)
       which axe was rejecting at 10px. */
    font-size: 11px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--oxblood-ink);
    font-weight: 700;
    padding: 4px 12px;
    background: var(--gold);
    border-radius: 2px;
  }

  .case-panel.bg-oxblood .verified-seal,
  .case-panel.bg-oxblood-deep .verified-seal,
  .case-panel.bg-ink .verified-seal {
    color: var(--oxblood-ink);
    background: var(--gold-pale, #D4B787);
  }

  .verified-note {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* Round-7 v3 · case-panel itself has bg-ivory; gold = 2.12:1 fails. Deep bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 500;
  }
  /* Round-7 v3 · dark variant for case panels with bg-ink/bg-oxblood (only first panel is bg-ivory) */
  .case-panel.bg-ink .verified-note,
  .case-panel.bg-oxblood .verified-note,
  .case-panel.bg-oxblood-deep .verified-note {
    color: var(--gold);
  }

  /* Case right (big stat) */
  .case-right {
    text-align: center;
  }

  .case-stat {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(72px, 8vw + 0.5rem, 140px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--gold);
    font-feature-settings: 'lnum', 'tnum';
    margin-bottom: 24px;
  }

  .case-stat-caption {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 1.6;
    max-width: 320px;
    margin-inline: auto;
  }

  .bg-oxblood .case-stat-caption { color: var(--pearl); opacity: 0.75; }
  .bg-ivory .case-stat-caption { color: var(--ink-muted); }

  /* Closing · Round-10 · was 96-160 → 48-80 */
  .closing-block {
    background: var(--ivory);
    padding-block: clamp(48px, 6vw, 80px);
    text-align: center;
  }

  .closing-hairline {
    height: 1px;
    background: var(--gold);
    width: 120px;
    margin: 0 auto 40px;
    opacity: 0.6;
  }

  .closing-quote {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(28px, 3vw + 0.5rem, 40px);
    font-style: italic;
    line-height: 1.2;
    color: var(--ink);
    max-width: 720px;
    margin-inline: auto;
    letter-spacing: -0.01em;
  }

  .closing-quote :global(.emph) {
    color: var(--oxblood);
    font-style: italic;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .case-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .case-right { text-align: left; }
    .case-stat-caption { margin-inline: 0; }
    .case-panel { min-height: auto; }
  }

  @media (max-width: 640px) {
    .case-quote { font-size: 24px; padding-left: 16px; }
    .case-body { font-size: 14px; }
    .case-stat { font-size: 80px; }
    .case-stat-caption { font-size: 10px; }
    .section-h2 { font-size: 36px; }
  }
</style>

<script>
  // Parallax: background layer moves at 0.6× scroll speed within each case panel.
  // Entrance animation: fade-in-up on case content.
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Parallax on scroll
    if (!reduce) {
      const panels = document.querySelectorAll<HTMLElement>('.case-panel');
      const updateParallax = () => {
        const vh = window.innerHeight;
        panels.forEach((panel) => {
          const rect = panel.getBoundingClientRect();
          if (rect.bottom < 0 || rect.top > vh) return;
          const mid = rect.top + rect.height / 2;
          const offset = (mid - vh / 2) * 0.3;
          const bg = panel.querySelector<HTMLElement>('.parallax-bg');
          if (bg) bg.style.transform = `translateY(${-offset}px)`;
        });
      };

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateParallax();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
      updateParallax();
    }

    // Entrance animation
    const entrance = document.querySelectorAll<HTMLElement>('.case-inner > *');
    entrance.forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 800ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 800ms cubic-bezier(0.2, 0.8, 0.2, 1)';
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const panel = entry.target as HTMLElement;
        const children = panel.querySelectorAll<HTMLElement>('.case-inner > *');
        children.forEach((child, i) => {
          setTimeout(() => {
            child.style.opacity = '1';
            child.style.transform = 'translateY(0)';
          }, i * 150);
        });
        observer.unobserve(panel);
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.case-panel').forEach((el) => observer.observe(el));

    /* Round-10 safety · ensure case panels always become visible after 3s even if observer never fires (deep-link, JS race) */
    setTimeout(() => {
      document.querySelectorAll('.case-panel:not(.in-view)').forEach(el => el.classList.add('in-view'));
    }, 3000);

    // Rolling counter on the case stat
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const final = el.textContent || '';
        const match = final.match(/^([+\-£$€]?)(\d+)(\.?\d*)([%MKB×]?)/);
        if (!match) {
          statObserver.unobserve(el);
          return;
        }
        const prefix = match[1] || '';
        const target = parseInt(match[2], 10);
        const suffix = (match[3] || '') + (match[4] || '');
        const duration = 1400;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.floor(target * eased);
          el.textContent = prefix + value + suffix;
          if (progress < 1) requestAnimationFrame(tick);
          else el.textContent = final;
        };
        el.textContent = prefix + '0' + suffix;
        requestAnimationFrame(tick);
        statObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll<HTMLElement>('.case-stat').forEach((el) => {
      // Only animate if the stat starts with a number-like pattern
      if (/^[+\-£$€]?\d/.test((el.textContent || '').trim())) {
        statObserver.observe(el);
      }
    });
  });
</script>
