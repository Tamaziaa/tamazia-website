---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
const lastUpdated = '5 May 2026';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://tamazia.co.uk/#organization',
  name: 'Tamazia',
  url: 'https://tamazia.co.uk',
  logo: 'https://tamazia.co.uk/tamazia-lockup-master.png',
  founder: {
    '@type': 'Person',
    name: 'Aman Pareek',
    jobTitle: 'Founder',
    alumniOf: { '@type': 'EducationalOrganization', name: "King’s College London" }
  },
  sameAs: [],
  contactPoint: { '@type': 'ContactPoint', contactType: 'press', email: 'founder@tamazia.co.uk' }
};
---
<BaseLayout
  ogImage="/og/press.png"
  title="Press · Tamazia"
  description="Press kit, brand assets, and media contact for Tamazia · lawyer-led SEO and compliance content for regulated enterprises."
  canonical="https://tamazia.co.uk/press/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  <Header />
  <main id="main" class="press">
    <article class="press-inner">
      <p class="eyebrow">PRESS · TAMAZIA</p>
      <h1>Press kit</h1>
      <p class="updated">Last updated {lastUpdated}.</p>

      <h2>About Tamazia</h2>
      <p>Tamazia is a lawyer-led SEO and compliance content firm working with regulated enterprises across the UK, EU, US, and Middle East. The founding team is based in London and Mumbai. Engagements are delivered by a small permanent team and a vetted network of freelance contributors.</p>

      <h2>Quick facts</h2>
      <ul class="facts">
        <li><strong>Founder:</strong> Aman Pareek · LLM, King’s College London</li>
        <li><strong>Founded:</strong> 2026</li>
        <li><strong>Markets served:</strong> UK · UAE · USA · France · Singapore · Hong Kong</li>
        <li><strong>Sectors:</strong> Healthcare · Law firms · Real estate · Hospitality · Finance · Education · F&B</li>
      </ul>

      <h2>Boilerplate paragraphs</h2>
      <h3>50 characters</h3>
      <p class="quote">Lawyer-led SEO for regulated enterprises.</p>

      <h3>150 characters</h3>
      <p class="quote">Tamazia is a lawyer-led SEO and compliance content firm. Every campaign passes through 400+ regulatory frameworks before anything goes live.</p>

      <h3>500 characters</h3>

      <h2>Brand assets</h2>
      <ul class="assets">
        <li><a href="/tamazia-lockup-master.png">Master lockup · PNG</a></li>
        <li><a href="/tamazia-mark-horse.png">Horse mark · PNG</a></li>
        <li><a href="/favicon.svg">Logo · SVG (favicon)</a></li>
        <li><a href="/og-default.png">Open Graph image · 1200 × 630</a></li>
        <li><a href="/brand-guidelines.pdf">Brand guidelines · PDF (placeholder · contact for current version)</a></li>
      </ul>

      <h2>Brand colours</h2>
      <ul class="colours">
        <li><code>#5A1A2B</code> · Oxblood · primary</li>
        <li><code>#2A0C14</code> · Oxblood Ink · text</li>
        <li><code>#C9A772</code> · Gold Soft · accent</li>
        <li><code>#FAF7F2</code> · Ivory · background</li>
        <li><code>#5C4047</code> · Ink Muted · secondary text</li>
      </ul>

      <h2>Type</h2>
      <ul>
        <li><strong>Display:</strong> Playfair Display 500</li>
        <li><strong>Body:</strong> Inter 400 / 500 / 600</li>
        <li><strong>Editorial:</strong> Georgia (system serif fallback)</li>
      </ul>

      <h2>Press contact</h2>
      <p>Aman Pareek · founder@tamazia.co.uk · responses within one working day, UK time.</p>

      <p class="back"><a href="/">Back to home →</a></p>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .press { background: var(--ivory, #FAF7F2); color: var(--oxblood-ink, #2A0C14); padding: 88px 24px 120px; }
  .press-inner { max-width: 800px; margin: 0 auto; }
  .eyebrow { font-family: 'Inter', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.16em; color: var(--oxblood, #5A1A2B); margin-bottom: 14px; }
  .press h1 { font-family: var(--ff-display, 'Playfair Display', Georgia, serif); font-weight: 500; font-size: clamp(36px, 6vw, 56px); margin: 0 0 8px; }
  .updated { font-family: 'Inter', system-ui, sans-serif; font-size: 13px; color: var(--ink-muted, #5C4047); margin-bottom: 32px; }
  .press h2 { font-family: var(--ff-display); font-weight: 500; font-size: 24px; margin: 36px 0 12px; }
  .press h3 { font-family: 'Inter', system-ui, sans-serif; font-size: 13px; letter-spacing: 0.06em; color: var(--ink-muted); text-transform: uppercase; margin: 24px 0 6px; }
  .press p { font-family: Georgia, serif; font-size: 17px; line-height: 1.6; margin: 0 0 16px; }
  .quote { background: rgba(201, 167, 114, 0.12); padding: 12px 16px; border-left: 2px solid var(--gold-soft, #C9A772); }
  .facts, .assets, .colours { font-family: 'Inter', system-ui, sans-serif; font-size: 14px; line-height: 1.6; padding-left: 18px; }
  .facts li, .assets li, .colours li { margin-bottom: 6px; }
  .colours code { font-family: ui-monospace, Menlo, monospace; font-size: 12px; background: rgba(0,0,0,0.04); padding: 2px 6px; border-radius: 2px; }
  .assets a { color: var(--oxblood, #5A1A2B); border-bottom: 1px solid var(--gold-soft, #C9A772); }
  .back { margin-top: 48px; }
  .back a { color: var(--oxblood, #5A1A2B); border-bottom: 1px solid var(--gold-soft, #C9A772); font-family: 'Inter', system-ui, sans-serif; font-size: 13px; }
</style>
