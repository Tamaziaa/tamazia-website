---
// 404 page · returned by Cloudflare Pages for any unknown URL.
// Without this, CF SPA-fallbacks to the home page with HTTP 200, which is an SEO + UX disaster
// (Google indexes phantom URLs, users see the homepage instead of an error).
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout
  title="Page not found · Tamazia"
  description="The page you were looking for is not on this site. Return to the home page or use the navigation."
  noindex={true}
>
  <Header />
  <main id="main" class="not-found">
    <div class="container">
      <p class="numeral">404</p>
      <h1 class="heading">This page is not on file.</h1>
      <p class="lede">
        The address you arrived at is not part of the Tamazia site. It may have been moved, retired,
        or never existed. Use the links below or the main navigation to continue.
      </p>
      <ul class="quick-links">
        <li><a href="/">Home</a></li>
        <li><a href="/#quick-audit">Run the compliance audit</a></li>
        <li><a href="/#sectors">Sectors we serve</a></li>
        <li><a href="/#contact">Request a briefing</a></li>
        <li><a href="/resources/">Resources</a></li>
      </ul>
      <p class="signature">Tamazia · International SEO for regulated enterprises</p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    padding: 96px 0 120px;
    background: var(--ivory);
    color: var(--oxblood-ink);
    display: flex;
    align-items: center;
  }
  .container { max-width: 720px; margin: 0 auto; padding: 0 24px; text-align: center; }
  .numeral {
    font-family: var(--ff-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(72px, 14vw, 160px);
    line-height: 1;
    color: var(--oxblood);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .heading {
    font-family: var(--ff-display, 'Playfair Display', Georgia, serif);
    font-weight: 500;
    font-size: clamp(28px, 5vw, 44px);
    margin: 0 0 16px;
    color: var(--oxblood-ink);
  }
  .lede {
    font-family: var(--ff-body, Inter, system-ui, sans-serif);
    font-size: 16px;
    line-height: 1.7;
    margin: 0 auto 32px;
    max-width: 560px;
    color: var(--oxblood-wine);
  }
  .quick-links {
    list-style: none;
    padding: 0;
    margin: 0 0 48px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 24px;
    font-family: var(--ff-body, Inter, system-ui, sans-serif);
    font-size: 14px;
    letter-spacing: 0.04em;
  }
  .quick-links a {
    color: var(--gold-text-strong, #5C3F18);
    text-decoration: none;
    border-bottom: 1px solid var(--gold-text-strong, #5C3F18);
    padding: 8px 0;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .quick-links a:hover { color: var(--oxblood); border-bottom-color: var(--oxblood); }
  .signature {
    font-family: var(--ff-body, Inter, system-ui, sans-serif);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--oxblood-mist, #6D2037);
    margin: 0;
  }
  @media (max-width: 640px) {
    .not-found { padding: 64px 0 80px; }
    .quick-links { flex-direction: column; gap: 4px; }
  }
</style>
