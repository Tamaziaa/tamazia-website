---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { insightSectors, insightPosts } from '../../content/insights';

const published = insightPosts.filter((p) => p.status === 'published');
---
<BaseLayout title="Resources · Tamazia" description="Sector-specific compliance and SEO resources for regulated enterprises. Legal, healthcare, hospitality, real estate, finance, and beyond.">
  <Header />
  <main id="main">
    <section class="insights-hero">
      <div class="container">
        <div class="eyebrow">TAMAZIA · Insights</div>
        <h1>Insights written against the framework that governs you.</h1>
        <p class="subline">
          Sector-specific compliance and SEO findings from the Tamazia team. SRA, MHRA, FCA, RERA, SEC Reg FD — every post is written against the regulatory line that applies to your business.
        </p>
      </div>
    </section>

    <section class="sectors-list">
      <div class="container">
        <h2 class="section-h2">Browse by sector</h2>
        <div class="sector-grid">
          {insightSectors.map((s) => {
            const sectorPosts = insightPosts.filter((p) => p.sectorSlug === s.slug);
            const sectorPublished = sectorPosts.filter((p) => p.status === 'published').length;
            return (
              <a class="sector-card" href={`/resources/${s.slug}/`}>
                <div class="sector-card-meta">{s.regulator}</div>
                <h3 class="sector-card-title">{s.title}</h3>
                <p class="sector-card-hero">{s.hero}</p>
                <div class="sector-card-stats">
                  <span class="stat">{sectorPublished} published</span>
                  <span class="dot">·</span>
                  <span class="stat">{sectorPosts.length - sectorPublished} in preparation</span>
                </div>
                <span class="sector-card-cta">Read insights →</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="latest-posts">
      <div class="container">
        <h2 class="section-h2">Latest published</h2>
        <div class="posts-grid">
          {published.map((p) => (
            <a class="post-card" href={`/resources/${p.sectorSlug}/${p.slug}/`}>
              <div class="post-meta">{p.sector} · {p.regulator}</div>
              <h3 class="post-title">{p.title}</h3>
              <p class="post-excerpt">{p.excerpt}</p>
              <div class="post-footer">
                <span class="reading-time">{p.readingTime}</span>
                <span class="read-link">Read →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }
  .insights-hero {
    background: var(--grad-hero);
    padding-block: clamp(80px, 10vw, 140px);
  }
  .insights-hero .eyebrow {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 18px;
  }
  .insights-hero h1 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(40px, 5vw + 0.5rem, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--oxblood-ink);
    max-width: 920px;
    margin-bottom: 16px;
  }
  .insights-hero .subline {
    font-family: var(--ff-body);
    font-size: clamp(15px, 0.6vw + 0.7rem, 17px);
    line-height: 1.55;
    color: var(--ink-muted);
    max-width: 720px;
  }
  .sectors-list, .latest-posts {
    background: var(--grad-whyus);
    padding-block: clamp(64px, 8vw, 112px);
  }
  .latest-posts {
    background: var(--grad-contact);
  }
  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(28px, 2.5vw + 0.5rem, 40px);
    color: var(--oxblood-ink);
    margin-bottom: 32px;
    letter-spacing: -0.015em;
  }
  .sector-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .sector-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--gold-hairline);
    border-radius: 4px;
    text-decoration: none;
    transition: transform 280ms var(--ease-out), border-color 280ms var(--ease-out), box-shadow 280ms var(--ease-out);
  }
  .sector-card:hover {
    transform: translateY(-4px);
    border-color: var(--gold);
    box-shadow: 0 12px 32px rgba(90, 26, 43, 0.1);
  }
  .sector-card-meta {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .sector-card-title {
    font-family: var(--ff-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--oxblood-ink);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .sector-card-hero {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-muted);
    flex: 1;
    margin-bottom: 16px;
  }
  .sector-card-stats {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 14px;
  }
  .sector-card-stats .dot { margin: 0 8px; color: var(--gold); }
  .sector-card-stats .stat:first-child { color: var(--oxblood); font-weight: 600; }
  .sector-card-cta {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    padding: 32px;
    background: var(--ivory);
    border: 1px solid var(--gold-hairline);
    border-radius: 4px;
    text-decoration: none;
    transition: transform 280ms var(--ease-out), border-color 280ms var(--ease-out);
  }
  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--gold);
  }
  .post-meta {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* Round-12 fix · bronze token replaces decorative gold for body-size accents on light bg */
    color: var(--gold-text-strong);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .post-title {
    font-family: var(--ff-display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.25;
    color: var(--oxblood-ink);
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .post-excerpt {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-muted);
    flex: 1;
    margin-bottom: 18px;
  }
  .post-footer {
    display: flex;
    justify-content: space-between;
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .reading-time { color: var(--ink-muted); }
  /* Round-12 fix · bronze token replaces decorative gold for accessible contrast */
  .read-link { color: var(--gold-text-strong); }
</style>
</BaseLayout>
