<script>
  (() => {
    /* ============================================================
       FinalHero - Sextant sector compass
       Scoped to .tz-mhero to avoid conflicts with other sections
    ============================================================ */

    // ---- 1. Sector data ----
    const SECTORS = [
      { name: "Law",          abbr: "LAW", laws: ["SRA Code", "MLR 2017", "GDPR Art.6", "DIFC L&R"],         fine: 'SRA · £300K · AML controls · <em>Mar 2025</em>' },
      { name: "Healthcare",   abbr: "HLT", laws: ["MHRA Blue", "FDA §202", "HIPAA", "ASA CAP-M"],            fine: 'MHRA · POM weight-loss enforcement · <em>2025</em>' },
      { name: "Hospitality",  abbr: "HSP", laws: ["DMCC 2024", "CMA CPR", "ASA CAP", "GDPR"],               fine: 'CMA · £4.2M · drip pricing · <em>2025</em>' },
      { name: "Real Estate",  abbr: "RE",  laws: ["SEC Reg-FD", "FCA LR9", "RERA L26", "EU Prosp."],         fine: 'SEC · $19M · IPO disclosure failure · <em>2024</em>' },
      { name: "Finance",      abbr: "FIN", laws: ["FCA COBS", "MiFID II", "SEC Mkt Rule", "DFSA COB"],       fine: 'FCA · £29M · AML control failure · <em>2024</em>' },
      { name: "Education",    abbr: "EDU", laws: ["ICO / DPA", "GDPR Art.8", "FERPA", "KCSIE 2024"],         fine: 'ICO · £350K · pupil data breach · <em>2024</em>' },
      { name: "Professional", abbr: "PRO", laws: ["FRC ES", "ABA MR 7.1", "ICAEW CoE", "LCIA Art.14"],       fine: 'FRC · £21M · audit independence · <em>2024</em>' }
    ];
    const N = SECTORS.length;
    const STEP_MS = 2000;
    const SWAP_MS = 240;

    const root = document.querySelector('.tz-mhero');
    if (!root) return;

    // ---- 2. Build rim ticks + abbreviations ----
    (() => {
      const ns = "http://www.w3.org/2000/svg";
      const g = root.querySelector("#tz-secs");
      if (!g) return;
      const cx = 150, cy = 130, Ri = 100, Ro = 108, Rt = 120;
      SECTORS.forEach((s, i) => {
        const deg = -60 + i * 20;
        const rad = (deg - 90) * Math.PI / 180;
        const x1 = cx + Ri * Math.cos(rad), y1 = cy + Ri * Math.sin(rad);
        const x2 = cx + Ro * Math.cos(rad), y2 = cy + Ro * Math.sin(rad);
        const xt = cx + Rt * Math.cos(rad), yt = cy + Rt * Math.sin(rad);

        const tick = document.createElementNS(ns, "line");
        tick.setAttribute("x1", x1.toFixed(1));
        tick.setAttribute("y1", y1.toFixed(1));
        tick.setAttribute("x2", x2.toFixed(1));
        tick.setAttribute("y2", y2.toFixed(1));
        tick.setAttribute("class", "tz-cp-tick");
        tick.dataset.i = String(i);
        g.appendChild(tick);

        const t = document.createElementNS(ns, "text");
        t.setAttribute("x", xt.toFixed(1));
        t.setAttribute("y", (yt + 2.5).toFixed(1));
        t.setAttribute("text-anchor", "middle");
        t.setAttribute("class", "tz-cp-abbr");
        t.dataset.i = String(i);
        t.textContent = s.abbr;
        g.appendChild(t);
      });
    })();

    // ---- 3. Synced cycle ----
    const Compass = (() => {
      const needleG = root.querySelector(".tz-cp-needle-g");
      const tickRoot = root.querySelector("#tz-secs");
      const nameEl   = root.querySelector("#tz-name");
      const idxEl    = root.querySelector("#tz-idx");
      const idxInln  = root.querySelector("#tz-idx-inline");
      const lawsEl   = root.querySelector("#tz-laws");
      const fineEl   = root.querySelector("#tz-fine");
      const fineRow  = root.querySelector(".tz-fine");
      const bandRow  = root.querySelector(".tz-band");

      let i = 1;
      let timer = null;
      let running = false;

      function paint(idx) {
        const s = SECTORS[idx];
        const deg = -60 + idx * 20;
        if (needleG) needleG.style.transform = `rotate(${deg}deg)`;
        if (tickRoot) {
          tickRoot.querySelectorAll("[data-i]").forEach(el => {
            el.classList.toggle("is-active", +el.dataset.i === idx);
          });
        }
        if (fineRow) fineRow.classList.add("is-swapping");
        if (bandRow) bandRow.classList.add("is-swapping");
        setTimeout(() => {
          if (nameEl)  nameEl.textContent  = s.name;
          if (idxEl)   idxEl.textContent   = String(idx + 1).padStart(2, "0");
          if (idxInln) idxInln.textContent = String(idx + 1).padStart(2, "0");
          if (lawsEl)  lawsEl.innerHTML    = s.laws.map(l => `<span>${l}</span>`).join("");
          if (fineEl)  fineEl.innerHTML    = s.fine;
          if (fineRow) fineRow.classList.remove("is-swapping");
          if (bandRow) bandRow.classList.remove("is-swapping");
        }, SWAP_MS);
      }

      function tick() { i = (i + 1) % N; paint(i); }
      function start() {
        if (running) return;
        running = true;
        paint(i);
        timer = setInterval(tick, STEP_MS);
      }
      function stop() {
        running = false;
        clearInterval(timer);
        timer = null;
      }
      return { start, stop };
    })();

    // ---- 4. Auto-start when in view, no hover pause ----
    (() => {
      const panel = root.querySelector(".tz-panel");
      if (!panel) return;
      let inView = false;
      const io = new IntersectionObserver(([e]) => {
        inView = e.isIntersecting;
        inView ? Compass.start() : Compass.stop();
      }, { threshold: 0.15 });
      io.observe(panel);
      // Tab hide/show
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) Compass.stop();
        else if (inView) Compass.start();
      });
    })();

    // ---- 5. Scroll-triggered reveals (scoped to .tz-mhero) ----
    (() => {
      const els = root.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window)) {
        els.forEach(el => el.classList.add("is-revealed"));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("is-revealed");
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.18, rootMargin: "0px 0px -8% 0px" });
      els.forEach(el => io.observe(el));
    })();

    // ---- 6. Founder portrait fallback ----
    (() => {
      const img = root.querySelector(".tz-founder-photo-img");
      if (!img) return;
      img.addEventListener("error", () => img.classList.add("is-broken"));
      if (!img.getAttribute("src")) img.classList.add("is-broken");
    })();
    // ---- 7. H1 typewriter ----
    (() => {
      function typeText(el, text, speed, onDone) {
        el.classList.add('tz-tw-typing');
        const segments = [];
        let remaining = text;
        while (remaining.length > 0) {
          const start = remaining.indexOf('{{');
          if (start === -1) { segments.push({ text: remaining, emph: false }); break; }
          if (start > 0) segments.push({ text: remaining.substring(0, start), emph: false });
          const end = remaining.indexOf('}}', start);
          segments.push({ text: remaining.substring(start + 2, end), emph: true });
          remaining = remaining.substring(end + 2);
        }
        let segIdx = 0, charIdx = 0;
        const iv = setInterval(() => {
          if (segIdx >= segments.length) {
            clearInterval(iv);
            el.classList.remove('tz-tw-typing');
            if (onDone) onDone();
            return;
          }
          const seg = segments[segIdx];
          charIdx++;
          let html = '';
          for (let j = 0; j < segIdx; j++) {
            html += segments[j].emph
              ? '<em class=\"tz-word\">' + segments[j].text + '</em>'
              : segments[j].text;
          }
          const partial = seg.text.substring(0, charIdx);
          html += seg.emph ? '<em class=\"tz-word\">' + partial + '</em>' : partial;
          el.innerHTML = html;
          if (charIdx >= seg.text.length) { segIdx++; charIdx = 0; }
        }, speed);
      }

      const twLines = Array.from(root.querySelectorAll('.tz-tw-line'));
      if (!twLines.length) return;

      let started = false;
      function startTypewriter() {
        if (started) return;
        started = true;
        function runLine(idx) {
          if (idx >= twLines.length) return;
          const el = twLines[idx];
          const text = el.dataset.text || '';
          typeText(el, text, 42, () => setTimeout(() => runLine(idx + 1), 280));
        }
        runLine(0);
      }

      const h2 = root.querySelector('.tz-headline');
      if (!h2) return;
      const twIo = new IntersectionObserver(([e]) => {
        if (e.isIntersecting) { twIo.disconnect(); setTimeout(startTypewriter, 250); }
      }, { threshold: 0.25 });
      twIo.observe(h2);
    })();

  })();
</script>
