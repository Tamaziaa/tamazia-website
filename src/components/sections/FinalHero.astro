---
// FinalHero.astro — Sextant sector compass hero
// Inserted in index.astro: after <Header />, before <LawsStrip />
// Founder portrait: /public/aman-portrait.webp (already in repo)
// No external font imports — site uses self-hosted WOFF2
import { heroContent } from '../../content/hero';
const frameworks = (heroContent as any).regulationFrameworks || [];
const goldFrameworks: string[] = (heroContent as any).goldHighlightedFrameworks || [];
const ribbonDouble = [...frameworks, ...frameworks];

/**
 * M3 typewriter substrate (audit findings A1/A2/A4): the headline is now a real
 * <h1> with its FULL text server-rendered. Words appear with steps(1) snaps,
 * each delayed by the time its characters would take to type, so the rhythm
 * reads as typing while crawlers and the LCP element see complete text, no
 * innerHTML runs at runtime, reduced-motion shows it instantly, and height
 * never shifts (opacity-only). Word-level spans (not per-character) preserve
 * Playfair's kerning and ligatures. {{segments}} keep the gold-italic emphasis.
 */
type Word = { w: string; emph: boolean; d: number };
const CHAR_MS = 34;            // pacing per character (was 42ms via setInterval)
const LINE_GAP_MS = 220;       // pause between lines (was 280ms)
function splitLine(text: string, startMs: number): { words: Word[]; endMs: number } {
  const words: Word[] = [];
  let t = startMs;
  const segs: { text: string; emph: boolean }[] = [];
  let rest = text;
  while (rest.length) {
    const open = rest.indexOf('{{');
    if (open === -1) { segs.push({ text: rest, emph: false }); break; }
    if (open > 0) segs.push({ text: rest.slice(0, open), emph: false });
    const close = rest.indexOf('}}', open);
    segs.push({ text: rest.slice(open + 2, close), emph: true });
    rest = rest.slice(close + 2);
  }
  for (const seg of segs) {
    for (const w of seg.text.split(' ').filter(Boolean)) {
      t += w.length * CHAR_MS;           // the word "finishes typing" at t
      words.push({ w, emph: seg.emph, d: t });
      t += CHAR_MS;                       // the space
    }
  }
  return { words, endMs: t };
}
const twSource = [
  'Outrank {{competitors.}}',
  'Master {{regulators.}}',
  'One agency.',
];
let cursorMs = 250; // small lead-in
const twLines = twSource.map((src, i) => {
  const { words, endMs } = splitLine(src, cursorMs);
  cursorMs = endMs + LINE_GAP_MS;
  return { words, em: i === 2 };
});
const twTotalMs = cursorMs - LINE_GAP_MS;
---

<div class="tz-hero-wrap">
<aside class="tz-laws-ribbon" aria-hidden="true">
  <div class="tz-laws-ribbon-track">
    {ribbonDouble.map((reg: string) => (
      <span class={goldFrameworks.includes(reg) ? 'gold' : ''}>{reg}</span>
    ))}
  </div>
</aside>
<section class="tz-mhero" aria-label="Tamazia sector compass hero">



  {/* F1 · Eyebrow principle — restyled, 'legal' standout */}
  <p class="tz-eyebrow-principle" data-reveal="fade" style="--rd:40ms">
    <span class="tz-eyebrow-orn" aria-hidden="true"></span>
    <span class="tz-eyebrow-text">Ranking is only valuable if it is <em><span class="tz-eyebrow-legal">legal.</span></em></span>
    <span class="tz-eyebrow-orn" aria-hidden="true"></span>
  </p>

  {/* M3: real h1, full text in server HTML, word-level steps(1) stagger paced
      by character count (the same typing rhythm, kerning preserved).
      Audit findings A1/A2/A4. */}
  <h1 class="tz-headline" style={`--tw-total:${twTotalMs}ms`}>
    {twLines.map((line) => (
      <span class={line.em ? 'tz-line tz-line-em' : 'tz-line'}>
        {line.words.map((word) => (
          <>
            {word.emph
              ? <em class="tz-word"><span class="tz-tw-w" style={`--d:${word.d}ms`}>{word.w}</span></em>
              : <span class="tz-tw-w" style={`--d:${word.d}ms`}>{word.w}</span>}
            {' '}
          </>
        ))}
      </span>
    ))}
    <span class="tz-caret" aria-hidden="true"></span>
  </h1>

  <div class="tz-subs">
    <div class="tz-sub" data-reveal="slide" style="--rd:480ms"><span class="tz-sub-rule"></span><em>Search dominance, every market.</em></div>
    <div class="tz-sub" data-reveal="slide" style="--rd:580ms"><span class="tz-sub-rule"></span><em>400+ frameworks reviewed, every word.</em></div>
    <div class="tz-sub" data-reveal="slide" style="--rd:680ms"><span class="tz-sub-rule"></span><em>Counsel-led, every campaign.</em></div>
  </div>

  <div class="tz-body tz-body-compact" data-reveal="slide">
    {/* F8 · single-line compliance line — dropcap dropped, sized as a balanced statement */}
    <p>Compliance reviewed before publication, every engagement.</p>
  </div>

  <div class="tz-pull-left" data-reveal="lift">
    <p>Your SEO agency doesn't have a <em>lawyer.</em> <em>Ours is run by one.</em></p>
  </div>

  <div class="tz-body tz-body-tight" data-reveal="slide">
    <p>Every campaign executed through us passes through <strong>400+ laws</strong> before anything goes live:</p>
  </div>
  {/* S11 (Impl Doc v1.0) · Hero chip row clickable to sector cards + hover tooltips */}
  <div class="tz-chips" data-reveal="fade" style="--rd:80ms">
    <a class="tz-chip" href="#sectors" title="Universal data-protection baseline · UK + EU + processor obligations" aria-label="GDPR · Universal data-protection baseline · UK + EU + processor obligations"><span>GDPR</span></a><a class="tz-chip" href="#sectors" title="Financial promotion + COBS 4 + MAR · applies wherever property or financial product offers appear" aria-label="FCA · Financial promotion + COBS 4 + MAR · applies wherever property or financial product offers appear"><span>FCA</span></a><a class="tz-chip" href="#sector-legal" title="UK solicitor advertising · Standards 8.7/8.9 + Transparency Rules 2018" aria-label="SRA · UK solicitor advertising · Standards 8.7/8.9 + Transparency Rules 2018"><span>SRA</span></a><a class="tz-chip" href="#sector-healthcare" title="UK medicines advertising · Human Medicines Regulations 2012 + ASA CAP-M enforcement" aria-label="MHRA · UK medicines advertising · Human Medicines Regulations 2012 + ASA CAP-M enforcement"><span>MHRA</span></a><a class="tz-chip" href="#sectors" title="UK advertising claims · CAP Code + AI-powered Active Ad Monitoring (live 2025+)" aria-label="ASA · UK advertising claims · CAP Code + AI-powered Active Ad Monitoring (live 2025+)"><span>ASA</span></a><a class="tz-chip" href="#sector-healthcare" title="US protected health information · 45 CFR 164.508/164.502 marketing rules" aria-label="HIPAA · US protected health information · 45 CFR 164.508/164.502 marketing rules"><span>HIPAA</span></a><a class="tz-chip" href="#sectors" title="AI system risk-tier rules · Article 6 high-risk applies to legal + healthcare practice systems" aria-label="EU AI ACT · AI system risk-tier rules · Article 6 high-risk applies to legal + healthcare practice systems"><span>EU AI ACT</span></a>
  </div>
  <p class="tz-chips-suffix" data-reveal="fade" style="--rd:160ms"><em>and international advertising laws.</em></p>

  <div class="tz-founder-cta-row">
  <aside class="tz-founder" data-reveal="lift">
    <div class="tz-founder-rule"><span></span><em>Founder</em><span></span></div>
    <div class="tz-founder-pill">
      <div class="tz-founder-head">
        <div class="tz-founder-photo">
          <img
            class="tz-founder-photo-img"
            src="/aman-portrait.webp"
            alt="Aman Pareek, founder of Tamazia"
            width="120"
            height="120"
            loading="lazy"
          />
          <span class="tz-founder-photo-mark" aria-hidden="true">AP</span>
        </div>
        <div class="tz-founder-body">
          <div class="tz-founder-name">Aman Pareek</div>
          <div class="tz-founder-creds">Founder · LLM in International Business Law<br/>King’s College London</div>
        </div>
      </div>
      {/* F3 · Founder quotation block per founder direction */}
      <blockquote class="tz-founder-quote">
        <p>We onboard a limited number of clients per practice area per jurisdiction, to ensure no competition between clients. Led personally by the founder from the first conversation. <em>£110M+</em> client revenue generated.</p>
      </blockquote>
      <div class="tz-founder-socials">
        <a
          class="tz-founder-li"
          href="https://www.linkedin.com/in/amanpareektamazia/"
          aria-label="Aman Pareek on LinkedIn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" width="15" height="15" fill="currentColor">
            <path d="M19 0H5a5 5 0 0 0-5 5v14a5 5 0 0 0 5 5h14a5 5 0 0 0 5-5V5a5 5 0 0 0-5-5zM8 19H5V8h3v11zM6.5 6.7c-1 0-1.7-.8-1.7-1.7s.7-1.7 1.7-1.7 1.7.8 1.7 1.7-.7 1.7-1.7 1.7zM20 19h-3v-5.6c0-3.4-4-3.1-4 0V19h-3V8h3v1.8c1.4-2.6 7-2.8 7 2.5V19z"/>
          </svg>
        </a>
        <a
          class="tz-founder-ig"
          href="https://www.instagram.com/tamaziauk/"
          aria-label="Tamazia on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" width="15" height="15" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>
  </aside>
  <div class="tz-ribbon-caption" aria-hidden="true"><span>400+ Frameworks reviewed every campaign</span></div>

  </div><!-- /.tz-founder-cta-row -->

  <div class="tz-colophon">
    <span>LONDON</span><span class="tz-dot">·</span>
    <span class="tz-colophon-prose">Engagements delivered in UK, UAE, USA, EU &amp; Worldwide</span>
  </div>

  {/* G2 · Primary CTA docked under the engagements colophon */}
  <div class="tz-cta-wrap tz-cta-wrap--colophon" data-reveal="lift">
    <a href="/instrument/" class="tz-cta">
      <span>Run my free audit</span>
      <span class="tz-cta-arr" aria-hidden="true">→</span>
    </a>
  </div>

</section>
</div><!-- /.tz-hero-wrap -->

<style is:global>
  /* ===== FinalHero - Sextant component ===== */
  /* All selectors under .tz-mhero - no bleed into other sections */

  .tz-mhero {
    --tz-ivory:   #FAF7F2;
    --tz-obsidian:#1A1A1D;
    --tz-oxblood: #5A1A2B;
    --tz-gold:    #C9A772;
    --tz-gold-light:#E8CF9C;
    --tz-pearl:   #E8E4DC;
    --tz-muted:   #6B6B6F;
    --tz-display: "Playfair Display", Georgia, serif;
    --tz-body:    "Inter", system-ui, sans-serif;
    --tz-mono:    "JetBrains Mono", ui-monospace, monospace;

    background: var(--tz-ivory);
    color: var(--tz-obsidian);
    font-family: var(--tz-body);
    -webkit-font-smoothing: antialiased;
    position: relative;
    overflow: hidden;

    /* Responsive centering */
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    border-left: 1px solid rgba(201,167,114,0.12);
    border-right: 1px solid rgba(201,167,114,0.12);
  }

  /* ===== Scroll-reveal system ===== */
  .tz-mhero [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 720ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms),
      transform 720ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms),
      filter 720ms ease var(--rd, 0ms);
    will-change: opacity, transform;
  }
  .tz-mhero [data-reveal="fade"]  { transform: none; filter: blur(2px); }
  .tz-mhero [data-reveal="slide"] { transform: translateY(20px); }
  .tz-mhero [data-reveal="lift"]  { transform: translateY(8px) scale(.985); }
  .tz-mhero [data-reveal="rule"]  { transform: scaleX(0); transform-origin: left; opacity: 1; transition: transform 700ms cubic-bezier(.2,.7,.2,1) var(--rd, 0ms); }
  .tz-mhero .is-revealed[data-reveal]        { opacity: 1; transform: none; filter: none; }
  .tz-mhero .is-revealed[data-reveal="rule"] { transform: scaleX(1); }
  @media (prefers-reduced-motion: reduce) {
    .tz-mhero [data-reveal] { opacity: 1 !important; transform: none !important; filter: none !important; transition: none !important; }
  }

  /* ===== Rail ===== */
  .tz-rail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 22px;
    border-bottom: 1px solid rgba(26,26,29,0.08);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.32em;
    color: var(--tz-muted);
    text-transform: uppercase;
  }
  .tz-rail-title {
    font-family: var(--tz-display);
    font-style: italic;
    letter-spacing: 0.04em;
    font-size: 18px;
    color: var(--tz-oxblood);
    text-transform: none;
    font-weight: 500;
  }
  .tz-rail-year { color: var(--tz-gold); }

  /* S3 · Sextant micro-copy line */
  .tz-rail-microcopy {
    margin: 0;
    padding: 12px 24px 10px;
    font-family: var(--tz-display);
    font-style: italic;
    font-size: 14px;
    color: var(--tz-ink, #2A0C14);
    line-height: 1.5;
    letter-spacing: 0.01em;
    text-align: center;
    border-bottom: 1px solid rgba(26,26,29,0.06);
    max-width: 620px;
    margin-inline: auto;
  }
  .tz-rail-microcopy em { font-style: italic; color: var(--tz-oxblood); }
  @media (min-width: 1024px) {
    .tz-rail-microcopy { padding: 14px 28px 12px; font-size: 15px; }
  }

  /* ===== Sector panel ===== */
  .tz-panel {
    padding: 10px 14px 8px;
    position: relative;
  }
  .tz-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(0deg, transparent 0 31px, rgba(201,167,114,0.16) 31px 32px, transparent 32px 64px);
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
  }
  .tz-panel > * { position: relative; z-index: 1; }
  .tz-panel-head {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--tz-muted);
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .tz-panel-head > :first-child,
  .tz-panel-head > :last-child { color: var(--tz-oxblood); }
  /* S4 · LIVE — Sector enforcement watch label + 4-second pulsing dot (burgundy) */
  .tz-panel-live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--tz-body);
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tz-oxblood);
  }
  .tz-live-dot {
    width: 6px; height: 6px;
    background: var(--tz-oxblood);
    border-radius: 50%;
    animation: tz-live-pulse 4s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes tz-live-pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50%      { opacity: 1;    transform: scale(1.15); box-shadow: 0 0 0 4px rgba(90,26,43,0.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tz-live-dot { animation: none; opacity: 0.85; }
  }
  @media (max-width: 480px) {
    .tz-panel-live { font-size: 6.5px; letter-spacing: 0.18em; }
  }

  .tz-panel-mid {
    font-family: var(--tz-display);
    font-style: italic;
    letter-spacing: 0.04em;
    font-size: 10px;
    color: var(--tz-gold);
    text-transform: none;
  }

  /* ===== Dual-band compass ===== */
  .tz-cp {
    width: 100%;
    aspect-ratio: 2.4 / 1;
    max-height: 150px;
    margin: 0 auto;
    position: relative;
  }
  .tz-cp svg { width: 100%; height: 100%; overflow: visible; display: block; }
  .tz-cp-arc      { fill: none; stroke: var(--tz-gold); stroke-width: 0.8; }
  .tz-cp-arc-inner{ stroke: rgba(26,26,29,0.16); stroke-dasharray: 1 3; stroke-width: 0.6; fill: none; }
  .tz-cp-deg      { font: 500 6.5px var(--tz-body); fill: var(--tz-muted); letter-spacing: 0.18em; }
  .tz-cp-sx-label { font: italic 8px var(--tz-display); fill: var(--tz-gold); letter-spacing: 0.04em; }
  .tz-cp-tick     { stroke: rgba(26,26,29,0.45); stroke-width: 0.7; transition: stroke 250ms ease, stroke-width 250ms ease; }
  .tz-cp-tick.is-active { stroke: var(--tz-oxblood); stroke-width: 1.6; }
  .tz-cp-abbr     { font: 600 6.5px var(--tz-body); fill: rgba(26,26,29,0.4); letter-spacing: 0.2em; transition: fill 250ms ease, font-size 250ms ease; }
  .tz-cp-abbr.is-active { fill: var(--tz-oxblood); font-size: 8px; font-weight: 700; }
  .tz-cp-needle-g { transform-origin: 150px 130px; transform: rotate(-60deg); transition: transform 1100ms cubic-bezier(.5,.05,.2,1); }
  .tz-cp-needle   { stroke: var(--tz-oxblood); stroke-width: 1.4; stroke-linecap: round; }
  .tz-cp-needle-tip  { fill: var(--tz-oxblood); }
  .tz-cp-needle-halo { fill: none; stroke: var(--tz-oxblood); stroke-width: 0.5; opacity: 0.4; }

  /* ===== Sector band ===== */
  .tz-band {
    margin-top: 8px;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid rgba(201,167,114,0.55);
    border-radius: 3px;
    background: linear-gradient(180deg, rgba(201,167,114,0.06), transparent 80%);
    align-items: center;
  }
  .tz-band-l        { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .tz-band-l-kicker { font: 600 7px var(--tz-body); letter-spacing: 0.3em; color: var(--tz-muted); text-transform: uppercase; }
  .tz-band-l-name   { font-family: var(--tz-display); font-style: italic; font-size: 18px; color: var(--tz-oxblood); line-height: 1; font-weight: 500; }
  .tz-band-l-idx    { font: 600 7px var(--tz-body); letter-spacing: 0.3em; color: var(--tz-gold); margin-top: 2px; }
  .tz-band-laws     { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; padding: 4px 0 2px; }
  .tz-band-laws span {
    font: 500 11.5px var(--tz-mono);
    color: var(--tz-obsidian);
    letter-spacing: 0.02em;
    line-height: 1.35;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .tz-band-laws span::before { content: ""; width: 4px; height: 4px; background: var(--tz-gold); border-radius: 50%; flex-shrink: 0; }
  /* sweep-3 · subtle accent on hover for readability */
  .tz-band-laws span:hover { color: var(--tz-oxblood); }

  /* ===== Fine enforcement pill ===== */
  .tz-fine {
    margin-top: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--tz-mono);
    font-size: 9px;
    color: var(--tz-muted);
    letter-spacing: 0.04em;
  }
  .tz-fine-rule { flex: 1 1 0; min-width: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(90,26,43,0.5), transparent); }
  /* F5 · Fined pill — allow wrap on narrow viewports so it never breaches container */
  .tz-fine-pill {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 4px 8px;
    padding: 6px 14px;
    background: rgba(90,26,43,0.06);
    border: 1px solid rgba(90,26,43,0.25);
    border-radius: 999px;
    color: var(--tz-oxblood);
    max-width: 100%;
    min-width: 0;
    flex-shrink: 1;
    text-align: center;
    transition: opacity 240ms ease, transform 240ms ease;
  }
  .tz-fine-pill .tz-fine-dot { width: 5px; height: 5px; background: var(--tz-oxblood); border-radius: 50%; flex-shrink: 0; }
  .tz-fine-pill .tz-fine-lab { font-family: var(--tz-display); font-style: italic; color: var(--tz-oxblood); font-weight: 500; font-size: 11px; letter-spacing: 0.01em; padding-right: 2px; }
  .tz-fine-pill #tz-fine     { font-size: 9px; letter-spacing: 0.02em; line-height: 1.4; }
  .tz-fine-pill em           { font-family: var(--tz-display); font-style: italic; font-size: 10.5px; color: var(--tz-oxblood); }
  .tz-fine.is-swapping .tz-fine-pill { opacity: 0; transform: translateY(3px); }
  .tz-band-l-name, #tz-laws  { transition: opacity 240ms ease, transform 240ms ease; }
  .tz-band.is-swapping .tz-band-l-name,
  .tz-band.is-swapping #tz-laws { opacity: 0; transform: translateY(3px); }

  /* F5 · mobile fine-pill cleanup — drop side rules on narrow widths, let pill fill row + wrap */
  @media (max-width: 520px) {
    .tz-fine { flex-direction: column; gap: 6px; }
    .tz-fine-rule { display: none; }
    .tz-fine-pill { width: 100%; padding: 8px 12px; }
    .tz-fine-pill .tz-fine-lab { font-size: 10px; }
    .tz-fine-pill #tz-fine { font-size: 8.5px; }
  }

  /* ===== Panel foot ===== */
  .tz-panel-foot {
    margin-top: 10px;
    padding: 8px 0 0;
    border-top: 1px dashed rgba(26,26,29,0.18);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .tz-foot-kicker {
    font-family: var(--tz-body);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tz-muted);
  }
  .tz-foot-clients {
    font-family: var(--tz-display);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--tz-oxblood);
    line-height: 1.5;
  }
  .tz-foot-tail {
    font-family: var(--tz-body);
    font-size: 9px;
    font-style: italic;
    color: var(--tz-muted);
    letter-spacing: 0.02em;
  }
  .tz-panel-foot strong { font-weight: 500; }

  /* ===== Coordinates ===== */
  .tz-coord {
    display: flex;
    justify-content: center;
    gap: 14px;
    padding: 18px 22px 6px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.32em;
    color: var(--tz-gold);
  }
  .tz-coord-dot { opacity: 0.7; }

  /* F1 · Eyebrow over-headline — brand-aligned beautification, 'legal' standout */
  .tz-eyebrow-principle {
    margin: 22px 0 10px;
    padding: 0 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--tz-oxblood);
    text-align: center;
    line-height: 1.55;
  }
  .tz-eyebrow-text {
    font-family: var(--tz-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    white-space: normal;
  }
  .tz-eyebrow-principle em {
    font-style: normal;
    text-transform: none;
    letter-spacing: 0;
  }
  .tz-eyebrow-legal {
    font-family: var(--tz-display);
    font-style: italic;
    font-weight: 600;
    font-size: 16px;
    color: var(--tz-gold);
    letter-spacing: 0.01em;
    padding: 0 2px;
    position: relative;
    background: linear-gradient(180deg, transparent 64%, rgba(201,167,114,0.18) 64%, rgba(201,167,114,0.18) 92%, transparent 92%);
  }
  .tz-eyebrow-orn {
    width: 28px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--tz-gold), transparent);
    opacity: 0.7;
    flex-shrink: 0;
  }
  @media (max-width: 480px) {
    .tz-eyebrow-principle { gap: 8px; padding: 0 16px; margin: 18px 0 6px; }
    .tz-eyebrow-text { font-size: 9px; letter-spacing: 0.28em; }
    .tz-eyebrow-legal { font-size: 14px; }
    .tz-eyebrow-orn { width: 18px; }
  }
  @media (min-width: 1024px) {
    .tz-eyebrow-principle { padding: 0 28px; margin: 28px 0 14px; gap: 16px; }
    .tz-eyebrow-text { font-size: 11px; }
    .tz-eyebrow-legal { font-size: 19px; }
    .tz-eyebrow-orn { width: 36px; }
  }

  /* ===== Headline ===== */
  .tz-headline {
    padding: 4px 22px 0;
    font-family: var(--tz-display);
    font-size: 42px;
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--tz-obsidian);
  }
  .tz-headline .tz-line    { display: block; }
  .tz-headline em.tz-word  { font-style: italic; color: var(--tz-oxblood); font-weight: 400; }
  .tz-line-em              { color: var(--tz-oxblood); }
  .tz-headline .tz-word    { display: inline-block; }
  .tz-headline .tz-word + .tz-word { margin-left: 0.22em; }

  /* M3 · word-level typing reveal: full text is in the HTML; each word snaps in
     (steps(1) = typewriter pop, no fade) at the moment it would finish typing.
     Opacity-only: no layout shift, kerning preserved within words. */
  .tz-tw-w {
    opacity: 0;
    animation-name: tz-tw-in;
    animation-duration: 2ms;       /* imperceptible: reads as a typewriter pop */
    animation-timing-function: linear;
    animation-delay: var(--d, 0ms);
    animation-fill-mode: forwards;
  }
  @keyframes tz-tw-in { from { opacity: 0; } to { opacity: 1; } }
  .tz-caret {
    display: inline-block;
    width: 0.45em;
    height: 0.04em;
    background: var(--tz-gold);
    vertical-align: baseline;
    margin-left: 0.12em;
    opacity: 0;
    animation: tz-caret-blink 0.7s step-end infinite;
    animation-delay: var(--tw-total, 2400ms);
  }
  @keyframes tz-caret-blink { 0%, 100% { opacity: 0; } 50% { opacity: 0.9; } }
  @media (prefers-reduced-motion: reduce) {
    .tz-tw-w { animation: none; opacity: 1; }
    .tz-caret { animation: none; opacity: 0; }
  }

  /* ===== Sub-bullets ===== */
  .tz-subs { padding: 14px 22px 0; display: flex; flex-direction: column; gap: 6px; }
  .tz-sub  { display: flex; align-items: center; gap: 8px; font-family: var(--tz-display); font-style: italic; font-size: 13px; color: var(--tz-gold); }
  .tz-sub-rule { width: 14px; height: 1px; background: var(--tz-gold); }

  /* ===== Body text ===== */
  .tz-body       { padding: 10px 22px; }
  .tz-body-tight { padding: 6px 22px 8px; }
  .tz-body p     { font-family: var(--tz-display); font-size: 14px; line-height: 1.6; margin: 0; }
  .tz-body em    { color: var(--tz-oxblood); font-style: italic; }
  .tz-body strong{ color: var(--tz-oxblood); }
  .tz-dropcap    { font-family: var(--tz-display); font-size: 50px; line-height: 0.8; float: left; padding: 4px 8px 0 0; color: var(--tz-oxblood); font-weight: 500; }
  /* F8 · single-line variant — no dropcap, just a balanced statement line that complements the eyebrow */
  .tz-body-compact p { font-family: var(--tz-display); font-style: italic; font-size: 14px; line-height: 1.55; text-align: center; color: var(--tz-obsidian); }
  .tz-body-compact p::before, .tz-body-compact p::after { content: ''; display: inline-block; width: 14px; height: 1px; background: var(--tz-gold); vertical-align: middle; margin: 0 10px; opacity: 0.7; }
  @media (min-width: 1024px) {
    .tz-body-compact p { font-size: 15px; }
    .tz-body-compact p::before, .tz-body-compact p::after { width: 18px; margin: 0 12px; }
  }

  /* ===== Pull quotes ===== */
  .tz-pull-left { padding: 0 22px 10px; }
  .tz-pull-left p { border-left: 3px solid var(--tz-oxblood); background: rgba(90,26,43,0.04); padding: 14px 16px; margin: 0; font-family: var(--tz-display); font-size: 17px; line-height: 1.35; font-weight: 500; }
  .tz-pull-left em { color: var(--tz-oxblood); font-style: italic; }

  .tz-pull-centre { margin: 4px 22px 18px; position: relative; text-align: center; padding: 22px 16px 18px; border: 1px solid var(--tz-gold); background: rgba(201,167,114,0.04); }
  .tz-pull-centre p { font-family: var(--tz-display); font-size: 22px; line-height: 1.2; margin: 0; font-weight: 500; letter-spacing: -0.005em; }
  .tz-pull-centre em { color: var(--tz-oxblood); font-style: italic; }
  .tz-pull-cite  { margin-top: 10px; font-size: 7.5px; font-weight: 600; letter-spacing: 0.4em; color: var(--tz-gold); }
  .tz-corner     { position: absolute; width: 10px; height: 10px; border: 1.5px solid var(--tz-oxblood); }
  .tz-corner-tl  { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .tz-corner-tr  { top: -1px; right: -1px; border-left: none; border-bottom: none; }
  .tz-corner-bl  { bottom: -1px; left: -1px; border-right: none; border-top: none; }
  .tz-corner-br  { bottom: -1px; right: -1px; border-left: none; border-top: none; }

  /* ===== Framework chips ===== */
  .tz-chips { padding: 0 22px 6px; display: flex; flex-wrap: wrap; gap: 6px; }
  .tz-chips span { font-size: 9px; font-weight: 600; letter-spacing: 0.16em; color: var(--tz-oxblood); border: 1px solid var(--tz-gold); padding: 4px 8px; background: var(--tz-ivory); }
  /* S11 · clickable chips inherit chip styling, add subtle hover + cursor */
  .tz-chips .tz-chip {
    display: inline-block;
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .tz-chips .tz-chip:hover {
    background: rgba(201,167,114,0.18);
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(90,26,43,0.10);
  }
  .tz-chips .tz-chip:focus-visible {
    outline: 2px solid var(--tz-gold);
    outline-offset: 2px;
  }
  .tz-chips .tz-chip > span {
    /* Inner span retains chip styling for both new (anchor) and any legacy plain spans */
    display: inline-block;
  }
  .tz-chips-suffix { padding: 0 22px 4px; font-family: var(--tz-display); font-style: italic; font-size: 13px; color: var(--tz-muted); margin: 0 0 4px; }

  /* ===== Founder pill ===== */
  .tz-founder { padding: 10px 22px 4px; }
  .tz-founder-rule { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .tz-founder-rule span { flex: 1; height: 1px; background: var(--tz-gold); opacity: 0.5; }
  .tz-founder-rule em   { font-family: var(--tz-display); font-style: italic; font-size: 11px; letter-spacing: 0.06em; color: var(--tz-oxblood); }

  /* G1 · Founder pill — compact stacked card · dense, no empty space */
  .tz-founder-pill {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    padding: 10px 12px 10px;
    border: 1px solid var(--tz-gold);
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(201,167,114,0.08), rgba(201,167,114,0.02));
    box-shadow: 0 4px 14px rgba(26,20,15,0.05);
    /* Founder directive 2026-06-10: socials anchor to the pill's top-right corner */
    position: relative;
  }
  .tz-founder-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  /* Quote sits flush, no left border / no inner padding — every pixel earns its space */
  .tz-founder-quote {
    margin: 0;
    padding: 6px 0 0;
    border-top: 1px solid rgba(201,167,114,0.32);
    background: transparent;
    border-left: 0;
    border-radius: 0;
  }
  .tz-founder-quote p {
    margin: 0;
    font-family: var(--tz-display);
    font-style: italic;
    font-size: 11px;
    line-height: 1.45;
    color: var(--tz-obsidian);
    letter-spacing: 0.005em;
  }
  .tz-founder-quote em {
    font-style: italic;
    color: var(--tz-oxblood);
    font-weight: 600;
  }
  /* G1 · Founder portrait sized for compact stacked card — 72px base, 84px desktop */
  .tz-founder-photo {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(201,167,114,0.55);
    background: var(--tz-pearl);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
  .tz-founder-photo::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(45deg, rgba(90,26,43,0.06) 0 2px, transparent 2px 6px);
  }
  .tz-founder-photo-mark {
    font-family: var(--tz-display);
    font-style: italic;
    font-size: 28px;
    color: var(--tz-oxblood);
    position: relative;
    z-index: 1;
    letter-spacing: 0.01em;
  }
  .tz-founder-photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
    z-index: 2;
    background: var(--tz-pearl);
  }
  .tz-founder-photo-img.is-broken { display: none; }
  .tz-founder-body  { flex: 1; min-width: 0; }
  .tz-founder-name  { font-family: var(--tz-display); font-style: italic; font-size: 20px; color: var(--tz-obsidian); line-height: 1.05; letter-spacing: -0.005em; font-weight: 600; }
  .tz-founder-creds { font-family: var(--tz-display); font-style: italic; font-size: 10px; letter-spacing: 0.02em; color: var(--tz-oxblood); text-transform: none; font-weight: 500; margin-top: 3px; line-height: 1.35; }
  .tz-founder-li {
    width: 34px;
    height: 34px;
    background: var(--tz-oxblood);
    color: var(--tz-gold);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
    box-shadow: 0 4px 10px rgba(62,17,25,0.18);
    transition: transform 200ms ease;
  }
  .tz-founder-li:hover { transform: translateY(-1px); }

  /* ===== Trusted by ===== */
  .tz-trusted { padding: 14px 22px 6px; }
  .tz-trusted-rule { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .tz-trusted-rule span { flex: 1; height: 1px; background: var(--tz-gold); opacity: 0.5; }
  .tz-trusted-rule em   { font-family: var(--tz-display); font-style: italic; font-size: 11px; letter-spacing: 0.06em; color: var(--tz-oxblood); }
  .tz-trusted-row { display: flex; flex-wrap: wrap; align-items: center; gap: 5px 8px; font-size: 9px; letter-spacing: 0.22em; font-weight: 600; text-transform: uppercase; color: var(--tz-oxblood); line-height: 1.4; }
  .tz-trusted-lab { color: var(--tz-gold); }
  .tz-trusted-dot { color: var(--tz-gold); font-weight: 700; }
  .tz-trusted-co i { font-style: normal; color: var(--tz-muted); font-weight: 500; letter-spacing: 0.18em; }
  .tz-trusted-foot { margin: 10px 0 0; font-family: var(--tz-display); font-style: italic; font-size: 13px; color: var(--tz-muted); line-height: 1.4; letter-spacing: 0.01em; }
  .tz-trusted-foot em { color: var(--tz-oxblood); font-style: italic; }

  /* G2 · Primary CTA docked under colophon · centered, narrow on desktop, full-width touch target on mobile */
  .tz-cta-wrap--colophon {
    padding: 6px 22px 14px;
    display: flex;
    justify-content: center;
  }
  .tz-cta-wrap--colophon .tz-cta {
    width: 100%;
    max-width: 360px;
    padding: 14px 20px;
    font-size: 11px;
  }
  @media (min-width: 1024px) {
    .tz-cta-wrap--colophon { padding: 14px 28px 22px; }
    .tz-cta-wrap--colophon .tz-cta { max-width: 320px; padding: 16px 22px; font-size: 12px; }
  }

  /* ===== CTA ===== */
  .tz-cta-wrap { padding: 14px 22px; }
  .tz-cta {
    background: var(--tz-oxblood);
    color: var(--tz-ivory);
    padding: 16px 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 999px;
    box-shadow: 0 6px 18px rgba(62,17,25,0.18);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .tz-cta:hover { transform: translateY(-1px); box-shadow: 0 10px 24px rgba(62,17,25,0.22); }
  .tz-cta-arr {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--tz-gold);
    color: var(--tz-gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ===== Colophon ===== */
  .tz-colophon {
    padding: 10px 22px 10px;
    border-top: 1px solid rgba(26,26,29,0.08);
    background: rgba(232,228,220,0.5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--tz-muted);
  }
  .tz-colophon .tz-dot { color: var(--tz-gold); }

  /* S14 (Impl Doc v1.0) · Long prose label inside colophon — flows on narrow viewports */
  .tz-colophon-prose {
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tz-muted);
    flex: 0 1 auto;
    min-width: 0;
    white-space: normal;
    text-align: right;
  }
  @media (max-width: 480px) {
    .tz-colophon { flex-wrap: wrap; gap: 6px; row-gap: 4px; }
    .tz-colophon-prose { font-size: 8px; letter-spacing: 0.14em; text-align: left; }
  }

  /* ===== Needle halo pulse ===== */
  @keyframes tzPulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 0.85; }
  }
  .tz-cp-needle-halo { animation: tzPulse 2.4s ease-in-out infinite; }

  /* ===== Responsive - Tablet 640px+ ===== */
  @media (min-width: 640px) {
    .tz-mhero { max-width: 680px; }
    .tz-headline { font-size: 52px; }
    .tz-cp { max-height: 180px; }
    .tz-band { grid-template-columns: 135px 1fr; gap: 16px; }
    .tz-body p { font-size: 15px; }
    .tz-pull-centre p { font-size: 24px; }
    .tz-pull-left p { font-size: 18px; }
  }

  /* ===== Responsive - Desktop 1024px+ ===== */
  @media (min-width: 1024px) {
    .tz-mhero { max-width: 860px; }
    .tz-headline { font-size: 68px; line-height: 0.94; }
    .tz-cp { max-height: 210px; }
    .tz-band { grid-template-columns: 155px 1fr; gap: 20px; }
    .tz-panel { padding: 14px 18px 10px; }
    .tz-rail  { padding: 12px 28px; }
    .tz-coord { padding: 22px 28px 8px; }
    .tz-headline  { padding: 6px 28px 0; }
    .tz-subs      { padding: 16px 28px 0; }
    .tz-body      { padding: 12px 28px; }
    .tz-body-tight{ padding: 8px 28px 10px; }
    .tz-pull-left { padding: 0 28px 12px; }
    .tz-pull-centre{ margin: 4px 28px 22px; }
    .tz-chips     { padding: 0 28px 8px; }
    .tz-chips-suffix{ padding: 0 28px 6px; }
    .tz-founder   { padding: 12px 28px 6px; }
    .tz-trusted   { padding: 16px 28px 8px; }
    .tz-cta-wrap  { padding: 16px 28px; }
    .tz-colophon  { padding: 12px 28px 12px; }
    .tz-body p    { font-size: 15px; }
    .tz-pull-centre p { font-size: 26px; }
    .tz-band-l-name { font-size: 22px; }
    .tz-sub       { font-size: 15px; }
  }

  /* ===== Responsive - Large 1280px+ ===== */
  @media (min-width: 1280px) {
    .tz-mhero { max-width: 1080px; }
    .tz-headline { font-size: 76px; }
  }

  /* ===== Responsive - Small mobile <380px ===== */
  @media (max-width: 380px) {
    .tz-headline { font-size: 36px; }
    .tz-pull-centre p { font-size: 18px; }
    .tz-founder-name { font-size: 17px; }
    .tz-fine-pill { padding: 3px 7px; }
    #tz-fine { font-size: 7.5px; }
  }

  /* ===== Wrapper: positioning context for ribbon ===== */
  .tz-hero-wrap {
    position: relative;
    width: 100%;
    overflow: hidden; /* clips ribbon-track scroll beyond hero height */
  }

  /* ===== Laws ribbon — verbatim Hero.astro pattern (regulation-ribbon) ===== */
  /* position:absolute within overflow:hidden wrapper · no CSS-var dependency  */
  .tz-laws-ribbon {
    display: none;
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 220px;
    overflow: hidden;
    pointer-events: none;
    z-index: 4;
    mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }
  .tz-laws-ribbon-track {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: 20px;
    padding-top: 80px;
    gap: 18px;
    animation: ribbon-vertical 240s linear infinite;
    /* hardcode fonts/colours — CSS vars are scoped to .tz-mhero, not available here */
    font-family: "Playfair Display", Georgia, serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5A1A2B;
    font-weight: 500;
  }
  .tz-laws-ribbon-track span {
    white-space: nowrap;
    display: block;
    text-align: right;
  }
  .tz-laws-ribbon-track span.gold {
    color: #C9A772;
    font-style: italic;
    font-weight: 600;
  }
  /* ===== Ribbon caption — horizontal label at base of ribbon column ===== */
  /* ===== Ribbon caption — horizontal label at top of laws ribbon column ===== */
  /* Sits above the ribbon's padding-top:80px so it appears before the first law */
  .tz-ribbon-caption {
    display: none;
    position: absolute;
    top: 82px;
    right: 0;
    width: 160px;
    text-align: center;
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    font-size: 7.5px;
    color: #C9A772;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.65;
    padding: 0 14px;
    pointer-events: none;
    z-index: 5;
  }
  .tz-ribbon-caption span {
    display: block;
  }

  /* Ribbon breakpoints — wider at large viewports so long law names aren't clipped */
  @media (min-width: 1180px) {
    .tz-laws-ribbon { display: block; width: 160px; }
    .tz-ribbon-caption { display: block; width: 160px; }
  }
  @media (min-width: 1280px) {
    .tz-laws-ribbon { width: 220px; }
    .tz-ribbon-caption { width: 220px; }
  }
  @media (min-width: 1440px) {
    .tz-laws-ribbon { width: 280px; }
    .tz-ribbon-caption { width: 280px; }
  }
  @media (min-width: 1600px) {
    .tz-laws-ribbon { width: 340px; }
    .tz-ribbon-caption { width: 340px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .tz-laws-ribbon-track { animation-duration: 480s; }
  }

  /* ===== Typewriter cursor ===== */
  /* M3: .tz-tw-typing caret removed with the JS typewriter (replaced by .tz-caret). */

  /* G4 GAP A · single .tz-founder-cta-row rule · founder pill is the only child after G2 */
  .tz-founder-cta-row {
    display: block;
    padding: 14px 22px 6px;
  }
  .tz-founder-cta-row .tz-founder {
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .tz-founder-cta-row .tz-founder-rule { margin-bottom: 8px; }
  /* G1 · cta-row founder pill — even tighter inside the section row */
  .tz-founder-cta-row .tz-founder-pill {
    flex: 1;
    padding: 10px 12px 10px;
    gap: 8px;
    border-radius: 10px;
  }
  .tz-founder-cta-row .tz-founder-name  { font-size: 20px; line-height: 1.05; }
  .tz-founder-cta-row .tz-founder-creds { font-size: 10px;  margin-top: 3px; line-height: 1.35; }
  .tz-founder-cta-row .tz-founder-photo { width: 64px; height: 64px; }
  .tz-founder-cta-row .tz-founder-photo-mark { font-size: 28px; }
  .tz-founder-cta-row .tz-founder-quote { padding: 6px 0 0; }
  .tz-founder-cta-row .tz-founder-quote p { font-size: 10.5px; line-height: 1.45; }
  @media (max-width: 600px) {
    .tz-founder-cta-row .tz-founder-name { font-size: 18px; }
    .tz-founder-cta-row .tz-founder-creds { font-size: 9.5px; }
    .tz-founder-cta-row .tz-founder-photo { width: 56px; height: 56px; }
    .tz-founder-cta-row .tz-founder-quote p { font-size: 10px; }
  }
  /* G4 GAP D · legacy .tz-founder-cta-row .tz-cta-wrap* rules removed; CTA was moved out of the row in G2. */
  /* G4 GAP D · mobile founder-cta-row · only padding tweak needed now that CTA is gone */
  @media (max-width: 600px) {
    .tz-founder-cta-row { padding: 8px 16px 4px; }
  }
  @media (max-width: 380px) {
    .tz-founder-cta-row { padding: 10px 14px 4px; }
  }
  @media (min-width: 1024px) {
    .tz-founder-cta-row { padding: 16px 28px 8px; gap: 14px; }
    /* G1 · compact founder photo — 84px desktop */
    .tz-founder-cta-row .tz-founder-photo { width: 84px; height: 84px; }
    .tz-founder-photo { width: 84px; height: 84px; }
    .tz-founder-photo-mark { font-size: 32px; }
    .tz-founder-cta-row .tz-founder-name { font-size: 22px; }
    /* G4 GAP B · cap pill width on desktop so the quote doesn't read like a banner */
    .tz-founder-cta-row .tz-founder-pill { max-width: 540px; margin-inline: auto; }
  }

  /* Gate 94 a11y · prefers-contrast + forced-colors — must be in a bundled _astro/*.css file */
  @media (prefers-contrast: more) {
    :root { color-scheme: light; }
    a:not([class]) { text-decoration: underline; text-underline-offset: 2px; }
    *:focus-visible { outline-width: 3px !important; }
  }
  @media (forced-colors: active) {
    a:focus-visible, button:focus-visible { outline: 2px solid CanvasText; }
    .nav-cta, .tz-cta, .briefings-btn { border: 1px solid CanvasText; }
  }

  /* G1 · compact socials — smaller, snug.
     Founder directive 2026-06-10: pinned to the top-right corner of the founder box. */
  .tz-founder-socials {
    display: flex;
    flex-direction: row;
    gap: 6px;
    flex-shrink: 0;
    margin-top: 0;
    position: absolute;
    top: 10px;
    right: 12px;
  }
  .tz-founder-li,
  .tz-founder-ig {
    width: 22px;
    height: 22px;
    background: var(--tz-oxblood);
    color: var(--tz-gold);
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(62,17,25,0.18);
    transition: transform 200ms ease;
  }
  .tz-founder-ig { background: #C13584; color: #fff; }
  .tz-founder-li:hover,
  .tz-founder-ig:hover { transform: translateY(-1px); }

  /* sweep-3 · desktop Sextant laws breathing space */
  @media (min-width: 1024px) {
    .tz-band-laws { gap: 8px 18px; }
    .tz-band-laws span { font-size: 12.5px; }
  }
</style>

<script>
  (() => {
    /* ============================================================
       FinalHero - Sextant sector compass
       Scoped to .tz-mhero to avoid conflicts with other sections
    ============================================================ */

    // ---- 1. Sector data ----
    // F7 · 6 sector enforcement triggers — concise format: [Amount] · [Why] · [Regulator] · [Framework] · [Year]
    //   References verified May 2026:
    //     Legal: SRA £25,000 firm fining power (active since 2022); 935 AML proactive engagements 2024-25.
    //     Healthcare: MHRA prosecutes unlicensed POM advertising; ASA upheld Beautaholics LED (Nov 2025).
    //     Hospitality: CMA £4.2M Wowcher drip-pricing 2025 (DMCC 2024 powers).
    //     Real Estate: SEC $19M IPO disclosure failure (Reg FD).
    //     F&B: HFSS junk-food advertising ban live 5 Jan 2026 (Health and Care Act 2022).
    //     Every sector: ASA AI-Active Ad Monitoring + 'Dr' titles upheld 2024-26 (CAP Code).
    const SECTORS = [
      { name: "Legal",        abbr: "LAW", laws: [
          "SRA Transparency Rules 2018", "SRA Code of Conduct 2019",
          "ICC Rules 2021 · LCIA 2020", "SIAC 2016 · DIAC 2022",
          "ABA Model Rules 7.1-7.3 (US)", "Section 21 FSMA",
          "Google E-E-A-T · YMYL", "LegalService schema",
          "Wikidata Q-identifier", "Wikipedia Notability (Lawyer)"],
        fine: '<em>£25,000</em> · AML control failures · SRA · MLR 2017 · <em>2024</em>' },
      { name: "Healthcare",   abbr: "HLT", laws: [
          "MHRA HMR 2012", "CQC Standards · Reg 17",
          "HIPAA (US)", "ASA CAP Section 12 (Health)",
          "GMC Good Medical Practice", "NICE Guidelines · NG",
          "Schema.org MedicalBusiness", "Google E-E-A-T · YMYL Medical",
          "UK GDPR · Health Data", "NHS Digital DCB0129"],
        fine: '<em>Prosecuted</em> · unlicensed POM weight-loss ads · MHRA · HMR 2012 · <em>2025</em>' },
      { name: "Hospitality",  abbr: "HSP", laws: [
          "ASA CAP Code Non-broadcast", "CMA DMCC Act 2024 · drip-pricing",
          "Package Travel Regs 2018", "Sleeping Accommodation Price Display 1977",
          "UK GDPR Article 6", "PCI-DSS Level 1",
          "Schema.org HotelRoom · LodgingBusiness", "Google Business Profile policy",
          "Equality Act 2010", "Food Safety Act 1990"],
        fine: '<em>£4.2M</em> · drip pricing · CMA · DMCC 2024 · <em>2025</em>' },
      { name: "Real Estate",  abbr: "RE",  laws: [
          "CPRs 2008 · Material Information", "Tenant Fees Act 2019",
          "RERA Law No. 7 of 2013 (UAE)", "UAE PDPL Federal Decree-Law 45/2021",
          "FCA MCOB · Financial Promotions", "TPO Code of Practice",
          "AML Regulations 2017", "HMRC SDLT Disclosure",
          "Schema.org RealEstateAgent", "UK GDPR"],
        fine: '<em>$19M</em> · IPO disclosure failure · SEC · Reg FD · <em>2024</em>' },
      { name: "Restaurants, Bars, F&B", abbr: "FB", laws: [
          "Food Information Regs 2014 (UK)", "Natasha\'s Law 2021 · allergen",
          "HFSS Health & Care Act 2021", "ASA CAP Code Section 15 (Food)",
          "FDA §101 (US Labelling)", "Local Pack ranking factors",
          "Schema.org Restaurant · MenuItem", "Google Maps citation architecture",
          "Allergen disclosure (PPDS)", "PCI-DSS Level 1"],
        fine: '<em>£500K cap</em> · junk food TV ban active · Ofcom · HFSS · <em>5 Jan 2026</em>' },
      { name: "Every sector", abbr: "ALL", laws: [
          "UK GDPR · Article 32", "EU GDPR (Regulation 2016/679)",
          "EU AI Act (Regulation 2024/1689)", "ASA CAP Code (General)",
          "Section 21 FSMA", "Google E-E-A-T Quality Rater Guidelines",
          "Wikipedia Notability (General)", "Wikipedia Verifiability",
          "Wikidata sameAs Q-identifier", "Schema.org structured data",
          "WCAG 2.1 AA accessibility", "PECR · Cookie consent"],
        fine: 'AI ad monitoring live · misleading <em>Dr</em> titles upheld · ASA · CAP Code · <em>2024-26</em>' }
    ];
    const N = SECTORS.length;
    const STEP_MS = 6500;  // sweep-3 · 6.5s rotation so users can read 10+ laws
    const SWAP_MS = 240;

    const root = document.querySelector('.tz-mhero');
    if (!root) return;

    // ---- 2. Build rim ticks + abbreviations ----
    (() => {
      const ns = "http://www.w3.org/2000/svg";
      const g = root.querySelector("#tz-secs");
      if (!g) return;
      const cx = 150, cy = 130, Ri = 100, Ro = 108, Rt = 120;
      SECTORS.forEach((s, i) => {
        const deg = -60 + i * 20;
        const rad = (deg - 90) * Math.PI / 180;
        const x1 = cx + Ri * Math.cos(rad), y1 = cy + Ri * Math.sin(rad);
        const x2 = cx + Ro * Math.cos(rad), y2 = cy + Ro * Math.sin(rad);
        const xt = cx + Rt * Math.cos(rad), yt = cy + Rt * Math.sin(rad);

        const tick = document.createElementNS(ns, "line");
        tick.setAttribute("x1", x1.toFixed(1));
        tick.setAttribute("y1", y1.toFixed(1));
        tick.setAttribute("x2", x2.toFixed(1));
        tick.setAttribute("y2", y2.toFixed(1));
        tick.setAttribute("class", "tz-cp-tick");
        tick.dataset.i = String(i);
        g.appendChild(tick);

        const t = document.createElementNS(ns, "text");
        t.setAttribute("x", xt.toFixed(1));
        t.setAttribute("y", (yt + 2.5).toFixed(1));
        t.setAttribute("text-anchor", "middle");
        t.setAttribute("class", "tz-cp-abbr");
        t.dataset.i = String(i);
        t.textContent = s.abbr;
        g.appendChild(t);
      });
    })();

    // ---- 3. Synced cycle ----
    const Compass = (() => {
      const needleG = root.querySelector(".tz-cp-needle-g");
      const tickRoot = root.querySelector("#tz-secs");
      const nameEl   = root.querySelector("#tz-name");
      const idxEl    = root.querySelector("#tz-idx");
      const idxInln  = root.querySelector("#tz-idx-inline");
      const lawsEl   = root.querySelector("#tz-laws");
      const fineEl   = root.querySelector("#tz-fine");
      const fineRow  = root.querySelector(".tz-fine");
      const bandRow  = root.querySelector(".tz-band");

      let i = 0;  // S4 · start on Legal (index 0)
      let timer = null;
      let running = false;

      function paint(idx) {
        const s = SECTORS[idx];
        const deg = -60 + idx * 20;
        if (needleG) needleG.style.transform = `rotate(${deg}deg)`;
        if (tickRoot) {
          tickRoot.querySelectorAll("[data-i]").forEach(el => {
            el.classList.toggle("is-active", +el.dataset.i === idx);
          });
        }
        if (fineRow) fineRow.classList.add("is-swapping");
        if (bandRow) bandRow.classList.add("is-swapping");
        setTimeout(() => {
          if (nameEl)  nameEl.textContent  = s.name;
          if (idxEl)   idxEl.textContent   = String(idx + 1).padStart(2, "0");
          if (idxInln) idxInln.textContent = String(idx + 1).padStart(2, "0");
          if (lawsEl)  lawsEl.innerHTML    = s.laws.map(l => `<span>${l}</span>`).join("");
          if (fineEl)  fineEl.innerHTML    = s.fine;
          if (fineRow) fineRow.classList.remove("is-swapping");
          if (bandRow) bandRow.classList.remove("is-swapping");
        }, SWAP_MS);
      }

      function tick() { i = (i + 1) % N; paint(i); }
      function start() {
        if (running) return;
        running = true;
        paint(i);
        timer = setInterval(tick, STEP_MS);
      }
      function stop() {
        running = false;
        clearInterval(timer);
        timer = null;
      }
      return { start, stop };
    })();

    // ---- 4. Auto-start when in view, no hover pause ----
    (() => {
      const panel = root.querySelector(".tz-panel");
      if (!panel) return;
      let inView = false;
      const io = new IntersectionObserver(([e]) => {
        inView = e.isIntersecting;
        inView ? Compass.start() : Compass.stop();
      }, { threshold: 0.15 });
      io.observe(panel);
      // Tab hide/show
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) Compass.stop();
        else if (inView) Compass.start();
      });
    })();

    // ---- 5. Scroll-triggered reveals (scoped to .tz-mhero) ----
    (() => {
      const els = root.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window)) {
        els.forEach(el => el.classList.add("is-revealed"));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("is-revealed");
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.18, rootMargin: "0px 0px -8% 0px" });
      els.forEach(el => io.observe(el));
    })();

    // ---- 6. Founder portrait fallback ----
    (() => {
      const img = root.querySelector(".tz-founder-photo-img");
      if (!img) return;
      img.addEventListener("error", () => img.classList.add("is-broken"));
      if (!img.getAttribute("src")) img.classList.add("is-broken");
    })();
    // ---- 7. H1 typewriter: replaced in M3 by build-time word spans + CSS
    //      steps(1) stagger (see the h1 markup). No runtime text writes remain.

  })();
</script>
