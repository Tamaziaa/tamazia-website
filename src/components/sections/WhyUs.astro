---
import Motif from '../ui/Motif.astro';
import { whyUsContent } from '../../content/whyUs';
import { parseEmph } from '../../content/hero';

const { eyebrow, h2, paragraphs, pullQuote, stats, credentialStripHeading, credentials } = whyUsContent;
const microLine = (whyUsContent as any).microLine;
const proofStrip = (whyUsContent as any).proofStrip;
---
<section class="why-us" id="why-us" aria-labelledby="why-us-heading">
  <!-- Subtle monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <div class="container">
    <!-- Header block -->
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <div class="motif-row" style="display:flex;justify-content:center;margin-bottom:10px"><Motif name="scale" size={42} /></div>
      <h2 id="why-us-heading" class="section-h2" set:html={parseEmph(h2)} />
      <div class="hairline" aria-hidden="true"></div>

      {paragraphs.map((p) => <p class="body-copy">{p}</p>)}

      <blockquote class="pull-quote" set:html={parseEmph(pullQuote)} />
    </div>

    <!-- Stats grid -->
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat anim-fade-up">
          <div class="stat-value" data-value={stat.value}>{stat.value}</div>
          <div class="stat-caption">{stat.caption}</div>
          {/* P1-037 · Uniform stat-rule hairline beneath every numeral (was 3 different icons) */}
          <svg class="stat-rule" viewBox="0 0 64 1" width="64" height="1" preserveAspectRatio="none" aria-hidden="true">
            <line x1="0" y1="0.5" x2="64" y2="0.5" stroke="var(--gold)" stroke-width="1"/>
          </svg>
          <span class="verified-pill">Verified</span>
        </div>
      ))}
    </div>

    {proofStrip && (
      <div class="proof-strip" aria-label="Compliance track record">{proofStrip}</div>
    )}

    <!-- Credential strip -->
    <div class="credential-strip">
      <div class="hairline-thin" aria-hidden="true"></div>
      <div class="credentials-heading">{credentialStripHeading}</div>
      <div class="credentials">
        {credentials.map((c) => (
          <span class="credential-item">{c}</span>
        ))}
      </div>
    </div>

    {microLine && (
      <div class="micro-line" aria-hidden="true">{microLine}</div>
    )}

  </div>
</section>

<style>
  .why-us {
    position: relative;
    background: var(--grad-whyus);
    padding-block: clamp(40px, 5vw, 64px);
    overflow: hidden;
  }

  /* Proof strip — SWF-allocator persona signal (B-38 fix) */
  .proof-strip {
    margin-top: 32px;
    padding: 16px 24px;
    background: var(--grad-oxblood-depth);
    color: var(--gold);
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    text-align: center;
    border-radius: 2px;
    border: 1px solid var(--gold-hairline);
  }

  /* Micro-line at section bottom (B-46 fix) · Round-7 contrast fix */
  .micro-line {
    margin-top: 40px;
    text-align: center;
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-text);
    font-weight: 500;
    opacity: 1;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    position: relative;
    z-index: 2;
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: 600px;
    color: var(--oxblood);
    line-height: 1;
    opacity: 0.025;
    letter-spacing: -0.04em;
    animation: monogram-breath 8s ease-in-out infinite;
  }

  /* Header block */
  .header-block {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: var(--ls-h2);
    color: var(--ink);
    margin-bottom: 18px;
    max-width: 720px;
    margin-inline: auto;
  }

  .section-h2 :global(.emph) {
    color: var(--oxblood);
    font-style: italic;
    font-weight: 500;
  }

  .hairline {
    height: 1px;
    background: var(--gold);
    width: 80px;
    margin: 0 auto 32px;
    opacity: 0.6;
  }

  .body-copy {
    font-family: var(--ff-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 16px;
    max-width: 640px;
    margin-inline: auto;
    font-weight: 300;
  }

  .pull-quote {
    margin: 32px auto 0;
    font-family: var(--ff-display);
    font-size: 22px;
    font-style: italic;
    /* Round-7 fix · 22px gold = 2.12:1 on ivory (italic doesn't qualify as large-text-bold); deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 500;
    max-width: 580px;
    line-height: 1.3;
    position: relative;
    padding: 20px 32px;
  }

  .pull-quote :global(.emph) {
    color: var(--gold-text-strong);
    font-style: italic;
    font-weight: 600;
  }

  .pull-quote::before,
  .pull-quote::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border-color: var(--gold);
    border-style: solid;
    border-width: 0;
  }

  .pull-quote::before {
    top: 0;
    left: 0;
    border-top-width: 1.5px;
    border-left-width: 1.5px;
  }

  .pull-quote::after {
    bottom: 0;
    right: 0;
    border-bottom-width: 1.5px;
    border-right-width: 1.5px;
  }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 40px;
    margin-top: 96px;
    max-width: 1100px;
    margin-inline: auto;
  }

  .stat {
    text-align: center;
    container-type: inline-size;
  }

  .stat-value {
    font-family: var(--ff-display);
    /* clamp tuned so $110M+ (~6 chars at heavy weight) fits the narrowest grid cell (~270px) */
    font-size: clamp(56px, 6.2vw, 96px);
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.02em;
    font-feature-settings: 'lnum', 'tnum';
    margin-bottom: 16px;
    /* Allow shrinking inside grid cells when content is wider than allotted column */
    min-width: 0;
    max-width: 100%;
    overflow-wrap: break-word;
    word-break: keep-all;
  }
  /* Defend the parent grid cell from being forced wide by an oversized stat */
  .stat-card { min-width: 0; }

  .stat-caption {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
    margin-bottom: 16px;
    max-width: 240px;
    margin-inline: auto;
    line-height: 1.5;
  }

  .stat-sparkline {
    width: 100px;
    height: 30px;
    margin: 0 auto 12px;
    display: block;
  }

  .stat-rule { width: 64px; height: 1px; margin: 16px auto 8px; display: block; opacity: 0.7; }
  .stat-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto 12px;
    display: block;
  }

  .verified-pill {
    position: relative;
    padding: 4px 14px;
    display: inline-block;
    font-family: var(--ff-body);
    font-size: 9px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-text-strong);
    margin-top: 8px;
    display: inline-block;
    padding: 3px 10px;
    border: 1px solid var(--gold);
    font-family: var(--ff-body);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
  
  }
  /* bracket frame · corner brackets [ ] around the verified pill */
  .verified-pill::before,
  .verified-pill::after {
    content: '';
    position: absolute;
    width: 5px;
    height: 8px;
    border-color: var(--gold);
    border-style: solid;
    top: 50%;
    transform: translateY(-50%);
  }
  .verified-pill::before { left: 0; border-width: 1px 0 1px 1px; }
  .verified-pill::after { right: 0; border-width: 1px 1px 1px 0; }

  /* Credential strip */
  .credential-strip {
    margin-top: 32px;
    text-align: center;
  }

  .hairline-thin {
    height: 1px;
    background: var(--gold);
    opacity: 0.4;
    width: 40%;
    max-width: 400px;
    margin: 0 auto 20px;
  }

  .credentials-heading {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    /* Round-7 fix · 11px gold = 2.12:1 on ivory; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 500;
    margin-bottom: 18px;
  }

  .credentials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .credential-item {
    font-family: var(--ff-body);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    transition: color 300ms ease, border-color 300ms ease;
  }

  .credential-item:hover {
    color: var(--oxblood);
    border-color: var(--gold);
  }

  /* Scroll prompt */
  .scroll-prompt {
    display: block;
    text-align: center;
    margin-top: 80px;
    font-family: var(--ff-body);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-muted);
    text-decoration: none;
    /* Round-8 fix · 44px min tap target on mobile (was ~24px) */
    padding: 11px 4px;
    min-height: 44px;
    line-height: 1.5;
    border-bottom: 1px solid var(--gold);
    max-width: fit-content;
    margin-inline: auto;
    transition: color 300ms ease;
  }

  .scroll-prompt:hover {
    color: var(--oxblood);
  }

  @media (max-width: 1024px) {
    .stats-grid { gap: 56px; }
  }

  @media (max-width: 640px) {
    .header-block { text-align: left; }
    .eyebrow { margin-left: 0; }
    .hairline { margin-inline: 0; }
    .body-copy { margin-inline: 0; }
    .pull-quote { margin-inline: 0; font-size: 18px; }
    .stats-grid { margin-top: 64px; }
    .stat-value { font-size: 72px; }
    .credentials { gap: 16px; }
    .credential-item { font-size: 11px; padding: 6px 12px; }
  }
</style>

<script>
  // Rolling counter animation on scroll-into-view
  document.addEventListener('DOMContentLoaded', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const final = el.dataset.value || '';

        // Extract numeric portion · supports "480%", "$110M+", "400+", "4×"
        const match = final.match(/^([£$€]?)(\d+)([%+×MKB]*)$/);  // M-punch: £110M+ now counts like the others
        if (!match) return;

        const prefix = match[1] || '';
        const target = parseInt(match[2], 10);
        const suffix = match[3] || '';
        const duration = 1400;
        const start = performance.now();

        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.floor(target * eased);
          el.textContent = prefix + value + suffix;
          if (progress < 1) requestAnimationFrame(tick);
          else el.textContent = final;
        };

        el.textContent = prefix + '0' + suffix;
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll<HTMLElement>('.stat-value').forEach((el) => observer.observe(el));
  });
</script>
