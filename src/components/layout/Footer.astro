---
import { footerContent } from '../../content/footer';

const { wordmark, tagline, locations, credentials, navigationHeading, navigationItems, briefingsHeading, briefingsBody, briefingsCta, briefingsConsent, legalLinks, copyright, legalEntity, modernSlaveryHref, complaintsHref, acceptableUseHref, securityHref, address } = footerContent as any;
const year = new Date().getFullYear();
import TurnstileWidget from '../security/TurnstileWidget.astro';
---
<footer class="footer" role="contentinfo">
  <!-- Monogram watermark -->
  <div class="monogram" aria-hidden="true">
    <span class="monogram-t">T</span>
  </div>

  <div class="container">
    <!-- Top hairline -->
    <div class="top-hairline" aria-hidden="true"></div>

    <!-- Three-column grid -->
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div class="col col-brand">
        {/* F6b · Footer brand lockup — exact-match the header masthead image so the wordmark + horse mark + gold strikethrough align with the header. */}
        <a href="/" class="brand-lockup" aria-label="Tamazia home">
          <picture>
            <source srcset="/tamazia-lockup-masthead-transparent.webp" type="image/webp" />
            <img src="/tamazia-lockup-masthead-transparent.png" alt="Tamazia" class="lockup-masthead-img" width="343" height="64" loading="lazy" decoding="async" />
          </picture>
        </a>

        <div class="tagline-rule" aria-hidden="true"></div>
        <p class="tagline">{tagline}</p>

        {/* G3 · 'London' chip removed per founder direction (still appears inside the address line below). */}
        <p class="presence">Engagements delivered in UK, UAE, USA, EU &amp; Worldwide.</p>

        <div class="credentials">
          {credentials.map((c, i) => (
            <>
              {i > 0 && <span class="sep">·</span>}
              <span class="cred">{c}</span>
            </>
          ))}
        </div>

        {/* S44 (Impl Doc v1.0) · founder-confirmed office address line */}
        {address && <p class="brand-address">{address}</p>}

        <!-- Partner badges (I.31) — Google Partner + Meta Business Partner -->
        <div class="partner-badges" aria-label="Agency certifications">
          <img src="/google-partner.png" alt="Google Partner" class="partner-badge" width="120" height="50" loading="lazy" />
          <img src="/meta-partner.png" alt="Meta Business Partner" class="partner-badge" width="120" height="50" loading="lazy" />
        </div>
      </div>

      <!-- Column 2: Navigation -->
      <nav class="col col-nav" aria-label="Footer navigation">
        <h3 class="col-heading">{navigationHeading}</h3>
        <ul>
          {navigationItems.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Column 3: Regulatory Briefings -->
      <div class="col col-briefings">
        <h3 class="col-heading">{briefingsHeading}</h3>
        <p class="briefings-body">{briefingsBody}</p>

        <form class="briefings-form" id="briefings-form" action="/api/briefings" method="POST" novalidate>
          <input type="text" name="bot-field" tabindex="-1" autocomplete="off" class="tamz-hp" aria-hidden="true" />
          <input type="text" name="c_website_2" tabindex="-1" autocomplete="off" class="tamz-hp" aria-hidden="true" />
          <input type="url" name="c_homepage_url" tabindex="-1" autocomplete="off" class="tamz-hp" aria-hidden="true" />
          <label class="sr-only" for="briefings-email">Email address</label>
          <input
            type="email"
            id="briefings-email"
            name="email"
            placeholder="your@domain.com"
            autocomplete="email"
            required
          />
          {/* Honeypot — hidden from real users; bots fill it and get silently 200'd */}
          <label class="sr-only" for="briefings-bot-field">Leave this field empty</label>
          <input type="text" id="briefings-bot-field" name="bot-field" tabindex="-1" autocomplete="off" aria-hidden="true" class="briefings-honeypot" />
          <p class="briefings-consent">{briefingsConsent}</p>
          <TurnstileWidget formId="briefings-form" mode="invisible" />
          <button type="submit" class="briefings-btn" id="briefings-submit">{briefingsCta}</button>
          <p class="briefings-status" id="briefings-status" role="status" aria-live="polite" hidden></p>
        </form>
      </div>
    </div>

    <!-- Bottom hairline -->
    <div class="bottom-hairline" aria-hidden="true"></div>

    <!-- Small print -->
    <div class="small-print">
      <div class="copyright">{copyright.replace('2026', year.toString())}</div>
        {/* Founder directive 2026-06-10: Article 27 line removed; legal lines render white */}
        <p class="legal-entity">{legalEntity?.name} · Registered office {legalEntity?.registeredOffice} · Data Controller {legalEntity?.dataController} · DPO {legalEntity?.dpoContact}</p>
        <ul class="extra-legal-links" aria-label="Legal disclosures">
          <li><a href={legalEntity?.dataProtectionNoticeHref || '/legal/data-protection/'}>Data Protection Notice</a></li>
          <li><a href={legalEntity?.dpaHref || '/legal/dpa/'}>DPA</a></li>
          <li><a href={legalEntity?.subProcessorsHref || '/legal/sub-processors/'}>Sub-processors</a></li>
          <li><a href={modernSlaveryHref}>Modern Slavery Statement</a></li>
          <li><a href={complaintsHref}>Complaints</a></li>
          <li><a href={acceptableUseHref}>Acceptable Use</a></li>
          <li><a href={securityHref}>Security</a></li>
          <li><a href="/status/">Status</a></li>
          <li><a href="/insights/feed.xml" rel="alternate" type="application/rss+xml">RSS</a></li>
        </ul>
      <div class="legal-links">
        {legalLinks.map((link, i) => (
          <>
            {i > 0 && <span class="sep" aria-hidden="true">·</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </div>
    </div>
  </div>

  <!-- Back to top button -->
  <a href="#" class="back-to-top" aria-label="Back to top" id="back-to-top">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M 12 4 L 12 20 M 6 10 L 12 4 L 18 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</footer>

<style>
  .footer {
    /* B-28 fix · gradient finale into oxblood-ink */
    background: linear-gradient(180deg, #3A0F1C 0%, #2A0C14 60%, #1F0810 100%);
    color: var(--pearl);
    /* H2 · footer padding tightened — 88/40 -> 48/28 desktop, 56/24 mobile */
    padding: 48px 0 28px;
    position: relative;
    overflow: hidden;
  }

  .monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .monogram-t {
    font-family: var(--ff-display);
    font-size: 600px;
    color: var(--gold);
    line-height: 1;
    opacity: 0.03;
    letter-spacing: -0.04em;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    position: relative;
    z-index: 2;
  }

  .top-hairline {
    height: 2px;
    background: var(--gold);
    margin-bottom: 40px;
    opacity: 0.6;
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  /* F6b · Brand column lockup — masthead image (matches header exactly) */
  .brand-lockup {
    display: inline-flex;
    align-items: center;
    margin-bottom: 24px;
    text-decoration: none;
    transition: opacity var(--duration-short, 250ms) ease;
  }
  .brand-lockup:hover { opacity: 0.88; }
  .brand-lockup:focus-visible { outline: 2px solid var(--gold); outline-offset: 4px; border-radius: 2px; }
  .lockup-masthead-img {
    /* F8 GAP3 · exact-match header masthead height (50px) so footer wordmark reads identically to header */
    height: 50px;
    width: auto;
    display: block;
    image-rendering: -webkit-optimize-contrast;
  }
  @media (max-width: 640px) {
    .lockup-masthead-img { height: 40px; }
  }

  .tagline-rule {
    height: 1px;
    width: 64px;
    background: var(--gold);
    opacity: 0.5;
    margin-bottom: 18px;
  }
  .tagline {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 18px;
    color: var(--gold);
    margin-bottom: 32px;
    max-width: 420px;
  }

  /* F6d · Footer typography audit · brand column harmonised */
  .locations {
    font-family: var(--ff-body);
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pearl);
    margin-bottom: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 0;
  }
  .locations .location { white-space: nowrap; }
  /* F6c · 'Engagements delivered…' paragraph — its own row, never overflows */
  .presence {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    line-height: 1.55;
    color: var(--pearl);
    opacity: 0.82;
    margin: 4px 0 10px;
    letter-spacing: 0.01em;
    max-width: 360px;
  }
  @media (max-width: 640px) {
    .presence { font-size: 13px; max-width: 100%; }
  }

  .locations .sep {
    color: var(--gold);
    margin: 0 10px;
    opacity: 0.7;
  }

  .credentials {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    line-height: 1.8;
    max-width: 460px;
  }

  .credentials .sep {
    margin: 0 8px;
    opacity: 0.5;
  }

  /* Navigation */
  .col-heading {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(201, 167, 114, 0.3);
  }

  .col-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .col-nav a {
    font-family: var(--ff-body);
    font-size: 14px;
    color: var(--pearl);
    text-decoration: none;
    letter-spacing: 0.02em;
    position: relative;
    padding-bottom: 2px;
    transition: color 300ms ease;
    display: inline-block;
  }

  .col-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 400ms var(--ease-out);
  }

  .col-nav a:hover {
    color: var(--gold);
  }

  .col-nav a:hover::after {
    width: 100%;
  }

  /* Briefings */
  .briefings-body {
    font-family: var(--ff-body);
    font-size: 14px;
    color: var(--pearl);
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 28px;
    font-weight: 300;
  }

  .briefings-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .briefings-form input {
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(201, 167, 114, 0.5);
    color: var(--ivory);
    padding: 12px 0;
    font-family: var(--ff-display);
    /* Round-8 fix · 16px prevents iOS Safari auto-zoom on focus */
    font-size: 16px;
    font-style: italic;
    outline: none;
    transition: border-color 300ms ease;
    border-radius: 0;
  }

  .briefings-form input::placeholder {
    color: var(--pearl);
    opacity: 0.5;
  }

  .briefings-form input:focus {
    border-bottom-color: var(--gold);
  }

  .briefings-btn {
    /* F4 · Receive briefings button — defensive sizing so mobile letter-spacing tail never overflows */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    height: 48px;
    padding: 0 18px;
    background: var(--oxblood);
    color: var(--ivory);
    border: 1px solid var(--gold);
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-align: center;
    white-space: nowrap;
    cursor: pointer;
    transition: background 300ms ease, border-color 300ms ease;
    border-radius: 4px;
  }
  @media (max-width: 480px) {
    /* F4 · narrower letter-spacing + slight font drop at <=480px so the arrow stays inside */
    .briefings-btn { font-size: 11px; letter-spacing: 0.14em; padding: 0 14px; }
  }

  .briefings-btn:hover {
    background: var(--oxblood-warm);
    border-color: var(--gold-warm);
  }

  .briefings-btn[disabled] {
    opacity: 0.55;
    cursor: wait;
  }

  /* Honeypot — fully hidden from sighted + AT users, but bots will fill it */
  .briefings-honeypot {
    position: absolute !important;
    left: -10000px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
    /* Round-12 fix · keeping ≥16px so L13 audit doesn't flag, but it's invisible */
    font-size: 16px;
  }

  /* GDPR consent microcopy */
  .briefings-consent {
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--pearl);
    opacity: 0.55;
    line-height: 1.5;
    margin: 0;
  }

  /* Status message under the form (success / error) */
  .briefings-status {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.04em;
    margin: 8px 0 0;
    padding: 10px 12px;
    border-left: 2px solid var(--gold);
    background: rgba(201, 167, 114, 0.08);
    color: var(--ivory);
    line-height: 1.5;
  }
  .briefings-status[data-status="error"] {
    border-left-color: #C76E2A;
    background: rgba(199, 110, 42, 0.12);
  }

  /* Bottom */
  .bottom-hairline {
    height: 1px;
    background: rgba(201, 167, 114, 0.4);
    margin-bottom: 24px;
  }

  .small-print {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    font-family: var(--ff-body);
    font-size: 11px;
    color: var(--pearl);
    font-weight: 400;
  }

  .copyright {
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .legal-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .legal-links a {
    color: var(--pearl);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    /* Round-8 fix · 44px min tap target on mobile (was 20px) */
    padding: 12px 4px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 300ms ease, border-color 300ms ease;
  }

  .legal-links a:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .legal-links .sep {
    color: var(--gold);
    opacity: 0.6;
  }

  /* Back to top */
  .back-to-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 44px;
    height: 44px;
    border: 1px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    background: var(--obsidian);
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms var(--ease-out), transform 400ms var(--ease-out), background 300ms ease;
    transform: translateY(8px);
    z-index: 90;
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background: var(--oxblood);
  }

  .back-to-top svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .footer { padding: 56px 0 24px; }
    .top-hairline { margin-bottom: 28px; }
    /* F6 · brand-lockup is now an image link — keep inline-flex */
    .small-print { flex-direction: column; align-items: flex-start; }
    .tagline-rule {
    height: 1px;
    width: 64px;
    background: var(--gold);
    opacity: 0.5;
    margin-bottom: 18px;
  }
  .tagline { font-size: 16px; }
    .back-to-top { bottom: 24px; right: 24px; width: 40px; height: 40px; }
  }

  /* I.31 · Partner badge strip */
  .partner-badges {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .partner-badge {
    /* Full-bleed monochrome badges · no card, no padding, no grey area */
    height: 56px;
    width: auto;
    object-fit: contain;
    opacity: 0.95;
    background: transparent;
    padding: 0;
    border-radius: 0;
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .partner-badge:hover { opacity: 1; transform: translateY(-1px); }

  /* Founder directive 2026-06-10: legal entity line + disclosure links visible in white */
  .legal-entity { font-family: 'Inter', system-ui, sans-serif; font-size: 11px; color: #FFFFFF; margin-top: 6px; line-height: 1.55; }
  .extra-legal-links { list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-wrap: wrap; gap: 14px; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; }
  .extra-legal-links a { color: #FFFFFF; text-decoration: none; border-bottom: 1px solid transparent; }
  .extra-legal-links a:hover { border-bottom-color: var(--gold-soft, #C9A772); }
  /* G3 · address line matches .presence scale, carries a subtle gold left rule for emphasis */
  .brand-address {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: 0.01em;
    color: var(--pearl);
    opacity: 0.92;
    margin: 4px 0 22px;
    padding: 0 0 0 12px;
    border-left: 1px solid rgba(201,167,114,0.55);
    max-width: 360px;
  }
  @media (max-width: 640px) {
    .brand-address { font-size: 13px; }
  }
</style>