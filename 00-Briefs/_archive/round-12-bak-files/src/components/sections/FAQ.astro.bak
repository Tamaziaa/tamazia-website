---
import { faqContent } from '../../content/faq';

const { eyebrow, h2, intro, categories, timeline, questions, closingLine } = faqContent;
---
<section class="faq" id="faq" aria-labelledby="faq-heading">
  <div class="container">
    <div class="header-block">
      <div class="eyebrow">{eyebrow}</div>
      <h2 id="faq-heading" class="section-h2">{h2}</h2>
      <p class="intro">{intro}</p>
    </div>

    <div class="faq-grid">
      <!-- Sticky category navigation -->
      <aside class="faq-nav" aria-label="FAQ categories">
        <div class="faq-nav-inner">
          {categories.map((cat) => (
            <a href={`#faq-${cat.id}`} class="faq-cat-link" data-cat={cat.id}>
              <span class="cat-label">{cat.label}</span>
              <span class="cat-count">({cat.count})</span>
            </a>
          ))}
        </div>
      </aside>

      <!-- Questions -->
      <div class="faq-content">
        <!-- 4-week timeline for audit-process -->
        <div class="timeline-wrap">
          <div class="timeline-heading">Four-week audit structure</div>
          <div class="timeline">
            {timeline.map((t: any) => (
              <div class="timeline-node" tabindex="0">
                <div class="node-circle">{t.week}</div>
                <div class="node-label">{t.label}</div>
                {t.detail && (
                  <div class="node-popover" role="tooltip">{t.detail}</div>
                )}
              </div>
            ))}
          </div>
        </div>

        {categories.map((cat) => (
          <div class="faq-category" id={`faq-${cat.id}`}>
            <h3 class="category-heading">{cat.label}</h3>
            {questions.filter(q => q.category === cat.id).map((q, i) => (
              <details class="faq-item" data-q={i}>
                <summary class="faq-question">
                  <span>{q.question}</span>
                  <span class="chevron" aria-hidden="true">▸</span>
                </summary>
                <div class="faq-answer">
                  {Array.isArray((q as any).answerParagraphs)
                    ? (q as any).answerParagraphs.map((p: string) => <p>{p}</p>)
                    : <p>{q.answer}</p>
                  }

                  {Array.isArray((q as any).sectorBreakdown) && (q as any).sectorBreakdown.length > 0 && (
                    <div class="sector-breakdown">
                      {(q as any).sectorBreakdown.map((sb: any) => (
                        <div class="breakdown-row">
                          <h4 class="breakdown-name">{sb.name}</h4>
                          <p class="breakdown-body">{sb.body}</p>
                        </div>
                      ))}
                    </div>
                  )}

                  {Array.isArray((q as any).auditScope) && (q as any).auditScope.length > 0 && (
                    <div class="audit-scope">
                      {(q as any).auditScope.map((a: any) => (
                        <div class="scope-row">
                          <h4 class="scope-name">{a.name}</h4>
                          <p class="scope-body">{a.body}</p>
                        </div>
                      ))}
                      {(q as any).closing && <p class="scope-closing">{(q as any).closing}</p>}
                    </div>
                  )}

                  {q.chips && q.chips.length > 0 && (
                    <div class="citation-chips">
                      {q.chips.map((c) => <span class="citation-chip">{c}</span>)}
                    </div>
                  )}
                </div>
              </details>
            ))}
          </div>
        ))}

        <div class="faq-closing">
          <p>{closingLine}</p>
          <a href="#contact" class="closing-cta">Reach out →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--ivory);
    padding-block: var(--section-padding-block);
    position: relative;
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .header-block {
    max-width: 720px;
    margin-bottom: clamp(32px, 4vw, 48px); /* R10 · was 64-96 */
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: var(--ls-caps-eyebrow);
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 24px;
    position: relative;
    padding-left: 40px;
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 28px;
    height: 1px;
    background: var(--oxblood);
  }

  .section-h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: var(--fs-h2);
    color: var(--ink);
    margin-bottom: 16px;
    letter-spacing: var(--ls-h2);
  }

  .intro {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-muted);
    line-height: 1.5;
  }

  /* Grid layout */
  .faq-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* Sticky nav */
  .faq-nav {
    position: sticky;
    top: 130px;
  }

  .faq-nav-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-cat-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
    padding: 8px 0;
    border-left: 2px solid transparent;
    padding-left: 16px;
    text-decoration: none;
    transition: color 300ms ease, border-color 300ms ease;
  }

  .faq-cat-link:hover,
  .faq-cat-link.active {
    color: var(--oxblood);
    border-left-color: var(--gold);
  }

  .cat-count {
    font-family: var(--ff-display);
    font-style: italic;
    /* Round-7 fix · gold on ivory at 0.7 opacity = 1.79:1; deeper bronze at full opacity passes */
    color: var(--gold-text);
    opacity: 1;
  }

  /* Timeline */
  .timeline-wrap {
    background: var(--pearl);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.4);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 48px;
  }

  .timeline-heading {
    font-family: var(--ff-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    margin-bottom: 24px;
  }

  .timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 12%;
    right: 12%;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
    z-index: 1;
  }

  .timeline-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 2;
    cursor: pointer;
  }
  .timeline-node:hover .node-circle,
  .timeline-node:focus-visible .node-circle {
    background: var(--gold);
    color: var(--oxblood-ink);
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(201, 167, 114, 0.4);
  }
  .node-circle { transition: background 240ms ease, color 240ms ease, transform 240ms ease, box-shadow 240ms ease; }

  /* B-16 fix · hover popover with detailed week tasks · Round-8 mobile fix · was overflowing 360px viewport by 44px */
  .node-popover {
    position: absolute;
    top: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    width: 320px;
    max-width: calc(100vw - 32px);
    background: var(--grad-oxblood-depth);
    color: var(--ivory);
    padding: 16px 18px;
    font-family: var(--ff-body);
    font-size: 12px;
    line-height: 1.55;
    border-radius: 6px;
    border: 1px solid var(--gold);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.25);
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms ease, transform 240ms ease;
    z-index: 50;
    /* Round-8 fix · prevent contributing to document width when hidden */
    visibility: hidden;
  }
  .timeline-node:hover .node-popover,
  .timeline-node:focus-within .node-popover { visibility: visible; }
  .node-popover::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-bottom-color: var(--gold);
  }
  .timeline-node:hover .node-popover,
  .timeline-node:focus-within .node-popover {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .node-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--ivory);
    border: 1px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 20px;
    color: var(--oxblood);
    margin-bottom: 12px;
  }

  .node-label {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
    line-height: 1.5;
  }

  /* Round-8 fix · stack timeline vertically on mobile + tablet portrait + inline popover (no horizontal overflow, touch-friendly) */
  @media (max-width: 900px) {
    .timeline { grid-template-columns: 1fr; gap: 12px; }
    .timeline::before { display: none; }
    .timeline-node {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 14px;
      padding: 8px 0;
    }
    .node-circle { margin-bottom: 0; flex-shrink: 0; }
    .node-label { padding-top: 14px; }
    /* Make popover inline always-visible block on mobile (no overflow risk) */
    .node-popover {
      position: static;
      transform: none !important;
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
      width: 100%;
      max-width: 100%;
      margin-top: 8px;
      box-shadow: none;
      flex-basis: 100%;
    }
    .node-popover::before { display: none; }
  }

  /* FAQ category + items (gold-box style) */
  .faq-category {
    margin-bottom: 48px;
  }

  .category-heading {
    font-family: var(--ff-body);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    /* Round-7 fix · 12px gold = 2.12:1 on ivory; deeper bronze passes 4.5:1 */
    color: var(--gold-text);
    font-weight: 500;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--gold);
    border-bottom-color: rgba(201, 167, 114, 0.35);
  }

  .faq-item {
    background: var(--oxblood);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.45);
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: border-color 300ms ease, box-shadow 300ms ease;
  }

  .faq-item[open] {
    border-color: var(--gold);
    box-shadow: 0 20px 40px -20px rgba(90, 26, 43, 0.3);
  }

  .faq-question {
    list-style: none;
    cursor: pointer;
    padding: 20px 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    font-family: var(--ff-display);
    font-size: 20px;
    color: var(--ivory);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .chevron {
    color: var(--gold);
    font-size: 14px;
    transform: rotate(0deg);
    transition: transform 400ms var(--ease-out);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .faq-item[open] .chevron {
    transform: rotate(90deg);
  }

  .faq-answer {
    padding: 0 24px 24px;
    color: var(--pearl);
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.65;
    font-weight: 300;
    opacity: 0.9;
  }

  .faq-answer p { margin: 0 0 14px; }
  .faq-answer p:last-child { margin-bottom: 0; }

  .sector-breakdown, .audit-scope {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--gold-hairline);
    display: grid;
    gap: 14px;
  }
  .breakdown-row, .scope-row {
    border-left: 2px solid var(--gold);
    padding-left: 14px;
  }
  .breakdown-name, .scope-name {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: 16px;
    font-weight: 500;
    color: var(--gold);
    margin-bottom: 4px;
  }
  .breakdown-body, .scope-body {
    font-family: var(--ff-body);
    font-size: 13px;
    line-height: 1.6;
    color: var(--pearl);
    margin: 0;
  }
  .scope-closing {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--gold-hairline);
    font-family: var(--ff-display);
    font-style: italic;
    color: var(--gold-pale);
    font-size: 14px;
  }

  .citation-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .citation-chip {
    font-family: var(--ff-body);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.5);
    border-radius: 2px;
    padding: 4px 10px;
    font-weight: 500;
  }

  /* Closing */
  .faq-closing {
    margin-top: 48px;
    padding: 32px;
    background: var(--pearl);
    border: 1px solid var(--gold);
    border-color: rgba(201, 167, 114, 0.4);
    border-radius: 12px;
    text-align: center;
  }

  .faq-closing p {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-muted);
    margin-bottom: 16px;
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .closing-cta {
    display: inline-block;
    font-family: var(--ff-body);
    font-size: 13px;
    color: var(--oxblood);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    /* Round-8 fix · 44px min tap target on mobile (was 24px) */
    padding: 11px 4px;
    min-height: 44px;
    line-height: 1.5;
    transition: color 300ms ease, border-color 300ms ease;
  }

  .closing-cta:hover {
    color: var(--oxblood-warm);
    border-color: var(--gold-warm);
  }

  @media (max-width: 1024px) {
    .faq-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      min-width: 0;
    }
    .faq-nav {
      position: relative;
      top: 0;
      /* Round-8 fix · clip nav so long category labels don't push doc width on mobile */
      max-width: 100%;
      overflow-x: auto;
      scrollbar-width: thin;
      -webkit-overflow-scrolling: touch;
    }
    .faq-nav-inner {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
      max-width: 100%;
    }
    .faq-cat-link {
      border-left: none;
      border-bottom: 2px solid transparent;
      padding: 8px 12px;
      /* Round-8 fix · 44px min-height for tap target on touch */
      min-height: 44px;
      align-items: center;
    }
    .faq-cat-link:hover, .faq-cat-link.active {
      border-bottom-color: var(--gold);
      border-left-color: transparent;
    }
  }

  @media (max-width: 640px) {
    /* Round-8 fix · stack timeline 1fr (was repeat(2,1fr) which kept popovers wide and overflowed viewport) */
    .timeline { grid-template-columns: 1fr; gap: 12px; }
    .timeline::before { display: none; }
    .faq-question { font-size: 16px; padding: 16px 20px; min-height: 44px; }
    .faq-answer { font-size: 13px; padding: 0 20px 20px; }
    .timeline-wrap { padding: 24px 20px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Scroll spy on nav
    const links = document.querySelectorAll<HTMLAnchorElement>('.faq-cat-link');
    const sections = Array.from(document.querySelectorAll<HTMLElement>('.faq-category'));

    const spy = () => {
      const y = window.scrollY + 200;
      let active: string | null = null;
      sections.forEach((s) => {
        if (s.offsetTop <= y) active = s.id;
      });
      links.forEach((l) => {
        const href = l.getAttribute('href') || '';
        l.classList.toggle('active', href === `#${active}`);
      });
    };
    window.addEventListener('scroll', spy, { passive: true });
    spy();
  });
</script>
